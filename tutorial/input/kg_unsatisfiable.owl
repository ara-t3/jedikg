<?xml version="1.0"?>
<rdf:RDF
    xmlns="http://example.org/test#"
    xml:base="http://example.org/test"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">

    <owl:Ontology rdf:about="http://example.org/test"/>

    <!-- Two disjoint classes -->
    <owl:Class rdf:about="http://example.org/test#A"/>
    <owl:Class rdf:about="http://example.org/test#B"/>

    <owl:AllDisjointClasses>
        <owl:members rdf:parseType="Collection">
            <rdf:Description rdf:about="http://example.org/test#A"/>
            <rdf:Description rdf:about="http://example.org/test#B"/>
        </owl:members>
    </owl:AllDisjointClasses>

    <!-- Unsatisfiable class -->
    <owl:Class rdf:about="http://example.org/test#Impossible1">
        <rdfs:subClassOf rdf:resource="http://example.org/test#A"/>
        <rdfs:subClassOf rdf:resource="http://example.org/test#B"/>
    </owl:Class>


    <!-- Unsatisfiable class -->
    <owl:Class rdf:about="http://example.org/test#Impossible2">
        <rdfs:subClassOf rdf:resource="http://example.org/test#A"/>
        <rdfs:subClassOf rdf:resource="http://example.org/test#B"/>
    </owl:Class>


</rdf:RDF>
