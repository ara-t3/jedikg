<?xml version="1.0"?>
<rdf:RDF xmlns="http://example.org/unsat#"
     xml:base="http://example.org/unsat"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">
    <owl:Ontology rdf:about="http://example.org/unsat"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.org/unsat#hasChild -->

    <owl:ObjectProperty rdf:about="http://example.org/unsat#hasChild">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.org/unsat#Female -->

    <owl:Class rdf:about="http://example.org/unsat#Female">
        <rdfs:subClassOf rdf:resource="http://example.org/unsat#Person"/>
        <owl:disjointWith rdf:resource="http://example.org/unsat#Male"/>
    </owl:Class>
    


    <!-- http://example.org/unsat#ImpossiblePerson -->

    <owl:Class rdf:about="http://example.org/unsat#ImpossiblePerson">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://example.org/unsat#Female"/>
                    <rdf:Description rdf:about="http://example.org/unsat#Male"/>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>
    


    <!-- http://example.org/unsat#Male -->

    <owl:Class rdf:about="http://example.org/unsat#Male">
        <rdfs:subClassOf rdf:resource="http://example.org/unsat#Person"/>
    </owl:Class>
    


    <!-- http://example.org/unsat#ParentOfSelf -->

    <owl:Class rdf:about="http://example.org/unsat#ParentOfSelf">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://example.org/unsat#Person"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://example.org/unsat#hasChild"/>
                        <owl:hasSelf rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:hasSelf>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>
    


    <!-- http://example.org/unsat#Person -->

    <owl:Class rdf:about="http://example.org/unsat#Person"/>
</rdf:RDF>



