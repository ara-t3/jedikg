{
    "dataset_name": "APULIA_TEST_DATASET",
    "verbose": 1,

    "paths": {
        "schema": "./test/test_data/schema.owl",
        "data": "./test/test_data/data.ttl",
        "output": "./test/test_data/"
    },

    "reasoning": {
        "java_8_home": "/usr/lib/jvm/java-1.8.0-openjdk-amd64",
        "java_11_home": "/usr/lib/jvm/java-1.11.0-openjdk-amd64",
        "java_max_ram": 20,
        "filter_unsatisfiable": true,

        "materialization": {
            "enabled": true,
            "axioms": [
                "SubClass",
                "EquivalentClass",
                "ObjectPropertyDomain"
            ]
        },

        "realization": {
            "enabled": true
        },

        "modularization": {
            "enabled": true
        },

        "decomposition" : {
            "tbox" : true,
            "rbox" : true
        }


    },



    "split": {
        "enabled": true,
        "train_percent": 80,
        "validation_percent": 10,
        "test_percent": 10,
        "transductive": true,
        "test_leakage_filtering": {
            "enabled": true,
            "minimum_frequency": 0.97

        }
    },

    "description_logic_profile": "EL",

    "post_processing": {
        "json_conversion": true,
        "id_mapping": true
    }
}