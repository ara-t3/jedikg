        <versionInfo xml:lang="it">stabile</versionInfo>
        <versionInfo xml:lang="en">stable</versionInfo>
    </ObjectProperty>
    


    <!-- https://w3id.org/italia/onto/POI/isPOICategoryFor -->

    <ObjectProperty rdf:about="https://w3id.org/italia/onto/POI/isPOICategoryFor">
