    <!-- https://w3id.org/italia/onto/SM/worstUserRating -->

    <DatatypeProperty rdf:about="https://w3id.org/italia/onto/SM/worstUserRating">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/SM/userRating"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/SM/Rating"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="en">Among all the rating associated with a thing of the modelled domain, it represents the worst rating.</rdfs:comment>
