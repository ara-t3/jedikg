        <rdfs:label xml:lang="it">qualificatore del toponimo</rdfs:label>
        <rdfs:label xml:lang="en">toponym qualifier</rdfs:label>
        <versionInfo xml:lang="it">stabile</versionInfo>
        <versionInfo xml:lang="en">stable</versionInfo>
    </DatatypeProperty>
    


