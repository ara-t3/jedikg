        <versionInfo xml:lang="en">stable</versionInfo>
    </ObjectProperty>
    


    <!-- https://w3id.org/italia/onto/SM/hasCreator -->

    <ObjectProperty rdf:about="https://w3id.org/italia/onto/SM/hasCreator">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <inverseOf rdf:resource="https://w3id.org/italia/onto/SM/isCreatorOf"/>
