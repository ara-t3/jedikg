        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;immagine a qualsiasi cosa. E&apos; la proprietà inversa di &apos;ha immagine&apos;.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property links an image to anything. It is defined as the inverse property of &apos;has image&apos;.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/italia/onto/SM"/>
        <rdfs:label xml:lang="en">is image of</rdfs:label>
        <rdfs:label xml:lang="it">è immagine di</rdfs:label>
    </ObjectProperty>
    


    <!-- https://w3id.org/italia/onto/SM/isOnlineContactPointOf -->

    <ObjectProperty rdf:about="https://w3id.org/italia/onto/SM/isOnlineContactPointOf">
