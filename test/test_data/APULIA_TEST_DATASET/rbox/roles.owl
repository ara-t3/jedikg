        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/SM/ContactPoint"/>
        <rdfs:comment xml:lang="en">Property that allows one to specify a contact point for a thing.</rdfs:comment>
        <rdfs:comment xml:lang="it">Proprietà che consente di specificare un punto di contatto associato a una cosa del dominio modellato.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/italia/onto/SM"/>
