        <rdfs:comment xml:lang="en">The aspect on which the review focusses.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/italia/onto/SM"/>
        <rdfs:label xml:lang="it">aspetto della recensione</rdfs:label>
        <rdfs:label xml:lang="en">review aspect</rdfs:label>
        <versionInfo xml:lang="it">stabile</versionInfo>
        <versionInfo xml:lang="en">stable</versionInfo>
    </DatatypeProperty>
    


    <!-- https://w3id.org/italia/onto/SM/socialMediaName -->

