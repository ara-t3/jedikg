        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="it">Questa proprietà è l&apos;inversa di &quot;ha punto di contatto online&quot; e collega un punto di contatto online con qualsiasi cosa del dominio modellato.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property is the inverse one for &quot;has online contact point&quot; and links an online contact point to any thing of the modelled domain.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/italia/onto/SM"/>
        <rdfs:label xml:lang="en">is online contact point of</rdfs:label>
        <rdfs:label xml:lang="it">è punto di contatto online di</rdfs:label>
        <versionInfo xml:lang="it">stabile</versionInfo>
        <versionInfo xml:lang="en">stable</versionInfo>
    </ObjectProperty>
    


