    <!-- https://w3id.org/italia/onto/AccessCondition/AccessCondition -->

    <Class rdf:about="https://w3id.org/italia/onto/AccessCondition/AccessCondition">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Characteristic"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Entity"/>
        <rdfs:subClassOf>
            <Restriction>
                <onProperty rdf:resource="https://w3id.org/italia/onto/l0/description"/>
                <allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </Restriction>
        </rdfs:subClassOf>
    </Class>
    


    <!-- https://w3id.org/italia/onto/AccessCondition/AdmissionType -->

    <Class rdf:about="https://w3id.org/italia/onto/AccessCondition/AdmissionType">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Characteristic"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Entity"/>
        <rdfs:subClassOf>
            <Restriction>
                <onProperty rdf:resource="https://w3id.org/italia/onto/l0/name"/>
                <someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <Restriction>
                <onProperty rdf:resource="https://w3id.org/italia/onto/l0/description"/>
                <allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </Restriction>
        </rdfs:subClassOf>
    </Class>
    


    <!-- https://w3id.org/italia/onto/AccessCondition/OpeningHoursSpecification -->

    <Class rdf:about="https://w3id.org/italia/onto/AccessCondition/OpeningHoursSpecification">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/AccessCondition/AccessCondition"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Characteristic"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Entity"/>
        <rdfs:subClassOf>
            <Restriction>
                <onProperty rdf:resource="https://w3id.org/italia/onto/TI/atTime"/>
                <allValuesFrom rdf:resource="https://w3id.org/italia/onto/TI/TimeInterval"/>
            </Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <Restriction>
                <onProperty rdf:resource="https://w3id.org/italia/onto/TI/hasDayOfWeek"/>
                <allValuesFrom rdf:resource="https://w3id.org/italia/onto/TI/DayOfWeek"/>
            </Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <Restriction>
                <onProperty rdf:resource="https://w3id.org/italia/onto/AccessCondition/hasAdmissionType"/>
                <maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</maxQualifiedCardinality>
                <onClass rdf:resource="https://w3id.org/italia/onto/AccessCondition/AdmissionType"/>
            </Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <Restriction>
                <onProperty rdf:resource="https://w3id.org/italia/onto/AccessCondition/closes"/>
                <allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#time"/>
            </Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <Restriction>
                <onProperty rdf:resource="https://w3id.org/italia/onto/AccessCondition/opens"/>
                <allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#time"/>
            </Restriction>
        </rdfs:subClassOf>
    </Class>
    


    <!-- https://w3id.org/italia/onto/AccessCondition/TemporaryClosure -->

