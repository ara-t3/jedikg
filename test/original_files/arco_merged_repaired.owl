        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is estimate of</rdfs:label>
        <rdfs:label xml:lang="it">è stima di</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: UB/STI - ICCD Normative di versione 2.00: UB/INV/INVS</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isExportImportCertificationOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isExportImportCertificationOf">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/ExportImportCertification"/>
        <rdfs:range rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un certificato di importazione/esportazione a un&apos;entità culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an export import certification to a cultural entity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is export import certification of</rdfs:label>
        <rdfs:label xml:lang="it">è certificato di importazione/esportazione di</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: TU/ESP</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isExportImportCertificationTypeOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isExportImportCertificationTypeOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isTypeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/ExportImportCertificationType"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/ExportImportCertification"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega la tipologia (es.: attestato di libera circolazione, licenza di esportazione definitiva, ecc) di una certificazione amministrativa di circolazione ed esportazione/importazione di un bene culturale alla relativa certificazione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the type (i.e. delivery confirmation certification, free movement certification etc) of an import-export certification of a cultural entity to the rrelated certification.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is export import certification type of</rdfs:label>
        <rdfs:label xml:lang="it">è tipo di certificazione di esportazione o importazione di</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {
?type core:isTypeOf ?thing .
}

WHERE {
?type a-cd:isExportImportCertificationTypeOf ?thing .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/isTypeOf"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isExportOfficeOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isExportOfficeOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isAgentInvolvedIn"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/ExportImportCertification"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un ufficio di esportazione a un certificazione di esportazione/importazione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an export office to an export/import certification.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is export office of</rdfs:label>
        <rdfs:label xml:lang="it">è ufficio esportazione di</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: TU/ESP/ESPU</a-cat:iccdNormTag>
        <core:constructQuery>PREFIX &lt;https://w3id.org/arco/ontology/arco-lite/isUserOf&gt;

CONSTRUCT {
?agent a-lite:isExportOfficeOf ?certif .
}

WHERE {
?agent a-cd:isExportOfficeOf ?certif .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/isExportOfficeOf"/>
        <core:replacingQuery>prefix &lt;https://w3id.org/arco/ontology/arco-lite/isUserOf&gt;

select * where {
?NEWagent core:isAgentOf ?NEWagentRole .
?NEWagentRole core:hasRole ?NEWrole ;
core:isAgentRoleOf a-cd:ImportExportCertification .
}</core:replacingQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isFindingContextOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isFindingContextOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isEventOrSituationInTimeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/FindingContext"/>
        <rdfs:range rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega il contesto di rinvenimento di un bene culturale, in particolare un reperto antropologico, al bene culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the finding context of a cultural property, and in particular an anthropological material, to the related cultural property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is finding context of</rdfs:label>
        <rdfs:label xml:lang="it">è contesto di rinvenimento di</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa AT 3.01: OG/OGC</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isFindingContextTypeOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isFindingContextTypeOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isTypeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/FindingContextType"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/FindingContext"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega il tipo di contesto di rinvenimento di un bene culturale, e in particolare di un reperto antropologico, al suo contesto.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a type of cultural property (i.e. anthropological material) finding context to its context.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is finding context type of</rdfs:label>
        <rdfs:label xml:lang="it">è tipo di contesto di rinvenimento di</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {
?type core:isTypeOf ?thing .
}

WHERE {
?type a-cd:isFindingContextTypeOf ?thing .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/isTypeOf"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isFindingLocationOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isFindingLocationOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/isWorkRelatedTo"/>
