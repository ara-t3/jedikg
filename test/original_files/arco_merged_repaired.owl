    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/construction-description/Construction -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/construction-description/Construction">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/construction-description/hasConstructionElement"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/construction-description/ConstructionElement"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/construction-description/hasConstructionSpace"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/construction-description/ConstructionSpace"/>
