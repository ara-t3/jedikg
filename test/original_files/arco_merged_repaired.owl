        <rdfs:range rdf:resource="https://w3id.org/italia/onto/CLV/Address"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una ripartizione territoriale interna a un&apos;area territoriale a un indirizzo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property links a territorial division within a territorial area to an address.</rdfs:comment>
