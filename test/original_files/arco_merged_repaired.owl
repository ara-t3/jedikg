    <!-- https://w3id.org/arco/ontology/core/hasPart -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/core/hasPart">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/core/isPartOf"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <opla:isNativeTo rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/partof.owl"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;entità a una sua parte.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an entity to its part.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="it">ha parte</rdfs:label>
        <rdfs:label xml:lang="en">has part</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">&quot;Riferimento alla parte&quot;, presente in molti campi strutturati delle normative ICCD</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/core/hasRole -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/core/hasRole">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/RO/withRole"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/core/isRoleOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/core/AgentRole"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/RO/Role"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una situazione in cui un ruolo viene ricoperto da un agente al ruolo stesso.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a situation in which an agent holds a role to that role.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="it">ha ruolo</rdfs:label>
        <rdfs:label xml:lang="en">has role</rdfs:label>
