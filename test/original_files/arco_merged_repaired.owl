        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/construction-description/ElevationDevelopment -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/construction-description/ElevationDevelopment">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/construction-description/ConstructionDevelopment"/>
        <owl:disjointWith rdf:resource="https://w3id.org/arco/ontology/construction-description/PlanimetricDevelopment"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta lo sviluppo in elevato dello spazio interno di una costruzione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the elevation development of the interior space of a construction.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/construction-description"/>
        <rdfs:label xml:lang="en">Horizontal subdivision</rdfs:label>
        <rdfs:label xml:lang="it">Suddivisione orizzontale</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa A: SI/SII/SIIO</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/construction-description/ElevationLayout -->

