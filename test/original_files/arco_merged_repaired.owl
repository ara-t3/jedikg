        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BNM: IMG/IMGC
ICCD Normativa BNPE: IRG/IRGC</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/location/ClimateSituation -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/location/ClimateSituation">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/EventOrSituationInTime"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/denotative-description/hasMeasurementCollection"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/denotative-description/MeasurementCollection"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/location/isClimateSituationOf"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/location/NaturalEnvironment"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Questa classe rappresenta la situazione climatica</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents class situation</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="en">Climate situation</rdfs:label>
        <rdfs:label xml:lang="it">Situazione climatica</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>Normativa PG: CA/CLM, CA/CAT. Normativa MODI: CA/CAT. Normativa BNB: LR/LRI/LRIH</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/location/Continent -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/location/Continent">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/CLV/Feature"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/location/isContinentOf"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta un Continente.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a Continent.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="en">Continent</rdfs:label>
        <rdfs:label xml:lang="it">Continente</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/location/Coordinates -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/location/Coordinates">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/CLV/Geometry"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/location/areCoordinatesOf"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/italia/onto/CLV/Geometry"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/location/lat"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/location/long"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/onto/CLV/alt"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta l&apos;insieme delle coordinate, geografiche o proiettate, che permettono la georeferenziazione di un oggetto. Per la georeferenziazione puntuale sarà presente soltanto una coppia di coordinate; per la georeferenziazione lineare e areale saranno presenti più coppie di coordinate che individuano i punti che definiscono la linea o l&apos;area che rappresenta il bene.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the set of coordinates, geographic or projected, which allows the georeferencing of an object. For the punctual georeferencing there is only a pair of coordinates. For the linear and areal georeferencing there are more pairs of coordinates identifying those points of the line or area representing the object.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="it">Coordinate</rdfs:label>
        <rdfs:label xml:lang="en">Coordinates</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale: GE/GEC - Normative precedenti: GP/GPD; GA/GAPD; GL/GLS</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/location/CulturalInstituteOrSiteDefinition -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/location/CulturalInstituteOrSiteDefinition">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Description"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta la definizione della tipologia di un contenitore giuridico.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the type definition of a cultural insititute or site.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="en">Cultural Institute or Site Definition</rdfs:label>
        <rdfs:label xml:lang="it">Definizione di Contenitore Giuridico</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa CG: CG/CGT</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/location/CulturalInstituteOrSiteSpecification -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/location/CulturalInstituteOrSiteSpecification">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Description"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta la specificazione della tipologia di un contenitore giuridico.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the type specification of a cultural insititute or site.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="en">Cultural Institute or Site Specification</rdfs:label>
        <rdfs:label xml:lang="it">Specificazione di Contenitore Giuridico</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa CG: CG/CGQ</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/location/CulturalInstituteOrSiteType -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/location/CulturalInstituteOrSiteType">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Type"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta la tipologia di un contenitore giuridico.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the type of a cultural insititute or site.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
