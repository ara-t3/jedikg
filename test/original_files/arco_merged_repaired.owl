        <rdfs:label xml:lang="en">Slang designation</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale: OGD/OGDT - Normative A e BDM 3: OGA/OGAG.</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT { ?x a a-cd:SlangDesignation .}
WHERE {?x a a-dd:SlangDesignation . }</core:constructQuery>
    </owl:NamedIndividual>
    


