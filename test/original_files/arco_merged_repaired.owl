        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/musical-instrument/VibratingLength"/>
        <core:replacingQuery>select * where {
?musicalinstrument a-mi:hasString ?string .
?string a-dd:hasMeasurementCollection ?meascol .
}</core:replacingQuery>
    </owl:NamedIndividual>
    


