        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>Normativa PG: IM/IMP/IMPT</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/construction-description/isWaterAvailabilityOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/construction-description/isWaterAvailabilityOf">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/construction-description/WaterAvailability"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/construction-description/WaterSystem"/>
