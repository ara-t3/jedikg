        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {
?x a-loc:isTerritorialAreaOf ?y .
}

WHERE {
?x a-loc:isTerritorialDivisionOf ?y .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/location/isTerritorialAreaOf"/>
    </owl:ObjectProperty>
    


