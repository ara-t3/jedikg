    <!-- https://w3id.org/arco/ontology/location/isOldTownAdministrativeTypeOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/location/isOldTownAdministrativeTypeOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isTypeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/location/OldTownAdmistrativeType"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/location/OldTown"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega il tipo di carattere amministrativo alle informazioni relative al suo centro storico.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property connects the administrative type with the information related to its historical center.</rdfs:comment>
