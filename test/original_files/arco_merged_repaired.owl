        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="it">Centro storico</rdfs:label>
        <rdfs:label xml:lang="en">Old town</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD normative A e PG: LC/CST</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/location/OldTownAdmistrativeType -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/location/OldTownAdmistrativeType">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Type"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/isTypeOf"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/location/OldTown"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta le informazioni che precisano il carattere amministrativo del centro storico, che può essere: un capoluogo, una frazione, un centro inglobato o una località.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the information clarifying the administrative character of the old town, which may be: a chief town, a town fraction, an incorporated area or a locality.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="en">Old town administrative type</rdfs:label>
        <rdfs:label xml:lang="it">Tipo di carattere amministrativo del centro storico</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normative A e PG: LC/CST/CSTA</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/location/Outcrop -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/location/Outcrop">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/location/OutcropType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/onto/TI/hasTemporalEntity"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/italia/onto/TI/TemporalEntity"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta l&apos;affioramento in cui è stato rinvenuto il campione</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the outcrop where the specimen was found</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="it">Affioramento</rdfs:label>
        <rdfs:label xml:lang="en">Outcrop</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa beni naturalistici: IM/IMA/IMAF, IMAD, IMAG, ET/ETA/ETAF, ETAD</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/location/OutcropType -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/location/OutcropType">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Type"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il tipo di affioramento.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the outcrop type</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="en">Outcrop type</rdfs:label>
        <rdfs:label xml:lang="it">Tipo di affioramento</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa beni naturalistici: IM/IMA/IMAF, ET/ETA/ETAF</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/location/PedologicalMap -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/location/PedologicalMap">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/location/Map"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta una carta pedologica.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a pedological map.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="it">Mappa pedologica</rdfs:label>
        <rdfs:label xml:lang="en">Pedological map</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa SI 3.00: CA/PED/PEDC</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/location/ShadeTolerance -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/location/ShadeTolerance">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Characteristic"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta la situazione luminosa di un ambiente naturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the shade tolerance of a natural environment.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="en">Shade tolerance</rdfs:label>
        <rdfs:label xml:lang="it">Situazione luminosa</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BN 3.01: LR/LRI/LRIS</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/location/SiteDefinition -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/location/SiteDefinition">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Description"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/location/isSiteDefinitionOf"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/location/SiteType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta la definizione della tipologia di un contenitore fisico.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the type definition of a physical container.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="it">Definizione di Contenitore Fisico</rdfs:label>
        <rdfs:label xml:lang="en">Site Definition</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale: LC/LDC/LDCT</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/location/SiteSpecification -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/location/SiteSpecification">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Description"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/location/isSiteSpecificationOf"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/location/SiteType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta specifiche sulla qualificazione del contenitore fisico, cioè l&apos;aggettivo o la locuzione che, rispetto alla Site Definition, precisa, integra o caratterizza il contenitore fisico dal punto di vista della condizione giuridico-amministrativa o funzionale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents specifications about the physical container, i.e. the adjective or the phrase that with respect to the Site Definition specifies, integrates or characterizes the physical container from the point of view of the legal-administrative or functional condition.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="it">Qualificazione del Contenitore Fisico</rdfs:label>
        <rdfs:label xml:lang="en">Site Specification</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale: LC/LDC/LDCQ</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/location/SiteType -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/location/SiteType">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Type"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/location/hasSiteDefinition"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/location/SiteDefinition"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/location/isSiteTypeOf"/>
                <owl:someValuesFrom rdf:resource="http://dati.beniculturali.it/cis/Site"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/location/hasSiteSpecification"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/location/SiteSpecification"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il tipo di contenitore fisico, cioè la tipologia del contenitore fisico ed eventuali aggettivi o locuzioni che precisano, integrano o caratterizzano il contenitore fisico dal punto di vista della condizione giuridico-amministrativa o funzionale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the type of a physical container, i.e. it contains adjectives or phrases that specify, integrate or characterize the physical container from the point of view of the legal-administrative or functional condition.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="en">Site type</rdfs:label>
        <rdfs:label xml:lang="it">Tipo di Contenitore Fisico</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale: LC/LDC/LDCT; LC/LDC/LDCQ</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/location/Soil -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/location/Soil">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/location/hasMap"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/location/LandUseMap"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/denotative-description/hasMeasurementCollection"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/denotative-description/MeasurementCollection"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il suolo</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the soil</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="en">Soil</rdfs:label>
        <rdfs:label xml:lang="it">Suolo</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/location/Stratum -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/location/Stratum">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/isClassifiedBy"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/location/ChronostratigraphicClass"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/isClassifiedBy"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/location/LithostratigraphicClass"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/location/hasGeochronology"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/italia/onto/TI/TimeInterval"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/location/Substrate -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/location/Substrate">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/location/SubstrateType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/location/hasIncline"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/location/Incline"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il substrato su cui è stato raccolto un campione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the substrate on which the sample is taken.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="en">Substrate</rdfs:label>
        <rdfs:label xml:lang="it">Substrato</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BNB: LR/LRI/LRIR</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/location/SubstrateType -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/location/SubstrateType">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Type"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il tipo di substrato.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represent the type of substrate.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="en">Substrate type</rdfs:label>
        <rdfs:label xml:lang="it">Tipo di substrato</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BNB: LR/LRI/LRIJ</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/location/TimeIndexedTypedLocation -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/location/TimeIndexedTypedLocation">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/EventOrSituationInTime"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/location/hasLocationType"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/location/LocationType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/location/isTimeIndexedTypedLocationOf"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/denotative-description/hasOrientation"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/denotative-description/Orientation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/location/atLocation"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/italia/onto/CLV/Feature"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/location/atSite"/>
                <owl:allValuesFrom rdf:resource="http://dati.beniculturali.it/cis/Site"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/location/hasCulturalInstituteOrSite"/>
                <owl:allValuesFrom rdf:resource="http://dati.beniculturali.it/cis/CulturalInstituteOrSite"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/location/hasGeologicalContext"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/location/GeologicalContext"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/hasGeologicalContext"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/GeologicalContext"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:description xml:lang="en">An example of usage of the class &apos;Time Indexed Typed Location&apos; is the following:
resource:TimeIndexedTypedLocation/0800055566-alternative-1
        a  a-loc:TimeIndexedTypedLocation ;
        rdfs:label &quot;Alternative location 1 of cultural property: 0800055566&quot;@en ;  a-loc:atSite  resource:Site/7761991208459c29ef5c7cee8ff29deb ;
        a-loc:hasLocationType a-loc:LastLocation ;
        tiapit:atTime resource:TimeInterval/2002 .</dc:description>
        <dc:description xml:lang="it">Un esempio d&apos;uso della classe &quot;Localizzazione tipizzata nel tempo&apos; è il seguente:
resource:TimeIndexedTypedLocation/0800055566-alternative-1
        a           a-loc:TimeIndexedTypedLocation ;
        rdfs:label &quot;Altra localizzazione 1 del bene culturale: 0800055566&quot;@en ;
       a-loc:atSite  resource:Site/7761991208459c29ef5c7cee8ff29deb ;
        a-loc:hasLocationType a-loc:LastLocation ;
        tiapit:atTime resource:TimeInterval/2002 .</dc:description>
        <rdfs:comment xml:lang="it">Questa classe rappresenta una localizzazione di un bene culturale, inserita in un arco temporale e qualificata in base al ruolo che la localizzazione riveste nei confronti del bene culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a localization of a cultural property, within a timeframe and qualified according to the role that the localization plays in relation to the cultural property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="it">Localizzazione tipizzata nel tempo</rdfs:label>
        <rdfs:label xml:lang="en">Time Indexed Typed Location</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale: LC; LA; per normativa F: anche LR. Normativa BDI: OC, AT/DML, DU/DUG, DV/DVG, DF/DFG, AI/AIA, AI/AIF, AI/AIG, VI/VIA, VI/VIF, VIG, FI/FIA, FIF, FIG</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/location/ToponymInTime -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/location/ToponymInTime">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/EventOrSituationInTime"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/location/isToponymInTimeOf"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/italia/onto/CLV/Feature"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/onto/l0/name"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta eventuali altre denominazioni del luogo, che cambiano nel tempo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents other place&apos;s designations changing over time.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="it">Toponimo nel tempo</rdfs:label>
        <rdfs:label xml:lang="en">Toponym in time</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale: LC/PVL/PVLT; LA/PRL/PRLT. - Versioni precedenti: LC/PVL, LA/PRL</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/location/TypeOfContext -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/location/TypeOfContext">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Concept"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/location/isTypeOfContextOf"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il tipo di contesto in cui si trova un bene culturale, che può essere urbano, suburbano, extraurbano, territoriale, subacqueo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the type of geographical context where the cultural property is located: i.e. urban, suburban, extra-urban, territorial, underwater.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="it">Tipo di contesto geografico</rdfs:label>
        <rdfs:label xml:lang="en">Type of geographic context</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale: LC/PVZ; LA/PRZ - Normative A e PG: LC/SET/SETT</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/location/UrbanArea -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/location/UrbanArea">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/CLV/AdminUnitComponent"/>
        <owl:disjointWith rdf:resource="https://w3id.org/italia/onto/CLV/District"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta le informazioni relative alla denominazione della zona urbana che fa parte del centro storico dove si trova il bene culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the informations on the denomination of the urban area that is part of the old town where the cultural property is located.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="en">Urban area</rdfs:label>
        <rdfs:label xml:lang="it">Zona urbana</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normative A e PG: LC/ZUR/ZURD.</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/location/ZoogeographicRegion -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/location/ZoogeographicRegion">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/CLV/Feature"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta una regione zoogeografica (i.e. la regione dove è stato raccolto un bene.)</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a zoogeographic region (i.e. where the cp was harvested.)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="it">Regione zoogeografica</rdfs:label>
        <rdfs:label xml:lang="en">Zoogeographic region</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BNZ: LR/LRVZ</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/musical-instrument/HornbostelSachsClass -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/musical-instrument/HornbostelSachsClass">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/musical-instrument/MusicalInstrumentTaxon"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta una classe della classificazione Hornbostel-Sachs per gli strumenti musicali</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the Hornbostel-Sachs class</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/musical-instrument"/>
        <rdfs:label xml:lang="it">Classe Hornbostel-Sachs</rdfs:label>
        <rdfs:label xml:lang="en">Hornbostel-Sachs class</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa SM 4.00: CL/CHS</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/musical-instrument/MusicalInstrument -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/musical-instrument/MusicalInstrument">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/denotative-description/isSoloInstrumentInvolvedIn"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/denotative-description/CommunicationMedium"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/musical-instrument/producesMusicalNote"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/musical-instrument/MusicalNote"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasClassificationInTime"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/core/ClassificationInTime"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/denotative-description/hasAccessory"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/denotative-description/Accessory"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta uno strumento musicale</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a musical instrument</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/musical-instrument"/>
        <rdfs:label xml:lang="en">Musical instrument</rdfs:label>
        <rdfs:label xml:lang="it">Strumento musicale</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa BDI 4.00: CU/CUS/CUSS-CUSA</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/musical-instrument/MusicalInstrumentTaxon -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/musical-instrument/MusicalInstrumentTaxon">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Taxon"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/classifies"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/musical-instrument/MusicalInstrument"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il taxon, ovvero il concetto che appartiene a una classificazione gerarchizzata degli strumenti musicali.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the taxon, that is a concept related to a hierarchical classification system of musical instruments.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/musical-instrument"/>
        <rdfs:label xml:lang="it">Classe degli strumenti musicali</rdfs:label>
        <rdfs:label xml:lang="en">Musical instrument taxon</rdfs:label>
        <rdfs:label xml:lang="it">Taxon degli strumenti musicali</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa SM 4.00: CL/CLA/CLAT</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/musical-instrument/MusicalNote -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/musical-instrument/MusicalNote">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
        <rdfs:comment xml:lang="it">Questa entità rappresenta una nota musicale</rdfs:comment>
        <rdfs:comment xml:lang="en">This entity represents a musical note</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/musical-instrument"/>
        <rdfs:label xml:lang="en">Musical note</rdfs:label>
        <rdfs:label xml:lang="it">Nota musicale</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa SM 4.00: AA/AAN</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/musical-instrument/String -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/musical-instrument/String">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/denotative-description/hasMeasurementCollection"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/denotative-description/MeasurementCollection"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa entità rappresenta la corda di uno strumento musicale cordofono</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the string of a chordophone musical instrument</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/musical-instrument"/>
        <rdfs:label xml:lang="it">Corda</rdfs:label>
        <rdfs:label xml:lang="en">String</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa SM 4.00: AA/AAL</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/natural-specimen-description/Accession -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/natural-specimen-description/Accession">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/EventOrSituation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/isAccessionOf"/>
                <owl:someValuesFrom rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/involvesAgent"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/onto/TI/hasTemporalEntity"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/italia/onto/TI/TemporalEntity"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/SpecimenHarvesting"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta l&apos;informazione (dato) sulla/e persona fisica o giuridica/che che a vario titolo ha/hanno fatto pervenire il bene (campione, raccolta, collezione ecc.) all&apos;Ente di riferimento.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the information about the way in which the cultural property has arrived to the organization</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description"/>
        <rdfs:label xml:lang="en">Accession</rdfs:label>
        <rdfs:label xml:lang="it">Accessione</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BNB: SB/ABC</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/natural-specimen-description/AlterationGrade -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/natural-specimen-description/AlterationGrade">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Characteristic"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/isAlterationGradeOf"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/Specimen"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il grado di alterazionedi un campione causato da processi atmosferici e geologici.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the alteration grade of a specimen,  by weathering process or geological process</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description"/>
        <rdfs:label xml:lang="en">Alteration grade</rdfs:label>
        <rdfs:label xml:lang="it">Grado di alterazione</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BNPE: SR/SRC/SRCZ</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/natural-specimen-description/AlterationType -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/natural-specimen-description/AlterationType">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Type"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/isAlterationTypeOf"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/Specimen"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il tipo di alterazione di un campione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the alteration type of a specimen</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description"/>
        <rdfs:label xml:lang="en">Alteration type</rdfs:label>
        <rdfs:label xml:lang="it">Tipo di alterazione</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BNPE: SR/SRC/SRCH</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/natural-specimen-description/Animal -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/natural-specimen-description/Animal">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta un animale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents an animal.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description"/>
        <rdfs:label xml:lang="en">Animal</rdfs:label>
        <rdfs:label xml:lang="it">Animale</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BNZ. Normativa BDI: DADRM/DRMA</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/natural-specimen-description/ArtificialSpecimen -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/natural-specimen-description/ArtificialSpecimen">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/Specimen"/>
        <owl:disjointWith rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/NaturalSpecimen"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta un campione artificiale</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents an artificial specimen</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description"/>
        <rdfs:label xml:lang="en">Artificial specimen</rdfs:label>
        <rdfs:label xml:lang="it">Campione artificiale</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>Iccd Normativa AT: DA/SRM/SRMT</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/natural-specimen-description/BiogenicSedimentaryStructure -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/natural-specimen-description/BiogenicSedimentaryStructure">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/SedimentaryStructure"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta la struttura sedimentaria biogenica</rdfs:comment>
        <rdfs:comment xml:lang="en">TThis class represents the biogenic sedimentary structure</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description"/>
        <rdfs:label xml:lang="en">Biogenic sedimentary structure</rdfs:label>
        <rdfs:label xml:lang="it">Struttura sedimentaria biogenica</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>Normativa ICCD BNPE: SR/SRC/SRCB</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/natural-specimen-description/BiologicalClass -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/natural-specimen-description/BiologicalClass">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/BiologicalTaxon"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasDirectHigherRank"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/BiologicalPhylum"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasDirectLowerRank"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/BiologicalOrder"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasHigherRank"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/arco/ontology/natural-specimen-description/BiologicalKingdom"/>
                            <rdf:Description rdf:about="https://w3id.org/arco/ontology/natural-specimen-description/BiologicalPhylum"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasLowerRank"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:complementOf>
                            <owl:Class>
                                <owl:unionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://w3id.org/arco/ontology/natural-specimen-description/BiologicalClass"/>
                                    <rdf:Description rdf:about="https://w3id.org/arco/ontology/natural-specimen-description/BiologicalKingdom"/>
                                    <rdf:Description rdf:about="https://w3id.org/arco/ontology/natural-specimen-description/BiologicalPhylum"/>
                                </owl:unionOf>
                            </owl:Class>
                        </owl:complementOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta uno dei livelli di classificazione di una tassonomia biologica, ovvero la classe.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents one level of a biological taxon, the class</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description"/>
        <rdfs:label xml:lang="en">Class</rdfs:label>
        <rdfs:label xml:lang="it">Classe</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>Normativa BNP: SP/SPS/SPSB. - Normativa BNZ: SZ/SZS/SZSB</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/natural-specimen-description/BiologicalFamily -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/natural-specimen-description/BiologicalFamily">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/BiologicalTaxon"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasDirectHigherRank"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/BiologicalOrder"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasDirectLowerRank"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/BiologicalGenus"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta uno dei livelli di classificazione di una tassonomia biologica, ovvero la famiglia</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents one level of a biological taxon, the family.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description"/>
        <rdfs:label xml:lang="it">Famiglia</rdfs:label>
        <rdfs:label xml:lang="en">Family</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
