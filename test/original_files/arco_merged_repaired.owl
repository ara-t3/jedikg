        <rdfs:comment xml:lang="en">This property connects a support (e.g. &quot;paper label&quot;) to an element (stamp, embelem, inscription, mark) which has been represented on it. It is the inverse property of hasSupport.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/denotative-description"/>
        <rdfs:label xml:lang="en">is support of</rdfs:label>
        <rdfs:label xml:lang="it">è supporto di</rdfs:label>
