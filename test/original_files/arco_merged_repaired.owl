        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {
?type a a-loc:PreviousLocation .
}

WHERE {
?type a a-loc:LastLocation .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/location/PreviousLocation"/>
    </owl:NamedIndividual>
    


