        <core:replacingQuery>select * where {
?agent core:isAgentOf ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/Transferor&gt; ;
core:isAgentRoleOf ?thing .
}</core:replacingQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isPrimaryDocumentationOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isPrimaryDocumentationOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/isDocumentationOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Documentation"/>
        <rdfs:range rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:comment xml:lang="it">Questa è la proprietà inversa di &quot;ha documentazione primaria&quot;.</rdfs:comment>
        <rdfs:comment xml:lang="en">This is the inverse property of &quot;has primary documentation&quot;.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is primary documentation of</rdfs:label>
        <rdfs:label xml:lang="it">è documentazione primaria di</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {
?rec a-cd:isRecordingOf ?cp ;
a-cd:primaryDocumentation &quot;True&quot; .
}

WHERE {
?rec a-cd:isPrimaryDocumentationOf ?cp .
}</core:constructQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isProfessionOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isProfessionOf">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Profession"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:comment xml:lang="it">Questa è la proprietà inversa di &quot;ha professione&quot;.</rdfs:comment>
        <rdfs:comment xml:lang="en">This is the inverse property of &quot;has profession&quot;.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is profession of</rdfs:label>
        <rdfs:label xml:lang="it">è professione di</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BDM 2.00: UT/UTN/UTNM - ICCD Normativa BDM 4.00: AU/AUT/AUTE. BDI: AT/ATT/ATTM, AI/AIF/AIFM, VI/VIF/VIFM, FI/FIF/FIFM. SM: MU/MUT/MUTM. Normativa AUT 4.00: AU/AUT/AUTQ</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isProponentAgencyOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isProponentAgencyOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/isAgentRelatedTo"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://dati.beniculturali.it/cis/CulturalEntity"/>
                    <rdf:Description rdf:about="https://w3id.org/arco/ontology/context-description/ProtectiveMeasure"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="it">Questa proprietà collega all&apos;ente proponente, ovvero il soggetto che ha proposto il provvedimento (identificato per mezzo della denominazione per esteso oppure, nel caso di Enti accreditati dall&apos;ICCD, del relativo codice assegnato dall&apos;Istituto) al provvedimento di tutela relativo al bene culturale, oppure direttamente al bene culturale. La relazione tra il ruolo e l&apos;agente che lo riveste è espressa, in maniera generica, nel nome della proprietà, che quindi ne fornisce una rappresentazione semplificata, con ridotta espressività. Nell&apos;ontologia questa relazione è modellata anche, in maniera più espressiva, dalla classe AgentRole, che permette di collegare l&apos;agente e il suo ruolo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an agent that is a proponent agency of a protective measure of a cultural property to the protective measure or to the cultural entity itself. The relation is declared in the name of the property, but within the ontology this relation is also modeled, in a more expressive way, through the class AgentRole.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is proponent agency of</rdfs:label>
        <rdfs:label xml:lang="it">è ente proponente di</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: TU/NVC/NVCA</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?agent a-lite:isProponentAgencyOf ?thing .
}

WHERE {
?agent a-cd:isProponentAgencyOf ?thing .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/isProponentAgencyOf"/>
        <core:replacingQuery>select * where {
?agent core:isAgentOf ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/ProponentAgency&gt; ;
core:isAgentRoleOf ?thing .
}</core:replacingQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isProtectiveMeasureOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isProtectiveMeasureOf">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/ProtectiveMeasure"/>
        <rdfs:range rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un provvedimento di tutela nazionale o internazionale al bene culturale cui si applica.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an international or national protective measure to the cultural enitity to which it is applied.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is protective measure of</rdfs:label>
        <rdfs:label xml:lang="it">è provvedimento di tutela di</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: TU/NVC</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isRecordingOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isRecordingOf">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Recording"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una registrazione alla rispettiva entità culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a recording to the related cultural entity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is recording of</rdfs:label>
        <rdfs:label xml:lang="it">è registrazione di</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BDI: DU</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isReferenceCatalogueOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isReferenceCatalogueOf">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/ReferenceCatalogue"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
        <rdfs:comment xml:lang="it">Questa è la proprietà inversa di &quot;ha repertorio di riferimento&quot;.</rdfs:comment>
        <rdfs:comment xml:lang="en">This is the inverse property of &quot;has reference catalogue&quot;.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is reference catalogue of</rdfs:label>
        <rdfs:label xml:lang="it">è repertorio di riferimento di</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa S 3: RO/COP/COPR
ICCD Normativa TMA 3.00: MA/MAC/MACP</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isRelatedToResearch -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isRelatedToResearch">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Research"/>
        <rdfs:comment>CONSTRUCT {
?x a-cd:hasResearch ?reas .
}

WHERE {
?x a-cd:isRelatedToResearch ?reas .
}</rdfs:comment>
        <rdfs:comment xml:lang="it">Questa proprietà collega un rilevamento di un bene musicale o demoetnoantropologico alla ricerca nell&apos;ambito della quale è stata redatta la scheda.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class relates an observation survey of musical or demoetnoanthropological heritage to the research in which the catalogue record describing a cultural property was recorded (e.g.: a cataloguing campaign)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is related to research</rdfs:label>
        <rdfs:label xml:lang="it">si riferisce a ricerca</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa SM 4.00: DR</a-cat:iccdNormTag>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/hasResearch"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isRelatedWorkInvolvedIn -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isRelatedWorkInvolvedIn">
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/RelatedWorkSituation"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;opera collegata a un bene culturale al rapporto tra l&apos;opera e il bene culturale (es.: un lavoro preparatorio, un prototipo, una copia, un reimpiego di tutto il bene o di una sua parte, ecc.)</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a work related to a cultural property (e.g.: a preparatory work, a prototype, a copy, a reuse, etc.) to the situation in which that work is related to the cultural property itself.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is related work involved in</rdfs:label>
        <rdfs:label xml:lang="it">è opera collegata coinvolta in</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isRelatedWorkSituationOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isRelatedWorkSituationOf">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/RelatedWorkSituation"/>
        <rdfs:range rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:comment xml:lang="it">Questa proprietà, inversa di &apos;ha rapporto con opera collegata&apos;, collega la relazione tra il bene culturale e un&apos;altra opera che ne costituisce una fase preparatoria o che ne rappresenta la fase finale al bene culturale stesso.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property, inverse of &apos;has related work situation&apos;, relates a situation in which a cultural property is related to another work, that could even be another cultural property, to the cultural property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is related work situation of</rdfs:label>
        <rdfs:label xml:lang="it">è rapporto con opera collegata di</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isRelationshipTypeOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isRelationshipTypeOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isTypeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/RelationshipType"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/RelatedWorkSituation"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega il tipo di relazione tra due beni alla situazione che ne descrive la relazione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the type of relationship between two cultural property and the related work situation itself.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is relationship type of</rdfs:label>
        <rdfs:label xml:lang="it">è tipo di relazione di</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale: ROFF
ICCD Normativa VeAC: AU/AUT/AUTO</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isReliabilityOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isReliabilityOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isCharacteristicOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Reliability"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/PhotoInterpretationRendering"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega il livello di affidabilità delle informazioni rilevate nell&apos;indagine a una fotointerpretazione o fotorestituzione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the reliability of the information collected during the survey to a photo interpretation rendering survey.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is reliability of</rdfs:label>
        <rdfs:label xml:lang="it">è affidabilità di</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isReproducedBy -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isReproducedBy">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/reproduces"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Reproduction"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una stampa con la sua riproduzione contenuta in una pubblicazione, di cui la stampa è, o è stata, parte integrante.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a print to the reproduction of that print in a publication.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is reproduced by</rdfs:label>
        <rdfs:label xml:lang="it">è riprodotto da</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa S 3: RO/ADL</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isReproductionOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isReproductionOf">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Reproduction"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/PrintInPublication"/>
        <rdfs:comment xml:lang="it">Questa è la proprietà inversa di &quot;ha riproduzione&quot;.</rdfs:comment>
        <rdfs:comment xml:lang="en">This is the inverse property of &quot;has reproduction&quot;.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is reproduction of</rdfs:label>
        <rdfs:label xml:lang="it">è riproduzione di</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa S 3: RO/ADL</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isReproductionPositionOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isReproductionPositionOf">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/ReproductionPosition"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Reproduction"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega la posizione fisica della riproduzione di una stampa all&apos;interno di una pubblicazione (es.: frontespizio, copertina, colophon, etc.). con la relativa riproduzione della stampa.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the position of the print reproduction in a publication to the print reproduction itself.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is reproduction position of</rdfs:label>
        <rdfs:label xml:lang="it">è posizione della riproduzione di</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa S 3: RO/ADL/ADLP</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isResearchOn -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isResearchOn">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Research"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="it">Questa proprietà la ricerca ad un&apos;entità.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a research to an entity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is research on</rdfs:label>
        <rdfs:label xml:lang="it">è ricerca su</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa SM e BDM 4.00: DR/DRT</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isResearchScientificDirectorOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isResearchScientificDirectorOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/isAgentRelatedTo"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Research"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega il responsabile scientifico di una ricerca alla ricerca.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the research&apos;s scientific responsible to its research.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is research scientific director of</rdfs:label>
        <rdfs:label xml:lang="it">è  responsabile scientifico della ricerca di</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?agent a-lite:isScientificDirectorOf ?thing .
}

WHERE {
?agent a-cd:isResearchScientificDirectorOf ?thing .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/isScientificDirectorOf"/>
        <core:replacingQuery>select * where {
?agent core:isAgentOf ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/ScientificDirector&gt; ;
core:isAgentRoleOf ?thing .
}</core:replacingQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isResponsibilityFor -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isResponsibilityFor">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isAgentRoleOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Responsibility"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="en">This property relates the attribution of a responsibility to an agent, relating to the activities of production and dissemination of photographic heritage (e.g.: committent, editor, printer, dedicatee, etc.) to photographic heritage.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is responsibility for</rdfs:label>
        <rdfs:label xml:lang="it">è responsibilità su</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa F: PD/PDF</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isResponsibilityTypeOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isResponsibilityTypeOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isTypeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/ResponsibilityType"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Responsibility"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega al tipo di responsabilità (es.: stampatori, ritoccatori, coloritori, ecc.) alla relativa responsabilità individuata relativamente ai processi di produzione e di divulgazione che caratterizzano specificamente i beni fotografici.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the responsibility type (i.e. printers, retouchers) to the related responsibility relative to some production or disclosure process which characterize photographic artefacts.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is responsibility type of</rdfs:label>
        <rdfs:label xml:lang="it">è tipo di responsabilità di</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {
?type core:isTypeOf ?thing .
}

WHERE {
?type a-cd:isResponsibilityTypeOf ?thing .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/isRoleOf"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isResponsibleForInsertionOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isResponsibleForInsertionOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/isAgentRelatedTo"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/CurrentInventory"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega il responsabile dell&apos;inventariazione patrimoniale del bene all&apos;inventario patrimoniale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the agent responsible for the cultural entity&apos;s inventory to the current inventory.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is responsible for insertion of</rdfs:label>
        <rdfs:label xml:lang="it">è responsabile dell&apos;immissione in patrimonio di</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?agent a-lite:isResponsibleAgentOf ?thing .
}

WHERE {
?agent a-cd:isResponsibleForInsertionOf ?thing .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/isResponsibleAgentOf"/>
        <core:replacingQuery>select * where {
?agent core:isAgentOf ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/ResponsibleAgent&gt; ;
core:isAgentRoleOf ?thing .
}</core:replacingQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isReusedBy -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isReusedBy">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/hasRelatedWork"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/reuses"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un bene culturale a un altro bene culturale collegato che lo riutilizza in tutto o in parte.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural entity to a connected cultural entity that reuse it or a part of it.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is reused by</rdfs:label>
        <rdfs:label xml:lang="it">è riutilizzato in</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale 4.00: RV/RSE/RSER = &apos;è riutilizzato in&apos; (versioni precedenti: &apos;bene composto&apos;)</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?x a-lite:isReusedBy ?y .
}

WHERE {
?x a-cd:isReusedBy ?y .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/isReusedBy"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isReviewOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isReviewOf">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Review"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;attività di revisione a un&apos;entità.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a review activity to an entity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is review of</rdfs:label>
        <rdfs:label xml:lang="it">è revisione di</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>Normativia BNB: RB/RBR. Normativa BNM: RM. Normativa BNPL: RP. Normativa BNPE: RR</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isSECCategoryOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isSECCategoryOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isCategoryOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/SECCategory"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/InventorySituation"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega la categoria SEC attribuita al bene alla situazione inventariale del bene.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a the patrimonial category attributed to the cultural property based on the SEC classification to the inventory situation.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is SEC category of</rdfs:label>
        <rdfs:label xml:lang="it">è categoria SEC di</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normtiva Trasversale 4.00: UB/INP/INPZ</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isScaleOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isScaleOf">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Scale"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/GraphicOrCartographicDocumentation"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega la scala di rappresentazione alla documentazione grafica e cartografica.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the representation scale to its graphic or cartographic representation.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is scale of</rdfs:label>
        <rdfs:label xml:lang="it">è scala di</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isSecondaryAuthorOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isSecondaryAuthorOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/isAgentRelatedTo"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega l&apos;autore secondario di un entità, come ad esempio un contributo o una parte di una pubblicazione, all&apos;entità stessa.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the secondary authors of an entity (i.e. a publication&apos;s contribution or section) to the related entity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is secondary author of</rdfs:label>
        <rdfs:label xml:lang="it">è autore secondario di</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?agent a-lite:isSecondaryAuthorOf ?thing .
}

WHERE {
?agent a-cd:isSecondaryAuthorOf ?thing .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/isSecondaryAuthorOf"/>
        <core:replacingQuery>select * where {
?agent core:isAgentOf ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/SecondaryAuthor&gt; ;
core:isAgentRoleOf ?thing .
}</core:replacingQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isSexInterpretationOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isSexInterpretationOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isSituationOf"/>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is sex interpretation of</rdfs:label>
        <rdfs:label xml:lang="it">è interpretazione del sesso di</rdfs:label>
        
        <core:constructQuery>CONSTRUCT {
?sexint a a-cd:Sex .
?sexint a-cd:isSexOf ?cultent .
}

WHERE {
?sexint a-cd:isSexInterpretationOf ?cultent .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/isSexOf"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isSexOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isSexOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isEventOrSituationInTimeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Sex"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega il sesso di un&apos;entità all&apos;entità stessa.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the sex to the entity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is sex of</rdfs:label>
        <rdfs:label xml:lang="it">è sesso di</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="it">unstable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isSpeciesIn -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isSpeciesIn">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isConceptOf"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una specie alla tassonomia in cui è classificata.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a species to the linnaean taxon in which it is classified.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is species in</rdfs:label>
        <rdfs:label xml:lang="it">è specie in</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {
?tax core:isTaxonOf ?identificationOrClassification . 
}

WHERE {
?tax a-cd:isSpeciesOf ?identificationOrClassification .
}</core:constructQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isSpecificBibliographicSourceOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isSpecificBibliographicSourceOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/isBibliographicSourceOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Edition"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega l&apos;edizione dell&apos;opera parte della bibliografia specifica con l&apos;entità di cui è bibliografia.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the edition of the work part of the specific bibliography to the involved entity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is specific bibliographic source of</rdfs:label>
        <rdfs:label xml:lang="it">è fonte bibliografica specifica di</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isStorageMediumOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isStorageMediumOf">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/StorageMedium"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Recording"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega il supporto di archiviazione di una registrazione con la registrazione stessa.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the storage medium of a recording to the recording itself.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is storage medium of</rdfs:label>
        <rdfs:label xml:lang="it">è supporto di memoria di</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BDI: DU/DUO, DU/DUM, DV/DVM, DV/DVO, AI/AIO, AI/AIM, VI/VIO, VI/VIM</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isStratigraphicUnitOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isStratigraphicUnitOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isLocationOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/StratigraphicUnit"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/ArchaeologicalExcavation"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega l&apos;unità stratigrafica dalla quale proviene il bene rinvenuto nello scavo al relativo scavo archeologico.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the stratigraphic unit from which a cultural property has been found to the related archeological excavation.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is stratigraphic unit of</rdfs:label>
        <rdfs:label xml:lang="it">è unità stratigrafica di</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: RE/DSC/DSCU</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isSubjectOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isSubjectOf">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Subject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="it">Questa proprietà, inversa a &quot;ha soggetto&quot;, collega un soggetto o motivo ornamentale al bene culturale o a un&apos;opera correlata a un bene culturale in quanto sua fase preparatoria o finale o a un apparato iconografico-decorativo su cui è rappresentato.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a subject or ornamental motif to the cultural property or to the final or preparatory work of a cultural property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is subject of</rdfs:label>
        <rdfs:label xml:lang="it">è soggetto di</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale: DA/AID/AIDI - Normativa F: SG/SGT/SGTI - Altre normative di versioni precedenti alla 4.00: OG/SGT/SGTI - ICCD Normative F, RA, SMO, PST, S, OAC, OA, MI, D, NU: RO/ROF/ROFS</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isSubjectOfInterpretation -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isSubjectOfInterpretation">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Interpretation"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isSubspeciesIn -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isSubspeciesIn">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isConceptOf"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una sottospecie alla tassonomia in cui è classificata.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a subspecies to the linnaean taxon in which it is classified.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is subspecies in</rdfs:label>
        <rdfs:label xml:lang="it">è sottospecie in</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {
?tax core:isTaxonOf ?identificationOrClassification . 
}

WHERE {
?tax a-cd:isSubspeciesOf ?identificationOrClassification .
}</core:constructQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isSurveyImageOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isSurveyImageOf">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/SurveyImage"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/PhotoInterpretationRendering"/>
        <rdfs:comment xml:lang="it">Questa è la proprietà inversa di &quot;ha immagine di indagine&quot;.</rdfs:comment>
        <rdfs:comment xml:lang="en">This is the inverse property of &quot;has survey image&quot;.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is survey image of</rdfs:label>
        <rdfs:label xml:lang="it">è immagine di indagine</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: RE/FOI/FOIT + FOID</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isSurveyImageTypeOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isSurveyImageTypeOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isTypeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/SurveyImageType"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/SurveyImage"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega il tipo una immagine di indagine (fotografia aerea o fotografia satellitare). con la relativa immagine di indagine.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the type of a survey image (i.e. aerial photograph, Satellite photograph) to the related survey image.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is survey image type of</rdfs:label>
        <rdfs:label xml:lang="it">è tipo di immagine di indagine di</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {
?type core:isTypeOf ?thing .
}

WHERE {
?type a-cd:isSurveyImageTypeOf ?thing .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/isTypeOf"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isSurveyMethodOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isSurveyMethodOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isMethodOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/SurveyMethod"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Survey"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega il metodo adottato nel corso di un&apos;indagine all&apos;indagine stessa.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the method adopted in a survey to the survey itself.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is survery method of</rdfs:label>
        <rdfs:label xml:lang="it">è metodo di indagine di</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: RE/RCG/RCGM; RE/DSC/DSCM - ICCD Normativa AT: PT/PTC/PTCM</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isSurveyMotivationOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isSurveyMotivationOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/isDescriptionOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/SurveyMotivation"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Survey"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega il motivo principale che ha determinato uno scavo archeologico, una ricognizione archeologica, un&apos;indagine archeometrica e diagnostica o una fotointerpretazione e fotorestituzione a ciascuno di essi.</rdfs:comment>
        <rdfs:comment xml:lang="it">This property relates the main motivation that led to an archeological, archaeometric or diagnostic survey or a photo interpretation rendering to each of them.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is survey motivation of</rdfs:label>
        <rdfs:label xml:lang="it">è motivo di indagine di</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>Normativa Trasversale: RE/RCG/RCGE; RE/DSC/DSCT; RE/IND/INDM; RE/FOI/FOIM</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isSurveyOn -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isSurveyOn">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Survey"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;indagine effettuata su un bene culturale al bene stesso.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural entity&apos;s survey to the cultural entity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is survey on</rdfs:label>
        <rdfs:label xml:lang="it">è indagine su</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: RE; CM/ISP - ICCD Normative NU, RA, BNB, MA, CA: RS/ALB - ICCD Normativa AT 3.00: IN/INI - Normativa BDM e SM 4.00: DR</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isSurveyPhotographerOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isSurveyPhotographerOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/isAgentRelatedTo"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/ObservationSurvey"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega il fotografo professionista (diverso dal rilevatore) che ha effettuato l&apos;indagine all&apos;indagine di rilevamento di un bene demo-etno-antropologico.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the professional photographer who took the shot to the observation survey of a demo-etno-antropologic entity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is observation photographer of</rdfs:label>
        <rdfs:label xml:lang="it">è fotografo dell&apos;indagine di</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?agent a-lite:isPhotographerOf ?thing .
}

WHERE {
?agent a-cd:isSurveyPhotographerOf ?thing .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/isPhotographerOf"/>
        <core:replacingQuery>select * where {
?agent core:isAgentOf ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/Photographer&gt; ;
core:isAgentRoleOf ?thing .
}</core:replacingQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isSurveyScientificDirectorOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isSurveyScientificDirectorOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/isAgentRelatedTo"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Survey"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega il responsabile scientifico di un&apos;indagine alla relativa indagine.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the scientific director of a survey to the related survey.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is survey scientific director of</rdfs:label>
        <rdfs:label xml:lang="it">è responsabile scientifico dell&apos;indagine di</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?agent a-lite:isScientificDirectorOf ?thing .
}

WHERE {
?agent a-cd:isSurveyScientificDirectorOf ?thing .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/isScientificDirectorOf"/>
        <core:replacingQuery>select * where {
?agent core:isAgentOf ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/ScientificDirector&gt; ;
core:isAgentRoleOf ?thing .
}</core:replacingQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isSurveySoundEngineerOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isSurveySoundEngineerOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/isAgentRelatedTo"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/ObservationSurvey"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega il fonico professionista (diverso dal rilevatore) che ha effettuato la registrazione sonora all&apos;indagine di rilevamento di un bene demo-etno-antropologico.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the sound engineer who recorded an observation survey to the related observation survey of a demo-etno-antropologic entity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is survey sound engineer of</rdfs:label>
        <rdfs:label xml:lang="it">è fonico dell&apos;indagine di</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?agent a-lite:isSoundEngineerOf ?thing .
}

WHERE {
?agent a-cd:isSurveySoundEngineerOf ?thing .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/isSoundEngineerOf"/>
        <core:replacingQuery>select * where {
?agent core:isAgentOf ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/SoundEngineer&gt; ;
core:isAgentRoleOf ?thing .
}</core:replacingQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isTimeIntervalFor -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isTimeIntervalFor">
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/TI/TimeInterval"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Dating"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un intervallo di tempo con la datazione di un evento relativo a un bene culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a time interval to the dating related to a cultural property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
