    <!-- https://w3id.org/arco/ontology/catalogue/isCatalogueRecordVersionRiTOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/catalogue/isCatalogueRecordVersionRiTOf">
