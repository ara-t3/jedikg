        <rdfs:label xml:lang="en">Covering</rdfs:label>
        <rdfs:label xml:lang="it">Rivestimento</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa A: PV e CP</a-cat:iccdNormTag>
    </owl:Class>
    


