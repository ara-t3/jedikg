    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/core/isSituationOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/core/isSituationOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isEventOrSituationInTimeOf"/>
