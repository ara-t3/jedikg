        <rdfs:label xml:lang="en">is water availability of</rdfs:label>
        <rdfs:label xml:lang="it">è disponibilità idrica di</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>Normativa PG: CA/CAI</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/construction-description/isWaterDistributionOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/construction-description/isWaterDistributionOf">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/construction-description/WaterDistribution"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/construction-description/WaterSystem"/>
        <rdfs:comment xml:lang="it">Questa proprietà collelga il tipo di distribuzione idrica all&apos;impianto idrico</rdfs:comment>
        <rdfs:comment xml:lang="en">This property connects the water distribution type to a water system.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/construction-description"/>
        <rdfs:label xml:lang="en">is water distribution type of</rdfs:label>
        <rdfs:label xml:lang="it">è tipo di distribuzione idrica di</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>Normativa PG: CA/CAI</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/construction-description/isWaterElementOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/construction-description/isWaterElementOf">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/construction-description/WaterElement"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="it">Questa proprietà collelga l&apos;elemento idrico all&apos;impianto idrico.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property connects a water element to the water system.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/construction-description"/>
        <rdfs:label xml:lang="en">is water element of</rdfs:label>
        <rdfs:label xml:lang="it">è elemento idrico di</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>Normativa PG: FO/FOT</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/construction-description/isWaterSystemOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/construction-description/isWaterSystemOf">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/construction-description/WaterSystem"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un sistema delle acque al suo ambiente naturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the water system of a natural environment with its natural environment.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/contruction-description"/>
        <rdfs:label xml:lang="en">is water system of</rdfs:label>
        <rdfs:label xml:lang="it">è sistema delle acque di</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/construction-description/laysOnSoil -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/construction-description/laysOnSoil">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/location/Soil"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega le fondazioni al terreno.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property connects the foundation to the soil.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/construction-description"/>
        <rdfs:label xml:lang="it">ha terreno di appoggio</rdfs:label>
        <rdfs:label xml:lang="en">lays on soil</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/laysOnSoil"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/definesEligibleIntervention -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/definesEligibleIntervention">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isEligibleInterventionDefinedBy"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/UrbanPlanningInstrument"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/InterventionType"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega uno strumento urbanistico-territoriale al tipo di intervento ammesso dalla normativa specifica (es.: restauro/ manutenzione straordinaria).</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a urban planning instrument to the eligible intervention type (e.g.: conservation intervention/ exceptional maintenance).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha intervento ammesso</rdfs:label>
        <rdfs:label xml:lang="en">has eligible intervention</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: TU/STU/STUN</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasAcquisition -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasAcquisition">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasEventOrSituationInTime"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isAcquisitionOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Acquisition"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un bene culturale coinvolto in un evento di acquisizione all&apos;acquisizione stessa.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultual property involved in an acquisition event to the actual acquisition.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha acquisizione</rdfs:label>
        <rdfs:label xml:lang="en">has acquisition</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: TU/ACQ</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasAcquisitionType -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasAcquisitionType">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isAcquisitionTypeOf"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Acquisition"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/AcquisitionType"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;acquisizione di un bene culturale al tipo di acquisizione (es.: donazione, alienazione, confisca).</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural entity&apos;s acquisition to its acquisition type (i.e. donation, seizure).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha tipo di acquisizione</rdfs:label>
        <rdfs:label xml:lang="en">has acquisition type</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: TU/ACQ/ACQT</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT   { ?acq a a-cd:Acquisition;
core:hasType ?type.
 }
WHERE       { ?acq a a-cd:Acquisition;
a-cd:hasAcquisitionType ?type.
 }</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasActivityOperator -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasActivityOperator">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/hasRelatedAgent"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isActivityOperatorOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Activity"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;attività (per esempio, un&apos;indagine o un intervento su un bene culturale) all&apos;operatore dell&apos;attività. La relazione tra il ruolo e l&apos;agente che lo riveste è espressa nel nome della proprietà, che quindi ne fornisce una rappresentazione semplificata, con ridotta espressività. Nell&apos;ontologia questa relazione è modellata anche, in maniera più espressiva, dalla classe AgentRole, che permette di collegare l&apos;agente e il suo ruolo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an activity to the agent who performed the activity. In the ontology this relationship is modelled also by the class AgentRole which allows more expressiveness.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha operatore dell&apos;attività</rdfs:label>
        <rdfs:label xml:lang="en">has activity operator</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale: RE/IND/INDN; CO/RST/RSTN - ICCD Normativa SM e BDM 4.00: DR/DRL - ICCD normative di versioni precedenti: RE/AIN/AINR. RS/ALB/ALBO; CO/ALB/ALBO. Normativa BNB: RB/RBR/RBRA</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?x a-lite:hasOperator ?agent .
}

WHERE {
?x a-cd:hasActivityOperator ?agent .
}</core:constructQuery>
        <core:constructQuery>select * where {
?activity core:hasAgentRole ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/Operator&gt; ;
core:hasAgent ?agent .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasOperator"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasActivityResponsible -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasActivityResponsible">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/hasRelatedAgent"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isActivityResponsibleOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Activity"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;attività (per esempio, un&apos;indagine o un intervento su un bene culturale) all&apos;ente o al soggetto responsabile del rilevamento. La relazione tra il ruolo e l&apos;agente che lo riveste è espressa nel nome della proprietà, che quindi ne fornisce una rappresentazione semplificata, con ridotta espressività. Nell&apos;ontologia questa relazione è modellata anche, in maniera più espressiva, dalla classe AgentRole, che permette di collegare l&apos;agente e il suo ruolo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an activity to the institution or the survey&apos;s responsible entity. In the ontology this relationship is modelled also by the class AgentRole which allows more expressiveness.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha responsabile dell&apos;attività</rdfs:label>
        <rdfs:label xml:lang="en">has activity responsible</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: RE/RCG/RCGR; RE/DSC/DSCF; RE/IND/INDE; RE/FOI/FOIE - Normativa SM e BDM 4.00: DR/DRV. RS/RST/RSTE. CM/ISP/ISPN. RS/ALB/ALBE; CO/ALB/ALBE.</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?x a-lite:hasResponsibleAgent ?agent .
}

WHERE {
?x a-cd:hasActivityResponsible ?agent .
}</core:constructQuery>
        <core:constructQuery>select * where {
?activity core:hasAgentRole ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/ResponsibleAgent&gt; ;
core:hasAgent ?agent .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasResponsibleAgent"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasActivitySponsor -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasActivitySponsor">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/hasRelatedAgent"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isActivitySponsorOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Activity"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;attività (per esempio, un&apos;indagine o un intervento su un bene culturale) all&apos;ente o al soggetto che ha finanziato l&apos;attività.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an activity to its investor. The investor may be an institution or an agent.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha finanziatore dell&apos;attività</rdfs:label>
        <rdfs:label xml:lang="en">has activity sponsor</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: RS/RST/RSTR; RE/IND/INDR</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?x a-lite:hasSponsor ?agent .
}

WHERE {
?x a-cd:hasActivitySponsor ?agent .
}</core:constructQuery>
        <core:constructQuery>select * where {
?activity core:hasAgentRole ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/Sponsor&gt; ;
core:hasAgent ?agent .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasSponsor"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasAge -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasAge">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasEventOrSituationInTime"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isAgeOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Age"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;entità alla sua età biologica.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an entity with its biological age.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha età</rdfs:label>
        <rdfs:label xml:lang="en">has age</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasAgeOfDeathInterpretation -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasAgeOfDeathInterpretation">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasSituation"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isAgeOfDeathInterpretationOf"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/AgeOfDeathInterpretation"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un reperto antropologico alla stima dell&apos;età della morte.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an antropologic artifact to the interpretation of its age of death.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha età della morte stimata</rdfs:label>
        <rdfs:label xml:lang="en">has age of death interpretation</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {
?cp a-cd:hasAge ?age .
}

WHERE {
?cp a-cd:hasAgeOfDeathInterpretation ?age .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/hasAge"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasAgeType -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasAgeType">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isAgeTypeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/AgeInterpretation"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/AgeType"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega l&apos;interpretazione dell&apos;età di un&apos;entità con il tipo di età.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the age interpretation to the type of the age.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha tipo di età</rdfs:label>
        <rdfs:label xml:lang="en">has age type</rdfs:label>
        
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT   { ?age a a-cd:Age;
core:hasType ?type.
 }
WHERE       { ?age a a-cd:AgeInterpretation;
a-cd:hasAgeType ?type.
 }</core:constructQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasAgentWithResponsibility -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasAgentWithResponsibility">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasAgent"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isAgentWithResponsibilityIn"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Responsibility"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega l&apos;individuazione di una responsabilità relativamente ai processi di produzione e di divulgazione che caratterizzano specificamente i beni fotografici all&apos;agente che ha quella specifica responsabilità.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the responsibility&apos;s identification to the agent which has that specific responsibility, focusing on the production process and dissemination of the photographic heritage.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha agente con responsabilità</rdfs:label>
        <rdfs:label xml:lang="en">has agent with responsibility</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa F e FF 4.00: PD/PDF/PDFN - ICCD Normativa F 3.00: PD/PDF/PDFN o PD/PDF/PDFB</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasAlternativeDatingType -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasAlternativeDatingType">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isAlternativeDatingTypeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/AlternativeDating"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/AlternativeDatingType"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una datazione alternativa con la sua tipologia.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an alternative dating to its type.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha datazione alternativa</rdfs:label>
        <rdfs:label xml:lang="en">has alternative dating type</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale: DT/ADT/ADTT</a-cat:iccdNormTag>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasAnomaly -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasAnomaly">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasEventOrSituationInTime"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isAnomalyOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/PhotoInterpretationRendering"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Anomaly"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una fotointerpretazione o fotorestituzione a un&apos;anomalia rilevata nel corso dell&apos;indagine.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a photo interepretation rendering to an anomaly revealed by a survey.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha anomalia</rdfs:label>
        <rdfs:label xml:lang="en">has anomaly</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: RE/FOI/FOIA + RE/FOI/FOIQ + RE/FOI/FOIF</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasAnomalyOrigin -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasAnomalyOrigin">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasCharacteristic"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isAnomalyOriginOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Anomaly"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/AnomalyOrigin"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;anomalia rilevata durante una fotointerpretazione o fotorestituzione all&apos;origine dell&apos;anomalia (naturale, antropica, incerta).</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an anomaly detected during a photo interpretation or rendering survey to the origin of the anomaly (e.g. natural, unsure).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha origine dell&apos;anomalia</rdfs:label>
        <rdfs:label xml:lang="en">has anomaly origin</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: RE/FOI/FOIA</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasAnomalyType -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasAnomalyType">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isAnomalyTypeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Anomaly"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/AnomalyType"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;anomalia rilevata nel corso di una fotointerpretazione o fotorestituzione al tipo di anomalia (puntuale, lineare, areale).</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an anomaly revealed by a photo interpretation rendering to its anomaly type (line, point, poligony anomaly).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha tipo di anomalia</rdfs:label>
        <rdfs:label xml:lang="en">has anomaly type</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: RE/FOI/FOIQ</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT   { ?anm a a-cd:Anomaly;
core:hasType ?type.
 }
WHERE       { ?anm a a-cd:Anomaly;
a-cd:hasAnomalyType ?type.
 }</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasArchaeologicalPropertySurveyType -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasArchaeologicalPropertySurveyType">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isArchaeologicalPropertySurveyTypeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/ArchaeologicalPropertySurvey"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/ArchaeologicalPropertySurveyType"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;indagine su un bene archeologico al tipo di indagine.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a survey on an archaeological property to the type of survey.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha tipo di indagine su bene archeologico</rdfs:label>
        <rdfs:label xml:lang="en">has archaeological property survey type</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa AT 3.00: IN/INI/INIT</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT   { ?surv a a-cd:ArchaeologicalPropertySurvey;
core:hasType ?type.
 }
WHERE       { ?surv a a-cd:ArchaeologicalPropertySurvey;
a-cd:hasArchaeologicalPropertySurveyType ?type.
 }</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasArchaeometricDiagnosticSurveyType -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasArchaeometricDiagnosticSurveyType">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isArchaeometricDiagnosticSurveyTypeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/ArchaeometricDiagnosticSurvey"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/ArchaeometricDiagnosticSurveyType"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;indagine archeometrica e diagnostica al suo tipo (es.: analisi della malta, carotaggio, termografia, etc.)</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an arecheometric diagnostic survey to its type (i.e. thermal imaging, coring).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha tipo di indagine archeometrica e diagnostica</rdfs:label>
        <rdfs:label xml:lang="en">has archaeometric diagnostic survey type</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale 4.00: RE/IND/INDI - ICCD normative di versioni precedenti: RE/AIN/AINT</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT   { ?surv a a-cd:ArchaeometricDiagnosticSurvey;
core:hasType ?type.
 }
WHERE       { ?surv a a-cd:ArchaeometricDiagnosticSurvey;
a-cd:hasArchaeometricDiagnosticSurveyType ?type.
 }</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasArchivalRecordSet -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasArchivalRecordSet">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/involvesCollection"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isArchivalRecordSetIn"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/ArchivalRecordSetMembership"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/ArchivalRecordSet"/>
        <rdfs:comment xml:lang="it">Questa proprietà, inversa a &quot;è unità archivistica complessa in&quot;, collega il rapporto tra una unità archivistica complessa e un bene culturale che ne fa parte alla unità archivistica stessa.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the relationship of an archival set and a one of its belonging cultural entities.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha unità archivistica complessa</rdfs:label>
        <rdfs:label xml:lang="en">has archival record set</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa F: UB/UBF</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?colmemb a-cd:involvesCollection ?coll .
}

WHERE {
?collmemb a-cd:hasArchivalRecordSet ?coll .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/involvesCollection"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasArchive -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasArchive">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/involvesAgent"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isArchivedIn"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/SourceAndDocument"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una documentazione costituita da fonti e documenti all&apos;archivio e/o istituzione conservativa.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the documentation made of sources and documents to the archive or conservative institution.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha archivio</rdfs:label>
        <rdfs:label xml:lang="en">has archive</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: DO/FNT/FNTN</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasAssociatedObject -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasAssociatedObject">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isObjectAssociatedTo"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega il contesto di rinvenimento di un bene culturale (in particolare, un reperto antropologico) a un elemento associato al bene in quel contesto (es.: orecchini, scudo, resti di tessuto).</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a finding context of a cultural property (in particular, an anthropological material) to an object associated to the cultural property (e.g: earrings, shield, cloth, etc.)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha elemento associato</rdfs:label>
        <rdfs:label xml:lang="en">has associated object</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa AT 3.01: OG/OGC/OGCE</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasAttachedDocumentation -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasAttachedDocumentation">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/hasDocumentation"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isAttachedDocumentationOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Documentation"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;entità alla documentazione allegata.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an entity with its attached documentation.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha documentazione allegata</rdfs:label>
        <rdfs:label xml:lang="en">has attached documentation</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale: FTAX, DRAX, VDCX,  REGX, FNTX, ADMX (solo v. 3.00 e 3.01)</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasAttributedAuthor -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasAttributedAuthor">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/involvesAgent"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isAttributedAuthorIn"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/AuthorshipAttribution"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una situazione in cui viene attribuito un autore a un bene culturale all&apos;autore stesso.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a situation where an autorship is attributed to a cultural entity&apos;s author.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha autore attribuito</rdfs:label>
        <rdfs:label xml:lang="en">has attributed author</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>AU/AUT/AUTN (+ AU/AUT/AUTS); AU/AAT; AU/AAT/AATN. ICCD Normativa F e FF 4.00: PD/PDF/PDFN - ICCD Normativa F 3.00: PD/PDF/PDFN o PD/PDF/PDFB</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?respo a-cd:hasAgentWithResponsibility ?agent .
?respo a a-cd:Responsibility .
}

WHERE {
?respo a-cd:hasAttributedAuthor ?agent .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/hasAgentWithResponsibility"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasAuthor -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasAuthor">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/hasRelatedAgent"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isAuthorOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://w3id.org/arco/ontology/context-description/hasAuthorshipAttribution"/>
            <rdf:Description rdf:about="https://w3id.org/arco/ontology/context-description/hasAttributedAuthor"/>
        </owl:propertyChainAxiom>
        <rdfs:comment xml:lang="it">Questa proprietà collega una entità di qualsiasi tipo (documentazione, bene culturale, etc.) con il suo autore.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a entity (i.e. documentation, cultural entity, etc.) to its author.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha autore</rdfs:label>
        <rdfs:label xml:lang="en">has author</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale: DO/FTA/FTAA, DO/DRA/DRAA, DO/VDC/VDCR, DO/REG/REGA, DO/FNT/FNTA, DO/BIB/BIBA - Normativa S 3: RO/ADL/ADLA - Normative VeAC e AT 3.01: DO/BSE/BSEA - Normativa MI 3.00: AU/DDC/DDCN</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?x a-lite:hasAuthor ?agent .
}

WHERE {
?x a-cd:hasAuthor ?agent .
}</core:constructQuery>
        <core:constructQuery>select * where {
?x core:hasAgentRole ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/Author&gt; ;
core:hasAgent ?agent .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasAuthor"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasAuthorityFileCataloguingAgency -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasAuthorityFileCataloguingAgency">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/hasRelatedAgent"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isAuthorityFileCataloguingAgencyOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;entità descritta in una scheda di Authority File all&apos;ente schedatore dell&apos;authority file stesso. Per esempio, l&apos;attribuzione di un autore a un bene culturale, uno scavo archeologico, una ricognizione archeologica, una bibliografia. Questa proprietà, esprimendo il significato della relazione nel nome, dà una rappresentazione semplificata della relazione che lega questa entità, l&apos;authority file, e l&apos;ente schedatore dell&apos;authority file.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an entity described in a authority file to the file&apos;s cataloguing institution.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha ente schedatore dell&apos;authority file</rdfs:label>
        <rdfs:label xml:lang="en">has authority file cataloguing agency</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: AU/AUT/AUTJ; DO/BIB/BIBJ; RE/RCG/RCGJ; RE/DSC/DSCJ - ICCD Normativa F: PD/PDF/PDFJ</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?x a-lite:hasCataloguingAcency ?agent .
}

WHERE {
?x a-cd:hasAuthorityFileCataloguingAgency ?agent .
}</core:constructQuery>
        <core:constructQuery>select * where {
?x core:hasAgentRole ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/CataloguingAcency&gt; ;
core:hasAgent ?agent .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasCataloguingAgency"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasAuthorshipAttribution -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasAuthorshipAttribution">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasEventOrSituationInTime"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isAuthorshipAttributionOf"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/arco/ontology/context-description/AuthorshipAttribution"/>
                    <rdf:Description rdf:about="https://w3id.org/arco/ontology/context-description/CulturalScopeAttribution"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="it">Proprietà che lega un oggetto culturale a un&apos;attribuzione di autore o di responsabilità relativa all&apos;oggetto.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural entity to an authorship or resposibility attribution of the entity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha attribuzione di autore/responsabilità</rdfs:label>
        <rdfs:label xml:lang="en">has authorship attribution</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: AU/AUT; AU/ATB; AU/AAT</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT  {
?cp a-cd:hasResponsibility ?attrRespo .
}

WHERE {
?cp a-cd:hasAuthorshipAttribution ?attrRespo .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/hasResponsibility"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasBibliographicSource -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasBibliographicSource">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isBibliographicSourceOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Edition"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;entità alla sua bibliografia. Per esempio, nell&apos;ambito del Catalogo Generale, collega un bene culturale alla bibliografia che riguarda il bene stesso, descritto in una scheda di catalogo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an entity to its bibliography.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha bibliografia</rdfs:label>
        <rdfs:label xml:lang="en">has bibliography</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: DO/BIB; RE/RCG/RCGS</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasBibliography -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasBibliography">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isBibliographyOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Bibliography"/>
        <rdfs:label xml:lang="it">ha bibliografia</rdfs:label>
        <rdfs:label xml:lang="en">has bibliography</rdfs:label>
        
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale 4.00: DO/BIB; RE/RCG/RCGS</a-cat:iccdNormTag>
        <core:replacingQuery>select * {
?thing a-cd:hasBibliographicSource ?edition .
?edition a a-cd:Edition ;
core:hasBibliographicEntry ?NEWbibEntry ;
a-cd:hasTitle ?NEWtitle .
?NEWbibEntry a BibliographicEntry ;
a-cd:completeBibliographicReference ?ref .
}</core:replacingQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasBibliographyType -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasBibliographyType">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isBibliographyTypeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Bibliography"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/BibliographyType"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega la bibliografia al tipo di riferimento bibliografico.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a bibliography to its bibliography type.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha tipo di bibliografia</rdfs:label>
        <rdfs:label xml:lang="en">has bibliography type</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>BIB/BIBF</a-cat:iccdNormTag>
        <core:replacingQuery>select * where {
?thing a-cd:hasBibliographicSource,
a-cd:hasSpecificBibliographicSource,
a-cd:hasContextBibliographicSource,
a-cd:hasComparisonBibliographicSource ?edition .
}</core:replacingQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasBiologicalTaxon -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasBiologicalTaxon">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasClassification"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isBiologicalTaxonOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/BiologicalTaxon"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;entità biologica a una tassonomia.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a biological entity to a taxon.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha tassonomia biologica</rdfs:label>
        <rdfs:label xml:lang="en">has biological taxon</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa AT: OG/OGS</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?thing core:isClassifiedBy ?taxon .
}

WHERE {
?thing a-cd:hasTaxon ?taxon .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/isClassifiedBy"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasBiologicalTaxonomy -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasBiologicalTaxonomy"/>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasChangeOfAvailability -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasChangeOfAvailability">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasEventOrSituationInTime"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isChangeOfAvailabilityOf"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/ChangeOfAvailability"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un bene culturale coinvolto in un un evento di mutamento di condizione materiale (furto, distruzione, recupero) all&apos;evento stesso.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural enity involved in a change of availability event (i.e. theft, destruction, recovery) to the event.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha mutamento condizione materiale</rdfs:label>
        <rdfs:label xml:lang="en">has change of availability</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale: TU/ALN</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasChangeOfAvailabilityType -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasChangeOfAvailabilityType">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isChangeOfAvailabilityTypeOf"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/ChangeOfAvailability"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/ChangeOfAvailabilityType"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega il mutamento di condizione materiale di un bene culturale al tipo di evento (es.: furto, distruzione, recupero).</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural entity&apos;s change of availability to the event type (i.e. theft, destruction, recovery).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha tipo di mutamento condizione materiale</rdfs:label>
        <rdfs:label xml:lang="en">has change of availability type</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: TU/ALN/ALNT</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT   { ?av a a-cd:ChangeOfAvailability;
core:hasType ?type.
 }
WHERE       { ?av a a-cd:ChangeOfAvailability;
a-cd:hasChangeOfAvailabilityType ?type.
 }</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasCircumstance -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasCircumstance">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasEventOrSituationInTime"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isCircumstanceOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Circumstance"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una situazione all&apos;occasione che ha determinato quella situazione. Per esempio, può collegare una situazione in cui viene indicata la committenza di un bene culturale all&apos;occasione che ha determinato quella committenza, oppure un luogo di ripresa di un bene fotografico all&apos;occasione che ha determinato il motivo della ripresa, o ancora l&apos;uso di un bene culturale all&apos;occasione d&apos;uso.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a situation to the circumstance which led to the situation. For example it can connect a situation where is indicated a cultural entity&apos;s committment to its circumstance.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha circostanza</rdfs:label>
        <rdfs:label xml:lang="en">has circumstance</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale: UT/UTU/UTUO; normativa BDM: UT/UTO; AU/CMM/CMMC; normativa VeAC: AU/FRU/FRUC; normativa F: LR/LRO - ICCD Normativa MI: AU/DDC/DDCC</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasCircumstanceType -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasCircumstanceType">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isCircumstanceTypeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Circumstance"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/CircumstanceType"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;occasione con il tipo di occasione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the circumstance to its type.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha tipo di circostanza</rdfs:label>
        <rdfs:label xml:lang="en">has circumstance type</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BDI: CA/CAR; CA/CAC</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT   { ?circ a a-cd:Circumstance;
core:hasType ?type.
 }
WHERE       { ?circ a a-cd:Circumstance;
a-cd:hasCiscumstanceType ?type.
 }</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasCoinIssuance -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasCoinIssuance">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasEventOrSituationInTime"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isCoinIssuanceOf"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/CoinIssuance"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un bene numismatico alla sua emissione, o una contromarca a una nuova emissione che sostituisce nominale, autorità emittente, zecca e cronologia della moneta originari.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a numismatic entity to its issuance.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha emissione di moneta</rdfs:label>
        <rdfs:label xml:lang="en">has coin issuance</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa NU: DA/AUE; DA/CON/CONN; DA/CON/CONZ; DA/CON/CONA; DA/CON/CONC - ICCD Normativa OA (dopo il rilascio della specifica scheda NU nel 2004 la scheda OA non è stata più utilizzata per la catalogazione di monete e medaglie): AU/EDT. DA/AUE/AUE</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasCoinMember -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasCoinMember">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/hasMemberOfCollection"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isCoinMemberOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/NumismaticSeries"/>
        <rdfs:range rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una serie di monete a una moneta che ne è membro.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a numismatic series to a coin that is member of it.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha moneta membro</rdfs:label>
        <rdfs:label xml:lang="en">has coin member</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt;

CONSTRUCT {
?coll a-lite:hasCollectionMember ?cp .
}

WHERE {
?coll a-cd:hasCoinMember ?cp .
}</core:constructQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasCollection -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasCollection">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/CollectionMembership"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega l&apos;appartenenza a una collezione di un bene culturale alla collezione stessa.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the collection membership of a cultural property to the collection itself.</rdfs:comment>
        <rdfs:label xml:lang="it">ha collezione</rdfs:label>
        <rdfs:label xml:lang="en">has collection</rdfs:label>
        
        <core:constructQuery>CONSTRUCT {
?colmemb a-cd:involvesCollection ?coll .
}

WHERE {
?collmemb a-cd:hasCollection ?coll .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/involvesCollection"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasCollector -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasCollector">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/hasRelatedAgent"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isCollectorOf"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CollectionCulEnt"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una collezione di beni culturali al collezionista.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a collection of cultural properties to its collector.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha collezionista</rdfs:label>
        <rdfs:label xml:lang="en">has collector</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>UB/COL/COLN</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?x a-lite:hasCollector ?agent .
}

WHERE {
?x a-cd:hasCollector ?agent .
}</core:constructQuery>
        <core:constructQuery>select * where {
?x core:hasAgentRole ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/Collector&gt; ;
core:hasAgent ?agent .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasCollector"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasCommission -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasCommission">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasEventOrSituationInTime"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isCommissionOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Commission"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un bene culturale alla sua committenza.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural entity to its commission.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/context-description"/>
        <rdfs:label xml:lang="it">ha committenza</rdfs:label>
        <rdfs:label xml:lang="en">has commission</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>AU/CMM</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasCommittent -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasCommittent">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/hasRelatedAgent"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isCommittentIn"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Commission"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una situazione in cui viene indicata la committenza di un bene culturale alla persona o istituzione committente.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a situation where it is indicated a cultural entity&apos;s commission to the investor agent or institution.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha committente</rdfs:label>
        <rdfs:label xml:lang="en">has committent</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: AU/CMM/CMMN</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?x a-lite:hasCommittent ?agent .
}

WHERE {
?x a-cd:hasActivityCommittent ?agent .
}</core:constructQuery>
        <core:constructQuery>select * where {
?x core:hasAgentRole ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/Committent&gt; ;
core:hasAgent ?agent .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasCommittent"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasComparisonBibliographicSource -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasComparisonBibliographicSource">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/hasBibliographicSource"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isComparisonBibliographicSourceOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Edition"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;entità all&apos;edizione dell&apos;opera parte della bibliografia di confronto.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an entity with the edition of the involved comparison bibliographic work.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha fonte bibliografica di confronto</rdfs:label>
        <rdfs:label xml:lang="en">has comparison bibliographic entry</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: DO/BIB/BIBX</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasConstructionCompany -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasConstructionCompany">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/involvesAgent"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isConstructionCompanyOf"/>
        <rdfs:range rdf:resource="http://dati.gov.it/onto/dcatapit#Organization"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega la realizzazione del bene culturale ad una ditta.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the realization of a cultural property to a construction company.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha ditta costruttrice</rdfs:label>
        <rdfs:label xml:lang="en">has construction company</rdfs:label>
        <owl:deprecated>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?cp a-lite:hasConstructionCompany ?agent .
}

WHERE {
?cp a-cd:hasConstructionCompany ?agent .
}</owl:deprecated>
        
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasConstructionCompany"/>
        <core:replacingQuery>select * where {
?x core:hasAgentRole ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/ConstructionCompany&gt; ;
core:hasAgent ?agent .
}</core:replacingQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasContextBibliographicSource -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasContextBibliographicSource">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/hasBibliographicSource"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isContextBibliographicSourceOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Edition"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;entità all&apos;edizione dell&apos;opera parte della bibliografica di contesto.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an entity with the edition of the involved contextual bibliographic work.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha fonte bibliografica di contesto</rdfs:label>
        <rdfs:label xml:lang="en">has context bibliographic source</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: DO/BIB/BIBX</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasCopyright -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasCopyright">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isCopyrightOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Copyright"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;entità, per esempio un bene fotografico, ai diritti d&apos;autore detenuti da un agente, o allo stato di &quot;in pubblico dominio&quot; relativo all&apos;entità stessa, qualora i diritti siano scaduti.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an entity to copiright held by an agent or its &quot;public domain&quot; condition, if it is out of copyright.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha diritti d&apos;autore</rdfs:label>
        <rdfs:label xml:lang="en">has copyright</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa F 4.00 e OAC: TU/CPR. ICCD Normativa Trasversale 4.00: DO/FTA/FTAY, DO/DRA/DRAY, DO/VDC/VDCY, DO/REG/REGY, DO/FNT/FNTY, DO/BIB/BIBY - ICCD Normativa MI 3.00: DA/PLC</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasCopyrightHolder -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasCopyrightHolder">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/hasRelatedAgent"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isCopyrightHolderIn"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Copyright"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega i diritti d&apos;autore di un&apos;entità al titolare dei diritti d&apos;autore. Questa proprietà fornisce una rappresentazione semplificata della relazione, il cui valore viene esplicitato nel nome della proprietà. La stessa relazione viene anche modellata nell&apos;ontologia, in maniera più espressiva, per mezzo della classe AgentRole, che permette di collegare un agente al ruolo che ha rivestito (in questo caso, al ruolo di &quot;titolare dei diritti d&apos;autore&quot;).</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an entity&apos;s copyright to its copyright holder. In the ontology this relationship is modelled also by the class AgentRole which allows more expressiveness.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha titolare dei diritti d&apos;autore</rdfs:label>
        <rdfs:label xml:lang="en">has copyright holder</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa F 4.00 e OAC: TU/CPR/CPRN</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?x a-lite:hasCopyrightHolder ?agent .
}

WHERE {
?x a-cd:hasCopyrightHolder ?agent .
}</core:constructQuery>
        <core:constructQuery>select * where {
?x core:hasAgentRole ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/CopyrightHolder&gt; ;
core:hasAgent ?agent .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasCopyrightHolder"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasCreationLocation -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasCreationLocation">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/hasRelatedWork"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isCreationLocationOf"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un bene culturale a un altro bene culturale collegato, che ne costituisce la sede di produzione/realizzazione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural entity to a connected cultural entity which constitutes its production site.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha luogo di creazione</rdfs:label>
        <rdfs:label xml:lang="en">has creation location</rdfs:label>
        <rdfs:label xml:lang="it">è stato realizzato in</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale 4.00: RV/RSE/RSER = &apos;è stato realizzato in&apos; (versioni precedenti: &apos;sede di realizzazione&apos;)</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?x a-lite:hasCreationLocation ?y .
}

WHERE {
?x a-cd:hasCreationLocation ?y .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasCreationLocation"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasCulturalGeographicArea -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasCulturalGeographicArea">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isCulturalGeographicAreaOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Use"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/CLV/Feature"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega l&apos;uso del bene con la sua area geografico-culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural entity&apos;s use to its cultural geographical area.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha area geografico-culturale</rdfs:label>
        <rdfs:label xml:lang="en">has cultural geographic area</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {
?x a a-cd:Use ;
&lt;https://w3id.org/italia/onto/CLV/hasSpatialCoverage&gt; ?feat .
}

WHERE {
?x a a-cd:Use ;
a-cd:hasCulturalGeographicArea ?feat .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/italia/onto/CLV/hasSpatialCoverage"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasCulturalPropertyEstimate -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasCulturalPropertyEstimate">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/hasEstimate"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isCulturalPropertyEstimateOf"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Estimate"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un bene culturale alla stima effettuata sul bene stesso.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural property to the estimate of that cultural property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha stima di bene culturale</rdfs:label>
        <rdfs:label xml:lang="en">has cultural property estimate</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {
?x a-cd:hasEstimate ?y .
}

WHERE {
?x a-cd:hasCulturalPropertyEstimate ?y .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/hasEstimate"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasCulturalPropertyStage -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasCulturalPropertyStage">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isCulturalPropertyStageIn"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/RelatedWorkSituation"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/CulturalPropertyStage"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega il rapporto tra un bene culturale e un&apos;altra entità collegata (opera preparatoria o opera finale) allo stadio di realizzazione del bene stesso in rapporto a questa entità.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the relatioship between a cultural property and a related work (preparatory or final work) to the stage of the cultural property referring to this related work.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha fase di realizzazione</rdfs:label>
        <rdfs:label xml:lang="en">has cultural property stage</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normative RA, SMO, PST, S, OAC, OA, MI, D, NU, F: RO/ROF/ROFF</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?rws a-cd:hasRelationshipType ?type .
}

WHERE {
?rws a-cd:hasCulturalPropertyStage ?type .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/hasRelationshipType"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasCulturalScope -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasCulturalScope">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isCulturalScopeOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/CulturalScope"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una situazione in cui viene attribuito un ambito culturale di un bene culturale all&apos;ambito culturale stesso.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a situation, where a cultural scope is attributed to a cultural entity, to the cultural scope.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha ambito culturale</rdfs:label>
        <rdfs:label xml:lang="en">has cultural scope</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: AU/ATB. Normativa BDM e SM: AU/AUT/AUTC. BDI: AT/ATT/ATTB, AI/AIF/AIFB, VI/VIF/VOFB, FI/FI/FIFB. Normativa SM: MU/MUT/MUTB. Normativa AUT: AU/AUT/AUTU</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasDating -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasDating">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasSituation"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isDatingOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Dating"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;entità alla sua cronologia.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an entity to its dating.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/context-description"/>
        <rdfs:label xml:lang="it">ha cronologia</rdfs:label>
        <rdfs:label xml:lang="en">has dating</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: DT - ICCD Normative F, RA, SMO, PST, S, OAC, OA, MI, D, NU: RO/ROF</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasDatingEvent -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasDatingEvent">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isDatingEventOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Dating"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/EventOrSituation"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una cronologia a un evento relativo al bene culturale, cui si riferisce la specifica cronologia.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a dating to an event involving the cultural property, which the dating is about.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha evento relativo a datazione</rdfs:label>
        <rdfs:label xml:lang="en">has event related to dating</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>DTN/DTNS; se non c&apos;è, Event = &quot;realizzazione&quot;. ICCD Normative F, RA, SMO, PST, S, OAC, OA, MI, D, NU: RO/ROF/ROFD. ICCD Normativa Trasversale: DT/ADT.</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasDerivatedWorkType -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasDerivatedWorkType">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isDerivatedWorkTypeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/DerivatedWork"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/DerivatedWorkType"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;opera derivata da un bene culturale al tipo di opera derivata.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a work derivated from a cultural entity to its type.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha tipo di opera derivata</rdfs:label>
        <rdfs:label xml:lang="en">has derivated work type</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa F: RO/CRF/CRFT - Normativa S: RO/ADL/ADLL - Normative RA, SMO, PST, S, OA, MI, D, NU: RO/REI/REIT - Normative CA, MA: RO/RIU/RIUT</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT   { ?dw a a-cd:DerivatedWork;
core:hasType ?type.
 }
WHERE       { ?dw a a-cd:DerivatedWork;
a-cd:hasDerivatedWorkType ?type.
 }</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasDesignationInTime -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasDesignationInTime">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasEventOrSituationInTime"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isDesignationInTimeOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/DesignationInTime"/>
        <rdfs:comment xml:lang="it">Questa proprietà associa un bene culturale alla sua denominazione e/o dedicazione o, per la normativa FF, titolo, nel corso del tempo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property connects a cultural entity to its denomination and/or dedication, or title (for FF legislation) over time.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha designazione nel tempo</rdfs:label>
        <rdfs:label xml:lang="en">has designation in time</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: OG/OGD. - Normativa BNB: OG/OGT/OGTE e OG/OGT/OGTC. - Normativa NU: OG/OGT/OGTO. - OG/OGT/OGTU. Normativa SI: OG/OGT/OGTY</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasDetectionMethod -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasDetectionMethod">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasMethod"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isDetectionMethodOf"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/DetectionMethod"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un bene culturale alla modalità di individuazione che ne ha permesso l&apos;individuazione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural property to the detection method that allowed the detection of the cultural property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha metodo di individuazione</rdfs:label>
        <rdfs:label xml:lang="en">has detection method</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: OG/OGM</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasDocumentation -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasDocumentation">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isDocumentationOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Documentation"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un bene culturale alla documentazione che riguarda il bene descritto in una scheda di catalogo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural entity to the documentation related to the cultural entity described in a catalogue record.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha documentazione</rdfs:label>
        <rdfs:label xml:lang="en">has documentation</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale 4.00: tutti i campi strutturati di DO tranne BIB</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasDocumentationType -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasDocumentationType">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isDocumentationTypeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Documentation"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/DocumentationType"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una documentazione al tipo di documentazione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a documentation to its type.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha tipo di documentazione</rdfs:label>
        <rdfs:label xml:lang="en">has documentation type</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>FTAP, DRAT, FNTP (+VDCP, REGP), ADMP (v. 3.00 e 3.01)</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT   { ?doc a a-cd:Documentation;
core:hasType ?type.
 }
WHERE       { ?doc a a-cd:Documentation;
a-cd:hasDocumentationType ?type.
 }</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasDomicile -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasDomicile">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isDomicileOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Location"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;agente al suo domicilio.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an agent to the domicile.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha domicilio</rdfs:label>
        <rdfs:label xml:lang="en">has domicile</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa BDI: AT/DML. Normativa SM: MU/DML.</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasEdition -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasEdition">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isEditionOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Edition"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;entità a una sua edizione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an entity to its edition.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha edizione</rdfs:label>
        <rdfs:label xml:lang="en">has edition</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normative VeAC e AT 3.01: DO/BSE/BSEN - Normativa S 3.00: RO/ADL/ADLE.</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasEditor -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasEditor">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/hasRelatedAgent"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isEditorOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Edition"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;edizione all&apos;editore.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an edition to its editor.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha editore</rdfs:label>
        <rdfs:label xml:lang="en">has editor</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?x a-lite:hasEditor ?agent .
}

WHERE {
?x a-cd:hasEditor ?agent .
}</core:constructQuery>
        <core:constructQuery>select * where {
?x core:hasAgentRole ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/Editor&gt; ;
core:hasAgent ?agent .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasEditor"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasEligibleIntervention -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasEligibleIntervention">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isInterventionEligibleBy"/>
        <rdfs:label xml:lang="it">ha intervento ammesso</rdfs:label>
        <rdfs:label xml:lang="en">has eligible intervention</rdfs:label>
        
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: TU/STU/STUN</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?x a-cd:definesEligibleIntervention ?intType .
}

WHERE {
?x a-cd:hasEligibleIntervention ?int .
?int a-cd:hasInterventionType ?intType .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/definesEligibleIntervention"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasEstimate -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasEstimate">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasEventOrSituationInTime"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isEstimateOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Estimate"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;entità a una sua stima.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an entity to its estimate.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha stima</rdfs:label>
        <rdfs:label xml:lang="en">has estimate</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: UB/STI - ICCD Normative di versione 2.00: UB/INV/INVS</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasExportImportCertification -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasExportImportCertification">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isExportImportCertificationOf"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/ExportImportCertification"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un bene culturale a una certificazione amministrativa per la circolazione e l&apos;esportazione/importazione che riguarda il bene stesso.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural entity to its import-export certification.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha certificazione di esportazione/importazione</rdfs:label>
        <rdfs:label xml:lang="en">has export/import certification</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: TU/ESP</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasExportImportCertificationType -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasExportImportCertificationType">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isExportImportCertificationTypeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/ExportImportCertification"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/ExportImportCertificationType"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una certificazione amministrativa di circolazione ed esportazione/importazione di un bene culturale alla sua tipologia (es.: attestato di libera circolazione, licenza di esportazione definitiva, ecc).</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a import-export certification of a cultural entity to its type (i.e. delivery confirmation certification, free movement certification etc).</rdfs:comment>
        <rdfs:comment xml:lang="it">ha tipo di certificazione di esportazione o importazione</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">has export import certification type</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: TU/ESP/ESPT</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT   { ?cert a a-cd:ExportImportCertification;
core:hasType ?type.
 }
WHERE       { ?cert a a-cd:ExportImportCertification;
a-cd:hasExportImportCertificationType ?type.
 }</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasExportOffice -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasExportOffice">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/involvesAgent"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isExportOfficeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/ExportImportCertification"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una certificazione di importazione/esportazione al&apos;Ufficio Esportazione che ha emesso la certificazione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an export/import certification to the certifying Export Department.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha ufficio esportazione</rdfs:label>
        <rdfs:label xml:lang="en">has export office</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: TU/ESP/ESPU</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?cert a-lite:hasExportOffice ?agent .
}

WHERE {
?cert a-cd:hasExportOffice ?agent .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasExportOffice"/>
        <core:replacingQuery>select * where {
?cert core:hasAgentRole ?NEWagentRole .
?NEWagentRole core:hasRole ?NEWrole ;
core:hasAgent ?agent .
}</core:replacingQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasFindingContext -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasFindingContext">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasEventOrSituationInTime"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isFindingContextOf"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/FindingContext"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un bene culturale, in particolare un reperto antropologico, al suo contesto di rinvenimento.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural property, and in particular an anthropological material, to its finding context.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha contesto di rinvenimento</rdfs:label>
        <rdfs:label xml:lang="en">has finding context</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa AT 3.01: OG/OGC</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasFindingContextType -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasFindingContextType">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isFindingContextTypeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/FindingContext"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/FindingContextType"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega il contesto di rinvenimento di un bene culturale, e in particolare di un reperto antropologico, al tipo di contesto.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural property (anthropological material) finding context to the type of context.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha tipo di contesto di rinvenimento</rdfs:label>
        <rdfs:label xml:lang="en">has finding context type</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa AT 3.01: OG/OGC/OGCT</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT   { ?con a a-cd:FindingContext;
core:hasType ?type.
 }
WHERE       { ?con a a-cd:FindingContext;
a-cd:hasFindingContextType ?type.
 }</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasFindingLocation -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasFindingLocation">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/hasRelatedWork"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isFindingLocationOf"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un bene culturale a un altro bene culturale collegato, che ne costituisce la sede di rinvenimento archeologico.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural entity to a connected cultural entity which constitutes the site where it was rediscovered.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha sede di rinvenimento</rdfs:label>
        <rdfs:label xml:lang="en">has finding location</rdfs:label>
        <rdfs:label xml:lang="it">è stato rinvenuto in</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale 4.00: RV/RSE/RSER = &apos;è stato rinvenuto in&apos; (versioni precedenti: &apos;sede di rinvenimento&apos;)</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?x a-lite:hasFindingLocation ?y .
}

WHERE {
?x a-cd:hasFindingLocation ?y .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasFindingLocation"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasFormat -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasFormat">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/hasDescription"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isFormatOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Documentation"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Format"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega la documentazione con il suo formato.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the documentation to its format.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha formato</rdfs:label>
        <rdfs:label xml:lang="en">has format</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale: DO/FTA/FTAF, DO/DRA/DRAF, DO/DNT/FNTR</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?thing a-dd:hasFormat ?form .
}

WHERE  {
?thing a-cd:hasFormat ?form .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/hasFormat"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasFruition -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasFruition">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasSituation"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isFruitionOf"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Fruition"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un vestimento antico o contemporaneo a un&apos;occasione in cui è stato indossato da una o più persone.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates garment to the context in which it has been worn.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha fruizione</rdfs:label>
        <rdfs:label xml:lang="en">has fruition</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>Normativa VeAC: AU/FRU</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?cp a-cd:hasUse ?use .
}

WHERE {
?cp a-cd:hasFruition ?use .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/hasUse"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasFunctionalPurpose -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasFunctionalPurpose">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isFunctionalPurposeOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/UseFunction"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;entità (es bene culturale, design, apparato iconografico/decorativo o elemento apposto su un bene culturale come un&apos;iscrizione) alla sua funzione di uso (decorativo, religioso, simbolico, magico-offensivo, etc.), inteso come funzione che deve svolgere.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property realtes an entity (e.g. cultural entity, design, iconographic/decorative apparatus, affixed element like an inscription) to its functional purpose, intended as the function the object has to perform (decorative, religious, symbolic, magic-offensive etc.).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description"/>
        <rdfs:label xml:lang="it">ha scopo funzionale</rdfs:label>
        <rdfs:label xml:lang="en">has functional purpose</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale: DA/ISE/ISEC - Normative di versioni precedenti: DA/ISR/ISRC; DA/APF/APFF</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasGenus -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasGenus">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasConcept"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isGenusIn"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una tassonomia linneana al genere, che è uno dei concetti della tassonomia.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a linnaean taxon to the genus, that is one of the concept of the taxon.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha genere</rdfs:label>
        <rdfs:label xml:lang="en">has genus</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa AT: OG/OGS/OGSG. - Normativa BNB: RB/RBN/RBNA; SB/NAA/NAAA; SB/NAT/NATA</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?identificationOrClassification core:hasTaxon ?tax .
}

WHERE {
?identificationOrClassification a-cd:hasGenus ?tax .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/hasTaxon"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasInterpretationCriterion -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasInterpretationCriterion">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/hasDescription"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isInterpretationCriterionOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/InterpretationCriterion"/>
        <rdfs:comment xml:lang="it">Questa proprietà associa una attribuzione di autore/responsabilità, una cronologia, una committenza, o altre situazioni che prevedono una interpretazione, alla motivazione o criterio che hanno determinato quella interpretazione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an authorship, dating, commission, or other interpretation situations, to the reason or criterion which led to that interpretation.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha criterio interpretativo</rdfs:label>
        <rdfs:label xml:lang="en">has interpretation criterion</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: AU/AUT/AUTM; AU/CMM/CMMF; AU/AAT/AATM; AU/ATB/ATBM; DT/DTM/DTMM; SG/SGT/SGTL - ICCD Normativa F: PD/PDF/PDFM - ICCD Normativa VeAC: AU/FRU/FRUF - CCD Normative F, RA, SMO, PST, S, OAC, OA, MI, D, NU: RO/ROF/ROFM. DA/SEM/SEMC. DA/STS/STSC. Normativa A e PG: RE/REN/RENF</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-cd: &lt;hhtps://w3id.org/arco/ontology/context-description/&gt;
prefix a-core: &lt;hhtps://w3id.org/arco/ontology/core/&gt;

CONSTRUCT {
?x a-core:informationSource ?y .
}

WHERE {
?x a-cd:hasInterpretationCriterion ?z .
?z rdfs:Label ?y
}</core:constructQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasInterpretationSubject -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasInterpretationSubject">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isSubjectOfInterpretation"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Interpretation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasIntervention -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasIntervention">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isInterventionOn"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Intervention"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un bene culturale con un intervento, a fini conservativi o di altro tipo, che lo ha interessato.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural entity to a intervention on it, for conservational or other purposes.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha intervento</rdfs:label>
        <rdfs:label xml:lang="en">has intervention</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale 4.00: CO/RST; normative di versioni precedenti: RS/RST - Normativa VeAC: CO/RIA - Normativa CA: RO/RIS</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasInterventionRole -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasInterventionRole">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasRole"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isInterventionRoleIn"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Responsibility"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/RO/Role"/>
        <rdfs:comment xml:lang="it">Questa proprietà associa un&apos;attribuzione di autore/responsabilità al ruolo rivestito dall&apos;autore/responsabilità o dall&apos;ambito culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an authorship attribution to the agent&apos;s role.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha ruolo nell&apos;intervento</rdfs:label>
        <rdfs:label xml:lang="en">has intervention role</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>AU/ATB/ATBR; AU/AUT/AUTR.
ICCD Normative F e FF: PD/PDF/PDFR</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasInterventionType -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasInterventionType">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isInterventionTypeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Intervention"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/InterventionType"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un intervento, a fini conservativi o di altro tipo, che ha interessato un bene culturale al tipo di intervento.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an intervention on a cultural property (i.e. conservation, interventions, reprocessing, restoring, etc.) to its intervention type.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha tipo di intervento</rdfs:label>
        <rdfs:label xml:lang="en">has intervention type</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale 4.00: valori di CO/RST/RSTI
Normativa VeAC: CO/RIA (riadattamento/modifica)
Normativa CA: RO/RIS (intervento successivo)</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT   { ?int a a-cd:Intervention;
core:hasType ?type.
 }
WHERE       { ?int a a-cd:Intervention;
a-cd:hasInterventionType ?type.
 }</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasInventory -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasInventory">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isInventoryOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/InventorySituation"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Inventory"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un bene culturale o una delle entità o attività collegate al bene culturale a un inventario che registra informazioni relative al bene culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural property or an entity or an activity related to it to an inventory.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha inventario</rdfs:label>
        <rdfs:label xml:lang="en">has inventory</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>UB/INV; ICCD Normativa Trasversale: UB/INP. -  ICCD Normativa RA 3.00 RE/DSC/DSCI</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasInventoryIdentifierResponsible -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasInventoryIdentifierResponsible">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/hasRelatedAgent"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isInventoryIdentifierResponsibleOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/InventorySituation"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un inventario al contenitore giuridico che conserva attualmente il bene o che lo ha conservato in passato, e che è responsabile dell&apos;assegnazione del numero di inventario.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an inventory to the juridical container responsible for the inventory identifier of the cultural property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha responsabile di numero di inventario</rdfs:label>
        <rdfs:label xml:lang="en">has inventory identifier responsible</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale: UB/INV/INVG</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?x a-lite:hasResponsibleAgent ?agent .
}

WHERE {
?x a-cd:hasInventoryIdentifierResponsible ?agent .
}</core:constructQuery>
        <core:constructQuery>select * where {
?x core:hasAgentRole ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/ResponsibleAgent&gt; ;
core:hasAgent ?agent .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasResponsibleAgent"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasInventorySituation -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasInventorySituation">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasEventOrSituationInTime"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isInventorySituationOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/InventorySituation"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una cosa alla situazione inventariale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an entity to its inventory situation.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha situazione inventariale</rdfs:label>
        <rdfs:label xml:lang="en">has inventory situation</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">UB/INV; ICCD Normativa Trasversale: UB/INP.</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasIssuer -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasIssuer">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/hasRelatedAgent"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isIssuerIn"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/CoinIssuance"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega l&apos;emissione della moneta al soggetto emittente. Questa proprietà, esprimendo il significato della relazione nel nome, dà una rappresentazione semplificata della relazione che lega questa entità e l&apos;agente; la stessa relazione è rappresentata attraverso una n-ary relation, arco-core:AgentRole, che permette di collegare l&apos;agente al ruolo che riveste nei confronti dell&apos;entità.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates to coin&apos;s issuance to the issuer agent. In the ontology this relationship is modelled also by the class AgentRole which allows more expressiveness.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha soggetto emittente</rdfs:label>
        <rdfs:label xml:lang="en">has issuer</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa NU: DA/AUE/AUEE - ICCD Normativa OA (dopo il rilascio della specifica scheda NU nel 2004 la scheda OA non è stata più utilizzata per la catalogazione di monete e medaglie): AU/EDT/EDTN. DA/CON/CONA</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?x a-lite:hasIssuer ?agent .
}

WHERE {
?x a-cd:hasIssuer ?agent .
}</core:constructQuery>
        <core:constructQuery>select * where {
?x core:hasAgentRole ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/Issuer&gt; ;
core:hasAgent ?agent .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasIssuer"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasIssuingAgency -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasIssuingAgency">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/hasRelatedAgent"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isIssuingAgencyOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/UrbanPlanningInstrument"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega uno strumento urbanistico-territoriale con l&apos;ente o l&apos;amministrazione che ha emanato il provvedimento.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an urban-planning instrument to the institution which issued the provision.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha ente che ha emanato il provvedimento</rdfs:label>
        <rdfs:label xml:lang="en">has issuing agency</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>TU/STU/STUE</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?x a-lite:hasIssuingAgency ?agent .
}

WHERE {
?x a-cd:hasIssuingAgency ?agent .
}</core:constructQuery>
        <core:constructQuery>select * where {
?x core:hasAgentRole ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/IssuingAgency&gt; ;
core:hasAgent ?agent .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasIssuingAgency"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasIssuingState -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasIssuingState">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/hasRelatedAgent"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isIssuingStateIn"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/CoinIssuance"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega l&apos;emissione della moneta alla realtà statuale emittente, coeva all&apos;emissione della moneta. Questa proprietà, esprimendo il significato della relazione nel nome, dà una rappresentazione semplificata della relazione che lega questa entità e l&apos;agente; la stessa relazione è rappresentata attraverso una n-ary relation, arco-core:AgentRole, che permette di collegare l&apos;agente al ruolo che riveste nei confronti dell&apos;entità.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the coin issuance to the issuing State of that historic period. In the ontology this relationship is modelled also by the class AgentRole which allows more expressiveness.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha Stato emittente</rdfs:label>
        <rdfs:label xml:lang="en">has issuing State</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa NU: DA/AUE/AUES - ICCD Normativa OA (dopo il rilascio della specifica scheda NU nel 2004 la scheda OA non è stata più utilizzata per la catalogazione di monete e medaglie): AU/EDT/EDTA</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?x a-lite:hasIssuer ?agent .
}

WHERE {
?x a-cd:hasIssuingState ?agent .
}</core:constructQuery>
        <core:constructQuery>select * where {
?x core:hasAgentRole ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/Issuer&gt; ;
core:hasAgent ?agent .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasIssuer"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasLaboratoryTestType -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasLaboratoryTestType">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isLaboratoryTestTypeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/LaboratoryTest"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/LaboratoryTestType"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;analisi di laboratorio con il tipo di analisi (es.: analisi metallurgica, analisi chimica, etc.).</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a laboratory test to its test type (i.e. chemical or metallurgical analysis).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha tipo di analisi di laboratorio</rdfs:label>
        <rdfs:label xml:lang="en">has laboratory test type</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normative NU, RA, BNB, MA, CA: RS/ALB/ALBT</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT   { ?test a a-cd:LaboratoryTest;
core:hasType ?type.
 }
WHERE       { ?test a a-cd:LaboratoryTest;
a-cd:hasLaboratoryTestType ?type.
 }</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasLegalSituation -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasLegalSituation">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasEventOrSituationInTime"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isLegalSituationOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/LegalSituation"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;entità, per esempio un bene culturale, alla sua condizione giuridica.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an entity, for example a cultural entity, to its legal situation.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha condizione giuridica</rdfs:label>
        <rdfs:label xml:lang="en">has legal situation</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: TU/CDG. - RP/LGC/LGCO. LS/CSS/CSSP. - CS/CTS/CTSP</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasLicense -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasLicense">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isLicenseOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/License"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;entità alla sua licenza di utilizzo. La licenza si distingue dal copyright in quanto la prima stabilisce le condizioni di utilizzo, mentre il secondo stabilisce l&apos;agente che detiene i diritti.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an entity to its license. The license differs from copyright in that the former establishes the conditions of use, while the latter establishes the agent who owns the rights.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha licenza</rdfs:label>
        <rdfs:label xml:lang="en">has license</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa SCAN: DO/DCM/DCML</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasMemberOfArchivalRecordSet -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasMemberOfArchivalRecordSet">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/hasMemberOfCollection"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isMemberOfArchivalRecordSetOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/ArchivalRecordSetMembership"/>
        <rdfs:range rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:comment xml:lang="it">Questa proprietà, inversa a &quot;è membro di unità archivistica complessa&quot;, collega l&apos;appartenenza di un bene culturale a un&apos;unità archivistica al bene coinvolto nella relazione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the membership of a cultural entity to an archival record set. It is the inverse property of &quot;isMemberofArchivalRecordSet&quot;.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha membro di unità archivistica complessa</rdfs:label>
        <rdfs:label xml:lang="en">has member of archival record set</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa F: UB/UBF</a-cat:iccdNormTag>
        <a-cat:iccdNormTag>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt;

CONSTRUCT {
?collmembership a-cd:involvesMember ?cp .
}

WHERE {
?collmembership a-cd:hasMemberOfArchivalRecordSet ?cp .
}</a-cat:iccdNormTag>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/involvesMember"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasMemberOfCollection -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasMemberOfCollection">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/hasMember"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isMemberOfCollectionOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/CollectionMembership"/>
        <rdfs:range rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:comment xml:lang="it">Questa proprietà, inversa a &quot;è membro di collezione&quot;, collega l&apos;appartenenza di un bene culturale a una collezione in un certo intervallo di tempo al bene culturale mobile coinvolto nella relazione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the membership of a movable cultural entity to a collection in a time interval. It is the inverse property of &quot;isMemberofCollection&quot;.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha membro di collezione</rdfs:label>
        <rdfs:label xml:lang="en">has member of collection</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>UB/COL</a-cat:iccdNormTag>
        <a-cat:iccdNormTag xml:lang="it">UB/COL</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt;

CONSTRUCT {
?coll a-cd:involvesMember ?cp .
}

WHERE {
?coll a-cd:hasCollectionMember ?cp .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/involvesMember"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasMemberOfPhotographicSeries -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasMemberOfPhotographicSeries">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/hasMemberOfCollection"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isMemberOfPhotographicSeriesIn"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/PhotographicSeriesMembership"/>
        <rdfs:range rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:comment xml:lang="it">Questa proprietà, inversa a &quot;è membro di serie&quot;, collega l&apos;appartenenza di un bene fotografico a una serie editoriale al bene fotografico coinvolto.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the membership of a cultural entity (e.g. photographic heritage) to its photographic series. It is the inverse property of &quot;isMemberPhotographicSeries&quot;.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha membro di serie fotografica</rdfs:label>
        <rdfs:label xml:lang="en">has member of photographic series</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa F: PD/SFI; PD/SSI</a-cat:iccdNormTag>
        <a-cat:iccdNormTag>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt;

CONSTRUCT {
?collmembership a-cd:involvesMember ?cp .
}

WHERE {
?collmembership a-cd:hasMemberOfPhotographicSeries ?cp .
}</a-cat:iccdNormTag>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/involvesMember"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasMemberOfPrintingPlatesSeries -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasMemberOfPrintingPlatesSeries">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/hasMemberOfCollection"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isMemberOfPrintingPlatesSeriesOf"/>
        <rdfs:range rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega l&apos;appartenenza (di un bene culturale a una serie di matrici incise) alla matrice incisa coinvolta nella relazione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the membership of a cultural entity to its printing plates series.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha membro di serie di matrici incise</rdfs:label>
        <rdfs:label xml:lang="en">has member of printing plates series</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa MI: OG/SGT/SGTS</a-cat:iccdNormTag>
        <a-cat:iccdNormTag>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt;

CONSTRUCT {
?collmembership a-cd:involvesMember ?cp .
}

WHERE {
?collmembership a-cd:hasMemberOfPrintingPlatesSeries ?cp .
}</a-cat:iccdNormTag>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/involvesMember"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasMint -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasMint">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/hasRelatedAgent"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isMintIn"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/CoinIssuance"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega l&apos;emissione della moneta alla Zecca. Questa proprietà, esprimendo il significato della relazione nel nome, dà una rappresentazione semplificata della relazione che lega questa entità e l&apos;agente; la stessa relazione è rappresentata attraverso una n-ary relation, arco-core:AgentRole, che permette di collegare l&apos;agente al ruolo che riveste nei confronti dell&apos;entità.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the coin issuance to the Mint. In the ontology this relationship is modelled also by the class AgentRole which allows more expressiveness.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha zecca</rdfs:label>
        <rdfs:label xml:lang="en">has mint</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa NU: DA/ZEC - ICCD Normativa OA (dopo il rilascio della specifica scheda NU nel 2004 la scheda OA non è stata più utilizzata per la catalogazione di monete e medaglie): AU/EDT/EDTZ</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?x a-lite:hasMint ?agent .
}

WHERE {
?x a-cd:hasMint ?agent .
}</core:constructQuery>
        <core:constructQuery>select * where {
?x core:hasAgentRole ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/Mint&gt; ;
core:hasAgent ?agent .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasMint"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasMinter -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasMinter">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/hasRelatedAgent"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isMinterIn"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/CoinIssuance"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega l&apos;emissione della moneta allo zecchiere, monetiere, maestro di zecca. Questa proprietà, esprimendo il significato della relazione nel nome, dà una rappresentazione semplificata della relazione che lega questa entità e l&apos;agente; la stessa relazione è rappresentata attraverso una n-ary relation, arco-core:AgentRole, che permette di collegare l&apos;agente al ruolo che riveste nei confronti dell&apos;entità.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the coin issuance to the minter. In the ontology this relationship is modelled also by the class AgentRole which allows more expressiveness.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha zecchiere</rdfs:label>
        <rdfs:label xml:lang="en">has minter</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa NU: DA/AUE/AUEZ</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?x a-lite:hasMinter ?agent .
}

WHERE {
?x a-cd:hasMinter ?agent .
}</core:constructQuery>
        <core:constructQuery>select * where {
?x core:hasAgentRole ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/Minter&gt; ;
core:hasAgent ?agent .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasMinter"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasMusicalEnsemble -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasMusicalEnsemble">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/hasRelatedAgent"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isMusicalEnsembleOf"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega uno strumento musicale al gruppo di musicisti (bande, complessi musicali, associazioni corali, ecc.) in cui lo strumento assume, o ha assunto, abitualmente un ruolo esecutivo. Questa relazione è modellata anche, con maggiore potere espressivo, tramite il pattern AgentRole, che collega lo strumento musicale a una situazione in cui un agente ha rivestito un ruolo (in questo caso, organico musicale).</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a musical instrument to the musical ensemble that played it. In the ontology this relationship is modelled also by the class AgentRole which allows more expressiveness.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha organico musicale</rdfs:label>
        <rdfs:label xml:lang="en">has musical ensemble</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa SM 4.00: OS/OSD</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?x a-lite:hasMusicalEnsemble ?agent .
}

WHERE {
?x a-cd:hasMusicalEnsemble ?agent .
}</core:constructQuery>
        <core:constructQuery>select * where {
?x core:hasAgentRole ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/MusicalEnsemble&gt; ;
core:hasAgent ?agent .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasMusicalEnsemble"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasMusician -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasMusician">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/hasRelatedAgent"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isMusicianOf"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega uno strumento musicale a una persona che assume - o ha assunto - un ruolo certo come esecutore dello strumento. Questa relazione è modellata anche, con maggiore potere espressivo, tramite il pattern AgentRole, che collega lo strumento musicale a una situazione in cui un agente ha rivestito un ruolo (in questo caso, chitarrista, flautista, pianista, ecc., o genericamente musicista).</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a musical instrument to the person who plays (in the present or past) a certain role as the instrument&apos;s exectutor. In the ontology this relationship is modelled also by the class AgentRole which allows more expressiveness.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha musicista</rdfs:label>
        <rdfs:label xml:lang="en">has musician</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa SM 4.00: MU/MUTN</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?x a-lite:hasMusician ?agent .
}

WHERE {
?x a-cd:hasMusician ?agent .
}</core:constructQuery>
        <core:constructQuery>select * where {
?x core:hasAgentRole ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/Musician&gt; ;
core:hasAgent ?agent .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasMusician"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasObservationSurveyType -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasObservationSurveyType">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isObservationSurveyTypeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/ObservationSurvey"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/ObservationSurveyType"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;indagine di rilevamento al tipo di indagine di rilevamento (nel contesto/decontestualizzato).</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an observation survey to the type of observation survey (in the context, out of context).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha tipo di indagine di rilevamento</rdfs:label>
        <rdfs:label xml:lang="en">has observation survey type</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BDI 4.00: LA/PRM</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT   { ?sur a a-cd:ObservationSurvey;
core:hasType ?type.
 }
WHERE       { ?sur a a-cd:ObservationSurvey;
a-cd:hasObservationSurveyType ?type.
 }</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasOwner -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasOwner">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/hasRelatedAgent"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isOwnerIn"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/LegalSituation"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una condizione giuridica al proprietario dell&apos;oggetto che si trova in quella condizione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a legal situation to the owner of the object that is in that legal situation.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha proprietario</rdfs:label>
        <rdfs:label xml:lang="en">has owner</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: TU/CDG/CDGS</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?x a-lite:hasOwner ?agent .
}

WHERE {
?x a-cd:hasOwner ?agent .
}</core:constructQuery>
        <core:constructQuery>select * where {
?x core:hasAgentRole ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/Owner&gt; ;
core:hasAgent ?agent .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasOwner"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasPhotographicSeries -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasPhotographicSeries">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/involvesCollection"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isPhotographicSeriesIn"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/PhotographicSeriesMembership"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/PhotographicSeries"/>
        <rdfs:comment xml:lang="it">Questa proprietà, inversa a &quot;è serie in&quot;, collega il rapporto tra una serie e un bene fotografico che ne fa parte alla serie stessa.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a photographic series to the cultural entity which belongs to it.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha serie fotografica</rdfs:label>
        <rdfs:label xml:lang="en">has photographic series</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale: PD/SFI; PD/SSI</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?colmemb a-cd:involvesCollection ?coll .
}

WHERE {
?collmemb a-cd:hasPhotographicSeries ?coll .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/involvesCollection"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasPreferredAuthor -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasPreferredAuthor">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/hasRelatedAgent"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isPreferredAuthorOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una entità di qualsiasi tipo (documentazione, bene culturale, etc.) con il suo autore riconosciuto cime preferito.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an entity (i.e. documentation, cultural entity, etc.) to its preferred author.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha autore preferito</rdfs:label>
        <rdfs:label xml:lang="en">has preferred author</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale: DO/FTA/FTAA, DO/DRA/DRAA, DO/VDC/VDCR, DO/REG/REGA, DO/FNT/FNTA, DO/BIB/BIBA - Normativa S 3: RO/ADL/ADLA - Normative VeAC e AT 3.01: DO/BSE/BSEA - Normativa MI 3.00: AU/DDC/DDCN</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?x a-lite:hasPreferredAuthor ?agent .
}

WHERE {
?x a-cd:hasPreferredAuthor ?agent .
}</core:constructQuery>
        <core:constructQuery>select * where {
?x core:hasAgentRole ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/PreferredAuthor&gt; ;
core:hasAgent ?agent .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasPreferredAuthor"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasPreviousLocation -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasPreviousLocation">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/hasRelatedWork"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isPreviousLocationOf"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un bene culturale a un altro bene culturale collegato, che ne costituisce la sede di provenienza, prima della sua attuale collocazione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural entity to a connected cultural entity which constitutes its provenance location before its current position.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">era contenuto in</rdfs:label>
        <rdfs:label xml:lang="it">ha sede di provenienza</rdfs:label>
        <rdfs:label xml:lang="en">has previous location</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale 4.00: RV/RSE/RSER = &apos;era contenuto in&apos; (versioni precedenti: &apos;sede di provenienza&apos;)</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?x a-lite:hasPreviousLocation ?y .
}

WHERE {
?x a-cd:hasPreviousLocation ?y .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasPreviousLocation"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasPreviousOwner -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasPreviousOwner">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/hasRelatedAgent"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isPreviousOwnerOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Acquisition"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un evento di acquisizione di un bene culturale al soggetto fonte dell&apos;acquisizione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the event of a cultural entity&apos;s acquisition to the agent which is the source of the acquisition.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha soggetto fonte dell&apos;acquisizione</rdfs:label>
        <rdfs:label xml:lang="en">has previous owner</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: TU/ACQ/ACQN</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?x a-lite:hasPreviousOwner ?agent .
}

WHERE {
?x a-cd:hasPreviousOwner ?agent .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasPreviousOwner"/>
        <core:replacingQuery>SELECT DISTINCT ?entity ?transferor WHERE{
?entity a-cd:hasAcquisition ?acq.
?acq core:hasAgentRole ?agentrole.
?agentrole core:hasAgent ?transferor;
core:hasRole &lt;https://w3id.org/arco/resource/Role/Transferor&gt; .
}</core:replacingQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasPrimaryDocumentation -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasPrimaryDocumentation">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/hasDocumentation"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isPrimaryDocumentationOf"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Documentation"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un bene demoetnoantropologico immateriale alla sua documentazione primaria, ovvero la documentazione che restituisce il bene immateriale e ritenuta più rappresentativa.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an intangible demoethnoanthropological property to its primary documentation, that is the documentation more representative of the intangible heritage.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha documentazione primaria</rdfs:label>
        <rdfs:label xml:lang="en">has primary documentation</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BDI 4.00: DU, DV, DF</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?cp a-cd:hasRecording ?rec .
?rec a-cd:primaryDocumentation True .
}

where {
?cp a-cd:hasPrimaryDocumentation ?rec .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/primaryDocument"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasProfession -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasProfession">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isProfessionOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/CPV/Person"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Profession"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un agente al suo mestiere o professione, per esempio l&apos;utente del bene oppure il responsabile della fabbricazione di un bene con il suo mestiere o la sua professione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an agent to its job. For example the agent responsible of the production of a cultual entity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha professione</rdfs:label>
        <rdfs:label xml:lang="en">has profession</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa BDM 2.00: UT/UTN/UTNM - ICCD Normativa BDM 4.00: AU/AUT/AUTE. BDI: AT/ATT/ATTM, AI/AIF/AIFM, VI/VIF/VIFM, FI/FIF/FIFM. SM: MU/MUT/MUTM. Normativa AUT 4.00: AU/AUT/AUTQ</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasProponentAgency -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasProponentAgency">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/hasRelatedAgent"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isProponentAgencyOf"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://dati.beniculturali.it/cis/CulturalEntity"/>
                    <rdf:Description rdf:about="https://w3id.org/arco/ontology/context-description/ProtectiveMeasure"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;entità, che può essere direttamente il bene culturale o specificamente il provvedimento di tutela relativo al bene culturale, all&apos;ente proponente, ovvero al soggetto che ha proposto il provvedimento, identificato per mezzo della denominazione per esteso oppure, nel caso di Enti accreditati dall&apos;ICCD, del relativo codice assegnato dall&apos;Istituto. La relazione tra il ruolo e l&apos;agente che lo riveste è espressa, in maniera generica, nel nome della proprietà, che quindi ne fornisce una rappresentazione semplificata, con ridotta espressività. Nell&apos;ontologia questa relazione è modellata anche, in maniera più espressiva, dalla classe AgentRole, che permette di collegare l&apos;agente e il suo ruolo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an entity (e.g a cultural entity or a cultual entity&apos;s protective measure) to the proposing institution. In the ontology this relationship is modelled also by the class AgentRole which allows more expressiveness.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha ente proponente</rdfs:label>
        <rdfs:label xml:lang="en">has proponet agency</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: TU/NVC/NVCA; Versioni precedenti: CD/EPR</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?x a-lite:hasProponentAgency ?agent .
}

WHERE {
?x a-cd:hasProponentAgency ?agent .
}</core:constructQuery>
        <core:constructQuery>select * where {
?x core:hasAgentRole ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/ProponentAgency&gt; ;
core:hasAgent ?agent .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasProponentAgency"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasProtectiveMeasure -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasProtectiveMeasure">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isProtectiveMeasureOf"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/ProtectiveMeasure"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un bene culturale a un provvedimento di tutela nazionale o internazionale che lo ha interessato.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha provvedimento di tutela</rdfs:label>
        <rdfs:label xml:lang="en">has protective measure</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: TU/NVC</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasRecording -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasRecording">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isRecordingOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Recording"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;entità culturale alla sua registrazione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural entity to its recording.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha registrazione</rdfs:label>
        <rdfs:label xml:lang="en">has recording</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BDI: DU</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasReferenceCatalogue -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasReferenceCatalogue">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isReferenceCatalogueOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/ReferenceCatalogue"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;entità al suo repertorio (es: la copia della stampa con il suo repertorio).</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an entity to its reference catalogue (i.e. a print&apos;s copy to its reference catalogue.).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha repertorio</rdfs:label>
        <rdfs:label xml:lang="en">has reference catalogue</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa S 3: RO/COP/COPR
ICCD Normativa TMA 3.00: MA/MAC/MACP</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasRelatedAgent -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasRelatedAgent">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isAgentRelatedTo"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://w3id.org/arco/ontology/core/hasAgentRole"/>
            <rdf:Description rdf:about="https://w3id.org/arco/ontology/core/hasAgent"/>
        </owl:propertyChainAxiom>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;entità di qualsiasi tipo a un agente che è collegato in qualche modo a quell&apos;entità. È una relazione generica che viene usata per quei casi in cui non sia possibile definire in maniera più precisa la natura della relazione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property is used to associate an entity of any kind to an agent related to that entity in some way. It is used when it is not possible to express the relation in a more specific way.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha agente correlato</rdfs:label>
        <rdfs:label xml:lang="en">has related agent</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale: AU/NMC</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?x a-cd:involvesAgent ?agent .
}

WHERE {
?x a-cd:hasRelatedAgent ?agent .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/involvesAgent"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasRelatedWork -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasRelatedWork">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isWorkRelatedTo"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un bene culturale a un&apos;altra opera collegata (es.: copia, fase preparatoria, etc.), che può essere essa stessa un bene culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural property to a related work (e.g. copy, preparatory work).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha opera collegata</rdfs:label>
        <rdfs:label xml:lang="en">has related work</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?x a-lite:hasRelatedWork ?y .
}

WHERE {
?x a-cd:hasRelatedWork ?y .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasRelatedWork"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasRelatedWorkSituation -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasRelatedWorkSituation">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasEventOrSituationInTime"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isRelatedWorkSituationOf"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/RelatedWorkSituation"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un bene culturale alla relazione tra il bene stesso e un&apos;altra opera che ne costituisce una fase preparatoria o che ne rappresenta la fase finale, e in riferimento alla quale il bene culturale si trova in un determinato stadio.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural property to a situation in which this cultural property is related to another work, that could even be another cultural property, as its preparatory or final phase.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha rapporto con opera collegata</rdfs:label>
        <rdfs:label xml:lang="en">has related work situation</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasRelationshipType -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasRelationshipType">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isRelationshipTypeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/RelatedWorkSituation"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/RelationshipType"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una situazione di relazione tra beni culturali (RelatedWorkSituation) con il tipo di relazione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a related work situation with the defined type of relationship.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha tipo di relazione</rdfs:label>
        <rdfs:label xml:lang="en">has relationship type</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale: ROFF
ICCD Normativa VeAC: AU/AUT/AUTO</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasReliability -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasReliability">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasCharacteristic"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isReliabilityOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/PhotoInterpretationRendering"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Reliability"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una fotointerpretazione o fotorestituzione al livello di affidabilità delle informazioni rilevate nell&apos;indagine.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a photo interpretation rendering survey to the reliability of the information collected during the survey.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha affidabilità</rdfs:label>
        <rdfs:label xml:lang="en">has reliability</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: RE/FOI/FOIO</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasReproduction -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasReproduction">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isReproductionOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/PrintInPublication"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Reproduction"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega la pubblicazione con la riproduzione della stampa che ne è, o è stata, parte integrante.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a publication to the print reproduction which is or was part of it.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha riproduzione</rdfs:label>
        <rdfs:label xml:lang="en">has reproduction</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa S 3: RO/ADL</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasReproductionPosition -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasReproductionPosition">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isReproductionPositionOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Reproduction"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/ReproductionPosition"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega la riproduzione di una stampa all&apos;interno di una pubblicazione con la posizione fisica nella pubblicazione stessa (es.: frontespizio, copertina, colophon, etc.).</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the print reproduction in a publication to the position in the publication.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha posizione della riproduzione</rdfs:label>
        <rdfs:label xml:lang="en">has reproduction position</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa S 3: RO/ADL/ADLP</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasResearch -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasResearch">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isResearchOn"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Research"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;entità alla ricerca.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an entity to the research.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha ricerca</rdfs:label>
        <rdfs:label xml:lang="en">has research</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa SM e BDM 4.00: DR/DRT</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasResearchScientificDirector -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasResearchScientificDirector">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/hasRelatedAgent"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isResearchScientificDirectorOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Research"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una ricerca al responsabile scientifico della ricerca. La relazione tra il ruolo e l&apos;agente che lo riveste è espressa nel nome della proprietà, che quindi ne fornisce una rappresentazione semplificata, con ridotta espressività. Nell&apos;ontologia questa relazione è modellata anche, in maniera più espressiva, dalla classe AgentRole, che permette di collegare l&apos;agente e il suo ruolo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a research to the research&apos;s scientific responsible. In the ontology this relationship is modelled also by the class AgentRole which allows more expressiveness.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha responsabile scientifico della ricerca</rdfs:label>
        <rdfs:label xml:lang="en">has research scientific director</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa SM e BDM 4.00: DR/DRR</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?x a-lite:hasScientificDirector ?agent .
}

WHERE {
?x a-cd:hasResearchScientificDirector ?agent .
}</core:constructQuery>
        <core:constructQuery>select * where {
?x core:hasAgentRole ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/ScientificDirector&gt; ;
core:hasAgent ?agent .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasScientificDirector"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasResponsibility -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasResponsibility">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasAgentRole"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isResponsibilityFor"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Responsibility"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un bene fotografico (fotografia o fondo fotografico) all&apos;individuazione di una responsabilità attribuibile a un agente relativamente ai processi di produzione e di divulgazione che caratterizzano specificamente i beni fotografici, quindi alle diverse personalità responsabili, a vario titolo, del ciclo produttivo del bene in esame, oltre che della sua circolazione, divulgazione, commercializzazione e promozione (committenti, stampatori, ritoccatori, coloritori, editori, distributori, sponsor, curatori e responsabili di edizioni e di serie, dedicanti e dedicatari, responsabili di collezioni e di collazioni, ecc.).</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a photographic cultural entity (photography or photographic fond) to the responsibility attribution of an agent. The agent is in charge of the production or disclosure process which characterises photographic heritage (i.e. printers, editors, distributors, sposors, collection responsibles etc.)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha responsabilità</rdfs:label>
        <rdfs:label xml:lang="en">has responsibility</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa F: PD/PDF</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasResponsibilityType -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasResponsibilityType">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isResponsibilityTypeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Responsibility"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/ResponsibilityType"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una responsabilità individuata relativamente ai processi di produzione e di divulgazione che caratterizzano specificamente i beni fotografici al tipo di responsabilità (es.: stampatori, ritoccatori, coloritori, ecc.).</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a responsibility relative to some production or disclosure process which characterize photographic artefacts, to its responsibility type (i.e. printers, retouchers).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha tipo di responsabilità</rdfs:label>
        <rdfs:label xml:lang="en">has responsibility type</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normative F e FF: PD/PDF/PDFR</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT   { ?resp a a-cd:Responsibility;
a-cd:hasInterventionRole ?role .
 }
WHERE       { ?resp a a-cd:Responsibility;
a-cd:hasResponsibilityType ?role.
 }</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/hasRole"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasResponsibleForInsertion -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasResponsibleForInsertion">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/hasRelatedAgent"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isResponsibleForInsertionOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/CurrentInventory"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:comment xml:lang="it">Questa proprietà, rappresentazione semplificata della relazione n-ary Agent Role, che rappresenta una situazione in cui un agente riveste un ruolo, collega un inventario patrimoniale al responsabile dell&apos;inventariazione patrimoniale del bene.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a current inventory to the agent responsible for the cultural entity&apos;s inventory. In the ontology this relationship is modelled also by the class AgentRole which allows more expressiveness.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha responsabile dell&apos;immissione in patrimonio</rdfs:label>
        <rdfs:label xml:lang="en">has responsible for insertion</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: UB/INP/INPE</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?x a-lite:hasResponsibleAgent ?agent .
}

WHERE {
?x a-cd:hasResponsibleForInsertion ?agent .
}</core:constructQuery>
        <core:constructQuery>select * where {
?x core:hasAgentRole ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/ResponsibleAgent&gt; ;
core:hasAgent ?agent .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasResponsibleAgent"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasReview -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasReview">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isReviewOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Review"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;entità a un&apos;attività di revisione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an entity to a review activity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha revisione</rdfs:label>
        <rdfs:label xml:lang="en">has review</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>Normativia BNB: RB/RBR. Normativa BNM: RM. Normativa BNPL: RP. Normativa BNPE: RR</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasSECCategory -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasSECCategory">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasCategory"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isSECCategoryOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/InventorySituation"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/SECCategory"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una situazione inventariale alla categoria SEC attribuita al bene.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a inventory situation to the patrimonial category attributed to the cultural property based on the SEC classification.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha categoria SEC</rdfs:label>
        <rdfs:label xml:lang="en">has SEC category</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normtiva Trasversale 4.00: UB/INP/INPZ</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasSECIdentifier -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasSECIdentifier">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasCategory"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/CurrentInventory"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/SECIdentifier"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un inventario patrimoniale al codice SEC (modello 15) attribuito al bene.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the current inventory to the patrimonial code of a cultural property, referring to the SEC classification 1995.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha codice SEC</rdfs:label>
        <rdfs:label xml:lang="en">has SEC identifier</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: UB/INP/INPS</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?inv a-lite:nationalIdentifier ?id .
}

WHERE {
?inv a-cd:hasSECIdentifier ?id .
}</core:constructQuery>
        <core:replacingQuery>select * {
?inv core:hasIdentifier ?NEWIdentifier .
?NEWIdentifier core:hasType core:NationalIdentifer ;
l0:identifier ?id .
}</core:replacingQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasScale -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasScale">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isScaleOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/GraphicOrCartographicDocumentation"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Scale"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega la documentazione grafica e cartografica alla sua scala di rappresentazione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the graphic or cartographic documentation to its representation scale.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha scala</rdfs:label>
        <rdfs:label xml:lang="en">has scale</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale: DO/DRA/DRAS</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasSecondaryAuthor -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasSecondaryAuthor">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/hasRelatedAgent"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isSecondaryAuthorOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;entità al suo autore secondario, come ad esempio l&apos;autore di un contributo o una parte di una pubblicazione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an entity to its secondary authors. For example an author of a publication&apos;s contribution or section.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha autore secondario</rdfs:label>
        <rdfs:label xml:lang="en">has secondary author</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normative VeAC e AT 3.01: DO/BSE/BSER</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?x a-lite:hasSecondaryAuthor ?agent .
}

WHERE {
?x a-cd:hasSecondaryAuthor ?agent .
}</core:constructQuery>
        <core:constructQuery>select * where {
?x core:hasAgentRole ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/SecondaryAuthor&gt; ;
core:hasAgent ?agent .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasSecondaryAuthor"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasSex -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasSex">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasEventOrSituationInTime"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isSexOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Sex"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;entità al sesso.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an entity to its sex.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha sesso</rdfs:label>
        <rdfs:label xml:lang="en">has sex</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa AT: DA/STS. Normativa BDI: AT/ATT/ATTS, AI/AIF/AIFO, VI/VIF/VIFO, FI/FIF/FIFO. Normativa SM: MU/MUT/MUTS</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasSexInterpetation -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasSexInterpetation">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasSituation"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isSexInterpretationOf"/>
        <rdfs:label xml:lang="it">ha interpretazione del sesso</rdfs:label>
        <rdfs:label xml:lang="en">has sex interpretation</rdfs:label>
        
        <core:constructQuery>CONSTRUCT {
?cp a-cd:hasSex ?sex .
}

WHERE {
?cp a-cd:hasSexInterpretation ?sex .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/hasSex"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasSexInterpretation -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasSexInterpretation"/>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasSpecies -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasSpecies">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasConcept"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isSpeciesIn"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una tassonomia biologica alla specie, che è uno dei concetti della tassonomia.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a linnaean taxon to the subspecies, that is one of the concept of the taxon.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha specie</rdfs:label>
        <rdfs:label xml:lang="en">has species</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa AT: OG/OGS/OGSN. - Normativa BNB: RB/RBN/RBNB; SB/NAA/NAAB; SB/NAT/NATB</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?identificationOrClassification core:hasTaxon ?tax .
}

WHERE {
?identificationOrClassification a-cd:hasSpecies ?tax .
}</core:constructQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasSpecificBibliographicSource -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasSpecificBibliographicSource">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/hasBibliographicSource"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isSpecificBibliographicSourceOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Edition"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;entità all&apos;edizione dell&apos;opera parte della bibliografica specifica.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an entity with the edition of the involved specific bibliographic work.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha specifica fonte bibliografica specifica</rdfs:label>
        <rdfs:label xml:lang="en">has specific bibliographic source</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: DO/BIB/BIBX</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasStorageMedium -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasStorageMedium">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isStorageMediumOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Recording"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/StorageMedium"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una registrazione al suo supporto di memoria.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a recording to its storage medium.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha supporto di memorizzazione</rdfs:label>
        <rdfs:label xml:lang="en">has storage medium</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BDI: DU/DUO, DU/DUM, DV/DVM, DV/DVO, AI/AIO, AI/AIM, VI/VIO, VI/VIM</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasStratigraphicUnit -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasStratigraphicUnit">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasLocation"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isStratigraphicUnitOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/ArchaeologicalExcavation"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/StratigraphicUnit"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega uno scavo archeologico all&apos;unità stratigrafica dalla quale proviene il bene rinvenuto nello scavo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an archeological excavation to the stratigraphic unit from which a cultural property has been found.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha unità stratigrafica</rdfs:label>
        <rdfs:label xml:lang="en">has stratigraphic unit</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: RE/DSC/DSCU</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasSubject -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasSubject">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isSubjectOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Subject"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un bene culturale, un&apos;opera correlata a un bene culturale in quanto sua fase preparatoria o finale, o un apparato iconografico-decorativo di un bene culturale al suo soggetto o motivo ornamentale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural property or a preparatory or final work of a cultural property to ist subject or ornamental motif.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha soggetto</rdfs:label>
        <rdfs:label xml:lang="en">has subject</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale: DA/AID/AIDI - Normativa F: SG/SGT/SGTI - Altre normative di versioni precedenti alla 4.00: OG/SGT/SGTI - ICCD Normative F, RA, SMO, PST, S, OAC, OA, MI, D, NU: RO/ROF/ROFS. DA/DES/DESU</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasSubspecies -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasSubspecies">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasConcept"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isSubspeciesIn"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una tassonomia biologica alla sottospecie, che è uno dei concetti della tassonomia.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a linnaean taxon to the subspecies, that is one of the concept of the taxon.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha sottospecie</rdfs:label>
        <rdfs:label xml:lang="en">has subspecies</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa AT: OG/OGS/OGST. -  Normativa BNB: RB/RBN/RBND; SB/NAA/NAAD; SB/NAT/NATD</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?identificationOrClassification core:hasTaxon ?tax .
}

WHERE {
?identificationOrClassification a-cd:hasSubspecies ?tax .
}</core:constructQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasSurvey -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasSurvey">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isSurveyOn"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Survey"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un bene culturale a un&apos;indagine effettuata sul bene stesso, per la sua individuazione, per il suo studio e per l&apos;approfondimento delle sue caratteristiche tecniche.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural entity&apos;s acquisition to its acquisition type.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha indagine</rdfs:label>
        <rdfs:label xml:lang="en">has survey</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: RE; CM/ISP - ICCD Normative NU, RA, BNB, MA, CA: RS/ALB - ICCD Normativa AT 3.00: IN/INI - Normativa BDM e SM 4.00: DR</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasSurveyImage -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasSurveyImage">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isSurveyImageOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/PhotoInterpretationRendering"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/SurveyImage"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una fotointerpretazione o fotorestituzione all&apos;immagine presa in esame nel corso dell&apos;indagine.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a photo interpretation rendering to the survey image.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha immagine di indagine</rdfs:label>
        <rdfs:label xml:lang="en">has survey image</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: RE/FOI/FOIT + FOID</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasSurveyImageType -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasSurveyImageType">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isSurveyImageTypeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/SurveyImage"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/SurveyImageType"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una immagine di indagine al suo tipo (fotografia aerea o fotografia satellitare).</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a survey image to its type (i.e. aerial photograph, Satellite photograph).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha tipo di immagine di indagine</rdfs:label>
        <rdfs:label xml:lang="en">has survey image type</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: RE/FOI/FOIT</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT   { ?img a a-cd:SurveyImage;
core:hasType ?type .
 }
WHERE       { ?img a a-cd:SurveyImage;
a-cd:hasSurveyImageType ?type.
 }</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasSurveyMethod -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasSurveyMethod">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasMethod"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isSurveyMethodOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Survey"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/SurveyMethod"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;indagine al metodo adottato nel corso dell&apos;indagine.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a survey to the method adopted in the survey.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha metodo di indagine</rdfs:label>
        <rdfs:label xml:lang="en">has survey method</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: RE/RCG/RCGM; RE/DSC/DSCM - ICCD Normativa AT: PT/PTC/PTCM</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasSurveyMotivation -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasSurveyMotivation">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/hasDescription"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isSurveyMotivationOf"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/arco/ontology/context-description/ArchaeologicalExcavation"/>
                    <rdf:Description rdf:about="https://w3id.org/arco/ontology/context-description/ArchaeologicalFieldSurvey"/>
                    <rdf:Description rdf:about="https://w3id.org/arco/ontology/context-description/ArchaeometricDiagnosticSurvey"/>
                    <rdf:Description rdf:about="https://w3id.org/arco/ontology/context-description/PhotoInterpretationRendering"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/SurveyMotivation"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega uno scavo archeologico, una ricognizione archeologica, un&apos;indagine archeometrica e diagnostica o una fotointerpretazione e fotorestituzione al motivo principale che li ha determinati.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an archeological, archaeometric or diagnostic survey or a photo interpretation rendering to the the main motivation that led to it.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha motivo di indagine</rdfs:label>
        <rdfs:label xml:lang="en">has survey motivation</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>Normativa Trasversale: RE/RCG/RCGE; RE/DSC/DSCT; RE/IND/INDM; RE/FOI/FOIM</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasSurveyPhotographer -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasSurveyPhotographer">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/hasRelatedAgent"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isSurveyPhotographerOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/ObservationSurvey"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;indagine di rilevamento di un bene demo-etno-antropologico al fotografo professionista (diverso dal rilevatore) che ha effettuato la ripresa. La relazione tra il ruolo e l&apos;agente che lo riveste è espressa nel nome della proprietà, che quindi ne fornisce una rappresentazione semplificata, con ridotta espressività. Nell&apos;ontologia questa relazione è modellata anche, in maniera più espressiva, dalla classe AgentRole, che permette di collegare l&apos;agente e il suo ruolo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an observation survey of a demo-etno-antropologic entity to the professional photographer who took the shot. In the ontology this relationship is modelled also by the class AgentRole which allows more expressiveness.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha fotografo dell&apos;indagine</rdfs:label>
        <rdfs:label xml:lang="en">has survey photographer</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BDI 3.00: DR/DRG</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?x a-lite:hasPhotographer ?agent .
}

WHERE {
?x a-cd:hasSurveyPhotographer ?agent .
}</core:constructQuery>
        <core:constructQuery>select * where {
?x core:hasAgentRole ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/Photographer&gt; ;
core:hasAgent ?agent .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasPhotographer"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasSurveyScientificDirector -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasSurveyScientificDirector">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/hasRelatedAgent"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isSurveyScientificDirectorOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Survey"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;indagine al suo responsabile scientifico.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a survey to its scientific director.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha responsabile scientifico dell&apos;indagine</rdfs:label>
        <rdfs:label xml:lang="en">has survey scientific director</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: RE/RCG/RCGA; RE/DSC/DSCA; RE/FOI/FOIS</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?x a-lite:hasScientificDirector ?agent .
}

WHERE {
?x a-cd:hasSurveyScientificDirector ?agent .
}</core:constructQuery>
        <core:constructQuery>select * where {
?x core:hasAgentRole ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/ScientificDirector&gt; ;
core:hasAgent ?agent .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasScientificDirector"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasSurveySoundEngineer -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasSurveySoundEngineer">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/hasRelatedAgent"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isSurveySoundEngineerOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/ObservationSurvey"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;indagine di rilevamento di un bene demo-etno-antropologico al fonico professionista (diverso dal rilevatore) che ha effettuato la registrazione sonora. La relazione tra il ruolo e l&apos;agente che lo riveste è espressa nel nome della proprietà, che quindi ne fornisce una rappresentazione semplificata, con ridotta espressività. Nell&apos;ontologia questa relazione è modellata anche, in maniera più espressiva, dalla classe AgentRole, che permette di collegare l&apos;agente e il suo ruolo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an observation survey of a demo-etno-antropologic entity to the sound engineer who recorded it. In the ontology this relationship is modelled also by the class AgentRole which allows more expressiveness.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha fonico dell&apos;indagine</rdfs:label>
        <rdfs:label xml:lang="en">has survey sound engineer</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BDI 3.00: DR/DRF</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?x a-lite:hasSoundEngineer ?agent .
}

WHERE {
?x a-cd:hasSurveySoundEngineer ?agent .
}</core:constructQuery>
        <core:constructQuery>select * where {
?x core:hasAgentRole ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/SoundEngineer&gt; ;
core:hasAgent ?agent .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasSoundEngineer"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasTimeInterval -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasTimeInterval">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isTimeIntervalFor"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Dating"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/TI/TimeInterval"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;entità con il suo intervallo di tempo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an entity to its time interval.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha intervallo di tempo</rdfs:label>
        <rdfs:label xml:lang="en">has time interval</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasTitle -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasTitle">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isTitleOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Title"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un oggetto al suo titolo. Nel caso del dominio dei beni culturali, può collegare un bene culturale o un&apos;opera collegata al bene culturale perché sua fase finale o preparatoria (proprio, attribuito, parallelo, alternativo), oppure un&apos;edizione al suo titolo (principale o secondario), oppure una serie fotografica al suo titolo, etc.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an object to its title.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha titolo</rdfs:label>
        <rdfs:label xml:lang="en">has title</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">OG/SGT/SGTP; SG/SGL/SGLT; SG/SGL/SGLL; OG/SGT/SGTR; DA/AID/AIDN; SG/SGL/SGLA; DA/AID/AIDT; OG/SGT/SGTT; RO/ROF/ROFT; DO/BSE/BSET; DO/BSE/BSEC; RO/ADL/ADLT, PD/EDI/EDIT, EDIP, EDIA.</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasTitleType -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasTitleType">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isTitleTypeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Title"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/TitleType"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un titolo di un bene culturale al tipo di titolo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural entity&apos;s title to its title type.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha tipo di titolo</rdfs:label>
        <rdfs:label xml:lang="en">has title type</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>OG/SGT/SGTP; SG/SGL/SGLT; SG/SGL/SGLL; OG/SGT/SGTR; DA/AID/AIDN; SG/SGL/SGLA; DA/AID/AIDT; OG/SGT/SGTT</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT   { ?title a a-cd:Title;
core:hasType ?type .
 }
WHERE       { ?title a a-cd:Title;
a-cd:hasTitleType ?type.
 }</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasTomb -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasTomb">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isTombOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/ArchaeologicalExcavation"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Tomb"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega uno scavo archeologico alla deposizione funeraria individuata durante l&apos;indagine.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an archaeological excavation to the tomb detected during the survey.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha deposizione funeraria</rdfs:label>
        <rdfs:label xml:lang="en">has tomb</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: RE/DSC/DSCS</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasUrbanPlanningEnvironmentalRelationWith -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasUrbanPlanningEnvironmentalRelationWith">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/hasRelatedWork"/>
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/isWorkRelatedTo"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un bene culturale a un altro bene culturale collegato, con cui è in relazione urbanistico-ambientale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural entity to another cultural entity, in an planning environmental relation.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha relazione urbanistico-ambientale con</rdfs:label>
        <rdfs:label xml:lang="en">has urban planning environmental relation with</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale 4.00: RV/RSE/RSER = &apos;è in relazione urbanistico - ambientale con&apos; (versioni precedenti: &apos;relazione urbanistico ambientale&apos;)</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?x a-lite:hasUrbanPlanningEnvironmentalRelationWith ?y .
}

WHERE {
?x a-cd:hasUrbanPlanningEnvironmentalRelationWith ?y .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasUrbanPlanningEnvironmentalRelationWith"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasUrbanPlanningInstrument -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasUrbanPlanningInstrument">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isUrbanPlanningInstrumentOf"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/UrbanPlanningInstrument"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un bene culturale a uno strumento urbanistico-territoriale, ovvero a un piano regolatore generale e particolareggiato o a un piano paesaggistico che interessa il bene stesso.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class relates a cultural property to the related urban planning instrument.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha strumento urbanistico-territoriale</rdfs:label>
        <rdfs:label xml:lang="en">has urban planning instrument</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: TU/STU</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasUse -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasUse">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasEventOrSituationInTime"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isUseOf"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Use"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega il bene culturale con il suo uso.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural entity to its use.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha uso</rdfs:label>
        <rdfs:label xml:lang="en">has use</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale: UT</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasUseFunction -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasUseFunction">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isUseFunctionOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Use"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/UseFunction"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;entità alla sua funzione d&apos;uso.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an entity to its use function.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha funzione d&apos;uso</rdfs:label>
        <rdfs:label xml:lang="en">has use function</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale: UT/UTU/UTUF; LC/LDC/LDCF; LA/PRC/PRCF - BDM 2.00:UT/UTF - PST 3.01: DA/UTF</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasUseType -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasUseType">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isUseTypeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Use"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/UseType"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega l&apos;uso del bene con il suo tipo (attuale, precedente, storico).</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural entity&apos;s use to its use type.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha tipo d&apos;uso</rdfs:label>
        <rdfs:label xml:lang="en">has use type</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale: UT/UTU/UTUT</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT   { ?use a a-cd:Use;
core:hasType ?type .
 }
WHERE       { ?use a a-cd:Use;
a-cd:hasUseType ?type.
 }</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasUseTypeSpecification -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasUseTypeSpecification">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isUseTypeSpecificationOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Use"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/UseTypeSpecification"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega l&apos;uso del bene con le specifiche relative al tipo di utilizzo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the use of a cultural property to the specification of the type of use.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha specifiche del tipo d&apos;uso</rdfs:label>
        <rdfs:label xml:lang="en">has use type specification</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale: UT/UTUS</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?thing core:hasType ?type .
?type a a-cd:UseType .
}

WHERE {
?thing a-cd:hasUseTypeSpecification ?type .
?type a a-cd:UseTypeSpecification .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasUser -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasUser">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/involvesAgent"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isUserOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;entità a un utente, inteso come agente che ha fatto uso di quell&apos;entità. Per esempio, può collegare un&apos;occasione in cui un vestimento antico o contemporaneo è stato indossato da una persona al fruitore stesso, oppure un particolare uso di un bene culturale al tipo di utente coinvolto in quell&apos;uso.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an entity to the user, intended as the agent who employed the entity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha utente</rdfs:label>
        <rdfs:label xml:lang="en">has user</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale: UT/UTU/UTUN; Normativa VeAC: AU/FRU/FRUF</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?cp a-lite:hasUser ?agent .
}

WHERE {
?cp a-cd:hasUser ?agent .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasUser"/>
        <core:replacingQuery>select * where {
?cp core:hasAgentRole ?NEWagentRole .
?NEWagentRole core:hasRole ?NEWrole ;
core:hasAgent ?agent .
}</core:replacingQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/hasUserSocialCategory -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasUserSocialCategory">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasCategory"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isUserSocialCategoryOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/UserSocialCategory"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega l&apos;utente di un bene culturale con la sua categoria sociale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the user of a cultural property to its social category.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha categoria sociale dell&apos;utente</rdfs:label>
        <rdfs:label xml:lang="en">has user social category</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normative BDM 2.00: UT/UTN/UTNC</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/involves -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/involves">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/isWorkRelatedTo"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isInvolvedIn"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:comment xml:lang="it">Questa è la proprietà inversa di &apos;is involved in&apos;, che collega un bene culturale a un altro bene culturale collegato, di tipo immateriale, in cui è coinvolto.</rdfs:comment>
        <rdfs:comment xml:lang="en">This is the inverse property of &apos;is involved in&apos;, which relates a cultural entity to another involved cultural entity (e.g. immaterial).</rdfs:comment>
        <rdfs:comment>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?x a-lite:involves ?y .
}

WHERE {
?x a-cd:involves ?y .
}</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">coinvolge</rdfs:label>
        <rdfs:label xml:lang="en">involves</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/involves"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/involvesCollection -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/involvesCollection">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isCollectionIn"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/CollectionMembership"/>
        <rdfs:range rdf:resource="http://dati.beniculturali.it/cis/CollectionCulEnt"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega l&apos;appartenenza di un bene culturale a una collezione in un intervallo di tempo alla collezione coinvolta nella relazione</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural property to the collection to which it belongs in a time span.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">coinvolge collezione</rdfs:label>
        <rdfs:label xml:lang="en">involves collection</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>UB/COL/COLD</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/involvesElement -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/involvesElement">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isElementInvolvedIn"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
        <rdfs:comment>ICCD Normativa BDI: DA/DRM/DRME-RDMO-DRMV-DRMA-DRMM</rdfs:comment>
        <rdfs:comment xml:lang="it">Questa proprietà collega una entità culturale a un suo elemento (animale, vegetale o minerale).</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural property to its element (animal, vegetal or mineral).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">coinvolge elemento</rdfs:label>
        <rdfs:label xml:lang="en">involves element</rdfs:label>
        
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {
?x &lt;https://w3id.org/arco/ontology/denotative-description/involvesElement&gt; ?y.
}

WHERE {
?x a-cd:involvesElement ?y.
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/involvesElement"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/involvesEntity -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/involvesEntity">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isEntityInvolvedIn"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Interpretation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/involvesMember -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/involvesMember">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isMemberInvolvedIn"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/CollectionMembership"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega l&apos;appartenenza a una collezione in un certo intervallo di tempo al bene culturale mobile coinvolto nella relazione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the membership of a movable cultural entity to a collection in a time interval.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">coinvolge membro</rdfs:label>
        <rdfs:label xml:lang="en">involves member</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>UB/COL. Normativa F: UB/UBF. Normativa NU: OG/OGT/OGTR. Normativa BN: OG/OGT/OGTC. Normativa MI e S: OG/SGT/SGTS. Normativa BDI: DU/DUR, SF/SFI, SS/SSI, DU/DUS, AI/AIR,AI/ AIS, VI/VIR,VI/VIV, DU/DUR.
ICCD Normativa F: PD/SFI; PD/SSI</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/involvesRelatedWork -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/involvesRelatedWork">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isRelatedWorkInvolvedIn"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/RelatedWorkSituation"/>
        <rdfs:range rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega il rapporto tra un bene culturale e un&apos;opera collegata all&apos;opera collegata stessa (es.: un lavoro preparatorio, un prototipo, una copia, un reimpiego di tutto il bene o di una sua parte, ecc.).</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the situation in which a cultural property is related to another work with the related work itself (e.g.: a preparatory work, a prototype, a copy, a reuse, etc.).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">coinvolge opera collegata</rdfs:label>
        <rdfs:label xml:lang="en">involves related work</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa trasversale: RV/RSE/RSEC
ICCD Normative versioni precedenti a 4.00: RV/ROZ
ICCD Normative RA, SMO, PST, S, OAC, OA, MI, D, NU, CA, MA, F: RO</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isAcquisitionOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isAcquisitionOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isEventOrSituationInTimeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Acquisition"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un evento di acquisizione al bene culturale coinvolto nell&apos;acquisizione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an acquisition event to the cultural entity involved in the acquisition.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is acquisition of</rdfs:label>
        <rdfs:label xml:lang="it">è acquisizione di</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: TU/ACQ</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isAcquisitionTypeOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isAcquisitionTypeOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isTypeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/AcquisitionType"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Acquisition"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega il tipo di acquisizione (es.: donazione, alienazione, confisca) all&apos;acquisizione di un bene culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural entity&apos;s acquisition type (i.e. donation, seizure) to its acquisition.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is acquisition type of</rdfs:label>
        <rdfs:label xml:lang="it">è tipo di acqusizione di</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {
?type core:isTypeOf ?thing .
}

WHERE {
?type a-cd:isAcquisitionTypeOf ?thing .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/isTypeOf"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isActivityOperatorOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isActivityOperatorOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/isAgentRelatedTo"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Activity"/>
        <rdfs:comment xml:lang="it">Questa è la proprietà inversa di &quot;ha operatore dell&apos;attività&quot;.</rdfs:comment>
        <rdfs:comment xml:lang="en">This is the inverse property of &quot;has activity operator&quot;.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is activity operator of</rdfs:label>
        <rdfs:label xml:lang="it">è operatore dell&apos;attività</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?agent a-lite:isOperatorOf ?thing .
}

WHERE {
?agent a-cd:isActivityOperatorOf ?thing .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/isOperatorOf"/>
        <core:replacingQuery>select * where {
?agent core:isAgentOf ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/Operator&gt; ;
core:isAgentRoleOf ?thing .
}</core:replacingQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isActivityResponsibleOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isActivityResponsibleOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/isAgentRelatedTo"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Activity"/>
        <rdfs:comment xml:lang="it">Questa è la proprietà inversa di &quot;ha responsabile dell&apos;attività&quot;.</rdfs:comment>
        <rdfs:comment xml:lang="en">This is the inverse property of &quot;has activity responsible&quot;.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is activity responsible of</rdfs:label>
        <rdfs:label xml:lang="it">è responsabile dell&apos;attività</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?agent a-lite:isResponsibleAgentOf ?thing .
}

WHERE {
?agent a-cd:isActivityResponsibleOf ?thing .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/isResponsibleAgentOf"/>
        <core:replacingQuery>select * where {
?agent core:isAgentOf ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/ResponsibleAgent&gt; ;
core:isAgentRoleOf ?thing .
}</core:replacingQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isActivitySponsorOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isActivitySponsorOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/isAgentRelatedTo"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Activity"/>
        <rdfs:comment xml:lang="it">Questa è la proprietà inversa a &quot;ha sponsor dell&apos;attività&quot;.</rdfs:comment>
        <rdfs:comment xml:lang="en">This is the inverse property of &quot;has activity sponsor&quot;.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is activity sponsor of</rdfs:label>
        <rdfs:label xml:lang="it">è sponsor dell&apos;attività</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?agent a-lite:isSponsorOf ?thing .
}

WHERE {
?agent a-cd:isActivitySponsorOf ?thing .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/isSponsorOf"/>
        <core:replacingQuery>select * where {
?agent core:isAgentOf ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/Sponsor&gt; ;
core:isAgentRoleOf ?thing .
}</core:replacingQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isAgeInterpretationOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isAgeInterpretationOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isSituationOf"/>
        <rdfs:range rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega l&apos;interpretazione dell&apos;età di un&apos;entità culturale con l&apos;entià cultural estessa.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the interpretation of age of a cultural entity to the cultural entity itself.</rdfs:comment>
        <rdfs:comment xml:lang="en">is age interpretation of</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">è interpretazione dell&apos;età di</rdfs:label>
        
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BNPE: SR/SRL/SRLE, SR/SRR/SRRE</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?cultent a-cd:isAgeOf ?age .
}

WHERE {
?cultent a-cd:isAgeInterpretationOf ?age .}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/isAgeOf"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isAgeOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isAgeOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isEventOrSituationInTimeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Age"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="en">This property relates the biological age of an entity with the entity itself.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Questa proprietà collega l&apos;età di un&apos;entità con l&apos;entità stessa.</rdfs:label>
        <rdfs:label xml:lang="en">is age of</rdfs:label>
        <rdfs:label xml:lang="it">è età di</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isAgeOfDeathInterpretationOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isAgeOfDeathInterpretationOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isSituationOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/AgeOfDeathInterpretation"/>
        <rdfs:range rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega la stima della morte di un reperto antropologico al suo reperto archeologico.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the age of death interpretation of an antropologic artifact to the its antropologic artifact.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is age of death interpretation of</rdfs:label>
        <rdfs:label xml:lang="it">è età della morte stimata di</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {
?cultent a-cd:isAgeOf ?age .
}

WHERE {
?cultent a-cd:isAgeOfDeathInterpretationOf ?age .}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/isAgeOf"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isAgeTypeOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isAgeTypeOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isTypeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/AgeType"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/AgeInterpretation"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega il tipo di età con l&apos;interpretazione dell&apos;età.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the age type to the age interpretation.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is age type of</rdfs:label>
        <rdfs:label xml:lang="it">è tipo di età di</rdfs:label>
        
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {
?type core:isTypeOf ?thing .
}

WHERE {
?type a-cd:isAgeTypeOf ?thing .
}</core:constructQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isAgentRelatedTo -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isAgentRelatedTo">
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un agente che è collegato in qualche modo a un&apos;entità di qualsiasi tipo a quell&apos;entità. È una relazione generica che viene usata per quei casi in cui non sia possibile definire in maniera più precisa la natura della relazione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property is used to associate an agent related in some way to an entity of any kind to that entity. It is used when it is not possible to express the relation in a more specific way.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is agent related to</rdfs:label>
        <rdfs:label xml:lang="it">è agente correlato a</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {
?agent core:isAgentInvolvedIn ?thing .
}

WHERE {
?agent a-cd:isAgentRelatedTo ?thing .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/isAgentinvolvedIn"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isAgentWithResponsibilityIn -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isAgentWithResponsibilityIn">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isAgentOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Responsibility"/>
        <rdfs:comment xml:lang="it">Questa è la proprietà inversa a &quot;ha agente con responsabilità&quot;.</rdfs:comment>
        <rdfs:comment xml:lang="en">This is the inverse property of &quot;has agent with responsibility&quot;.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is agent with responsibility in</rdfs:label>
        <rdfs:label xml:lang="it">è agente con responsabilità in</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa F e FF 4.00: PD/PDF/PDFN - ICCD Normativa F 3.00: PD/PDF/PDFN o PD/PDF/PDFB</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isAlternativeDatingTypeOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isAlternativeDatingTypeOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isTypeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/AlternativeDatingType"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/AlternativeDating"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega la tipologia di datazione alternativa con la relativa datazione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the type of an alternative dating to the related dating.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is alternative dating type</rdfs:label>
        <rdfs:label xml:lang="it">è datazione alternativa di</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {
?type core:isTypeOf ?thing .
}

WHERE {
?type a-cd:isAlternativeDatingTypeOf ?thing .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/isTypeOf"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isAnomalyOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isAnomalyOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isEventOrSituationInTimeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Anomaly"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/PhotoInterpretationRendering"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;anomalia rilevata nel corso dell&apos;indagine tramite fotointerpretazione o fotorestituzione alla relativa indagine.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an anomaly revealed by a photo interpretation rendering to the related survey.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is anomaly of</rdfs:label>
        <rdfs:label xml:lang="it">è anomalia di</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isAnomalyOriginOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isAnomalyOriginOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isCharacteristicOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/AnomalyOrigin"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Anomaly"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega l&apos;origine dell&apos;anomalia (naturale, antropica, incerta) all&apos;anomalia rilevata durante una fotointerpretazione o fotorestituzione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the origin of the anomaly (e.g. natural, unsure) to an anomaly detected during a photo interpretation or rendering survey.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is anomaly origin of</rdfs:label>
        <rdfs:label xml:lang="it">è origine dell&apos;anomalia di</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isAnomalyTypeOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isAnomalyTypeOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isTypeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/AnomalyType"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Anomaly"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega il tipo di anomalia (puntuale, lineare, areale) a un&apos;anomalia rilevata nel corso di una fotointerpretazione o fotorestituzione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the anomaly type (line, point, poligony anomaly) to an anomaly revealed by a photo interpretation rendering.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is anomaly type of</rdfs:label>
        <rdfs:label xml:lang="it">è tipo di anomalia di</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {
?type core:isTypeOf ?thing .
}

WHERE {
?type a-cd:isAnomalyTypeOf ?thing .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/isTypeOf"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isArchaeologicalPropertySurveyTypeOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isArchaeologicalPropertySurveyTypeOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isTypeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/ArchaeologicalPropertySurveyType"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/ArchaeologicalPropertySurvey"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega il tipo di indagine alla relativa indagine su un bene archeologico.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the type of a survey to the related survey on an archaeological property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is archaeological property survey type of</rdfs:label>
        <rdfs:label xml:lang="it">è tipo di indagine su bene archeologico</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {
?type core:isTypeOf ?thing .
}

WHERE {
?type a-cd:isArchaeologicalPropertySurveyTypeOf ?thing .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/isTypeOf"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isArchaeometricDiagnosticSurveyTypeOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isArchaeometricDiagnosticSurveyTypeOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isTypeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/ArchaeometricDiagnosticSurveyType"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/ArchaeometricDiagnosticSurvey"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega il tipo d&apos;indagine archeometrica e diagnostica (es.: analisi della malta, carotaggio, termografia, etc.) alla relativa indagine.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the type of an arecheometric diagnostic survey (i.e. thermal imaging, coring) to the survey itself .</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is archaeometric diagnostic survey type of</rdfs:label>
        <rdfs:label xml:lang="it">è tipo di indagine archeometrica e diagnostica di</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {
?type core:isTypeOf ?thing .
}

WHERE {
?type a-cd:isArchaeometricDiagnosticSurveyTypeOf ?thing .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/isTypeOf"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isArchivalRecordSetIn -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isArchivalRecordSetIn">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/ArchivalRecordSet"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/ArchivalRecordSetMembership"/>
        <rdfs:comment xml:lang="it">Questa proprietà, inversa a &quot;ha unità archivistica complessa&quot;, collega una unità archivistica complessa al rapporto tra l&apos;unità stessa e un bene culturale che ne fa parte.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an archival record set to the relationship (membership) between the set itself and a cultural property that is member of it.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is archival record set in</rdfs:label>
        <rdfs:label xml:lang="it">è unità archivistica complessa in</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa F: UB/UBF</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?set a-cd:isCollectionIn ?collmemb .
?collmemb a a-cd:CollectionMembership .
}

WHERE {
?set a-cd:isArchivalRecordSetIn ?collmemb .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/isCollectionIn"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isArchivedIn -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isArchivedIn">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isAgentInvolvedIn"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/SourceAndDocument"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega l&apos;archivio e/o istituzione conservativa con la relativa documentazione costituita da fonti e documenti.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the archive or conservative institution to the documentation made of sources and documents.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is archived in</rdfs:label>
        <rdfs:label xml:lang="it">è archiviato in</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isAttachedDocumentationOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isAttachedDocumentationOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/isDocumentationOf"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega la documentazione allegata di un&apos;entità all&apos;entità stessa.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the attached documentation to its entity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is attached documentation of</rdfs:label>
        <rdfs:label xml:lang="it">è documentazione allegata di</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>FTAX, DRAX, VDCX, REGX, FNTX, ADMX (solo v. 3.00 e 3.01)</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isAttributedAuthorIn -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isAttributedAuthorIn">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isAgentInvolvedIn"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/AuthorshipAttribution"/>
        <rdfs:comment xml:lang="it">Questa è la proprietà inversa a &quot;ha autore attribuito&quot;.</rdfs:comment>
        <rdfs:comment xml:lang="en">This is the inverse property of &quot;has attributed author&quot;.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is attributed author in</rdfs:label>
        <rdfs:label xml:lang="it">è autore attribuito in</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {
?respo a a-cd:Responsibility .
?agent a-cd:isAgentWithResponsibilityIn ?respo .
}

WHERE {
?agent a-cd:isAttributedAuthorIn ?respo .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/isAgentWithResponsibilityIn"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isAuthorOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isAuthorOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/isAgentRelatedTo"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://w3id.org/arco/ontology/context-description/isAttributedAuthorIn"/>
            <rdf:Description rdf:about="https://w3id.org/arco/ontology/context-description/isAuthorshipAttributionOf"/>
        </owl:propertyChainAxiom>
        <rdfs:comment xml:lang="it">Questa proprietà collega un agent a una entità di qualsiasi tipo (documentazione, bene culturale, etc.) di cui quell&apos;agente è autore.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an agent to an entity the agent is author of.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is author of</rdfs:label>
        <rdfs:label xml:lang="it">è autore di</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?agent a-lite:isAuthorOf ?thing .
}

WHERE {
?agent a-cd:isAuthorOf ?thing .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/isAuthorOf"/>
        <core:replacingQuery>select * where {
?agent core:isAgentOf ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/Author&gt; ;
core:isAgentRoleOf ?thing .
}</core:replacingQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isAuthorityFileCataloguingAgencyOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isAuthorityFileCataloguingAgencyOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/isAgentRelatedTo"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega l&apos;ente schedatore dell&apos;authority file a un&apos;entità descritta in una scheda di Authority File.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the file&apos;s cataloguing institution to an entity described in a authority file.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is authority file cataloguing agency of</rdfs:label>
        <rdfs:label xml:lang="it">è ente schedatore dell&apos;authority file di</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?agent a-lite:isCataloguingAgencyOf ?thing .
}

WHERE {
?agent a-cd:isAuthorityFileCataloguingAgencyOf ?thing .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/isCataloguingAgencyOf"/>
        <core:replacingQuery>select * where {
?agent core:isAgentOf ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/CataloguingAgency&gt; ;
core:isAgentRoleOf ?thing .
}</core:replacingQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isAuthorshipAttributionOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isAuthorshipAttributionOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isEventOrSituationInTimeOf"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/arco/ontology/context-description/AuthorshipAttribution"/>
                    <rdf:Description rdf:about="https://w3id.org/arco/ontology/context-description/CulturalScopeAttribution"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:comment xml:lang="en">Property that links an authorship attribution referred to a cultural entity to that cultural entity.</rdfs:comment>
        <rdfs:comment xml:lang="it">Proprietà che lega un&apos;attribuzione di autore o di responsabilità relativa a un&apos;entità culturale all&apos;entità culturale stessa.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is authorship attribution of</rdfs:label>
        <rdfs:label xml:lang="it">è attribuzione di autore/responsabilità di</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: AU/AUT; AU/ATB; AU/AAT</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?respo a a-cd:Responsibility .
?respo a-cd:isResponsibilityFor ?cp  .
}

WHERE {
?respo a-cd:isAuthorshipAttributionOf ?cp .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/isResponsibilityFor"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isBibliographicSourceOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isBibliographicSourceOf">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Edition"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una bibliografia all&apos;entità alla quale si riferisce.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a bibliography to the entity which is referred to.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is bibliography of</rdfs:label>
        <rdfs:label xml:lang="it">è bibliografia di</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: DO/BIB; RE/RCG/RCGS</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isBibliographyOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isBibliographyOf">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Bibliography"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una bibliografia all&apos;entità alla quale si riferisce.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a bibliography to the entity which is referred to.</rdfs:comment>
        <rdfs:label xml:lang="en">is bibliography of</rdfs:label>
        <rdfs:label xml:lang="it">è bibliografia di</rdfs:label>
        
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag></a-cat:iccdNormTag>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: DO/BIB; RE/RCG/RCGS</a-cat:iccdNormTag>
        <core:replacingQuery>select * {
?thing a-cd:hasBibliographicSource ?edition .
?edition a a-cd:Edition ;
core:hasBibliographicEntry ?NEWbibEntry ;
a-cd:hasTitle ?NEWtitle .
?NEWbibEntry a BibliographicEntry ;
a-cd:completeBibliographicReference ?ref .
}</core:replacingQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isBibliographyTypeOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isBibliographyTypeOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isTypeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/BibliographyType"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Bibliography"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega il tipo di riferimento bibliografico alla bibliografia.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the bibliography type to its bibliography.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is bibliography type of</rdfs:label>
        <rdfs:label xml:lang="it">è tipo di bibliografia di</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:replacingQuery>select * {
?thing a-cd:hasBibliographicSource ?edition .
?edition a a-cd:Edition ;
core:hasBibliographicEntry ?NEWbibEntry ;
a-cd:hasTitle ?NEWtitle .
?NEWbibEntry a BibliographicEntry ;
a-cd:completeBibliographicReference ?ref .
}</core:replacingQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isBiologicalTaxonOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isBiologicalTaxonOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isClassificationOf"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una tassonomia con un&apos;entità biologica.</rdfs:comment>
        <rdfs:comment xml:lang="it">This property relates a taxon to a biological entity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is biological taxon of</rdfs:label>
        <rdfs:label xml:lang="it">è tassonomia biologica di</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {
?taxon core:classifies ?taxon .
}

WHERE {
?taxon a-cd:isBiologicalTaxonOf ?thing .
}</core:constructQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isChangeOfAvailabilityOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isChangeOfAvailabilityOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isEventOrSituationInTimeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/ChangeOfAvailability"/>
        <rdfs:range rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un mutamento di condizione materiale a un&apos;entità culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a change of availability to a cultural entity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is change of availability of</rdfs:label>
        <rdfs:label xml:lang="it">è mutamento di condizione materiale di</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isChangeOfAvailabilityTypeOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isChangeOfAvailabilityTypeOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isTypeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/ChangeOfAvailabilityType"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/ChangeOfAvailability"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega il tipo di evento (es.: furto, distruzione, recupero) di mutamento di condizione materiale di un bene culturale al mutamento stesso.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the event type (i.e. theft, destruction, recovery) of a cultural entity change of availability to the change itself.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is change of availability type of</rdfs:label>
        <rdfs:label xml:lang="it">è tipo di mutamento condizione materiale di</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {
?type core:isTypeOf ?thing .
}

WHERE {
?type a-cd:isChangeOfAvailabilityTypeOf ?thing .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/isTypeOf"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isCircumstanceOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isCircumstanceOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isEventOrSituationInTimeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Circumstance"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="it">Questa proprietà, inversa di &apos;ha circostanza&apos;, collega l&apos;occasione che ha determinato una situazione (es. la committenza di un bene culturale, l&apos;uso di un bene culturale ecc.) alla relativa situazione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property, inverse of &apos;has circumstance&apos; relates the circumstance which led to a situation (e.g. a cultural entity committment, a cultural entity use, etc.) to the related situation.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is circumstance of</rdfs:label>
        <rdfs:label xml:lang="it">è circostanza di</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isCircumstanceTypeOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isCircumstanceTypeOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isTypeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/CircumstanceType"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Circumstance"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega il tipo di occasione con la relativa occasione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the type of circumstance to the related circumstance.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is circumstance type of</rdfs:label>
        <rdfs:label xml:lang="it">è tipo di circostanza di</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {
?type core:isTypeOf ?thing .
}

WHERE {
?type a-cd:isCircumstanceTypeOf ?thing .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/isTypeOf"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isCoinIssuanceOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isCoinIssuanceOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isEventOrSituationInTimeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/CoinIssuance"/>
        <rdfs:range rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:comment xml:lang="it">Questa è la proprietà inversa a &quot;ha emissione di moneta&quot;.</rdfs:comment>
        <rdfs:comment xml:lang="en">This is the inverse property of &quot;has coin issuance&quot;.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is coin issuance of</rdfs:label>
        <rdfs:label xml:lang="it">è emissione di moneta</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isCoinMemberOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isCoinMemberOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/isMemberOfCollectionOf"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/NumismaticSeries"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una moneta a una serie di monete di cui è membro.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a coin to a numismatic series which is member of.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is coin member of</rdfs:label>
        <rdfs:label xml:lang="it">è moneta membro di</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>prefix a-lite: &lt;http://w3id.org/arco/ontology/arco-lite/&gt;
CONSTRUCT {
?cp a-lite:isCollectionMemberOf ?coll .
}

WHERE {
?cp a-cd:isCoinMemberOf ?coll .
}</core:constructQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isCollectionIn -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isCollectionIn">
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Collection"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/CollectionMembership"/>
        <rdfs:comment xml:lang="it">Questa proprietà, inversa a &quot;ha collezione&quot;, rappresenta la partecipazione di una collezione nel rapporto tra una collezione e un bene culturale che ne fa parte, in un certo intervallo di tempo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a collection to the relationship (membership) between the collection itself and a cultural property that is member of it.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is collection in</rdfs:label>
        <rdfs:label xml:lang="en">is collection involved in</rdfs:label>
        <rdfs:label xml:lang="it">è collezione coinvolta in</rdfs:label>
        <rdfs:label xml:lang="it">è collezione in</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>UB/COL/COLD</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isCollectorOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isCollectorOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/isAgentRelatedTo"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:range rdf:resource="http://dati.beniculturali.it/cis/CollectionCulEnt"/>
        <rdfs:comment xml:lang="it">Questa proprietà, inversa a &quot;ha collezionista&quot;, collega un collezionista alla relativa collezione di beni culturali.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a collector to its collection of cultural properties.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/context-description"/>
        <rdfs:label xml:lang="en">is collector of</rdfs:label>
        <rdfs:label xml:lang="it">è collezionista di</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>UB/COL/COLN</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?agent a-lite:isCollectorOf ?thing .
}

WHERE {
?agent a-cd:isCollectorOf ?thing .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/isCollectorOf"/>
        <core:replacingQuery>select * where {
?agent core:isAgentOf ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/Collector&gt; ;
core:isAgentRoleOf ?thing .
}</core:replacingQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isCommissionOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isCommissionOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isEventOrSituationInTimeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Commission"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega l&apos;individuazione di una committenza all&apos;entità culturale che è stata commissionata.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a commission to the cultural entity that was commissioned.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is commission of</rdfs:label>
        <rdfs:label xml:lang="it">è committenza di</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isCommittentIn -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isCommittentIn">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/isAgentRelatedTo"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Commission"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una persona o istituzione committente a una situazione in cui viene indicata la committenza di un bene culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an agent that is committent of a cultural property to the identification of the commission of that cultural property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is committent in</rdfs:label>
        <rdfs:label xml:lang="it">è committente in</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: AU/CMM/CMMN</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?agent a-lite:isCommittentOf ?thing .
}

WHERE {
?agent a-cd:isCommittentIn ?thing .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/isCommittentOf"/>
        <core:replacingQuery>select * where {
?agent core:isAgentOf ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/Committent&gt; ;
core:isAgentRoleOf ?thing .
}</core:replacingQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isComparisonBibliographicSourceOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isComparisonBibliographicSourceOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/isBibliographicSourceOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Edition"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega l&apos;edizione dell&apos;opera parte della bibliografia di confronto con l&apos;entità di cui è bibliografia.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the edition of the work part of the comparative bibliography to the involved entity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is comparative bibliographic source of</rdfs:label>
        <rdfs:label xml:lang="it">è fonte bibliografica di confronto di</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isConstructionCompanyOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isConstructionCompanyOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isAgentInvolvedIn"/>
        <rdfs:domain rdf:resource="http://dati.gov.it/onto/dcatapit#Organization"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una ditta alla realizzazione del bene culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a construction company to the realization of a cultural property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is construction company of</rdfs:label>
        <rdfs:label xml:lang="it">è ditta costruttrice di</rdfs:label>
        
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <core:constructQuery>PREFIX &lt;https://w3id.org/arco/ontology/arco-lite/&gt;

CONSTRUCT {
?agent a-lite:isConstructionCompanyOf ?thing .
}

WHERE {
?agent a-cd:isConstructionCompanyOf ?thing .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/isConstructionCompanyOf"/>
        <core:replacingQuery>prefix &lt;https://w3id.org/arco/ontology/arco-lite/isUserOf&gt;

select * where {
?NEWagent core:isAgentOf ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/ConstructionCompany&gt; ;
core:isAgentRoleOf ?y  .
}</core:replacingQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isContextBibliographicSourceOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isContextBibliographicSourceOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/isBibliographicSourceOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Edition"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega l&apos;edizione dell&apos;opera parte della bibliografia di contesto con l&apos;entità di cui è bibliografia.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the edition of the work part of the context bibliography to the involved entity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is context bibliographic source of</rdfs:label>
        <rdfs:label xml:lang="it">è fonte bibliografica di contesto di</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isCopyrightHolderIn -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isCopyrightHolderIn">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/isAgentRelatedTo"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Copyright"/>
        <rdfs:comment xml:lang="it">Questa è la proprietà inversa di &quot;ha titolare dei diritti d&apos;autore&quot;</rdfs:comment>
        <rdfs:comment xml:lang="en">This is the inverse property of &quot;has copyright holder&quot;.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is copyright holder in</rdfs:label>
        <rdfs:label xml:lang="it">è titolare dei diritti d&apos;autore in</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?agent a-lite:isCopyrhightHolderOf ?thing .
}

WHERE {
?agent a-cd:isCopyrightHolderIn ?thing .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/isCopyrightHolderOf"/>
        <core:replacingQuery>select * where {
?agent core:isAgentOf ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/CopyrightHolder&gt; ;
core:isAgentRoleOf ?thing .
}</core:replacingQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isCopyrightOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isCopyrightOf">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Copyright"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="it">Questa è la proprietà inversa di &quot;ha diritti d&apos;autore&quot;.</rdfs:comment>
        <rdfs:comment xml:lang="en">This is the inverse property of &quot;is copyright of&quot;.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is copyright of</rdfs:label>
        <rdfs:label xml:lang="it">sono diritti d&apos;autore di</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isCreationLocationOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isCreationLocationOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/isWorkRelatedTo"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:comment xml:lang="it">Questa è la proprietà inversa di &quot;ha luogo di creazione&quot;.</rdfs:comment>
        <rdfs:comment xml:lang="en">This is the inverse property of &quot;has creation location&quot;.</rdfs:comment>
        <rdfs:comment>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?x a-lite:isCreationLocationOf ?y .
}

WHERE {
?x a-cd:isCreationLocationOf ?y .
}</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is creation location of</rdfs:label>
        <rdfs:label xml:lang="it">è luogo di realizzazione di</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/isCreationLocationOf"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isCulturalGeographicAreaOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isCulturalGeographicAreaOf">
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/CLV/Feature"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Use"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega l&apos;area geografico-culturale con l&apos;uso del bene presente.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural geographical area to the use of the cultural property which is present.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is cultural geographic area of</rdfs:label>
        <rdfs:label xml:lang="it">è area geografico-culturale di</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isCulturalPropertyEstimateOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isCulturalPropertyEstimateOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/isEstimateOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Estimate"/>
        <rdfs:range rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una stima di un bene culturale al bene culturale stimato.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural property estimate to the estimated cultural property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is cultural property estimate of</rdfs:label>
        <rdfs:label xml:lang="it">è stima del bene culturale</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {
?x a-cd:isEstimateOf ?y .
}

WHERE {
?x a-cd:isCulturalPropertyEstimateOf ?y .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/isEstimateOf"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isCulturalPropertyStageIn -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isCulturalPropertyStageIn">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/CulturalPropertyStage"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/RelatedWorkSituation"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega lo stadio di realizzazione del bene culturale in relazione a un&apos;altra entità collegata (opera preparatoria o opera finale) al  rapporto tra il bene culturale stesso e questa entità.</rdfs:comment>
        <rdfs:comment xml:lang="en">This cultural property relates the stage of a cultural property referring to another entity (preparatory or final work) to this relationship between the two entities.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is cultural property stage in</rdfs:label>
        <rdfs:label xml:lang="it">è stadio del bene culturale in</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normative RA, SMO, PST, S, OAC, OA, MI, D, NU, F: RO/ROF/ROFF</a-cat:iccdNormTag>
        <core:constructQuery xml:lang="it">CONSTRUCT {
?reltype a a-cd:RelationshipType ;
a-cd:isRelationshipTypeOf ?rws .
}

WHERE {
?reltype a-cd:isCulturalPropertyStageOf ?rws .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/isRelationshipTypeOf"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isCulturalScopeOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isCulturalScopeOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/isTopicOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/CulturalScope"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega l&apos;ambito culturale attribuito a un bene culturale alla situazione in cui è avvenuta tale attribuzione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural scope of a cultural entity to the situation where this cultural scope is attributed.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is cultural scope of</rdfs:label>
        <rdfs:label xml:lang="it">è ambito culturale di</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: AU/ATB. Normativa BDM e SM: AU/AUT/AUTC. BDI: AT/ATT/ATTB, AI/AIF/AIFB, VI/VIF/VOFB, FI/FI/FIFB. Normativa SM: MU/MUT/MUTB. Normativa AUT: AU/AUT/AUTU</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isDatingEventOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isDatingEventOf">
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/EventOrSituation"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Dating"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un evento relativo al bene culturale, cui si riferisce la specifica cronologia a una cronologia.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an event involving the cultural property, which the dating is about, to a dating.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is dating event of</rdfs:label>
        <rdfs:label xml:lang="it">è evento relativo alla datazione di</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>DTN/DTNS; se non c&apos;è, Event = &quot;realizzazione&quot;. ICCD Normative F, RA, SMO, PST, S, OAC, OA, MI, D, NU: RO/ROF/ROFD. ICCD Normativa Trasversale: DT/ADT.</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isDatingOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isDatingOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isSituationOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Dating"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una cronologia all&apos;entità cui si riferisce.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a dating to an entity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is dating of</rdfs:label>
        <rdfs:label xml:lang="it">è cronologia di</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: DT - ICCD Normative F, RA, SMO, PST, S, OAC, OA, MI, D, NU: RO/ROF</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isDerivatedWorkTypeOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isDerivatedWorkTypeOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isTypeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/DerivatedWorkType"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/DerivatedWork"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega il tipo di opera derivata da un bene culturale alla relativa opera derivata.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the type of a work derivated from a cultural entity to its work derivated.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is derivated work type of</rdfs:label>
        <rdfs:label xml:lang="it">è tipo di opera derivata di</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {
?type core:isTypeOf ?thing .
}

WHERE {
?type a-cd:isDerivatedWorkTypeOf ?thing .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/isTypeOf"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isDesignationInTimeOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isDesignationInTimeOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isEventOrSituationInTimeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/DesignationInTime"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="it">Questa è la proprietà inversa di &quot;ha designazione nel tempo&quot;.</rdfs:comment>
        <rdfs:comment xml:lang="en">This is the inverse property of &quot;has designation in time&quot;.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is designation in time of</rdfs:label>
        <rdfs:label xml:lang="it">è denominazione nel tempo di</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: OG/OGD. - Normativa BNB: OG/OGT/OGTE e OG/OGT/OGTC. - Normativa NU: OG/OGT/OGTO. - OG/OGT/OGTU. Normativa SI: OG/OGT/OGTY</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isDetectionMethodOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isDetectionMethodOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isMethodOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/DetectionMethod"/>
        <rdfs:range rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega la modalità di individuazione di un bene culturale al bene culturale stesso.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the detection method of a cultural property to the cultural property itself.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is detection method of</rdfs:label>
        <rdfs:label xml:lang="it">è metodo di individuazione di</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: OG/OGM</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isDocumentationOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isDocumentationOf">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Documentation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una documentazione a un&apos;entità che viene documentata. Per esempio, può collega una documentazione che riguarda il bene descritto in una scheda di catalogo al bene stesso.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a documentation to an entity. For example, it can relates a documentation concerning a cultural property described in a catalogue record to that cultural property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is documentation of</rdfs:label>
        <rdfs:label xml:lang="it">è documentazione di</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale 4.00: tutti i campi strutturati di DO tranne BIB</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isDocumentationTypeOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isDocumentationTypeOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isTypeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/DocumentationType"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Documentation"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega il tipo di documentazione alla sua documetanzione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the type of documentation to its documentation.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is documentation type of</rdfs:label>
        <rdfs:label xml:lang="it">è tipo di documentazione di</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {
?type core:isTypeOf ?thing .
}

WHERE {
?type a-cd:isDocumentationTypeOf ?thing .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/isTypeOf"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isDomicileOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isDomicileOf">
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Location"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega il domicilio all&apos;agente.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a domicile to the agent.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is domicile of</rdfs:label>
        <rdfs:label xml:lang="it">è domicilio di</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BDI: AT/DML. Normativa SM: MU/DML.</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isEditionOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isEditionOf">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Edition"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;edizione di un&apos;entità all&apos;entità stessa.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an entity&apos;s edition to the entity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is edition of</rdfs:label>
        <rdfs:label xml:lang="it">è edizione di</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normative VeAC e AT 3.01: DO/BSE/BSEN - Normativa S 3.00: RO/ADL/ADLE.</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isEditorOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isEditorOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/isAgentRelatedTo"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Edition"/>
        <rdfs:comment xml:lang="it">Questa è la proprietà inversa di &quot;ha editore&quot;.</rdfs:comment>
        <rdfs:comment xml:lang="en">This is the inverse property of &quot;has editor&quot;.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is editor of</rdfs:label>
        <rdfs:label xml:lang="it">è editore di</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?agent a-lite:isEditorOf ?thing .
}

WHERE {
?agent a-cd:isEditorOf ?thing .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/isEditorOf"/>
        <core:replacingQuery>select * where {
?agent core:isAgentOf ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/Editor&gt; ;
core:isAgentRoleOf ?thing .
}</core:replacingQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isElementInvolvedIn -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isElementInvolvedIn">
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
        <rdfs:range rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un elemento (animale, vegetale o minerale) a un bene culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an element (animal, vegetal or mineral) to the related cultural property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is element involved in</rdfs:label>
        <rdfs:label xml:lang="it">è elemento coinvolto in</rdfs:label>
        
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {
?x &lt;https://w3id.org/arco/ontology/denotative-description/isElementInvolvedIn&gt; ?y.
}

WHERE {
?x a-cd:isElementInvolvedIn ?y.
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/isElementInvolvedIn"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isEligibleInterventionDefinedBy -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isEligibleInterventionDefinedBy">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/InterventionType"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/UrbanPlanningInstrument"/>
        <rdfs:comment xml:lang="it">Questa proprietà, inversa a &quot;ha intervento ammesso&quot;, collega un tipo di intervento allo strumento urbanistico-territoriale che ammette quell&apos;intervento.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property, inverse of &quot;has eligible intervention&quot;, relates an intervention type to the urban planning instrument that finds eligible that intervention.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is intervention eligible by</rdfs:label>
        <rdfs:label xml:lang="it">è intervento ammesso da</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: TU/STU/STUN</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isEntityInvolvedIn -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isEntityInvolvedIn">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Interpretation"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isEstimateOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isEstimateOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isEventOrSituationInTimeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Estimate"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una stima di un&apos;entità all&apos;entità stimata.</rdfs:comment>
