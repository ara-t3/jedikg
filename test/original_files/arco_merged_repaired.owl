    <!-- https://w3id.org/italia/onto/l0/precedes -->

    <owl:ObjectProperty rdf:about="https://w3id.org/italia/onto/l0/precedes">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Entity"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Entity"/>
        <rdfs:comment xml:lang="it">La relazione per rappresentare il predecessore di un entità in una sequenza.</rdfs:comment>
        <rdfs:comment xml:lang="en">The relation for represending the precedecessor of an entity in a sequence.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/italia/onto/l0"/>
        <rdfs:label xml:lang="it">precede</rdfs:label>
        <rdfs:label xml:lang="en">precedes</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://w3id.org/arco/ontology/arco/HSDefinition -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/arco/HSDefinition">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/arco/HornbostelSachsClassification"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la definizione associata allo strumento musicale, secondo la classificazione Hornbostel-Sachs.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the definition associated to a musical instrument, according to the Hornbostel-Sachs classification.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/arco"/>
        <rdfs:label xml:lang="en">Hornbostel-Sachs definition</rdfs:label>
        <rdfs:label xml:lang="it">definizione Hornbostel-Sachs</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>Normativa SM 4.00: CL/CHS/CHSD</a-cat:iccdNormTag>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/musical-instrument/HSDefinition"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/arco/HSEdition -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/arco/HSEdition">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/arco/HornbostelSachsClassification"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta l&apos;indicazione bibliografica dell&apos;edizione Hornbostel-Sachs utilizzata per la classificazione dello strumento musicale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the edition Horbonstel-Sachs used for classifying a musical instrument.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/arco"/>
        <rdfs:label xml:lang="en">Hornbostel-Sachs edition</rdfs:label>
        <rdfs:label xml:lang="it">edizione Hornbostel-Sachs</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>Normativa SM 4.00: CL/CHS/CHSE</a-cat:iccdNormTag>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/musical-instrument/HSEdition"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/arco/HSNumber -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/arco/HSNumber">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/identifier"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/arco/HornbostelSachsClassification"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta il codice numerico, secondo l&apos;edizione specifica Hornbostel-Sachs, associato allo strumento musicale nell&apos;ambito della classificazione Hornbostel-Sachs.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the numerical code associated to a musical instrument according to a specific edition of the Hornbostel-Sachs classification.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/arco"/>
        <rdfs:label xml:lang="it">Codice numerico Hornbostel-Sachs</rdfs:label>
        <rdfs:label xml:lang="en">Hornbostel-Sachs number</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>Normativa SM 4.00: CL/CHS/CHSN</a-cat:iccdNormTag>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/musical-instrument/HSNumber"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/arco/RVERidentifier -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/arco/RVERidentifier">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/identifier"/>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/arco"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/arco/archaeologicMaterialConcentration -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/arco/archaeologicMaterialConcentration">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/arco/ArchaeologicalMaterial"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la densità di concentrazione del materiale archeologico</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the archaeologic material concentration</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/arco"/>
        <rdfs:label xml:lang="en">archaeologic material concentration</rdfs:label>
        <rdfs:label xml:lang="it">densità di concentrazione del materiale archeologico</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa SI: DA/MTP/MTPS</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/arco/archaeologicalSiteIdentifier -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/arco/archaeologicalSiteIdentifier">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/identifier"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/arco/ArchaeologicalProperty"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la sigla del saggio stratigrafico.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the archaeological site identifier.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/arco"/>
        <rdfs:label xml:lang="en">archaeological site identifier</rdfs:label>
        <rdfs:label xml:lang="it">sigla identificativa del saggio stratigrafico</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa SAS: OG/OGT/OGTI</a-cat:iccdNormTag>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/hasIdentifier"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/arco/cartographicSymbolIdentifier -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/arco/cartographicSymbolIdentifier">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/identifier"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta il codice identificativo attribuito al simbolo cartografico.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the identifier associated to the cartographic symbol.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/arco"/>
        <rdfs:label xml:lang="en">cartographic symbol identifier</rdfs:label>
        <rdfs:label xml:lang="it">identificativo del simbolo cartografico</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: CT/CTM/CTMS</a-cat:iccdNormTag>
        <core:replacedBy rdf:resource="https://w3id.org/italia/onto/l0/identifier"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/arco/catalogueNumber -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/arco/catalogueNumber">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/identifier"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/arco/CulturalProperty"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà permette di associare il numero di catalogo generale a un bene culturale descritto in una scheda catalografica.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the general catalogue number associated to a cultural property described by a catalogue record.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/arco"/>
        <rdfs:label xml:lang="en">catalogue number</rdfs:label>
        <rdfs:label xml:lang="it">numero catalogo generale</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: CD/NCT/NCTN</a-cat:iccdNormTag>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/catalogue/catalogueNumber"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/arco/classifiedSubject -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/arco/classifiedSubject">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/arco/PhotographicHeritageClassification"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la descrizione codificata del/i soggetto/i raffigurato/i nell&apos;opera secondo il sistema di classificazione scelto dall&apos;Ente schedatore, in alternativa e/o in aggiunta ad Iconclass.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the subject of a photographic heritage as described in a photographic heritage classification other than Iconclass.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/arco"/>
        <rdfs:label xml:lang="en">classified subject</rdfs:label>
        <rdfs:label xml:lang="it">soggetto classificato</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa F 4.00: SG/CLF/CLFS</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/arco/completedCollection -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/arco/completedCollection">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/arco/CulturalPropertyCollection"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="it">Questa proprietà segnala se la serie risulta completa o incompleta</rdfs:comment>
        <rdfs:comment xml:lang="en">This property indicates if the collection is completed or not</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/arco"/>
        <rdfs:label xml:lang="it">collezione completa</rdfs:label>
        <rdfs:label xml:lang="en">completed collection</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD normative F, MI, S: OG/QNT/QNTC</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/arco/containerSequence -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/arco/containerSequence">
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta il codice che definisce la sequenza dei contenitori.</rdfs:comment>
        <rdfs:comment xml:lang="en">Thisproperty represents the code defining the container sequence.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/arco"/>
        <rdfs:label xml:lang="it">codice sequenza</rdfs:label>
        <rdfs:label xml:lang="en">container sequence</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BNB: AC/ACZ</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?x &lt;https://w3id.org/arco/ontology/natural-specimen-description/containerSequence&gt; ?y .
}

WHERE {
?x arco:containerSequence ?y .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/containerSequence"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/arco/definitionAndPositionOfComponents -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/arco/definitionAndPositionOfComponents">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/arco/ComplexCulturalProperty"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta le informazioni sulla definizione e posizione delle parti componenti di un bene culturale complesso.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents information on definition and position of the components of a complex cultural property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/arco"/>
        <rdfs:label xml:lang="en">definition and position of components</rdfs:label>
        <rdfs:label xml:lang="it">definizione e posizione delle parti componenti</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: OG/OGC/OGCD</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?x a-core:note ?y .
}

WHERE {
?x a-arco:definitionAndPOsitionOfComponents ?y .
}</core:constructQuery>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/arco/digitalPhotographNote -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/arco/digitalPhotographNote">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/note"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/arco/PhotographicHeritage"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta le note relative alla fotografia digitale. Può rappresentare informazioni utili a identificare le intenzioni dell&apos;autore in relazione alla visualizzazione o rioggettivazione della fotografia digitale, come la dimensione del quadro, la risoluzione di stampa e relativa unità di misura, altre indicazioni per la stampa (tipo stampante, correzioni cromatiche, ecc.), categoria, URL, ecc.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents notes on a digital photograph.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/arco"/>
        <rdfs:label xml:lang="en">digital photograph note</rdfs:label>
        <rdfs:label xml:lang="it">note sulla fotografia digitale</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa F: MT/FVC/FVCV</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?x a-core:note ?y .
}

WHERE {
?x a-arco:digitalPhotographNote ?y .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/note"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/arco/endTime -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/arco/endTime">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/TI/time"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/TI/TimeInterval"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la data di fine di un intervallo temporale, che può essere espressa secondo criteri diversi e a diverso livello di dettaglio (secolo, intervallo di secoli, anno, intervallo di anni, aaaa/mm/gg, periodo storico, etc.)</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the end time of a time interval, according to different criteria and level of detail (century, century interval, year, yyyy/mm/dd, historical period, etc.).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/arco"/>
        <rdfs:label xml:lang="it">data di fine</rdfs:label>
        <rdfs:label xml:lang="en">end time</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/arco/internationalIdentifier -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/arco/internationalIdentifier">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/identifier"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/arco/CulturalProperty"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta il numero di codice internazionale che identifica un bene scientifico e tecnologico. All&apos;indirizzo http://www.isin.org/ è possibile reperire tutte le specifiche per l&apos;adesione al progetto e l&apos;attribuzione del codice internazionale. Il Registro Online è un database che raccoglie informazioni su strumenti scientifici di interesse storico promosso dal Museum of the History of Science di Oxford in collaborazione con la Commissione Strumenti Scientifici dell&apos;International Union of the History and Philosophy of Science.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the international identifier of a scientific or technological heritage. More info can be found at https://www.isin.org/</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/arco"/>
        <rdfs:label xml:lang="it">codice internazionale</rdfs:label>
        <rdfs:label xml:lang="en">international identifier</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa PST: AC/ACI</a-cat:iccdNormTag>
        <core:replacedBy rdf:resource="https://w3id.org/italia/onto/l0/identifier"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/arco/musicalInstrumentNote -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/arco/musicalInstrumentNote">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/note"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/arco/MusicHeritage"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta le note relative agli aspetti acustici di uno strumento musicale, ed eventualmente anche relative ai rilevamenti e ai criteri adottati in sede di restauro.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents notes on a musical instrument.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/arco"/>
        <rdfs:label xml:lang="en">musical instrument note</rdfs:label>
        <rdfs:label xml:lang="it">note sullo strumento musicale</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa SM 4.00: AA/AAS</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?x a-core:note ?y .
}

WHERE {
?x a-arco:musicalInstrumentNote ?y .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/note"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/arco/numberOfArchaeologicalMaterials -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/arco/numberOfArchaeologicalMaterials">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/arco/numberOfParts"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/arco/ArchaeologicalMaterial"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la quantità complessiva di uno stesso materiale archeologico componente di un lotto di materiali.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the total quantity of an archaeological material that is part of a lot of archaeological materials.</rdfs:comment>
        <rdfs:comment xml:lang="it">numero di materiali archeologici componenti</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/arco"/>
        <rdfs:label xml:lang="en">number of archeological materials</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa TMA: MA/MAC/MACQ</a-cat:iccdNormTag>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco/numberOfComponents"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/arco/numberOfComponents -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/arco/numberOfComponents">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/arco/numberOfParts"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta il numero di oggetti componenti di un bene culturale identificato come serie o come insieme.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the number of components of a complex cultural property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/arco"/>
        <rdfs:label xml:lang="en">number of components</rdfs:label>
        <rdfs:label xml:lang="it">numero di componenti</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: OG/QNT/QNTN; OG/QNT/QNTS</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/arco/numberOfCulturalPropertyParts -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/arco/numberOfCulturalPropertyParts">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/arco/numberOfParts"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/arco/CulturalPropertyPart"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta il numero di esemplari di una stessa parte di un bene culturale (es.: il numero di denti di un reperto antropologico)</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the number of specimens of the same cultural property part (es.: the number of the teeth of an anthropological material).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/arco"/>
        <rdfs:label xml:lang="en">number of cultural property part</rdfs:label>
        <rdfs:label xml:lang="it">numero di parte di bene culturale</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa AT 3.01: EL/ELE/ELEM</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/arco/numberOfElements -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/arco/numberOfElements">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/arco/numberOfParts"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
        <rdfs:comment xml:lang="it">Questa propietà rappresenta  il numero complessivo, espresso in cifre, degli elementi che costituiscono il bene catalogato, nel caso esso sia un insieme o una serie i cui esemplari/oggetti componenti comprendono ciascuno più elementi.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the total number of elements of a complex cultural property, when it is composed by parts containing more elements.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/arco"/>
        <rdfs:label xml:lang="en">number of elements</rdfs:label>
        <rdfs:label xml:lang="it">numero di elementi</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: OG/QNT/QNTI; OG/QNT/QNTS</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/arco/numberOfMembers -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/arco/numberOfMembers">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/arco/numberOfParts"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/arco/CulturalPropertyCollection"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta il numero di membri di un bene culturale che si identifica come una collezione (es.: serie)</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the number of members of a cultural property that is a collection (e.g.: series)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/arco"/>
        <rdfs:label xml:lang="en">number of members</rdfs:label>
        <rdfs:label xml:lang="it">numero di membri</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: OG/QNT/QNTN; OG/QNT/QNTI; OG/QNT/QNTS</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/arco/numberOfParts -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/arco/numberOfParts">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta il numero di parti di un&apos;entità.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the number of parts of an entity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/arco"/>
        <rdfs:label xml:lang="en">number of parts</rdfs:label>
        <rdfs:label xml:lang="it">numero di parti</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/arco/numberOfResiduals -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/arco/numberOfResiduals">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/arco/numberOfParts"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/arco/CulturalPropertyResidual"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta il numero di parti residuali, nel caso in cui si stia descrivendo un bene di cui si conservano più parti residuali.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the number of residuals (only if more than one) of a cultural property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/arco"/>
        <rdfs:label xml:lang="en">number of cultural property residual parts</rdfs:label>
        <rdfs:label xml:lang="it">numero di parti residuali di bene culturale</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>OG/QNT/QNTR</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/arco/positionInSequence -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/arco/positionInSequence">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/arco/CulturalPropertyComponent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la posizione o il numero d’ordine dell’elemento all’interno del bene preso in considerazione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the position of a cultural property component in the sequence to which it belogns.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/arco"/>
        <rdfs:label xml:lang="it">numero d&apos;ordine</rdfs:label>
        <rdfs:label xml:lang="en">position in sequence</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD normative F, MI, OAC, S: OG/QNT/QNTO</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/arco/previousIdentifier -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/arco/previousIdentifier">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/identifier"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta qualsiasi codice precedente a quello attuale che identifica il campione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents any previous identifier of the specimen.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/arco"/>
        <rdfs:label xml:lang="it">identificativo precedente</rdfs:label>
        <rdfs:label xml:lang="en">previous identifier</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BNB: AC/ACN</a-cat:iccdNormTag>
        <core:replacedBy rdf:resource="https://w3id.org/italia/onto/l0/identifier"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/arco/regionIdentifier -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/arco/regionIdentifier">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/identifier"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/arco/CulturalProperty"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà permette di associare il codice regione a un bene culturale descritto in una scheda catalografica.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the &quot;region identifier&quot; associated to a cultural property described by a catalogue record.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/arco"/>
        <rdfs:label xml:lang="it">codice regione</rdfs:label>
        <rdfs:label xml:lang="en">region identifier</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: CD/NCT/NCTR</a-cat:iccdNormTag>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/catalogue/regionIdentifier"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/arco/startTime -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/arco/startTime">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/TI/time"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/TI/TimeInterval"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la data di inizio di un intervallo temporale, che può essere espressa secondo criteri diversi e a diverso livello di dettaglio (secolo, intervallo di secoli, anno, intervallo di anni, aaaa/mm/gg, periodo storico, etc.)</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the start time of a time interval, according to different criteria and level of detail (century, century interval, year, yyyy/mm/dd, historical period, etc.).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/arco"/>
        <rdfs:label xml:lang="it">data di inizio</rdfs:label>
        <rdfs:label xml:lang="en">start time</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/arco/suffix -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/arco/suffix">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/identifier"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/arco/CulturalProperty"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà permette di associare il suffisso a un bene culturale descritto in una scheda catalografica.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the &quot;suffix&quot; associated to a cultural property described by a catalogue record.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/arco"/>
        <rdfs:label xml:lang="it">suffisso</rdfs:label>
        <rdfs:label xml:lang="en">suffix</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: CD/NCT/NCTS</a-cat:iccdNormTag>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/catalogue/suffix"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/arco/taxon -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/arco/taxon">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/arco/AlternativeMusicalInstrumentClassification"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta il codice tassonomico e la definizione attribuiti allo strumento musicale schedato nell&apos;ambito del sistema di classificazione preso in considerazione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the taxon code and the taxon definition associated to the musical instrument, according to a musical instrument classification.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/arco"/>
        <rdfs:label xml:lang="en">taxon</rdfs:label>
        <rdfs:label xml:lang="it">taxon</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>Normativa SM 4.00: CL/CLA/CLAT</a-cat:iccdNormTag>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/isClassifiedBy"/>
        <core:replacingQuery>CONSTRUCT {
?x a-core:isClassifiedBy ?class.
?class rdfs:label ?y .
}

WHERE {
?x a-arco:taxon ?y .
}</core:replacingQuery>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/arco/uniqueIdentifier -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/arco/uniqueIdentifier">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/identifier"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/arco/CulturalProperty"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà permette di associare il codice univoco (ricavato dalla concatenazione di codice regione, numero di catalogo generale ed eventuale suffisso) a un bene culturale descritto in una scheda catalografica.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the unique identifier (derived as the concatenation of the region identifier, the catalogue number and the suffix) of a cultural property describey by a catalogue record.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/arco"/>
        <rdfs:label xml:lang="it">codice univoco</rdfs:label>
        <rdfs:label xml:lang="en">unique identifier</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: concat(CD/NCT/NCTR + CD/NCT/NCTN + CD/NCT/NCTS); RV/RVE/RVER (identificativo univoco delle schede collegate); scheda A e PG, v. 1 e v. 2: RV/RVE/RVES (identificativo univoco delle schede collegate). RV/RSE/RSEC (identificativo univoco delle schede collegate)</a-cat:iccdNormTag>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/uniqueIdentifier"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/catalogue/ICCDIdentifier -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/catalogue/ICCDIdentifier">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/identifier"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta un codice assegnato a un&apos;entità dall&apos;ICCD. Si specializza in sottoproprietà (es.: codice univoco ICCD dell&apos;autore, codice univoco ICCD del riferimento bibliografico, etc.)</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the identifier assigned to a cultural property by ICCD.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="en">ICCD identifier</rdfs:label>
        <rdfs:label xml:lang="it">codice univoco ICCD</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>prefix l0: &lt;https://w3id.org/italia/onto/l0/&gt; 

CONSTRUCT {
?thing l0:identifier ?id .
}

WHERE {
?thing a-cat:ICCDIdentifier ?id .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/ICCDIdentifier"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/catalogue/ICCDUsageContext -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/catalogue/ICCDUsageContext">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;entità all&apos;ambito di applicazione ICCD scelto. Es: pubblicazione sul Catalogo o sulla Fototeca</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the usage context chose by ICCD for an entity. i.e. the publication on the Catalogue website, on the Fototeca website</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="it">ICCD ambito di applicazione</rdfs:label>
        <rdfs:label xml:lang="en">ICCD usage context</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/catalogue/additionalFormIdentifier -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/catalogue/additionalFormIdentifier">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/identifier"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/catalogue/AdditionalForm"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà permette di associare un identificativo a un modulo di approfondimento.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the additional form identifier.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="en">additional form identifier</rdfs:label>
        <rdfs:label xml:lang="it">identificativo del modulo di approfondimento</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: DA/APP/APPC</a-cat:iccdNormTag>
        <core:constructQuery>prefix l0: &lt;https://w3id.org/italia/onto/l0/&gt; 

CONSTRUCT {
?thing l0:identifier ?id .
}

WHERE {
?thing a-cat:additionalFormIdentifier ?id .
}</core:constructQuery>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/catalogue/catalogueNumber -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/catalogue/catalogueNumber">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/identifier"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/core/Identifier"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà permette di associare il numero di catalogo generale a scheda catalografica.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the general catalogue number associated to a catalogue record.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="en">catalogue number</rdfs:label>
        <rdfs:label xml:lang="it">numero catalogo generale</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: CD/NCT/NCTN</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/catalogue/catalogueRecordIdentifier -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/catalogue/catalogueRecordIdentifier">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/identifier"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/catalogue/CatalogueRecord"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà permette di associare l&apos;identificativo a una scheda catalografica che descrive un bene culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the identifier of a catalogue record describing a cultural property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="en">catalogue record identifier</rdfs:label>
        <rdfs:label xml:lang="it">identificativo della scheda di catalogo</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">Concatenazione dei sottocampi di CD/NCT (NCTR, NCTN, NCTS) e RV/RVE/RVEL</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt;

CONSTRUCT {
?thing a-lite:nationalIdentifier ?id .
}

WHERE {
?thing a-cat:CatalogueRecordIdentifier ?id .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/italia/onto/l0/identifier"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/catalogue/culturalPropertyRecordIdentifier -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/catalogue/culturalPropertyRecordIdentifier">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/identifier"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/catalogue/Record"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà permette di associare l&apos;identificativo a una scheda in cui si analizza un bene culturale per finalità diverse da quella specificazione della catalogazione del patrimonio culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property is used to associate the identifier to a catalogue record that analyze the cultural property for reasons other than cataloguing the cultural heritage.</rdfs:comment>
        <rdfs:label xml:lang="en">cultural property record identifier</rdfs:label>
        <rdfs:label xml:lang="it">identificativo di scheda su bene culturale</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: AC/ACS/ACSC</a-cat:iccdNormTag>
        <core:constructQuery>prefix l0: &lt;https://w3id.org/italia/onto/l0/&gt; 

CONSTRUCT {
?thing l0:identifier ?id .
}

WHERE {
?thing a-cat:CulturalPropertyRecordIdentifier ?id .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/italia/onto/l0/identifier"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/catalogue/deletedICCDIdentifier -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/catalogue/deletedICCDIdentifier">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/identifier"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/catalogue/CatalogueRecord"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta un codice ICCD eventualmente soppresso per motivi di diversa natura, utile per poter ricercare e consultare le schede pregresse nell&apos;Archivio storico gestito dall&apos;Istituto o da altri Enti.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the ICCD&apos;s identifier deleted for many reasons, used to search for obsolete catalogue records.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="it">codice ICCD soppresso</rdfs:label>
        <rdfs:label xml:lang="en">deleted ICCD identifier</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale 4.00: RV/RSP; versioni precedenti: RV/RVE/RVES</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/catalogue/informationFormIdentifier -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/catalogue/informationFormIdentifier">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/identifier"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà permette di associare l&apos;identificativo a un modulo informativo che è collegato a un bene culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property links an identifier to an information form related to a cultural property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="it">identificativo del modulo informativo</rdfs:label>
        <rdfs:label xml:lang="en">information form identifier</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: AC/MOD/MODI</a-cat:iccdNormTag>
        <core:constructQuery>prefix l0: &lt;https://w3id.org/italia/onto/l0/&gt; 

CONSTRUCT {
?thing l0:identifier ?id .
}

WHERE {
?thing a-cat:informationFormIdentifier ?id .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/italia/onto/l0/identifier"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/catalogue/lastUpdateDate -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/catalogue/lastUpdateDate">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/TI/date"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/catalogue/Record"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la data dell&apos;ultimo aggiornamento della scheda di catalogo</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents information about the last update date of a catalogue record.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="it">data dell&apos;ultimo aggiornamento</rdfs:label>
        <rdfs:label xml:lang="en">last update date</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/catalogue/localIdentifier -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/catalogue/localIdentifier">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/identifier"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta un identificativo che individua un&apos;entità in modo univoco nell&apos;ambito di un repertorio locale. Si specializza in sottoproprietà (es.: identificativo dell&apos;autore nell&apos;ambito di un repertorio locale, identificativo dell&apos;indagine archeologica nell&apos;ambito di un repertorio locale, etc.)</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents a unique identifier of an entity, within a local inventory.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="it">identificativo di repertorio locale</rdfs:label>
        <rdfs:label xml:lang="it">local identifier</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>prefix l0: &lt;https://w3id.org/italia/onto/l0/&gt; 

CONSTRUCT {
?thing l0:identifier ?id .
}

WHERE {
?thing a-cat:localIdentifier ?id .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/italia/onto/l0/identifier"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/catalogue/public -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/catalogue/public">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta lo stato di visibilità di un&apos;entità: visibile/pubblicata oppure non visibile.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the visibility state of an entity: public or not.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="it">pubblico</rdfs:label>
        <rdfs:label xml:lang="en">public</rdfs:label>
        <rdfs:label xml:lang="it">visibile</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/catalogue/recoveredData -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/catalogue/recoveredData">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/catalogue/CatalogueRecord"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta eventuali informazioni provenienti da schede pregresse redatte sulla base di standard obsoleti, per le quali non è stato possibile effettuare il trasferimento nel tracciato della scheda aggiornato, secondo la sintassi: “acronimocampo: valore; acronimocampo: valore”</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents information extracted from versions of a catalogue record using obsolete standards.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="it">dati pregressi recuperati</rdfs:label>
        <rdfs:label xml:lang="en">recovered data</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: AN/RDP</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/catalogue/referenceProject -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/catalogue/referenceProject">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta il progetto nell&apos;ambito del quale è stata prodotta una scheda, quella a cui si associa un codice alternativo, assegnato da enti diversi da ICCD, o quella che analizza un bene culturale per finalità diverse da quella specifica della catalogazione del patrimonio culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the reference project of a record about a cultural property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="it">progetto di riferimento</rdfs:label>
        <rdfs:label xml:lang="en">reference project</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: AC/ACC/ACCP; AC/ACS/ACSP</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/catalogue/regionIdentifier -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/catalogue/regionIdentifier">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/identifier"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/core/Identifier"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà permette di associare il codice regione a una scheda catalografica.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the &quot;region identifier&quot; associated to a catalogue record.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="it">codice regione</rdfs:label>
        <rdfs:label xml:lang="en">region identifier</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: CD/NCT/NCTR</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/catalogue/suffix -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/catalogue/suffix">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/identifier"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/core/Identifier"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta un suffisso di due lettere che può essere aggiunto all&apos;identificativo delle schede di catalogo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents a two-character suffix that might be added to the catalogue record number.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="it">suffisso</rdfs:label>
        <rdfs:label xml:lang="en">suffix</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="it">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: CD/NCT/NCTS</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/catalogue/systemRecordCode -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/catalogue/systemRecordCode">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/identifier"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/catalogue/CatalogueRecord"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta l&apos;identificativo di sistema che viene associato all&apos;interno del sistema Sigec al file xml contenente una scheda di catalogo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the identifier associated in the context of the SIGECweb to the xml file containing a catalogue record.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="it">identificativo di sistema</rdfs:label>
        <rdfs:label xml:lang="en">system record code</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>prefix arco-lite: &lt;https://w3id.org/italia/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?thing arco-lite:systemIdentifier ?id .
}

WHERE {
?thing a-cat:systemRecordCode ?id .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/systemIdentifier"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/clothing-description/appliedDecoration -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/clothing-description/appliedDecoration">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/denotative-description/IconographicOrDecorativeApparatus"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="it">Questa proprietà indica se la decorazione di un capo è applicata oppure no (e.g. ricamata)</rdfs:comment>
        <rdfs:comment xml:lang="en">This property claims if a decoration is applied on the clothing or not (e.g. embrodered)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/clothing-description"/>
        <rdfs:label xml:lang="en">applied decoration</rdfs:label>
        <rdfs:label xml:lang="it">decorazione applicata</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/clothing-description/costumeSpecification -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/clothing-description/costumeSpecification">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/arco/ontology/clothing-description/Clothing"/>
                    <rdf:Description rdf:about="https://w3id.org/arco/ontology/clothing-description/ClothingElement"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un costume alle sue specifiche</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a costume with its specification</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/clothing-description"/>
        <rdfs:label xml:lang="en">costume specification</rdfs:label>
        <rdfs:label xml:lang="it">specifiche di costume</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/clothing-description/intendedUser -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/clothing-description/intendedUser">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/clothing-description/Clothing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un vestimento al tipo di utente per cui è stato realizzato</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a clothing with the indended user type</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/clothing-description"/>
        <rdfs:label xml:lang="en">intended user</rdfs:label>
        <rdfs:label xml:lang="it">utente designato</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa VeAC 3.01: OG/OGT/OGTG, OG/OGTA+OGTR/Q</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/clothing-description/uniformSpecification -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/clothing-description/uniformSpecification">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/arco/ontology/clothing-description/Clothing"/>
                    <rdf:Description rdf:about="https://w3id.org/arco/ontology/clothing-description/ClothingElement"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;uniforme con le sue specifiche</rdfs:comment>
        <rdfs:comment xml:lang="en">This property links a uniform with its specifications</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/clothing-description"/>
        <rdfs:label xml:lang="it">specifiche di uniforme</rdfs:label>
        <rdfs:label xml:lang="en">uniform specification</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/construction-description/apsidalTermination -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/construction-description/apsidalTermination">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/construction-description/ArchitecturalSpace"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="it">Questa proprietà indica se uno spazio ha una terminazione absidata.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property indicates if a space has an apsidal termination.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/construction-description"/>
        <rdfs:label xml:lang="en">apsidal termination</rdfs:label>
        <rdfs:label xml:lang="it">teminazione absidata</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/construction-description/auxiliaryStructuralElement -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/construction-description/auxiliaryStructuralElement">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/construction-description/ArchitecturalElement"/>
