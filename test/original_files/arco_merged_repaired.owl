        <rdfs:label xml:lang="en">Tipo di elemento architettonico</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/construction-description/ArchitecturalEnsemble -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/construction-description/ArchitecturalEnsemble">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/construction-description/ConstructionSpace"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasPart"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/construction-description/Building"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://w3id.org/arco/ontology/construction-description/Building"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta un insieme di diverse costruzioni che costituiscono una unità architettonica omogenea.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a set of different constructions that constitute an homogeneous architectural whole.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/construction-description"/>
        <rdfs:label xml:lang="en">Architectural ensemble</rdfs:label>
        <rdfs:label xml:lang="it">Complesso architettonico</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/construction-description/ArchitecturalOrder -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/construction-description/ArchitecturalOrder">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Characteristic"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta ognuno dei cinque maggiori stili classici dell&apos;architettura classificata in base allo stile delle colonne, dei capitelli, delle trabeazioni (es. tuscanico, dorico, ionico, corinzio, composito).</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents any of the five major classical styles of architecture classified by the style of columns, capitals, entablatures (i.e. Tuscan, Doric, Ionic, Corinthian, Composite).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/construction-description"/>
        <rdfs:label xml:lang="en">Architectural order</rdfs:label>
        <rdfs:label xml:lang="it">Ordine architettonico</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/construction-description/ArchitecturalSpace -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/construction-description/ArchitecturalSpace"/>
    


