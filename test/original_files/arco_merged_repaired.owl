        <rdfs:label xml:lang="en">Connection element</rdfs:label>
        <rdfs:label xml:lang="it">Elemento di collegamento</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:Class>
    


