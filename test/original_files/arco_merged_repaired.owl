        <rdfs:label xml:lang="en">Flooring type</rdfs:label>
        <rdfs:label xml:lang="it">Tipo di pavimentazione</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>Normativa A: PV/PVM/PVMG</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/construction-description/Foundation -->

