        <rdfs:comment xml:lang="it">Questo individuo rappresenta l&apos;età di un essere vivente all&apos;evento della sua morte.</rdfs:comment>
        <rdfs:comment xml:lang="en">This individual represents the age of death of a living being.</rdfs:comment>
        <rdfs:label xml:lang="en">Age of death</rdfs:label>
        <rdfs:label xml:lang="it">Età di morte</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/arco/ontology/context-description/AlternativeDating -->

    <owl:NamedIndividual rdf:about="https://w3id.org/arco/ontology/context-description/AlternativeDating"/>
    


    <!-- https://w3id.org/arco/ontology/context-description/AlternativeDesignation -->

    <owl:NamedIndividual rdf:about="https://w3id.org/arco/ontology/context-description/AlternativeDesignation">
        <rdf:type rdf:resource="https://w3id.org/arco/ontology/context-description/DesignationType"/>
        <rdfs:comment xml:lang="it">Questo individuo rappresenta una denominazione alternativa.</rdfs:comment>
        <rdfs:comment xml:lang="en">This individual represents an alternative denomination.</rdfs:comment>
        <rdfs:label xml:lang="en">Alvernative designation</rdfs:label>
        <rdfs:label xml:lang="it">Designazione alternativa</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale: OGD/OGDT - Normative A, BDM, PG 3: OGA/OGAG - Normativa BNB: OG/OGT/OGTE e OG/OGT/OGTC</a-cat:iccdNormTag>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/arco/ontology/context-description/AlternativeOrObsoleteResponsibility -->

    <owl:NamedIndividual rdf:about="https://w3id.org/arco/ontology/context-description/AlternativeOrObsoleteResponsibility">
        <rdf:type rdf:resource="https://w3id.org/arco/ontology/context-description/ResponsibilityType"/>
        <rdfs:comment xml:lang="it">Questo individuo rappresenta la responsabilità alternativa o superata di un agente su un&apos;opera.</rdfs:comment>
        <rdfs:comment xml:lang="en">This individual represents the alternative or outdated responsibility of an agent on a work.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description"/>
        <rdfs:label xml:lang="en">Alternative or outdated responsibility</rdfs:label>
        <rdfs:label xml:lang="it">Responsabilità alternativa o sorpassata</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/arco/ontology/context-description/AlternativeTitle -->

    <owl:NamedIndividual rdf:about="https://w3id.org/arco/ontology/context-description/AlternativeTitle">
        <rdf:type rdf:resource="https://w3id.org/arco/ontology/context-description/TitleType"/>
        <rdfs:comment xml:lang="it">Rappresenta un altro titolo noto del soggetto, in alternativa o in aggiunta al titolo più noto o accreditato.</rdfs:comment>
        <rdfs:comment xml:lang="en">Represents subject&apos;s alternative title.</rdfs:comment>
        <rdfs:label xml:lang="en">Alternative title</rdfs:label>
        <rdfs:label xml:lang="it">Titolo alternativo</rdfs:label>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale: DA/AID/AIDN</a-cat:iccdNormTag>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/arco/ontology/context-description/AnthropicOrigin -->

    <owl:NamedIndividual rdf:about="https://w3id.org/arco/ontology/context-description/AnthropicOrigin">
        <rdf:type rdf:resource="https://w3id.org/arco/ontology/context-description/AnomalyOrigin"/>
        <rdfs:comment xml:lang="it">Questo individuo rappresenta l&apos;origine antropica di un&apos;anomalia rilevata in un indagine di fotointerpretazione/fotorestituzione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This individual represents the anthropic origin of a photointerpretation anomaly.</rdfs:comment>
        <rdfs:label xml:lang="en">Anthropic origin</rdfs:label>
        <rdfs:label xml:lang="it">Origine antropica</rdfs:label>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale: RE/FOI/FOIA</a-cat:iccdNormTag>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/arco/ontology/context-description/ArchivalResearch -->

    <owl:NamedIndividual rdf:about="https://w3id.org/arco/ontology/context-description/ArchivalResearch">
        <rdf:type rdf:resource="https://w3id.org/arco/ontology/context-description/DetectionMethod"/>
        <rdfs:comment xml:lang="it">Questo individuo rappresenta la ricerca d&apos;archivio come modalità di individuazione e descrizione del bene.</rdfs:comment>
        <rdfs:comment xml:lang="en">This individual represents archival research as a detection mode for cultural entities.</rdfs:comment>
        <rdfs:label xml:lang="en">Archival research</rdfs:label>
        <rdfs:label xml:lang="it">Dati di archivio</rdfs:label>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale: OG/OGM</a-cat:iccdNormTag>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/arco/ontology/context-description/AssignedDesignation -->

    <owl:NamedIndividual rdf:about="https://w3id.org/arco/ontology/context-description/AssignedDesignation">
        <rdf:type rdf:resource="https://w3id.org/arco/ontology/context-description/DesignationType"/>
        <rdfs:comment xml:lang="it">Questo individuo rappresenta una denominazione attribuita.</rdfs:comment>
        <rdfs:comment xml:lang="en">This individual represents an attributed denomination.</rdfs:comment>
        <rdfs:label xml:lang="en">Assigned designation</rdfs:label>
        <rdfs:label xml:lang="it">Denominazione attribuita</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale: OGD/OGDT - Normative A, BDM, PG 3: OGA/OGAG.</a-cat:iccdNormTag>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/arco/ontology/context-description/AttachedDocumentation -->

    <owl:NamedIndividual rdf:about="https://w3id.org/arco/ontology/context-description/AttachedDocumentation">
        <rdf:type rdf:resource="https://w3id.org/arco/ontology/context-description/DocumentationCategory"/>
        <rdfs:comment xml:lang="it">Questo individuo rappresenta la definizione (vocabolario chiuso) della documentazione acclusa alla scheda di catalogo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This individual represents documenation definition included inside catalog.</rdfs:comment>
        <rdfs:label xml:lang="en">Attached documentation</rdfs:label>
        <rdfs:label xml:lang="it">Documentazione allegata</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {
?x a-cd:hasAttachedDocumentation ?doc .
}

WHERE {
?x a-cd:hasDocumentation ?doc .
?doc core:hasCategory a-cd:AttachedDocumentation .
}</core:constructQuery>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/arco/ontology/context-description/AttributedTitle -->

    <owl:NamedIndividual rdf:about="https://w3id.org/arco/ontology/context-description/AttributedTitle">
        <rdf:type rdf:resource="https://w3id.org/arco/ontology/context-description/TitleType"/>
        <rdfs:comment xml:lang="it">Rappresenta un titolo attribuito di una fotografia, cioè un titolo desunto, se possibile, da fonti archivistiche, bibliografiche, orali o iconografiche (altri esemplari della stessa immagine) oppure creato in base al contenuto dell&apos;immagine (o della serie di immagini; è necessario nei casi in cui siano del tutto assenti titoli sul/nel documento, o su materiali ad esso complementari, e nel caso in cui tali titoli risultino errati.</rdfs:comment>
        <rdfs:comment xml:lang="en">Represents an attributed title of a photograph, that is a title taken from archival, bibliographic, oral or iconographic sources, or created based on picture contents.</rdfs:comment>
        <rdfs:label xml:lang="en">Attributed title</rdfs:label>
        <rdfs:label xml:lang="it">Titolo attribuito</rdfs:label>
        <a-cat:iccdNormTag xml:lang="it">Normativa F: SG/SGL/SGLA - Normativa FF: se PA/PAC/PACG = &apos;attribuita&apos;</a-cat:iccdNormTag>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/arco/ontology/context-description/BiologicalAge -->

    <owl:NamedIndividual rdf:about="https://w3id.org/arco/ontology/context-description/BiologicalAge">
        <rdf:type rdf:resource="https://w3id.org/arco/ontology/context-description/AgeType"/>
        <rdfs:comment xml:lang="it">Questo individuo rappresenta l&apos;età biologica di un essere vivente.</rdfs:comment>
        <rdfs:comment xml:lang="en">This individual represents the biological age of a living being.</rdfs:comment>
        <rdfs:label xml:lang="en">Biological age</rdfs:label>
        <rdfs:label xml:lang="it">Età biologica</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/arco/ontology/context-description/BuildingUse -->

    <owl:NamedIndividual rdf:about="https://w3id.org/arco/ontology/context-description/BuildingUse">
        <rdf:type rdf:resource="https://w3id.org/arco/ontology/context-description/UseType"/>
        <rdfs:comment xml:lang="it">Questo individuo rappresenta le specifiche d&apos;uso edilizio di un bene.</rdfs:comment>
        <rdfs:comment xml:lang="en">This individual represents cultural entity  building use specifications.</rdfs:comment>
        <rdfs:label xml:lang="en">Building use</rdfs:label>
        <rdfs:label xml:lang="it">Uso edilizio</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/arco/ontology/context-description/ChronologicalAge -->

    <owl:NamedIndividual rdf:about="https://w3id.org/arco/ontology/context-description/ChronologicalAge">
        <rdf:type rdf:resource="https://w3id.org/arco/ontology/context-description/AgeType"/>
        <rdfs:comment xml:lang="it">Questo individuo rappresenta l&apos;età cronologica di un&apos;entità.</rdfs:comment>
        <rdfs:comment xml:lang="en">This individual represents chronological age of an enity.</rdfs:comment>
        <rdfs:label xml:lang="en">Chronological age</rdfs:label>
        <rdfs:label xml:lang="it">Età cronologica</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/arco/ontology/context-description/CivilCircumstance -->

    <owl:NamedIndividual rdf:about="https://w3id.org/arco/ontology/context-description/CivilCircumstance">
        <rdf:type rdf:resource="https://w3id.org/arco/ontology/context-description/CircumstanceType"/>
        <rdfs:comment xml:lang="it">Questo individuo rappresenta l&apos;occasione civile in cui si colloca un bene demoetnoatropologico immateriale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This individual represents the civil occasion in which an immaterial demo-ethno-atropological entity occurs.</rdfs:comment>
        <rdfs:label xml:lang="en">Civil circumstance</rdfs:label>
        <rdfs:label xml:lang="it">Occasione civile</rdfs:label>
        <a-cat:iccdNormTag>ICCD Normativa BDI: CA/CAR; CA/CAC</a-cat:iccdNormTag>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/arco/ontology/context-description/ComparativeBibliography -->

    <owl:NamedIndividual rdf:about="https://w3id.org/arco/ontology/context-description/ComparativeBibliography">
        <rdf:type rdf:resource="https://w3id.org/arco/ontology/context-description/BibliographyCategory"/>
        <rdfs:comment xml:lang="it">Questo individuo rappresenta la definizione (vocabolario chiuso) relativa al genere di bibliografia utilizzata per confronti (stilistici, tipologici, ecc.).</rdfs:comment>
        <rdfs:comment xml:lang="en">This individual represents the definition relative to the kind of bibliography used for comparisons.</rdfs:comment>
        <rdfs:label xml:lang="it">Bibliografia di confronto</rdfs:label>
        <rdfs:label xml:lang="en">Comparative bibliography</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {
?x a-cd:hasComparativeBibliographicSource ?ed .
}

WHERE {
?x a-cd:hasBibliography ?bib .
?bib a-cd:hasCategory ?bibCat ;
a-cd:hasEdition ?ed .
?bibCat a a-cd:ComparativeBibliography .
}</core:constructQuery>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/arco/ontology/context-description/CoordinatedResponsibility -->

    <owl:NamedIndividual rdf:about="https://w3id.org/arco/ontology/context-description/CoordinatedResponsibility">
        <rdf:type rdf:resource="https://w3id.org/arco/ontology/context-description/ResponsibilityType"/>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/onology/context-description"/>
        <rdfs:isDefinedBy xml:lang="it">Questo individuo rappresenta la responsabilità coordinata che condividono più agenti su una stessa opera. Nello standard UNIMARC viene denominata &quot;alternative responsibility&quot;.</rdfs:isDefinedBy>
        <rdfs:isDefinedBy xml:lang="en">This individual represents a coordinated responsibility of multiple agents that they share on the same work. In the UNIMARC standard it is called &quot;alternative responsibility&quot;.</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Coordinated responsibility</rdfs:label>
        <rdfs:label xml:lang="it">Responsabilità coordinata</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/arco/ontology/context-description/CosmicRayExposureAge -->

    <owl:NamedIndividual rdf:about="https://w3id.org/arco/ontology/context-description/CosmicRayExposureAge">
        <rdf:type rdf:resource="https://w3id.org/arco/ontology/context-description/AgeType"/>
        <rdfs:comment xml:lang="it">Questo individuo rappresenta l&apos;età di esposizione ai raggi cosmici (CREA).</rdfs:comment>
        <rdfs:comment xml:lang="en">This individual represents the cosmic ray exposure age (CREA).</rdfs:comment>
        <rdfs:label xml:lang="en">Cosmic ray exposure age</rdfs:label>
        <rdfs:label xml:lang="it">Età di esposizione ai raggi cosmici</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normative BNPL: SP/SPD/SPDX</a-cat:iccdNormTag>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/arco/ontology/context-description/CurrentUse -->

    <owl:NamedIndividual rdf:about="https://w3id.org/arco/ontology/context-description/CurrentUse">
        <rdf:type rdf:resource="https://w3id.org/arco/ontology/context-description/UseType"/>
        <rdfs:comment xml:lang="it">Questo individuo rappresenta l&apos;uso attuale di un bene.</rdfs:comment>
        <rdfs:comment xml:lang="en">This individual represents cultural entity current use.</rdfs:comment>
        <rdfs:label xml:lang="en">Current use</rdfs:label>
        <rdfs:label xml:lang="it">Uso attuale</rdfs:label>
