    <!-- https://w3id.org/arco/ontology/context-description/isLaboratoryTestTypeOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isLaboratoryTestTypeOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isTypeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/LaboratoryTestType"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/LaboratoryTest"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega il tipo di analisi di laboratorio (es.: analisi metallurgica, analisi chimica, etc.) con la relativa analisi.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the laboratory test type (i.e. chemical or metallurgical analysis) to the related laboratory test.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is laboratory test type of</rdfs:label>
        <rdfs:label xml:lang="it">è tipo di analisi di laboratorio di</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {
?type core:isTypeOf ?thing .
}

WHERE {
?type a-cd:isLaboratoryTestTypeOf ?thing .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/isTypeOf"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isLegalSituationOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isLegalSituationOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isEventOrSituationInTimeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/LegalSituation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una condizione giuridica a un&apos;entità che si trova in quella condizione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a legal situation to an entity that is in that situation.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is legal situation of</rdfs:label>
        <rdfs:label xml:lang="it">è condizione giuridica di</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: TU/CDG. - RP/LGC/LGCO. LS/CSS/CSSP. - CS/CTS/CTSP</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isLicenseOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isLicenseOf">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/License"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una licenza d&apos;uso ad un&apos;entità.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a license to an entity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is license of</rdfs:label>
        <rdfs:label xml:lang="it">è licenza di</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa SCAN: DO/DCM/DCML</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isLocatedIn -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isLocatedIn">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/hasRelatedWork"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/isLocationOf"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un bene culturale a un altro bene culturale collegato, che ne costituisce il luogo di collocazione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural entity to a connected cultural entity which constitutes its location area.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">ha luogo di collocazione</rdfs:label>
        <rdfs:label xml:lang="en">is located in</rdfs:label>
        <rdfs:label xml:lang="it">è contenuto in</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale 4.00: RV/RSE/RSER = &apos;è contenuto in&apos; (versioni precedenti: &apos;luogo di collocazione/localizzazione&apos;; &apos;scheda contenitore&apos;)</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?x a-lite:isLocatedIn ?y .
}

WHERE {
?x a-cd:isLocatedIn ?y .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/isLocatedIn"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isLocationOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isLocationOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/isWorkRelatedTo"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:comment xml:lang="it">Questa proprietà, inversa di &apos;is located in&apos;, collega un bene culturale a un altro bene culturale collegato, che costituisce il luogo di collocazione del primo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property, inverse of &apos;is located in&apos;, relates a cultural entity to a connected cultural entity, which constitutes its location area.</rdfs:comment>
        <rdfs:comment>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?cult a-lite:isLocationOf ?cultsec .
}

WHERE {
?cult a-cd:isLocationOf ?cultsec .
}</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is location of</rdfs:label>
        <rdfs:label xml:lang="it">è luogo di collocazione di</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/isLocationOf"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isMemberInvolvedIn -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isMemberInvolvedIn">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/CollectionMembership"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un bene culturale mobile alla classe che rappresenta l&apos;appartenenza del bene culturale a una collezione in un certo intervallo di tempo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural property to the class that represents the membership relation between this cultural property and a collection.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is member involved in</rdfs:label>
        <rdfs:label xml:lang="it">è membro coinvolto in</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isMemberOfArchivalRecordSetOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isMemberOfArchivalRecordSetOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/isMemberOfCollectionOf"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/ArchivalRecordSetMembership"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un bene culturale alla classe che rappresenta l&apos;appartenenza del bene a una unità archivistica complessa.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural property to the class that represents the membership relation between this cultural property and an archival record set.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/contex-description"/>
        <rdfs:label xml:lang="en">is member of archival record set of</rdfs:label>
        <rdfs:label xml:lang="it">è membro di un&apos;unità archivistica complessa di</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa F: UB/UBF</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;http://w3id.org/arco/ontology/arco-lite/&gt;
CONSTRUCT {
?cp a-lite:isCollectionMemberOf ?coll .
}

WHERE {
?cp a-cd:isCoinMemberOf ?coll .
}</core:constructQuery>
        <core:constructQuery>prefix a-lite: &lt;http://w3id.org/arco/ontology/arco-lite/&gt;
CONSTRUCT {
?cp a-lite:isCollectionMemberOf ?coll .
}

WHERE {
?cp a-cd:isMemberOfArchivalRecordSet ?coll .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/isCollectionMemberOf"/>
    </owl:ObjectProperty>
    


