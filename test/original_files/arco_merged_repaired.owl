        <rdfs:comment xml:lang="en">This individual represents the relative age of a paleontological cultural entity.</rdfs:comment>
        <rdfs:label xml:lang="it">Età relativa</rdfs:label>
        <rdfs:label xml:lang="en">Relative age</rdfs:label>
        <a-cat:iccdNormTag>Normativa ICCD BNPE: SR/SRL/SRLE</a-cat:iccdNormTag>
    </owl:NamedIndividual>
    


