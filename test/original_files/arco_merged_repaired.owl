        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="it">Questa proprietà indica se un elemento della costruzione è originale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents a original construction element.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/construction-description"/>
        <rdfs:label xml:lang="it">elemento originale</rdfs:label>
        <rdfs:label xml:lang="en">original element</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/construction-description/overlooking -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/construction-description/overlooking">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/construction-description/Facade"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa propiretà indica l&apos;affaccio della facciata dell&apos;edificio che si sta descrivendo</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a facade with the view it overlooks.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/construction-description"/>
        <rdfs:label xml:lang="it">affaccio</rdfs:label>
        <rdfs:label xml:lang="en">overlooking</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/construction-description/refersToFloorOrLevel -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/construction-description/refersToFloorOrLevel">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/construction-description/Construction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta il piano o la quota (m., cm.) del livello a cui si riferisce la pianta che
viene descritta.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the floor or the quote of the construction design.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/construction-description"/>
        <rdfs:label xml:lang="en">refers to floor or level</rdfs:label>
        <rdfs:label xml:lang="it">riferimento a piano o quota</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>PN/PNT/PNTQ</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/construction-description/significantIconographicInformation -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/construction-description/significantIconographicInformation">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/construction-description/Construction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la presenza e il numero di eventuali elementi icnografici significativi.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents iconographic information about the construction design.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/construction-description"/>
        <rdfs:label xml:lang="it">informazioni iconografiche significative</rdfs:label>
        <rdfs:label xml:lang="en">significant iconographic information</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>PN/PNT/PNTE</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/construction-description/spatialLocation -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/construction-description/spatialLocation">
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la collocazione delle scale in rapporto alla tipologia dell&apos;edificio.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the spatial location of a stair.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/construction-description"/>
        <rdfs:label xml:lang="it">riferimento spaziale</rdfs:label>
        <rdfs:label xml:lang="en">spatial location</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/construction-description/symmetrical -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/construction-description/symmetrical">
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="it">Questa proprietà indica se la costruzione è simmetrica</rdfs:comment>
        <rdfs:comment xml:lang="en">This property indicates whether the construction is symmetrical</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/construction-description"/>
        <rdfs:label xml:lang="it">simmetrica</rdfs:label>
        <rdfs:label xml:lang="en">symmetrical</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/construction-description/transeptPrecence -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/construction-description/transeptPrecence">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/construction-description/PlanimetricDevelopment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="it">Questa proprietà indica se è presente un transetto</rdfs:comment>
        <rdfs:comment xml:lang="en">This property indicates whether there is a transept</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/construction-description"/>
        <rdfs:label xml:lang="en">presenza del transetto</rdfs:label>
        <rdfs:label xml:lang="it">transept presente</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/construction-description/withoutOpening -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/construction-description/withoutOpening">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/construction-description/Construction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta una costruzione cieca</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents a construction without openings</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/construction-description"/>
        <rdfs:label xml:lang="it">cieca</rdfs:label>
        <rdfs:label xml:lang="it">cieco</rdfs:label>
        <rdfs:label xml:lang="en">withoutOpening</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/RCSReason -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/RCSReason">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/CurrentInventory"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta il codice della causale RCS (Ragioneria Centrale dello Stato) di aumento o diminuzione del valore del bene.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the code of the RCS causal (Central State Accounting Office) of increasing or decreasing property value.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">RCS reason</rdfs:label>
        <rdfs:label xml:lang="it">causale RCS</rdfs:label>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: UB/INP/INPU</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/abbreviation -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/abbreviation">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Edition"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment></rdfs:comment>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta l&apos;abbreviazione che identifica il riferimento bibliografico.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the abbreviation that identifies the bibliographic reference.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">abbreviation</rdfs:label>
        <rdfs:label xml:lang="it">abbreviazione</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">BIBR</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/acquisitionCost -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/acquisitionCost">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Acquisition"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta il costo di acquisizione</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the acquisition cost</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">acquisition cost</rdfs:label>
        <rdfs:label xml:lang="it">costo di acquisizione</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: TU/ACQ/ACQC</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/acquisitionLocation -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/acquisitionLocation">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Acquisition"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta il luogo in cui è avvenuto un evento di acquisizione, generalmente espresso, in base ai dati disponibili, nella forma: &quot;Regione/sigla provincia/denominazione per esteso del Comune/località o toponimo&quot;</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the place where an acquisition event, generally expressed, based on the available data, took place, in the form: &quot;Region / abbreviation province / full name of the Municipality / locality or toponym&quot;</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">acquisition location</rdfs:label>
        <rdfs:label xml:lang="it">luogo di acquisizione</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: TU/ACQ/ACQL. BDI: DU/DUQ/DUQL</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/activityPlaceAndPeriod -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/activityPlaceAndPeriod">
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta il luogo e il periodo di attvità di un autore.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the place and the period of activity of an author.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">activity place and period</rdfs:label>
        <rdfs:label xml:lang="it">luogo e periodo di attività</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa AUT: AU/AUT/AUTG</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/address -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/address">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/contacts"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta l&apos;indirizzo di riferimento di un agente (persona, organizzazione), inteso come un tipo specifico di contatto presso il quale l&apos;agente è reperibile.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents a specific type of contact at which the agent is available.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">address</rdfs:label>
        <rdfs:label xml:lang="it">indirizzo</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: TU/CDG/CDGI, TU/CPR/CPRI</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/age -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/age">
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega la situazione sull&apos;età di un bene al valore numerico dell&apos;età.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an age situation of a cultural property to the age value.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">age</rdfs:label>
        <rdfs:label xml:lang="it">età</rdfs:label>
        
        <core:constructQuery>CONSTRUCT {
?sit a-cd:ageValue ?age .
}

WHERE {
?sit a-cd:age ?age .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/ageValue"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/ageOfDeath -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/ageOfDeath">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/AgeOfDeathInterpretation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta l&apos;età della morte stimata nel contesto della stima dell&apos;età della morte di un reperto antropologico.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents an anthropological finding estimated age of death.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">estimated age of death</rdfs:label>
        <rdfs:label xml:lang="it">età della morte stimata</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>DA/SEM/SEME</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?sit a-cd:ageValue ?age . 
}

WHERE {
?sit a-cd:estimatedAgeOfDeath ?age .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/age"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/ageValue -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/ageValue">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/AgeInterpretation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta l&apos;età di un campione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the age of a specimen.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">age</rdfs:label>
        <rdfs:label xml:lang="it">età</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>DA/SEM/SEME</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/agentDate -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/agentDate">
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà permette di associare delle indicazioni cronologiche generiche (le date di nascita e di morte o, quando queste sono ignote, le date di attività), anche sotto forma testuale, a un agente.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property allows you to associate generic chronological indications to an agent.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">agent date</rdfs:label>
        <rdfs:label xml:lang="it">indicazioni cronologiche relative a un agente</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>AU/AUT/AUTA</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/agentLocalIdentifier -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/agentLocalIdentifier">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/catalogue/localIdentifier"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta il codice identificativo, che individua il riferimento autoriale in modo univoco nell&apos;ambito di un repertorio locale, di un agente, per esempio di un autore di un bene culturale o di un agente che riveste una responsabilità nei confronti del bene (es.: editore, stampatore, etc.).</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the identification code, which identifies the author&apos;s reference unambiguously in the context of a local repertoire, of an agent.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">agent local identifier</rdfs:label>
        <rdfs:label xml:lang="it">codice identificativo locale dell&apos;agente</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: AU/AUT/AUTH - ICCD Normativa F 4.00: RO/CRF/CRFX; PD/PDF/PDFH - ICCD Normativa F 3.00: RO/CRF/CRFH</a-cat:iccdNormTag>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/local-identifier"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/alternativeName -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/alternativeName">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/name"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta una variante del nome di un agente.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents an alternative name of an agent.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">alternative name</rdfs:label>
        <rdfs:label xml:lang="it">variante del nome</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa AUT: AU/AUT/AUTE, AUTV. AU/AUV</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/alternativeTitle -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/alternativeTitle">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/title"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta un altro titolo noto del soggetto, in alternativa o in aggiunta al titolo più noto o accreditato.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents an entity&apos;s alternative title.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">alternative title</rdfs:label>
        <rdfs:label xml:lang="it">titolo alternativo</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale: DA/AID/AIDN</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt;

CONSTRUCT {
?cp a-lite:alternativeTitle ?title .
}

WHERE {
?cp a-cd:alternativeTitle ?title .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/alternativeTitle"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/archaeologicalExcavationICCDIdentifier -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/archaeologicalExcavationICCDIdentifier">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/catalogue/ICCDIdentifier"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/ArchaeologicalExcavation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta il codice, assegnato dall&apos;ICCD, che individua lo scavo archeologico in modo univoco a livello nazionale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the code, assigned by the ICCD, which identifies the archaeological excavation unequivocally at national level.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">archaeological excavation ICCD identifier</rdfs:label>
        <rdfs:label xml:lang="it">codice univoco ICCD dello scavo archeologico</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: RE/DSC/DSCK</a-cat:iccdNormTag>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/ICCDIdentifier"/>
        <core:replacingQuery>CONSTRUCT {
?thing a-lite:ICCDIdentifier ?id .
}

WHERE {
?thing a-cd:archaeologicalExcavationICCDIdentifier ?id .
}</core:replacingQuery>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/archaeologicalExcavationLocalIdentifier -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/archaeologicalExcavationLocalIdentifier">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/catalogue/localIdentifier"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/ArchaeologicalExcavation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="en">Questa proprietà rappresenta il codice identificativo, numerico o alfanumerico, che individua lo scavo archeologico in modo univoco nell&apos;ambito di un repertorio locale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the identification code, numeric or alphanumeric, which identifies the archaeological excavation unambiguously in the context of a local repertoire.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">archaeological excavation local identifier</rdfs:label>
        <rdfs:label xml:lang="it">codice identificativo locale dello scavo archeologico</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: RE/DSC/DSCH</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?thing a-lite:localIdentifier ?id .
}

WHERE {
?thing a-cd:archaeologicalExcavationLocalIdentifier ?id .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/localIdentifier"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/archaeologicalFieldSurveyICCDIdentifier -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/archaeologicalFieldSurveyICCDIdentifier">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/catalogue/ICCDIdentifier"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/ArchaeologicalFieldSurvey"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta il codice, assegnato dall&apos;ICCD, che individua il la ricognizione archeologica in modo univoco a livello nazionale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the code, assigned by the ICCD, which identifies the field survey unequivocally at national level.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">archaeological field survey ICCD identifier</rdfs:label>
        <rdfs:label xml:lang="it">codice univoco ICCD della ricognizione archeologica</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: RE/RCG/RCGK</a-cat:iccdNormTag>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/ICCDIdentifier"/>
        <core:replacingQuery>CONSTRUCT {
?thing a-lite:ICCDIdentifier ?id .
}

WHERE {
?thing a-cd:archaeologicalFieldSurveyICCDIdentifier ?id .
}</core:replacingQuery>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/archaeologicalFieldSurveyLocalIdentifier -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/archaeologicalFieldSurveyLocalIdentifier">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/catalogue/localIdentifier"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/ArchaeologicalFieldSurvey"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta il codice identificativo, numerico o alfanumerico, che individua la ricognizione archeologica in modo univoco nell&apos;ambito di un repertorio locale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the identification code, numeric or alphanumeric, which identifies the field survey unambiguously in the context of a local repertoire.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">archaeological field survey local identifier</rdfs:label>
        <rdfs:label xml:lang="it">codice identificativo locale della ricognizione archeologica</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: RE/RCG/RCGH, NUNC</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?thing a-lite:localIdentifier ?id .
}

WHERE {
?thing a-cd:archaeologicalFieldSurveyLocalIdentifier ?id .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/localIdentifier"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/archivalRecordIdentifier -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/archivalRecordIdentifier">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/identifier"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/ArchivalRecord"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta l&apos;identificativo di un&apos;unità documentaria.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the identifier of an archival record.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">archival record identifier</rdfs:label>
        <rdfs:label xml:lang="it">identificativo di unità documentaria</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa FF: PA/PAC/PACI; PA/PAC/PACA</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt;

CONSTRUCT  { ?doc a-lite:localIdentifier ?id .
}

WHERE 
      { ?doc a-cd:archivalRecordIdentifier ?id .
 }</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/hasIdentifier"/>
        <core:replacingQuery>select * {
?rec core:hasIdentifier ?NEWIdentifier .
?NEWIdentifier core:hasType core:LocalIdentifer ;
l0:identifier ?id .
}</core:replacingQuery>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/archivalRecordLocation -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/archivalRecordLocation">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/ArchivalRecordSetMembership"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la collocazione di un&apos;unità documentaria all&apos;interno di un&apos;unità archivistica complessa.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the location of a documentary unit within a complex archival unit.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">archival record location</rdfs:label>
        <rdfs:label xml:lang="it">collocazione di unità documentaria</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa F: UB/UBF/UBFC</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?doc l0:positionInSequence ?id .
}

WHERE {
?doc a-cd:archivalRecordLocation ?id .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/italia/onto/l0/positionInSequence"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/archivalRecordSetIdentifier -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/archivalRecordSetIdentifier">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/identifier"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/ArchivalRecordSet"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta l&apos;identificativo di un&apos;unità archivistica complessa.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the identifier of an archival record set.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">archival record set identifier</rdfs:label>
        <rdfs:label xml:lang="it">identificativo di unità archivistica complessa</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa FF: PA/PAC/PACI; PA/PAC/PACA</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt;

CONSTRUCT  { ?doc a-lite:localIdentifier ?id .
}

WHERE 
      { ?doc a-cd:archivalRecordSetIdentifier ?id .
 }</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/hasIdentifier"/>
        <core:replacingQuery>select * {
?set core:hasIdentifier ?NEWIdentifier .
?NEWIdentifier core:hasType core:LocalIdentifer ;
l0:identifier ?id .
}</core:replacingQuery>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/archivalRecordSetTitle -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/archivalRecordSetTitle">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/CollectionMembership"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta il titolo dell&apos;unità archivistica complessa (fondo, serie, sottoserie, etc.) in cui si trova un&apos;unità documentaria.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the title of the archival record set in which a documentary unit is located.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">archival record set title</rdfs:label>
        <rdfs:label xml:lang="it">titolo di unità archivistica complessa</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa F: UB/UBF/UBFU</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/areaRoomSquare -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/areaRoomSquare">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/ArchaeologicalExcavation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega uno scavo archeologico alla successione delle denominazioni, assegnate nell&apos;ambito dello scavo, al settore (o
l&apos;area), all&apos;ambiente e al quadrato da cui proviene il bene.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an archaeological excavation to the succession of the denominations, assigned in the excavation, to the sector (or
the area), to the environment and to the square from which the good comes.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">area room square</rdfs:label>
        <rdfs:label xml:lang="it">settore ambiente quadrato</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: RE/DSC/DSCQ</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/attributedTitle -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/attributedTitle">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/title"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta un titolo attribuito di una fotografia, cioè un titolo desunto, se possibile, da fonti archivistiche, bibliografiche, orali o iconografiche (altri esemplari della stessa immagine) oppure creato in base al contenuto dell&apos;immagine (o della serie di immagini; è necessario nei casi in cui siano del tutto assenti titoli sul/nel documento, o su materiali ad esso complementari, e nel caso in cui tali titoli risultino errati.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents an attributed title of a photograph, that is a title taken from archival, bibliographic, oral or iconographic sources, or created based on picture contents.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">attributed title</rdfs:label>
        <rdfs:label xml:lang="it">titolo attribuito</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>Normativa F: SG/SGL/SGLA</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt;

CONSTRUCT {
?cp a-lite:attributedTitle ?title .
}

WHERE {
?cp a-cd:attributedTitle ?title .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/attributedTitle"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/authorICCDIdentifier -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/authorICCDIdentifier">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/catalogue/ICCDIdentifier"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà permette di associare il codice univoco ICCD a un autore.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property allows you to associate the unique ICCD code with an author.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">author ICCD identifier</rdfs:label>
        <rdfs:label xml:lang="it">codice univoco ICCD dell&apos;autore</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: AU/AUT/AUTK</a-cat:iccdNormTag>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/ICCDIdentifier"/>
        <core:replacingQuery>CONSTRUCT {
?thing a-lite:ICCDIdentifier ?id .
}

WHERE {
?thing a-cd:authorICCDIdentifier ?id .
}</core:replacingQuery>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/authorIntervention -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/authorIntervention">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/arco/ontology/context-description/AlternativeAuthorshipAttribution"/>
                    <rdf:Description rdf:about="https://w3id.org/arco/ontology/context-description/PreferredAuthorshipAttribution"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta specifiche relative all&apos;intervento effettuato dall&apos;autore sul bene culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents specifications relating to the intervention carried out by the author on the cultural property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">author intervention</rdfs:label>
        <rdfs:label xml:lang="it">intervento dell&apos;autore</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>AU/AUT/AUTY</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?res a-cd:specifications ?int . 
}

WHERE {
?res a-cd:authorIntervention ?int .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/specifications"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/bibliographicReferenceAuthor -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/bibliographicReferenceAuthor">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Bibliography"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta l&apos;autore relativo al riferimento bibliografico.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the author related to the bibliographic reference.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">autore del riferimento bibliografico</rdfs:label>
        <rdfs:label xml:lang="en">bibliographic reference author</rdfs:label>
        
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>DO/BIB/BIBA</a-cat:iccdNormTag>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasAuthor"/>
        <core:replacingQuery>select * where {
?bib core:hasAgentRole ?NEWagentRole .
?NEWagentRole core:hasRole ?NEWrole ;
core:hasAgent ?agent .
}</core:replacingQuery>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/bibliographicReferenceDate -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/bibliographicReferenceDate">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/TI/date"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Bibliography"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la data relativa al riferimento bibliografico.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the date of publication related to the bibliographic reference.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">bibliographic reference date</rdfs:label>
        <rdfs:label xml:lang="it">data del riferimento bibliografico</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>DO/BIB/BIBD</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/bibliographyICCDIdentifier -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/bibliographyICCDIdentifier">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/catalogue/ICCDIdentifier"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Bibliography"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta il codice, assegnato dall&apos;ICCD, che individua il riferimento bibliografico in modo univoco a livello nazionale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the code, assigned by the ICCD, which identifies the bibliographic reference uniquely at national level.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">bibliography ICCD identifier</rdfs:label>
        <rdfs:label xml:lang="it">codice univoco ICCD della bibliografia</rdfs:label>
        <owl:deprecated rdf:resource="https://w3id.org/arco/ontology/arco-lite/ICCDIdentifier"/>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: DO/BIB/BIBK</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?thing a-lite:ICCDIdentifier ?id .
}

WHERE {
?thing a-cd:bibliographyICCDIdentifier ?id .
}</core:constructQuery>
        <core:replacingQuery>select * {
?doc core:hasIdentifier ?NEWIdentifier .
?NEWIdentifier core:hasType core:LocalIdentifer ;
l0:identifier ?id .
}</core:replacingQuery>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/bibliographyLocalIdentifier -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/bibliographyLocalIdentifier">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/catalogue/localIdentifier"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Bibliography"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta una sequenza numerica o alfanumerica che identifica il riferimento bibliografico in modo univoco nell&apos;ambito di un repertorio locale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents a numerical or alphanumeric sequence that uniquely identifies the bibliographic reference within a local repertoire.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">bibliography local identifier</rdfs:label>
        <rdfs:label xml:lang="it">codice identificativo locale della bibliografia</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: DO/BIB/BIBH</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt;

CONSTRUCT {
?edi a-lite:localIdentifier ?id .
}

WHERE {
?edi a-cd:bibliographyLocalIdentifier ?id .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/localIdentifier"/>
        <core:replacingQuery>select * {
?edi core:hasIdentifier ?NEWIdentifier .
?NEWIdentifier core:hasType core:LocalIdentifer ;
l0:identifier ?id .
}</core:replacingQuery>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/bilbiographicReference -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/bilbiographicReference">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Bibliography"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta il riferimento bibliografico.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the bibliographic reference.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">bibliographic reference</rdfs:label>
        <rdfs:label xml:lang="it">riferimento bibliografico</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>DO/BIB/BIBA e DO/BIB/BIBD</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/caption -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/caption">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/PhotographicDocumentation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta una sintetica didascalia, se presente e utile alla comprensione di quanto documentato.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents a synthetic caption, useful for understanding what is documented.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">caption</rdfs:label>
        <rdfs:label xml:lang="it">didascalia</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">FNTN</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/claySpecifications -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/claySpecifications">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/specifications"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/LaboratoryTest"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta le specifiche su eventuali componenti significativi per lo studio del bene, nel caso di analisi su reperti in argilla.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents specifications on any significant components for the study of the entity, in case of analysis on clay findings.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">clay specifications</rdfs:label>
        <rdfs:label xml:lang="it">specifiche su pasta/argilla</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>RS/ALB/ALBA. CO/ALB/ALBA</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/collectionIdentifier -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/collectionIdentifier">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/identifier"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CollectionCulEnt"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta il codice identificativo di una collezione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the collection identifier.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">codice della collezione</rdfs:label>
        <rdfs:label xml:lang="en">collection identifier</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt;

CONSTRUCT  { ?doc a-lite:localIdentifier ?id .
}

WHERE 
      { ?doc a-cd:collectionIdentifier ?id .
 }</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/hasIdentifier"/>
        <core:replacingQuery>select * {
?coll core:hasIdentifier ?NEWIdentifier .
?NEWIdentifier core:hasType core:LocalIdentifer ;
l0:identifier ?id .
}</core:replacingQuery>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/collectionLeavingReason -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/collectionLeavingReason">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/CollectionMembership"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta il motivo che ha determinato l&apos;uscita da una collezione di un bene culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the reason that led a cultural entity to the exit from a collection.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">collection leaving reason</rdfs:label>
        <rdfs:label xml:lang="it">motivo di uscita dalla collezione</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>UB/COL/COLM</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/collectionUnitIdentifier -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/collectionUnitIdentifier">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/identifier"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta il codice d&apos;inventario attribuito al bene nella collezione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the inventory code assigned to the cultural entity inside a collection.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">codice inventario bene in collezione</rdfs:label>
        <rdfs:label xml:lang="en">collection unit inventory identifier</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>UB/COL/COLI. OG/QNT/QNTO. Normativa BDI: VIRN, DURN, DUSN
AIRN, AISN. Normativa F: PD/SFI/SFIN, SSIN</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt;

CONSTRUCT  { ?doc l0:positionInSequence ?id .
}

WHERE 
      { ?doc a-cd:collectionUnitIdentifier ?id .
 }</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/italia/onto/l0/positionInSequence"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/completeBibliographicReference -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/completeBibliographicReference">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Edition"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta il riferimento bibliografico completo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the complete bibliographic reference.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">complete bibliographic reference</rdfs:label>
        <rdfs:label xml:lang="it">riferimento bibliografico completo</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale 4.00: DO/BIB/BIBM; RE/RCG/RCGS - versioni precedenti: DO/BIL</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/contacts -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/contacts">
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta i contatti di riferimento di un agente (persona, organizzazione), es. indirizzo, numeri di telefono e di fax, indirizzi di posta elettronica, ecc.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents contacts of an agent (i.e. email, telephone number...)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">contacts</rdfs:label>
        <rdfs:label xml:lang="it">contatti</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa SM 4.00: OS/OSE</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/culturalPropertyInventoryDescription -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/culturalPropertyInventoryDescription">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Inventory"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la descrizione patrimoniale del bene, con riferimento a quanto inserito nel modello 15 RCS a cura dell&apos;ente competente per tutela. Il dato viene richiesto direttamente agli uffici di catalogo/inventario dei relativi Istituti.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents a cultural entity inventory description.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">cultural property inventory description</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: UB/INP/INPD</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?x core:description ?y .
}

WHERE {
?x a-cd:culturalPropertyInventoryDescription ?y .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/description"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/depiction -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/depiction">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;entità all&apos;uri della sua rappresentazione grafica</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an entity to the uri of its graphic representation</rdfs:comment>
        <rdfs:label xml:lang="en">depiction</rdfs:label>
        <rdfs:label xml:lang="it">rappresentazione</rdfs:label>
        
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt;

CONSTRUCT {
?thing a-lite:depiction ?uri .
}

WHERE {
?thing a-cd:depiction ?uri .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/depiction"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/derivatedWorkLocation -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/derivatedWorkLocation">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/DerivatedWork"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la localizzazione geografica e collocazione specifica dell&apos;opera derivata dal bene culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents derivated work&apos;s geographical and specific location.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">collocazione dell&apos;opera derivata</rdfs:label>
        <rdfs:label xml:lang="en">derivated work location</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normative F, RA, SMO, PST, S, OAC, OA, MI, D, NU: RO/ROF/ROFC - Normativa S: RO/COP/COPC - Normativa F: RO/CRF/CRFC</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?work a-cd:relatedWorkLocation ?loc .
}

WHERE {
?work a-cd:derivatedWorkLocation ?loc .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/relatedWorkLocation"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/diagnosis -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/diagnosis">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/PaleopathologySurvey"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la diagnosi di una paleopatologia di un reperto antropologico.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the diagnosis of an anthropological finding paleopathology.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">diagnosi</rdfs:label>
        <rdfs:label xml:lang="en">diagnosis</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa AT: PT/PTC/PTCD</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-spe: &lt;https://w3id.org/arco/ontology/natural-specimen-description/&gt;

CONSTRUCT {
?cp a-spe:diagnosis ?diag .
}

WHERE {
?cp a-cd:diagnosis ?diag .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/natrual-specimen-description/diagnosis"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/digitalFilename -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/digitalFilename">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/name"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Documentation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta il nome del file digitale che riproduce il documento, nel caso della documentazione allegata alla scheda di catalogo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the name of the digital file that reproduces the document.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">digital filename</rdfs:label>
        <rdfs:label xml:lang="it">nome del file digitale</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">FTAK, DRAK, VDCK, REGK, FNTK</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/documentationIdentifier -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/documentationIdentifier">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/identifier"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Documentation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta una sequenza numerica o alfanumerica che identifica la scheda a cui il documento si riferisce.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents a numeric or alphanumeric sequence that identifies the record to which the document refers.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">codice identificativo della documentazione</rdfs:label>
        <rdfs:label xml:lang="en">documentation identifier</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: DO/FTA/FTAN; DO/DRA/DRAN; DO/VDC/VDCN; DO/REG/REGN; DO/FNT/FNTI</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt;

CONSTRUCT  { ?doc a-lite:localIdentifier ?id .
}

WHERE 
      { ?doc a-cd:documentationIdentifier ?id .
 }</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/hasIdentifier"/>
        <core:replacingQuery>select * {
?doc core:hasIdentifier ?NEWidentifier .
?NEWidentifier core:hasType core:LocalIdentifer ;
l0:identifier ?id .
}</core:replacingQuery>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/documentationLocation -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/documentationLocation">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Documentation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la collocazione del documento, che può anche essere espressa per mezzo della collocazione inventariale o dell&apos;identificativo (numerico o alfanumerico) della fonte o del documento.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents document location, which can also be expressed by inventory location or identifier.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">collocazione della documentazione</rdfs:label>
        <rdfs:label xml:lang="en">documentation location</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: DO/FTA/FTAC, DO/DRA/DRAC, DO/VDC/VDCC, DO/REG/REGC, DO/FNT/FNTS</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/documentationTitle -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/documentationTitle">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Documentation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta il titolo o la denominazione del documento.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents document title or denomination.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">documentation title</rdfs:label>
        <rdfs:label xml:lang="it">titolo della documentazione</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">FTAM, DRAM, VDCA, REGZ, FNTT</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/editionLocation -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/editionLocation">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Edition"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta il luogo dell&apos;edizione di un&apos;opera.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents work&apos;s edition place.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">edition location</rdfs:label>
        <rdfs:label xml:lang="it">luogo dell&apos;edizione</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normative VeAC e AT 3.01: DO/BSE/BSEL. Normative MI, S, OAC: AU/EDT/EDTL. Normativa F: PD/PDF/PDFL</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/environmentalState -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/environmentalState">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/ArchaeologicalFieldSurvey"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una ricognizione archeologica alla situazione ambientale al momento della ricognizione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an archaeological survey to environmental situation.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">environmental state</rdfs:label>
        <rdfs:label xml:lang="it">situazione ambientale</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: RE/RCG/RCGT - Versioni precedenti: RE/RCG/RCGU + RE/RCG/RCGC</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/estimatedCulturalPropertyValue -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/estimatedCulturalPropertyValue">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/estimatedValue"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/CulturalPropertyEstimate"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta il valore economico di un bene culturale. Nel caso di una collezione, questa proprietà rappresenta il valore del bene desunto, quando presente, dall&apos;inventario della collezione o dal suo prezzo di acquisto o vendita. Nel caso di un inventario patrimoniale, questa proprietà rappresenta la stima patrimoniale del bene. Il valore viene preceduto dalla specifica della valuta.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents cultural entity&apos;s economic value.. The value is preceded by the currency specification.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">cultural property value</rdfs:label>
        <rdfs:label xml:lang="it">valore del bene culturale</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: UB/COL/COLV; UB/INP/INP/INPA; UB/STI</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?cp a-cd:culturalPropertyValue ?val .
}

WHERE {
?cp a-cd:estimatedValue ?val .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/estimatedValue"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/estimatedValue -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/estimatedValue">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Estimate"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta il valore stimato durante il processo di stima di un&apos;entità.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the value estimated in the context of an estimate process.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">estimated value</rdfs:label>
        <rdfs:label xml:lang="it">valore stimato</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: UB/COL/COLV; UB/INP/INP/INPA; UB/STI</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/expired -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/expired">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Copyright"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="it">Questa proprietà indica se il copyright di un&apos;entità è scaduto o meno.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the expired copyright of an entity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">expired</rdfs:label>
        <rdfs:label xml:lang="it">scaduto</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/expiryDate -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/expiryDate">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/TI/time"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta una data di scadenza, per esempio la data di scadenza dei diritti d&apos;autore su un oggetto (come un bene culturale).</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents an expiration date.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">data di scadenza</rdfs:label>
        <rdfs:label xml:lang="en">expiry date</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa F 4.00 e OAC: TU/CPR/CPRD. AD/ADS/ADSD</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/explanationNote -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/explanationNote">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/note"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà permette di rappresentare l&apos;interpretazione di un bene culturale, ricavabile dall&apos;osservazione diretta e dai dati conoscitivi disponibili.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents a cultural asset interpretation.</rdfs:comment>
        <rdfs:label xml:lang="en">explanation note</rdfs:label>
        <rdfs:label xml:lang="it">note interpretative</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa CA: DA/INT - ICCD Normativa TMA: DA/DES/DESI - ICCD Normativa SI: DA/NCS</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/findingNote -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/findingNote">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/note"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta le note relative alle modalità di individuazione e di reperimento del bene in esame, in forma di testo libero. Possono essere integrative rispetto a quanto rappresentato come Scavo Archeologico o Ricognizione Archeologica, oppure possono essere le uniche informazioni registrate sull&apos;individuazione e il reperimento del bene, in quelle situazioni in cui i dati a disposizione non consentono di compilare le schede di Authority file RCG-Ricognizione archeologica e/o DSC-Scavo archeologico. Vengono quindi collegate direttamente al bene.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents notes relating to methods for identifying and finding the cultural property in question.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">finding note</rdfs:label>
        <rdfs:label xml:lang="it">note di reperimento</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: RE/RES - ICCD Normativa RA 2.00: RP/SPR; RP/ROC/ROCC; RP/ROC/ROCI</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/folio -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/folio">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/SourceAndDocument"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà codifica il numero di foglio o di carta del documento per la classe di documentazione Fonti e documenti.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represent document&apos;s folio number.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">foglio</rdfs:label>
        <rdfs:label xml:lang="en">folio</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>DO/FNT/FNTF</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/framework -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/framework">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/ConservationIntervention"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la situazione in cui si svolge l&apos;intervento di restauro. Nel caso in cui l’intervento sul bene sia in corso al momento della schedatura e non risulti ancora concluso, il valore di questa proprietà sarà &quot;intervento in corso&quot; con l&apos;eventuale indicazione del luogo presso cui si sta effettuando.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the framework in which the restoration is carried out.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">framework</rdfs:label>
        <rdfs:label xml:lang="it">situazione</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>RS/RST/RSTS</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/historicalBiographicalInformation -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/historicalBiographicalInformation">
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta informazioni di natura storico biografica relative a un agente.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents historical biographical information about an agent.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">historical biographic information</rdfs:label>
        <rdfs:label xml:lang="en">historical biographical information</rdfs:label>
        <rdfs:label xml:lang="it">informazioni biografiche storiche</rdfs:label>
        <rdfs:label xml:lang="it">profilo storico biografico</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa F: PD/PDF/PDFB 
ICCD Normativa AUT: AU/NSC</a-cat:iccdNormTag>
        <a-cat:iccdNormTag>ICCD Normativa FF: PD/PDF/PDFB</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/historicalInformation -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/historicalInformation">
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">historical information</rdfs:label>
        <rdfs:label xml:lang="it">informazioni storiche</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: DA/NSC. - Normativa BNB: OG/OGT/OGTS</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/historicalInterest -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/historicalInterest">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta l&apos;interesse storico associto ad una cosa</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the historical interest related to a thing</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">historical interest</rdfs:label>
        <rdfs:label xml:lang="it">interesse storico</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/iconclassCode -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/iconclassCode">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/identifier"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la codifica iconclass che permette di descrivere, mediante un codice alfanumerico, il soggetto o il motivo decorativo rappresentato su un bene culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the Iconclass code, for describing the subject or ornamental motif represented by the cultural property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Codifica Iconclass</rdfs:label>
        <rdfs:label xml:lang="en">Iconclass Code</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>DA/DES/DESI (tranne per normativa TMA). DA/AID/AIDC</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/informationGatheredOnSite -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/informationGatheredOnSite">
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta le informazioni raccolte sul luogo dove si trova il bene o sul luogo dove il bene è stato rilevato.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents information collected on the place where the cultural entity is located or on the place where it was detected.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">information gathered on site</rdfs:label>
        <rdfs:label xml:lang="it">informazioni raccolte sul luogo</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: DA/NRL</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/insertionDate -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/insertionDate">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/InventorySituation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="it">Questa propretà rappresenta la data di inventariazione patrimoniale di un bene.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the date of insertion of an object in an inventory.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">data di inserimento</rdfs:label>
        <rdfs:label xml:lang="en">insertion date</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale: UB/INP/INPR, UN/INV/INVD</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/inventoryIdentifier -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/inventoryIdentifier">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/identifier"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega la situazione inventariale di un bene culturale al numero di collocamento d&apos;inventario del bene stesso.</rdfs:comment>
        <rdfs:comment xml:lang="en">Questa proprietà collega la situazione inventariale di un bene culturale al numero di collocamento d&apos;inventario del bene stesso.
This property relates the inventory situation of a cultural property to the inventory identifier number of the cultural property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">inventory identifier</rdfs:label>
        <rdfs:label xml:lang="it">numero identificativo d&apos;inventario</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: UB/INV/INVN - UB/INP/INPC</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt;

CONSTRUCT  { ?doc a-cd:inventoryNumber ?id .
}

WHERE 
      { ?doc a-cd:inventoryIdentifier ?id .
 }</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/inventoryNumber"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/inventoryLocation -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/inventoryLocation">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Inventory"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la collocazione dell&apos;inventario, cioè il luogo in cui è attualmente conservato l’inventario.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the location of the inventory about a cultural property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">collocazione dell&apos;inventario</rdfs:label>
        <rdfs:label xml:lang="en">inventory location</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>UB/INV/INVC</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/inventoryNumber -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/inventoryNumber">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/InventorySituation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta il codice di inventario nella forma numerica o alfanumerica attribuita dalla struttura conservativa (soprintendenza, museo, galleria, deposito, ecc.) che ha effettuato l&apos;inventariazione del bene.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the inventory identifier attributed by a juridical container to a cultural property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">codice d&apos;inventario</rdfs:label>
        <rdfs:label xml:lang="en">inventory number</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: UB/INV/INVN - UB/INP/INPC</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isKeptIn -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/isKeptIn">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Use"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la collocazione del bene nel suo ambiente, ovvero il luogo dove esso viene riposto quando non viene usato.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the location of the asset in its environment, i.e. the place where it is stored when not in use.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is kept in</rdfs:label>
        <rdfs:label xml:lang="it">è mantenuto in</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BDM 2.00: UT/UTA. Normativa BNM, BNPE, BNPL: CO/STC/STCT</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/issueDate -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/issueDate">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/TI/date"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/arco/ontology/context-description/ExportImportCertification"/>
                    <rdf:Description rdf:about="https://w3id.org/arco/ontology/context-description/ProtectiveMeasure"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la data di emissione di un provvedimento amministrativo o di una certificazione (es.: per la circolazione, esportazione/importazione di un bene culturale)</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents issue date of an administrative provision or a certification.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">data di emissione</rdfs:label>
        <rdfs:label xml:lang="en">issue date</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: TU/NVC/NVCE; TU/ESP/ESPD</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/methodOfInsertion -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/methodOfInsertion">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Inventory"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta, a testo libero, le modalità di acquisizione del bene nel patrimonio.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents how the cultural entity was inserted inside a collection.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">method of insertion</rdfs:label>
        <rdfs:label xml:lang="it">modalità di acquisizione</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: UB/INP/INPM</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/methodOfInterventionAndDigitization -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/methodOfInterventionAndDigitization">
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta, a testo libero, le modalità di intervento catalografico adottate successivamente alla fase di ricognizione e studio del fondo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents how the cultural entity the catalogue methods adopted after the study of the photographic fond.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">method of intervention and digitization</rdfs:label>
        <rdfs:label xml:lang="it">metodo di intervento e digitalizzazione</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa FF: DA/MTI</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/methodOfManufacturing -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/methodOfManufacturing">
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la modalità di fabbricazione/esecuzione di un bene culturale</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the manufacturing method of a cultural entity.</rdfs:comment>
        <rdfs:label xml:lang="en">method of manufacturing</rdfs:label>
        <rdfs:label xml:lang="it">modalità fabbricazione/esecuzione</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>BDM: MT/MOF</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/nationality -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/nationality">
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/CPV/Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la nazionalità di una persona</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the nationality of a person</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">nationality</rdfs:label>
        <rdfs:label xml:lang="it">nazionalità</rdfs:label>
        <a-cat:iccdNormTag>ICCD Norm AUT: AU/AUT/AUTF, AUTY. BDI and BDM: AT/ATT/ATTZ, AI/AIF/AIFZ, VI/VIF/VIFZ, FI/FIF/FIFZ. Normativa SM: MU/MUT/MUTZ.</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/noticeDate -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/noticeDate">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/TI/date"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/ProtectiveMeasure"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la data della notifica del provvedimento amministrativo al proprietario.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the date of notification of the administrative provision to the owner.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">data di notifica</rdfs:label>
        <rdfs:label xml:lang="en">notice date</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: TU/NVC/NVCD</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/numberInCirculation -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/numberInCirculation">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la numerazione dell&apos;esemplare della fotografia o della stampa all&apos;interno della tiratura e il numero complessivo degli esemplari tirati, qualora la fotografia o la stampa risalgano a una tiratura. Nel caso delle fotografie, per tiratura si intende un insieme prestabilito e limitato di esemplari (uguali) tratti dallo stesso negativo o dalla stessa, ovvero non modificata, fotografia digitale (o dalla stessa serie di matrici), numerati progressivamente.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents photograph copies numbering.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">number in circulation</rdfs:label>
        <rdfs:label xml:lang="it">numero nella tiratura</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa F: PD/TRT; ICCD Normativa S: PD/TRT/TRTN</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/numberOfEnvelopes -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/numberOfEnvelopes"/>
    


    <!-- https://w3id.org/arco/ontology/context-description/numberOfLabels -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/numberOfLabels"/>
    


    <!-- https://w3id.org/arco/ontology/context-description/openingNoticeDate -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/openingNoticeDate">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/TI/date"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/ProtectiveMeasure"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la data (nella forma “aaaa/mm/gg”) della comunicazione di avvio del procedimento di dichiarazione di interesse al proprietario, possessore o detentore.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents date of interest declaration communication to the owner or holder.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">data di comunicazione di avvio</rdfs:label>
        <rdfs:label xml:lang="en">opening notice date</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: TU/NVC/NVCI</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/originalStorageMedium -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/originalStorageMedium">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/StorageMedium"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="it">Questa proprietà indica l&apos;originalità del supporto di memorizzazione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the originality of the storage medium.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">original storage medium</rdfs:label>
        <rdfs:label xml:lang="it">supporto di memoria originale</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BDI: DU/DUO, DV/DVO, AI/AIO, VI/VIO</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/overlapSpecifications -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/overlapSpecifications">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/specifications"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/PhotoInterpretationRendering"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta le specifiche per effettuare sovrapposizioni con altri documenti utili per la lettura e l&apos;interpretazione dell&apos;immagine analizzata durante uan fotointerpretazione o fotorestituzione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents specifications to make overlaps with other documents useful for reading and interpreting image analyzed during a photointerpretation or photo-repayment.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">overlap specifications</rdfs:label>
        <rdfs:label xml:lang="it">specifiche sulla sovrapposizione</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: RE/FOI/FOIP</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/pageOrTableNumber -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/pageOrTableNumber">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/ReproductionPosition"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta le informazioni relative al numero della pagina o numero della tavola della pubblicazione in cui compare la stampa.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents information about page number or table number of publication in which the print appears.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">numero di pagina o tavola</rdfs:label>
        <rdfs:label xml:lang="en">page or table number</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa S 3: RO/ADL/ADLN</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/parallelTitle -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/parallelTitle">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/title"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta un titolo parallelo, cioè lo stesso titolo principale tradotto in altre lingue e presentato come equivalente.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the parallel title of a cultural property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">parallel title</rdfs:label>
        <rdfs:label xml:lang="it">titolo parallelo</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>Normativa F: SG/SGL/SGLL - Normative S e MI: OG/SGT/SGTR</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt;

CONSTRUCT {
?cp a-lite:parallelTitle ?title .
}

WHERE {
?cp a-cd:parallelTitle ?title .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/parallelTitle"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/photographicSeriesItemNumber -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/photographicSeriesItemNumber">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/PhotographicSeriesMembership"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la numerazione della fotografia all&apos;interno della serie fotografica editoriale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents numbering of the photograph within editorial photographic series.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">numero dell&apos;item all&apos;interno della serie</rdfs:label>
        <rdfs:label xml:lang="en">series item number</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa F: PD/SFI/SFIN</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/photographicSubseriesItemNumber -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/photographicSubseriesItemNumber">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/PhotographicSeriesMembership"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la numerazione della fotografia all&apos;interno della sottoserie fotografica editoriale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents numbering of the photograph within the editorial photographic subseries.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">numero dell&apos;item all&apos;interno della sottoserie fotografica</rdfs:label>
        <rdfs:label xml:lang="en">photographic subseries item number</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="it">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa F: PD/SSI/SSIN</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/preferredAuthorshipAttribution -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/preferredAuthorshipAttribution">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/AuthorshipAttribution"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta l&apos;attribuzione preferita di autore o responsabilità</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the preferrred authorship attribution</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">attribuzione di autore preferita</rdfs:label>
        <rdfs:label xml:lang="en">preferred authorship attibution</rdfs:label>
        
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {
?sit a-cd:preferredAuthorshipAttribution ?bool .
}

WHERE {
?sit a-cd:mainResponsibility ?bool .
}</core:constructQuery>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/primaryDocument -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/primaryDocument">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Recording"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="it">Questa proprietà indica se il docuemento in esame fa parte della documentazione primaria.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents whether a document is primary documentation.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">documentazione primaria</rdfs:label>
        <rdfs:label xml:lang="en">primary document</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BDI 4.00: DU, DV, DF</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/properTitle -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/properTitle">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/title"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Rappresenta il titolo proprio del soggetto di una stampa, di una matrice incisa o di una fotografia. Per titolo proprio di una stampa si intende il titolo principale nella forma in cui appare sulla stampa o sulla matrice stessa. Per titolo proprio (principale) di una fotografia, si intende nella forma in cui appare nell&apos;immagine (o su uno dei suoi supporti, o nelle schede a campi testuali, o nei commenti sonori presenti all&apos;interno del file contenente l&apos;immagine digitale). Per la normativa F, Il titolo proprio include anche ogni eventuale titolo alternativo (altre denominazioni dell&apos;opera che appaiano insieme al titolo principale) e, facoltativamente, i complementi del titolo proprio (ossia sottotitoli od ulteriori indicazioni che contribuiscono a qualificare più specificamente il contenuto dell&apos;immagine).</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the proper title of a cultural property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">proper title</rdfs:label>
        <rdfs:label xml:lang="it">titolo proprio</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>Normative S e MI: OG/SGT/SGTP - Normativa F: SG/SGL/SGLT</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt;

CONSTRUCT {
?cp a-lite:properTitle ?title .
}

WHERE {
?cp a-cd:properTitle ?title .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/properTitle"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/proposedIntervention -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/proposedIntervention">
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta le proposte per interventi conservativi di un bene.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the proposed intervention for conserving the involved cultural entity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">proposed intervention</rdfs:label>
        <rdfs:label xml:lang="it">proposta di intervento</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa NT 4.00: CO/STP</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/provenance -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/provenance">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Inventory"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta, a testo libero, la provenienza del bene acquisito nel patrimonio.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents origin of the cultural entity acquired in the heritage.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">provenance</rdfs:label>
        <rdfs:label xml:lang="it">provenienza</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: UB/INP/INPP</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/pseudonym -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/pseudonym">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/name"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/CPV/Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta uno pseudonimo</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents pseudonym</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">pseudonimo</rdfs:label>
        <rdfs:label xml:lang="en">pseudonym</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa AUT: AU/AUT/AUTP</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/recordingEquipment -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/recordingEquipment">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Recording"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta l&apos;attrezzatura tecnica impiegata per eseguire la registrazione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the recording equipment used for making the recording.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">attrezzatura tecnica</rdfs:label>
        <rdfs:label xml:lang="en">recording equipment</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BDI: DU/DUO/DUOA</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/recordingLocation -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/recordingLocation">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Recording"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta il luogo dove è avvenuta la registrazione di un bene culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the location where the recording of the cultural property took place.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">luogo di registrazione</rdfs:label>
        <rdfs:label xml:lang="en">recording location</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BDI: DUOQL, DVQL, DFQL, AIQL, VIQL, FIQL</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/refersToSurveys -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/refersToSurveys">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/PaleopathologySurvey"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta altre indagini cui fa riferimento un&apos;indagine volta a elaborare una diagnosi di una paleopatologia rilevata in un reperto antropologico.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents other investigations referred to in a survey aimed at developing a diagnosis of a paleopathology found in an anthropological finding.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">fa riferimento a indagini</rdfs:label>
        <rdfs:label xml:lang="en">refers to surveys</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa AT: PT/PTC/PTCI</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-spe: &lt;https://w3id.org/arco/ontology/natural-specimen-description/&gt;

CONSTRUCT {
?sit a-spe:refersToSurveys ?sur .
}

WHERE {
?sit a-cd:refersToSurveys ?sur .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/refersToSurveys"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/registrationDateOrGU -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/registrationDateOrGU">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/TI/date"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/ProtectiveMeasure"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la data dell&apos;avvenuta trascrizione al registro immobiliare, quando trattasi di vincoli imposti con leggi che richiedano la trascrizione, o il numero della Gazzetta Ufficiale su cui è stato pubblicato il decreto.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the date of the registration or the number of the Official Journal on which the decree was published.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">data di registrazione o gazzetta ufficiale</rdfs:label>
        <rdfs:label xml:lang="en">registration date or official journal</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: TU/NVC/NVCR</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/relatedWorkLocation -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/relatedWorkLocation">
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la localizzazione geografica e collocazione specifica dell&apos;opera collegata al bene culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents geographical location and specific location of the work related to the cultural property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">collocazione dell&apos;opera collegata</rdfs:label>
        <rdfs:label xml:lang="en">related work location</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normative F, RA, SMO, PST, S, OAC, OA, MI, D, NU: RO/ROF/ROFC - Normativa S: RO/COP/COPC - Normativa F: RO/CRF/CRFC</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/relatedWorkNote -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/relatedWorkNote">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/note"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta note generali sulle relazioni instaurate fra il bene in esame e altre opere.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents general notes on the relationships established between the property in question and other works.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">note su opere collegate</rdfs:label>
        <rdfs:label xml:lang="en">related work note</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: RV/REZ</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/relatedWorkPreviousLocation -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/relatedWorkPreviousLocation">
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta le informazioni relative all&apos;antica o precedente l&apos;attuale collocazione dell&apos;opera da cui è tratta la matrice o la stampa presso collezioni, palazzi, chiese, ecc., quando questa è segnalata sulla matrice/stampa o sicuramente deducibile dalle fonti bibliografiche.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents information relating to ancient or previous location of the work from which the matrix or print is ​​drawn.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">collocazione precedente dell&apos;opera collegata</rdfs:label>
        <rdfs:label xml:lang="en">related work previous location</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normative S, MI 3: RO/ROF/ROFR</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/relatedWorkRecordIdentifier -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/relatedWorkRecordIdentifier">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/identifier"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta il codice, qualora esista, che identifica la scheda relativa all&apos;opera finale o preparatoria in relazione con il bene culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the code which identifies the record relating to the final or preparatory work in relation with the cultural property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">codice della scheda dell&apos;opera collegata</rdfs:label>
        <rdfs:label xml:lang="en">related work record identifier</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normative F, RA, SMO, PST, S, OAC, OA, MI, D, NU: RO/ROF/ROFX</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt;

CONSTRUCT  { ?doc a-lite:localIdentifier ?id .
}

WHERE 
      { ?doc a-cd:relatedWorkRecordIdentifier ?id .
 }</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/hasIdentifier"/>
        <core:replacingQuery>select * {
?cp core:hasIdentifier ?NEWIdentifier .
?NEWIdentifier core:hasType core:LocalIdentifer ;
l0:identifier ?id .
}</core:replacingQuery>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/relevantLegalAct -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/relevantLegalAct">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/CurrentInventory"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta, a testo libero, eventuali riferimenti a documenti (atti amministrativi; riproduzioni digitali di registri inventariali, ecc.) che interessano l&apos;acquisizione del bene nel patrimonio. Rappresenta anche i dati relativi ai registri inventariali in vigore, ma comunque dotati di qualità storica.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents any references to documents that affect cultural entity acquisition.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">relevant legal act</rdfs:label>
        <rdfs:label xml:lang="it">riferimento agli atti</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: IUB/INP/INPO</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/report -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/report">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Survey"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment>ICCD Normativa Trasversale 4.00: RE/IND/INDT - ICCD Normativa AT 3.00: IN/INI/INIR</rdfs:comment>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta il referto di un&apos;indagine archeometrica e diagnostica o di una tipologia particolare di bene archeologico, ovvero i reperti antropologici.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the report of a anthropological finding&apos;s archaeometric and diagnostic investigation.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">referto</rdfs:label>
        <rdfs:label xml:lang="en">report</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/rights -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/rights">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://dati.beniculturali.it/cis/CulturalEntity"/>
                    <rdf:Description rdf:about="https://w3id.org/arco/ontology/context-description/Documentation"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta le informazioni a testo libero sulla gestione dei diritti. Nel caso di un bene culturale, permette di rappresentare indicazioni sulla presenza dei privilegi, autorizzazioni, licenze, specificando il concedente, eventualmente riportando anche il periodo di tempo della privativa.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents information on rights management.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">gestione diritti</rdfs:label>
        <rdfs:label xml:lang="en">rights</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: DO/FTA/FTAY, DO/DRA/DRAY, DO/VDC/VDCY, DO/REG/REGY, DO/FNT/FNTY, DO/BIB/BIBY - ICCD Normativa MI 3.00: DA/PLC</a-cat:iccdNormTag>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/hasCopyright"/>
        <core:replacingQuery>select * where {
?cp a-cd:hasCopyright ?NEWcp .
?NEWcp a-cd:specifications ?spec .
}</core:replacingQuery>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/sex -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/sex">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Sex"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/SexInterpretation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta il sesso dei una entità.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the sex of an entity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">sesso</rdfs:label>
        <rdfs:label xml:lang="en">sex</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>Normativa AT: DA/STS/STSS. Normativa BDI: AT/ATT/ATTS</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/signature -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/signature">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/name"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/CPV/Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la firma o il monogramma</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the signature</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">firma</rdfs:label>
        <rdfs:label xml:lang="en">signature</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa AUT: AU/AUT/AUTF</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/stripRunAndFrameNumber -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/stripRunAndFrameNumber">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/PhotographicDocumentation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta, per le foto aeree, le informazioni relative alla strisciata e al fotogramma.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents aerial photos information about run and frame.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">strip run/frame number</rdfs:label>
        <rdfs:label xml:lang="it">strisciata/numero fotogramma</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">FTAR</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/subject -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/subject">
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta il soggetto rappresentato da un bene culturale o il suo motivo decorativo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the subject of a cultural property, or its ornamental motif.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">soggetto</rdfs:label>
        <rdfs:label xml:lang="en">subject</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale: DA/AID/AIDI - Normativa F: SG/SGT/SGTI - Altre normative di versioni precedenti alla 4.00: OG/SGT/SGTI. DA/DES/DESU</a-cat:iccdNormTag>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasCulturalPropertySubject"/>
        <core:replacingQuery>select * where {
?cp a-lite:hasCulturalPropertySubject ?NEWsubj .
?NEWsubj rdfs:label ?subj .
}</core:replacingQuery>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/subjectDescription -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/subjectDescription">
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresanta la descrizione del soggetto</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the description of a subject of a cultural property</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">descrizione del soggetto</rdfs:label>
        <rdfs:label xml:lang="en">subject description</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="en">Normativa D e F: OG/SGT/SGTD, SG/SGT/SGTD</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/surveyImageIdentifier -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/surveyImageIdentifier">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/identifier"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/SurveyImage"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta il codice identificativo che individua l&apos;immagine presa in esame nel corso di un&apos;indagine di fotointerpretazione o fotorestituzione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the identification code that identifies the image examined during a photo-interpretation or photo-restoration investigation.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">identificativo immagine di indagine</rdfs:label>
        <rdfs:label xml:lang="en">survey image identifier</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: RE/FOI/FOID</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt;

CONSTRUCT  { ?doc a-lite:localIdentifier ?id .
}

WHERE 
      { ?doc a-cd:surveyImageIdentifier ?id .
 }</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/hasIdentifier"/>
        <core:replacingQuery>select * {
?img core:hasIdentifier ?NEWIdentifier .
?NEWIdentifier core:hasType core:LocalIdentifer ;
l0:identifier ?id .
}</core:replacingQuery>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/synonym -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/synonym"/>
    


    <!-- https://w3id.org/arco/ontology/context-description/taxonAuthorAndDate -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/taxonAuthorAndDate">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/core/Concept"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta l&apos;autore che ha descritto la specie e l&apos;anno di descrizione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the author that described the species and the date of description.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">autore e data del taxon</rdfs:label>
        <rdfs:label xml:lang="en">taxon author and date</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa AT: OG/OGS/OGSA</a-cat:iccdNormTag>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasAuthor"/>
        <core:replacingQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

select * {
?cp a-lite:hasAuthor ?NEWAuth .
?NEWAuth rdfs:label ?auth .
}</core:replacingQuery>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/technicalDocumentation -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/technicalDocumentation">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Survey"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la documentazione relativa alle informazioni rilevate nel corso dell&apos;indagine su reperto antropologico.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents documentation relating to information collected during survey on anthropological evidence.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">documentazione tecnica</rdfs:label>
        <rdfs:label xml:lang="en">technical documentation</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa AT 3.01: IN/INI/INIZ</a-cat:iccdNormTag>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/informationSource"/>
        <core:replacingQuery>select * where {
?sur a-cd:hasBibliographicSource ?NEWsource .
?NEWsource rdfs:label ?doc .
}</core:replacingQuery>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/testResults -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/testResults">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/LaboratoryTest"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà descrive i risultati dell&apos;attività di analisi</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the results of a test activity</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">risultati dell&apos;analisi</rdfs:label>
        <rdfs:label xml:lang="en">test results</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">RS/ALB/ALBR. CO/ALB/ALBR</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/thesaurus -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/thesaurus">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/core/Concept"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un concetto alla fonte (thesaurus) da cui proviene.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the source of information (thesaurus) of a concept.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">denominazione thesaurus</rdfs:label>
        <rdfs:label xml:lang="en">thesaurus</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa F: SG/THS/THST</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/title -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/title">
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta il titolo del soggetto di un bene culturale. La proprietà viene specificata in sottoproprietà per esprimere tipologie di titolo specifiche. Per la normativa trasversale è il titolo più noto e accreditato; nelle altre normative si specifica che è il titolo dato dall&apos;autore o la denominazione tradizionale del soggetto.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the title of a cultural property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">title</rdfs:label>
        <rdfs:label xml:lang="it">titolo</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">Normativa trasversale: DA/AID/AIDT - Altre normative di versioni precedenti alla 4.00: OG/SGT/SGTT</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt;

CONSTRUCT {
?cp a-lite:title ?title .
}

WHERE {
?cp a-cd:title ?title .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/title"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/useCondition -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/useCondition">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Use"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">modalità di uso</rdfs:label>
        <rdfs:label xml:lang="en">use condition</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: UT/UTU/UTUM - BDM 2.00: UT/UTM - SMO, PTS 3.01: DA/UTM</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/useFunction -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/context-description/useFunction">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/UseFunction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la funzione che l&apos;oggetto ha o ha avuto.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents object function.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">funzione d&apos;uso</rdfs:label>
        <rdfs:label xml:lang="en">use function</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale: UT/UTU/UTUF - BDM 2.00:UT/UTF - PST 3.01: DA/UTF</a-cat:iccdNormTag>
        <core:constructQuery></core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasCulturalEntityUseFunction"/>
        <core:replacingQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt;

select * where {
?cp a-lite:hasCulturalEntityUseFunction ?NEWusefunction ;
    a-cd:hasUse ?NEWUse .
?NEWUse a-cd:hasUseFunction ?NEWusefunction .
?NEWusefunction rdfs:label ?usef .
}</core:replacingQuery>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/core/abstract -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/core/abstract">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta l&apos;abstract di un testo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the abstract of an entity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="en">abstract</rdfs:label>
        <rdfs:label xml:lang="it">abstract</rdfs:label>
        <rdfs:label xml:lang="it">riassunto</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/core/current -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/core/current">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="it">Questa porprietà indica se i dati relativi all&apos;istanza di un pattern sono attuali o no.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property indicates if data releated to an instance of a pattern is current or not</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="it">attuale</rdfs:label>
        <rdfs:label xml:lang="en">current</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/core/description -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/core/description">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta una descrizione associata a una certa entità, che viene arricchita con ulteriori dettagli che la descrivono.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a description associated to an entity, in order to add details and some more information.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="en">description</rdfs:label>
        <rdfs:label xml:lang="it">descrizione</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/core/hasIdentifier -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/core/hasIdentifier"/>
    


    <!-- https://w3id.org/arco/ontology/core/identifier -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/core/identifier">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/identifier"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/core/Identifier"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;entità al suo codice identificativo.</rdfs:comment>
        <rdfs:comment>This property relates an entity with its identifier code.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="it">identificativo</rdfs:label>
        <rdfs:label xml:lang="en">identifier</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/core/informationSource -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/core/informationSource">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la fonte da cui vengono prese le informazioni.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the source of information.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="it">fonte dell&apos;informazione</rdfs:label>
        <rdfs:label xml:lang="en">information source</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>AU/CMM/CMMF</a-cat:iccdNormTag>
        <a-cat:iccdNormTag>Normativa trasversale e precedenti: *SGT/SGTL, RO/ROF/ROFM,, DT/DTM/DTMM, DT/ADT/ADTM, RE/REN/RENF, AU/DDC/DDCF, AU/FRU/FRUF, AU/ATB/ATBM, AU/AUT/AUTM, AU/AUF/AUFM, AU/AUI/AUIM, AU/AFB/AFBM, AU/AAT/AATM, AUAAFAAFM, PD/PDF/PDFM, UB/INP/INPA, UB/INV/INVS, UB/STI/STIM, AU/CMM/CMMF, LS/LTS/LTSF, LS/LVS/LVSF. Normativa BDI: AT/ATT/ATTE; AI/AIF/AIFH, VI/VIF/VIFH, FI/FIF/FIFH. Normativa SM: MU/MUT/MUTE. Normativa AT: DA/STS/STSC, DA/SEM/SEMC. Normativa BNPE: SR/SRRSRRM, RR/RRR/RRRM. Normativa BNPL: SP/SPD/SPDR, SPDS, SPDU, SPDD, SPDP, SPDH, SPDN, SPDA, SPDC, SPDB, SPDL</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/core/keyword -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/core/keyword">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta una parola chiave relativa a un&apos;entità, che può essere utilizzata per la ricerca dell&apos;entità.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents a keyword related to an entity, used to search for that entity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="en">keyword</rdfs:label>
        <rdfs:label xml:lang="it">parola chiave</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa PST: CT/CTC</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/core/note -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/core/note">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta eventuali note, relative a una certa informazione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents notes associated to a piece of information.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="en">note</rdfs:label>
        <rdfs:label xml:lang="it">note</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/core/specifications -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/core/specifications">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta eventuali specifiche, relative a una certa informazione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents specifications associated to a piece of information.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="en">specifications</rdfs:label>
        <rdfs:label xml:lang="it">specifiche</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/specifications"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/core/synonym -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/core/synonym">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un sinonimo a un&apos;entità</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a synonym to an entity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="it">sinonimo</rdfs:label>
        <rdfs:label xml:lang="en">synonym</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>Normativa BNM: SM/SMN/SMNS, RM/RMS/RMNS. Normativa BNP; SP/SPV. Normativa BNPE: SR/SRN/SRNC, SRNN, RR/RRN/RRNC, RRNN. Normativa BNZ: SZ/SZS/SZSN</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/core/uncertainData -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/core/uncertainData">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="it">Questa porprietà indica se i dati relativi all&apos;istanza di un pattern sono incerti</rdfs:comment>
        <rdfs:comment xml:lang="en">This property indicates if data releated to an instance of a pattern is uncertain</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="it">dati incerti</rdfs:label>
        <rdfs:label xml:lang="en">uncertain data</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/cultural-event/eventTimeLocation -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/cultural-event/eventTimeLocation">
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEvent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta il luogo e il tempo di un evento culturale, quando espressi unitamente.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the time and location of a cultural event, when they are recorded together.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/cultural-event"/>
        <rdfs:label xml:lang="en">event time and location</rdfs:label>
        <rdfs:label xml:lang="it">tempo e luogo dell&apos;evento</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale e normative di versione 4.00: MS/MST/MSTL</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/cultural-event/timePeriodValue -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/cultural-event/timePeriodValue">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/cultural-event/RecurrentTimePeriod"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta il valore del periodo di tempo che intercorre tra il verificarsi di due eventi membri di un evento ricorrente.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the value associated to the time period that elapses between one of the member events of a recurrent event, as a collection of events, and the next one.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/cultural-event"/>
        <rdfs:label xml:lang="en">time period value</rdfs:label>
        <rdfs:label xml:lang="it">valore del periodo di tempo</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/accuracy -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/accuracy">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/denotative-description/Measurement"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la validità, intesa come livello di accuratezza, di una misura osservata per un oggetto.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the validity, intended as accurancy level, of an observed measure for an object.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description"/>
        <rdfs:label xml:lang="en">accuracy</rdfs:label>
        <rdfs:label xml:lang="it">accuratezza</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BNB, BNM, BNP, BNPE, BNPL, BNZ, CA, D, F, MA, MI, OA, OAC, PST, RA, S, SAS, SI, SM: MT/MIS/MIST

ICCD Normativa MI, S: MT/MIF/MIFV</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/anthropologicalMaterialMorphology -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/anthropologicalMaterialMorphology">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la morfologia di un reperto antropologico (es.: morfologia naturale; morfologia alterata intra-vitam per cause naturali e/o per intervento antropico; morfologia/ struttura alterata post-mortem per cause naturali).</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the morphology of an anthropological material.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="en">anthropological material morphology</rdfs:label>
        <rdfs:label xml:lang="it">morfologia di reperto antropologico</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa AT 3.01: OG/OGT/OGTM</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/associatedObject -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/associatedObject">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;entità con il proprio oggetto associato. Es. nell&apos;antropologia fisica: un bene connesso ad eventuali oggetti posti a contatto con il corpo durante la sua preparazione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an entity to its object associated with.
i.e. a physical antropology cultural entity with an amulet.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha oggetto associato</rdfs:label>
        <rdfs:label xml:lang="en">has associated object</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa AT 3.01: PR/PRR</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/bodyTranscript -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/bodyTranscript">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/transcript"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta il testo scritto nel corpo dell&apos;etichetta</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the text written in the body of the label</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="en">body transcript</rdfs:label>
        <rdfs:label xml:lang="it">trascrizione del corpo</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BNB: SB/SBE/SBET</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/creationDate -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/creationDate">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/denotative-description/Accessory"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la data di costruzione di un accessorio di uno strumento musicale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the date of construction of a musical instrument&apos;s accessory.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="en">creation date</rdfs:label>
        <rdfs:label xml:lang="it">data di creazione</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa SM 4.00: AS/ASS/ASSD</a-cat:iccdNormTag>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasRealizationDate"/>
        <core:replacingQuery>select distinct * where {
?cp &lt;https://w3id.org/arco/ontology/arco-lite/hasRealizationDate&gt; ?date
}</core:replacingQuery>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/geologicalDescription -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/geologicalDescription">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/description"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/denotative-description/Soil"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la descrizione geologica di un suolo</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents geological description of a soil</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">descrizione geologica</rdfs:label>
        <rdfs:label xml:lang="en">geological description</rdfs:label>
        
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {?class &lt;https://w3id.org/arco/ontology/location/geologicalDescription&gt; ?des .}
WHERE {?class a-dd:geologicalDescription ?des.}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/location/geologicalDescription"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/graphicSymbols -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/graphicSymbols">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;entità ai suoi simboli grafici. Es: un bene demoetnoatropologico con i simboli grafici coinvolti.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an entity with its graphic symbols. i.e. a demoethnoanthropological cultural property to its symbols.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="en">graphic symbols</rdfs:label>
        <rdfs:label xml:lang="it">simboli grafici</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BDI 3.01: CU/CUR/CURS
ICCD Normativa BNB: SBEG</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/handwriting -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/handwriting">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="it">Questa proprietà indica se l&apos;etichetta è autografa o meno</rdfs:comment>
        <rdfs:comment xml:lang="en">This property indicates if the label is handwritten or not</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">autografa</rdfs:label>
        <rdfs:label xml:lang="en">handwriting</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BNB: SB/SBE/SBEA</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/headingTranscript -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/headingTranscript">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/transcript"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta il testo scritto nell&apos;intestazione dell&apos;etichetta</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the heading of the label</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="en">heading transcript</rdfs:label>
        <rdfs:label xml:lang="it">trascrizione dell&apos;intestazione</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BNB: SB/SBE/SBEI
ICCD Normativa BNM: SMEI, RMEI
ICCD Normativa BNP: SPEI
ICCD Normativa BNPE: SPEI, RREI
ICCD Normativa BNPL: SPEI, RPEI
ICCD Normativa BNZ: SZEI</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/italianTranslation -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/italianTranslation">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/denotative-description/AffixedElement"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la traduzione italiana della trascrizione di un testo contenuto in un&apos;iscrizione, un&apos;emblema, etc.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the italian translation of a text transcription contained in an inscription, emblem etc.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="en">italian translation</rdfs:label>
        <rdfs:label xml:lang="it">traduzione italiana</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: DA/ISE/ISEB</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/morphologicalDescription -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/morphologicalDescription">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/description"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/denotative-description/Soil"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la descrizione morfologica di un suolo</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents morphological description of a soil</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">descrizione morfologica</rdfs:label>
        <rdfs:label xml:lang="en">morphological description</rdfs:label>
        
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {?class &lt;https://w3id.org/arco/ontology/location/morphologicalDescription&gt; ?des .}
WHERE {?class a-dd:morphologicalDescription ?des.}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/location/morphologicalDescription"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/numberOfChildParticipants -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/numberOfChildParticipants">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/denotative-description/CommunicationMedium"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta il numero dei bambini che attuano una comunicazione (verbale, musicale vocale).</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the number of the child participants to a communication (verbal, singing, kinesic).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="en">number of child participants</rdfs:label>
        <rdfs:label xml:lang="it">numero di partecipanti infantili</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BDI: CU/CUV/CUVI; CU/CUM/CUMI</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/numberOfElements -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/numberOfElements">
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
        <rdfs:comment xml:lang="it">Questa proprietá rappresenta il numero di elementi di un&apos;entitá culturale.
es: il numero di fogli o parti che costituiscono un campione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the number of elements that constitutes a cultural entity.
es: the number of elements of a specimen.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="en">number of elements</rdfs:label>
        <rdfs:label xml:lang="it">numero di elementi</rdfs:label>
        <a-cat:iccdNormTag>ICCD Normativa BNB: SB/CBP/CBPF</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/numberOfEnvelopes -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/numberOfEnvelopes">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta il numero di buste dell&apos;etichetta di un campione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the number of envelopes of a specimen label.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="en">number of envelopes</rdfs:label>
        <rdfs:label xml:lang="it">numero di buste</rdfs:label>
        <owl:versionInfo xml:lang="en">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>Normativa BNB: SB/CBP/CBPB</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/numberOfFemaleParticipants -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/numberOfFemaleParticipants">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/denotative-description/CommunicationMedium"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta il numero delle persone di sesso femminile che attuano una comunicazione (verbale, musicale vocale, cinesica).</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the number of the male participants to a communication (verbal, singing, kinesic).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="en">number of female participants</rdfs:label>
        <rdfs:label xml:lang="it">numero di partecipanti femminili</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BDI: CU/CUV/CUVF; CU/CUM/CUMF; CU/CUC/CUCF</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/numberOfLabels -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/numberOfLabels">
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta etichette presenti assieme al campione</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the number of labels with the specimen</rdfs:comment>
        <rdfs:isDefinedBy>https://w3id.org/arco/ontology/denotative-description</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">number of labels</rdfs:label>
        <rdfs:label xml:lang="it">numero di etichette</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BNB: SB/CBP/CBPE</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/numberOfMaleParticipants -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/numberOfMaleParticipants">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/denotative-description/CommunicationMedium"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta il numero delle persone di sesso maschile che attuano una comunicazione (verbale, musicale vocale, cinesica)</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the number of the male participants to a communication (verbal, singing, kinesic).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="en">number of male participants</rdfs:label>
        <rdfs:label xml:lang="it">numero di partecipanti maschili</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BDI: CU/CUV/CUVM; CU/CUM/CUMM; CU/CUC/CUCM</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/occurrences -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/occurrences">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/denotative-description/AffixedElement"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta le occorrenze di un emblema, marchio, iscrizione, etc., su uno stesso bene culturale, cioè quante volte l&apos;elemento descritto compare sul bene.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the occurrences of an affixed element on a cultular entity, that is how many times the outlined element appears on the cultual entity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">occorrenze</rdfs:label>
        <rdfs:label xml:lang="en">occurrences</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale 4.00: DA/ISE/ISEQ - Normative di versioni precedenti: DA/STM/STMU</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/positionInComplexCulturalProperty -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/positionInComplexCulturalProperty">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la posizione di un bene rispetto al bene complesso di cui è parte componente.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents a cultural entity&apos;s position with respect to a complex entity to which it belongs.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="en">position in complex cultural property</rdfs:label>
        <rdfs:label xml:lang="it">posizione rispetto al bene culturale complesso</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normative D, OA, RA, BDM (v.1 e v.2): OG/OGT/OGTP</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?x a-dd:positionOnCulturalProperty ?y .
}

WHERE {
?x a a-dd:positionOnComplexCulturalProperty ?y .
}</core:constructQuery>
        <core:constructQuery>CONSTRUCT {?class a-dd:positionOnCulturalProperty ?pos .}
WHERE {?class a-dd:positionInComplexCulturalProperty ?pos.}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/positionOnCulturalProperty"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/positionOnCulturalProperty -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/positionOnCulturalProperty">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la posizione di un oggetto (es.: elementi come stemmi, emblemi, timbri, etc., oppure i soggetti rappresentati) rispetto all&apos;intero bene o a una sua specifica parte.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents a cultural entity&apos;s postion (e.g. elements like crests, emblems, stamps or the depicted subjects), with respect to the whole entity or to its specific part.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="en">position on cultural property</rdfs:label>
        <rdfs:label xml:lang="it">posizione su bene culturale</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale 4.00: DA/ISE/ISEP - Normative di versioni precedenti: DA/STM/STMP; DA/ISR/ISRP - Normativa A: LI/LSI/LSIU - Normativa PST: OG/SGT/SGTP - ICCD Normative MA, CA, SI, SAS: MC/CMN/CMNP - ICCD Normative D, OA, RA, BDM (v.1 e v.2): OG/OGT/OGTP</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/proposedIntervention -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/proposedIntervention">
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta eventuali proposte per interventi conservativi, dopo aver valutato le condizioni del bene al momento della sua catalogazione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents potential proposals for conservative interventions after evaluating the cultual entity&apos;s conditions at time of its cataloguing.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="en">proposed intervention</rdfs:label>
        <rdfs:label xml:lang="it">proposte di interventi</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>CO/STP</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {?class a-cd:proposedIntervention ?int .}
WHERE {?class a-dd:proposedIntervention ?int.}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/proposedIntervention"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/sampleCollectedIdentifier -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/sampleCollectedIdentifier">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/identifier"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/denotative-description/SampleCollected"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta il numero che identifica il campione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the sample collected identifier.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">identificativo del campione prelevato</rdfs:label>
        <rdfs:label xml:lang="en">sample collected identifier</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa MA, CA, SI, SAS: MC/CMN</a-cat:iccdNormTag>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/localIdentifier"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/storageConditions -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/storageConditions">
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta informazioni sulle condizioni ambientali e microclimatiche in cui si trova il bene al momento della catalogazione ed eventuali indicazioni per una sua corretta conservazione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents informations about the storage conditions of a cultural property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">modalità di conservazione</rdfs:label>
        <rdfs:label xml:lang="en">storage conditions</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>CO/STD</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/transcript -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/transcript">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;iscrizione, un emblema, etc., alla trascrizione del testo, utilizzando scioglimenti e integrazioni scientificamente accettati.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property connects an inscription, emblem etc., to the text&apos;s transcription, using scientifically accepted integrations.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="en">transcript</rdfs:label>
        <rdfs:label xml:lang="it">trascrizione</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: DA/ISE/ISEI - Normative di versioni precedenti: DA/ISR/ISRI. DA/DES/DESG, DESL</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/validity -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/validity">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/denotative-description/MeasurementCollection"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la validità, intesa come livello di accuratezza, di una misura osservata per un oggetto.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the validity, intended as accurancy level, of an observed measure for an object.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="en">validity</rdfs:label>
        <rdfs:label xml:lang="it">validità</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/accuracy"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/writingMethod -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/writingMethod">
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment rdf:resource="https://w3id.org/arco/ontology/denotative-description"/>
        <rdfs:comment xml:lang="it">Questa proprietà indica il metodo di scrittura utilizzato. Per esempio, se la scritta in esame è autografa, manoscritta, stampata, ecc.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the writing method of a text. E.g. handritten, printed, signed etc.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">metodo di scrittura</rdfs:label>
        <rdfs:label xml:lang="en">writing method</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BNB: SBEA
ICCD Normativa BNP: SPEP</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/location/administrativeOrderNumber -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/location/administrativeOrderNumber">
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà associa il numero d&apos;ordine che identifica una località intesa come unità amministrativa, ovvero un centro storico, una zona urbana e un settore.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property associates the order number that identifies a location intended as an administrative unit, i.e. an old town, an urban area and a sector.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="en">administrative order number</rdfs:label>
        <rdfs:label xml:lang="it">numero d&apos;ordine amministrativo</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normative A e PG: LC/CST/CSTN; LC/ZUR/ZURN; LC/SET/SETN</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/location/alt -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/location/alt">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/location/Altitude"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la coordinata z di un oggetto, che ne definisce l&apos;altitudine rispetto al livello del mare.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the z coordinate of an object, which defines its altitude above sea level.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="en">altitude</rdfs:label>
        <rdfs:label xml:lang="it">altitudine</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale 4.00: GE/GEC/GECZ - Normative precedenti: GP/GPC/GPCL</a-cat:iccdNormTag>
        <core:constructQuery>prefix clv: &lt;https://w3id.org/italia/onto/CLV/&gt; 

CONSTRUCT {
?x clv:alt ?alt .
}

WHERE {
?x a-loc:hasCoordinates ?coor .
?coor a-loc:hasAltitude ?altclass .
?altclass a-loc:alt ?alt .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/italia/onto/CLV/alt"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/location/cadastreName -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/location/cadastreName">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/name"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/location/CadastralIdentity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la denominazione con cui è noto un catasto storico.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the designation of a historical cadastre.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="en">cadastre name</rdfs:label>
        <rdfs:label xml:lang="it">denominazione del catasto</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: LS/CSS/CSSD</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?x a a-cd:Cadastre ;
rdfs:label ?name .
}

WHERE {
?x a-loc:cadastreName ?name .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/location/Cadastre"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/location/culturalInstituteOrSiteIdentifier -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/location/culturalInstituteOrSiteIdentifier">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/identifier"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalInstituteOrSite"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà permette di associare un contenitore giuridico al codice assegnatogli dall&apos;ICCD.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property allows to associate a legal container to its code assigned by the ICCD.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="en">cultural institute or site identifier</rdfs:label>
        <rdfs:label xml:lang="it">identificativo del contenitore giuridico</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale: LC/LDC/LDCG; LA/PRC/PRCG</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?thing a-lite:culturalInstituteOrSiteIdentifier ?id .
}

WHERE {
?thing a-loc:culturalInstituteOrSiteIdentifier ?id .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/culturalInstituteOrSiteIdentifier"/>
        <core:replacingQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

select * where {
?x core:hasIdentifier ?idclass .
?idclass l0:identifier ?id ;
core:hasType ?type .
}</core:replacingQuery>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/location/districtNumber -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/location/districtNumber">
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/CLV/District"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta il numero progressivo che individua il settore dove si trova il bene culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the progressive number that identifies the district where the cultural property is located.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="en">district number</rdfs:label>
        <rdfs:label xml:lang="it">numero del settore</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normative A e PG: LC/SET/SETP</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/location/drainageBasin -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/location/drainageBasin">
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/CLV/Feature"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una localizzazione al bacino idrografico</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a feature with the drainage basin</rdfs:comment>
        <rdfs:label xml:lang="it">bacino idrografico</rdfs:label>
        <rdfs:label xml:lang="en">drainage basin</rdfs:label>
        <a-cat:iccdNormTag>Normativa BNM: */BID</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/location/geographicalDescription -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/location/geographicalDescription">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/description"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/location/NaturalEnvironment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un ambiente naturale con la sua descrizione geografica.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a natural environment with its geographical description.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="it">descrizione geografica</rdfs:label>
        <rdfs:label xml:lang="en">geographical description</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa SI 3.00: CA/GEF/GEFD-GEFI</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/location/geologicalDescription -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/location/geologicalDescription">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/description"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/location/NaturalEnvironment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un ambiente naturale con la sua descrizione geological.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a natural environment with its geological description.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="it">descrizione geologica</rdfs:label>
        <rdfs:label xml:lang="en">geological description</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa SI 3.00: CA/GELD
ICCD Normativa PG 3.00: CA/CAG/CAGG, CAGP</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/location/geomorphologicalDescription -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/location/geomorphologicalDescription">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/description"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/location/NaturalEnvironment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un ambiente naturale con la sua descrizione geomorfologica.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a natural environment with its geomorphological description.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="it">descizione geomorfologica</rdfs:label>
        <rdfs:label xml:lang="en">geomorphological description</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa SI 3.00: CA/GEO/GEOD</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/location/historicalEnvironmentContextDescription -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/location/historicalEnvironmentContextDescription">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/description"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/location/NaturalEnvironment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un ambiente naturale alla descrizione dei suoi caratteri ambientali storici.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a natural environment with a description of its historical and environmental context.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="it">descrizione del contesto ambientale storico</rdfs:label>
        <rdfs:label xml:lang="en">historical environment context description</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa SI 3.00: CA/CAS (CASD+CASF+CASA)</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/location/lat -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/location/lat">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/location/Coordinates"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la coordinata y, ovvero la latitudine.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the y coordinate, that is the latitude.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="en">latitude</rdfs:label>
        <rdfs:label xml:lang="it">latitudine</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale 4.00: GE/GEC/GECY - Normative precedenti: GP/GPD/GPDP/GPDPY; GA/GAD/GADP/GADPY; GL/GLD/GLDP/GLDPY</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/location/locationDetails -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/location/locationDetails">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/location/TimeIndexedTypedLocation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà è utilizzata per rappresentare informazioni sui percorsi che permettono l’accesso al bene o che lo delimitano, o ulteriori specifiche per la localizzazione del bene.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property is used to represent other paths and details about the cultural property location.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="it">dettagli della localizzazione</rdfs:label>
        <rdfs:label xml:lang="en">location details</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale: LC/PVC/PVCV</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/location/long -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/location/long">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/location/Coordinates"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la coordinata x, ovvero la longitudine.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the x coordinate, that is the longitude.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="en">longitude</rdfs:label>
        <rdfs:label xml:lang="it">longitudine</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale 4.00: GE/GEC/GECX - Normative precedenti: GP/GPD/GPDP/GPDPX; GA/GAD/GADP/GADPX; GL/GLD/GLDP/GLDPX</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/location/maxAlt -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/location/maxAlt">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/CLV/alt"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/location/Geometry"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta l&apos;altitudine massima assoluta rispetto al livello del mare.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the absolute maximum altitude above sea level.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="it">altitudine massima</rdfs:label>
        <rdfs:label xml:lang="en">maximum altitude</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale 4.00: MT/MTA/MTAX - Normative precedenti: GP/GPC/GPCS; GA/GAQS; GL/GLQ/GLQS</a-cat:iccdNormTag>
        <a-cat:iccdNormTag>quota massima: GP/GPC/GPCS - GA/GAQS - GL/GLQ/GLQS - MT/MTA/MTAX</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/location/minAlt -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/location/minAlt">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/CLV/alt"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/location/Geometry"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta l&apos;altitudine minima assoluta rispetto al livello del mare.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the absolute minimum altitude above sea level.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="it">altitudine minima</rdfs:label>
        <rdfs:label xml:lang="en">minimum altitude</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale 4.00: MT/MTA/MTAM; versioni precedenti: GP/GPC/GPCI -GA/GAQ/GAQI - GL/GLQ/GLQI</a-cat:iccdNormTag>
        <a-cat:iccdNormTag>quota minima: GP/GPC/GPCI -GA/GAQ/GAQI - GL/GLQ/GLQI - MT/MTA/MTAM</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/location/morphologicalDescription -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/location/morphologicalDescription">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/description"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/location/NaturalEnvironment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un ambiente naturale con la sua descrizione morfologica.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a natural environment with its morphological description.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="it">descrizione morfologica</rdfs:label>
        <rdfs:label xml:lang="en">morphological description</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa PG 3.00: CA/CAM</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/location/naturalWaterArrangement -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/location/naturalWaterArrangement">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/location/NaturalEnvironment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà descrive la disposizione e la disponibilità delle acque naturali di un ambiente naturale</rdfs:comment>
        <rdfs:comment xml:lang="en">This property describes the arrangement and availability of natural waters in a natural environment</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="it">assetto delle acque naturali</rdfs:label>
        <rdfs:label xml:lang="en">natural water arrangement</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/location/pedologicalDescription -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/location/pedologicalDescription">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/description"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/location/NaturalEnvironment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un ambiente naturale con la sua descrizione pedologica.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a natural environment with its pedological description.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="it">descrizione pedologica</rdfs:label>
        <rdfs:label xml:lang="en">pedological description</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa SI 3.00: CA/PED/PEDD+PEDE</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/location/pointType -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/location/pointType">
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/CLV/Geometry"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta il tipo di punto che georeferenzia il bene catalogato. La definizione del tipo di punto non è univoca e dipende dalla tipologia e dalla conformazione del bene e dal tipo di localizzazione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the type of point that georeferences the catalogued cultural property. The definition of the point type is not univocal and depends on the cultural property&apos;s type and conformation as well as on the type of location.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="en">point type</rdfs:label>
        <rdfs:label xml:lang="it">tipo di punto</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">Normative precedenti alla 4.00: GP/GPC/GPCT</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/location/relativeAlt -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/location/relativeAlt">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/CLV/alt"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/location/Geometry"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta l&apos;altezza relativa dell&apos;oggetto rispetto a un punto, un elemento o una situazione da specificare.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the object relative height by reference to a point or an element or a situation to be specified.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="it">altitudine relativa</rdfs:label>
        <rdfs:label xml:lang="en">relative altitude</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: MT/MTA/MTAR</a-cat:iccdNormTag>
        <a-cat:iccdNormTag>quota relativa: MT/MTA/MTAR</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/location/seaOrOcean -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/location/seaOrOcean">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà indica il mare o l&apos;oceano dove è stato raccolto il bene.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property indicates the sea or ocean where the culrutal entity was harvested.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="it">mare o oceano</rdfs:label>
        <rdfs:label xml:lang="en">sea or ocean</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BNM 3.01: LT/MAO</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/location/siteIdentifier -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/location/siteIdentifier">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/identifier"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/Site"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà permette di associare un contenitore fisico al codice assegnatogli dall&apos;ICCD.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property allows to associate a physical container to its code assigned by the ICCD.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="it">identificativo del contenitore fisico</rdfs:label>
        <rdfs:label xml:lang="en">site identifier</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale: LC/LDC/LDCK; LA/PRC/PRCK</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?thing a-lite:nationalIdentifier ?id .
}

WHERE {
?thing a-loc:siteIdentifier ?id .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/nationalIdentifier"/>
        <core:replacingQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

select * where {
?x core:hasIdentifier ?idclass .
?idclass l0:identifier ?id ;
core:hasType core:NationalIdentifier .
}</core:replacingQuery>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/location/soilUse -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/location/soilUse">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/location/Soil"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega il suolo all&apos;utilizzazione del suolo in esame, con particolare riferimento ai popolamenti vegetali naturali, alle coltivazioni, agli usi urbanistici e alle attività estrattive di superficie.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a soil to its usage.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="en">soil use</rdfs:label>
        <rdfs:label xml:lang="it">uso del suolo</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa SI 3.00: CA/USD</a-cat:iccdNormTag>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/arco/ontology/location/spatialReferenceSystem -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/location/spatialReferenceSystem">
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/CLV/Geometry"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta il sistema di riferimento utilizzato per la georeferenziazione (ad es. WGS84, WGS84 UTM32, ecc.).</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the reference system used for the object georeferencing (e.g. WGS84, WGS84 UTM32, etc.).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="it">sistema di riferimento</rdfs:label>
        <rdfs:label xml:lang="en">spatial reference system</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale 4.00: GE/GEP - Normative precedenti: GA/GAP; GL/GLP; GP/GPP</a-cat:iccdNormTag>
        <core:constructQuery>prefix clv: &lt;https://w3id.org/italia/onto/CLV/&gt; 

CONSTRUCT {
?x clv:coordinateSystem ?sys .
}

WHERE {
?x a-loc:spatialReferenceSystem ?sys .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/italia/onto/CLV/coordinateSystem"/>
    </owl:DatatypeProperty>
    


