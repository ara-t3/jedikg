        <rdfs:comment xml:lang="en">This individual represents original designation.</rdfs:comment>
        <rdfs:label xml:lang="it">Denominazione originaria</rdfs:label>
        <rdfs:label xml:lang="en">Original designation</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale: OGD/OGDT - Normative A e PG 3: OGA/OGAG.</a-cat:iccdNormTag>
