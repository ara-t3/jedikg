    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/natural-specimen-description/TypeOfTypeSpecimen -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/natural-specimen-description/TypeOfTypeSpecimen">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Type"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il tipo del campione che è servito a denominare un taxon specifico o infraspecifico</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the type of a specimen used to produce a specific taxon</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description"/>
        <rdfs:label xml:lang="it">Tipo di campione nomenclaturale</rdfs:label>
        <rdfs:label xml:lang="en">Type of type specimen</rdfs:label>
