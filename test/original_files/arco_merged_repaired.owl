        <rdfs:comment xml:lang="it">Rappresenta un evento culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">it represents an event that typically is related to the cultural domain</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://dati.beniculturali.it/cis/"/>
        <rdfs:label xml:lang="en">Cultural Event</rdfs:label>
        <rdfs:label xml:lang="it">Evento Culturale</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:Class>
    


