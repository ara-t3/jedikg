        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="it">La object property che collega un identificativo a una entità.</rdfs:comment>
        <rdfs:comment xml:lang="en">The object property that links an identifier to an entity.</rdfs:comment>
