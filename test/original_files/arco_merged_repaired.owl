    </owl:NamedIndividual>
    


    <!-- https://w3id.org/arco/ontology/context-description/AbsoluteAge -->

    <owl:NamedIndividual rdf:about="https://w3id.org/arco/ontology/context-description/AbsoluteAge">
        <rdf:type rdf:resource="https://w3id.org/arco/ontology/context-description/AgeType"/>
        <rdfs:comment xml:lang="it">Questo individuo rappresenta l&apos;età assoluta geologica.</rdfs:comment>
        <rdfs:comment xml:lang="en">This individual represents the absolute geologic age.</rdfs:comment>
        <rdfs:label xml:lang="en">Absolute age</rdfs:label>
        <rdfs:label xml:lang="it">Età assoluta</rdfs:label>
        <a-cat:iccdNormTag>Normativa ICCD BNPE: SR/SRR/SRRE</a-cat:iccdNormTag>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/arco/ontology/context-description/AccompanyingBibliography -->

    <owl:NamedIndividual rdf:about="https://w3id.org/arco/ontology/context-description/AccompanyingBibliography">
        <rdf:type rdf:resource="https://w3id.org/arco/ontology/context-description/BibliographyCategory"/>
        <rdfs:comment xml:lang="it">Questo individuo rappresenta la definizione (vocabolario chiuso) relativa al genere di bibliografia che riguarda in modo più generico il contesto in cui si è venuto a trovare il bene nel corso della sua storia.</rdfs:comment>
        <rdfs:comment xml:lang="en">This individual represents the definition relative to the genre of bibliography.</rdfs:comment>
        <rdfs:label xml:lang="en">Accompanying bibliography</rdfs:label>
        <rdfs:label xml:lang="it">Bibliografia di corredo</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {
?x a-cd:hasBibliographicSource ?ed .
}

WHERE {
?x a-cd:hasBibliography ?bib .
?bib a-cd:hasCategory ?bibCat ;
a-cd:hasEdition ?ed .
?bibCat a a-cd:AccompanyingBibliography .
}</core:constructQuery>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/arco/ontology/context-description/AerialPhotograph -->

    <owl:NamedIndividual rdf:about="https://w3id.org/arco/ontology/context-description/AerialPhotograph">
        <rdf:type rdf:resource="https://w3id.org/arco/ontology/context-description/SurveyImageType"/>
        <rdfs:comment xml:lang="it">Qiesto individuo rappresenta una fotografia aerea.</rdfs:comment>
        <rdfs:comment xml:lang="en">This individual represents an aerial photograph</rdfs:comment>
        <rdfs:label xml:lang="en">Aerial photograph</rdfs:label>
        <rdfs:label xml:lang="it">Fotografia aerea</rdfs:label>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale: RE/FOI/FOIT</a-cat:iccdNormTag>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/arco/ontology/context-description/AgeOfDeath -->

    <owl:NamedIndividual rdf:about="https://w3id.org/arco/ontology/context-description/AgeOfDeath">
