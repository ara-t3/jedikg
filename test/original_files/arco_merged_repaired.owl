        <rdfs:label xml:lang="en">Horizontal element type</rdfs:label>
        <rdfs:label xml:lang="it">Tipo di elemento orizzontale</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa A: SO/SOF/SOFG;SOFP</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/construction-description/Layout -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/construction-description/Layout">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Description"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta la forma della pianta e del prospetto di una costruzione e il modo in cui le varie parti di essi sono assemblate nella composizione d&apos;insieme.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the shape of the plan and the elevation of a construction and the way in which the different parts of them are arranged in the whole composition.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/construction-description"/>
        <rdfs:label xml:lang="en">Layout</rdfs:label>
        <rdfs:label xml:lang="it">Schema iconografico</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>Normativa A: PN/PNT/PNTS e PN/PNT/PNTF. Normativa PG: MP/MPT/MPTS E MP/MPT/MPTF</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/construction-description/Lift -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/construction-description/Lift">
