        <rdfs:comment xml:lang="it">Questo individuo rappresenta un&apos;etichetta, che è possibile trovare sovrapposta a un&apos;altra entità culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This individual represents a label, a type of affixed element that could be found on a cultural entity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">Etichetta</rdfs:label>
        <rdfs:label xml:lang="en">Label</rdfs:label>
        <owl:versionInfo>ICCD Normativa BNB: SB/SBE</owl:versionInfo>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/Length -->

    <owl:NamedIndividual rdf:about="https://w3id.org/arco/ontology/denotative-description/Length">
