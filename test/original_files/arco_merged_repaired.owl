        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il tipo di spazio della costruzione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the construction space type.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/construction-description"/>
        <rdfs:label xml:lang="en">Construction space type</rdfs:label>
        <rdfs:label xml:lang="it">Tipo di spazio della costruzione</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/construction-description/Covering -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/construction-description/Covering">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/construction-description/CoveringType"/>
