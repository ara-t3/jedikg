        <rdfs:label xml:lang="en">Other language designation</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale: OGD/OGDT - Normative A, BDM, PG 3: OGA/OGAG.</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT { ?x a a-cd:AlternativeDesignation .}
WHERE {?x a a-dd:OtherLanguageDesignation . }</core:constructQuery>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/PartiallyAccessible -->

    <owl:NamedIndividual rdf:about="https://w3id.org/arco/ontology/denotative-description/PartiallyAccessible">
        <rdf:type rdf:resource="https://w3id.org/arco/ontology/denotative-description/CulturalPropertyAccessibility"/>
        <rdfs:label xml:lang="en">Partially accessible</rdfs:label>
        <rdfs:label xml:lang="it">Parzialmente accessibile</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/Perimeter -->

    <owl:NamedIndividual rdf:about="https://w3id.org/arco/ontology/denotative-description/Perimeter">
        <rdf:type rdf:resource="https://w3id.org/arco/ontology/denotative-description/MeasurementType"/>
        <rdfs:label xml:lang="en">Perimeter</rdfs:label>
        <rdfs:label xml:lang="it">Perimetro</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>Normativa BDM: MT/MIS/MISI</a-cat:iccdNormTag>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/Ph -->

    <owl:NamedIndividual rdf:about="https://w3id.org/arco/ontology/denotative-description/Ph">
        <rdf:type rdf:resource="https://w3id.org/arco/ontology/denotative-description/MeasurementType"/>
        <rdfs:label xml:lang="en">Ph</rdfs:label>
        <rdfs:label xml:lang="it">Ph</rdfs:label>
        
        <owl:versionInfo xml:lang="it">Instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/PhotoColour -->

    <owl:NamedIndividual rdf:about="https://w3id.org/arco/ontology/denotative-description/PhotoColour">
        <rdf:type rdf:resource="https://w3id.org/arco/ontology/denotative-description/TechnicalConcept"/>
        <rdfs:comment xml:lang="it">Questo individuo rappresenta il colore della fotografia digitale, ovvero se trattasi di fotografia in bianco/nero o a colori.</rdfs:comment>
        <rdfs:comment xml:lang="en">This individual represents a digital photograph&apos;s colour, i.e. black and white or colours.</rdfs:comment>
        <rdfs:label xml:lang="it">Colore della fotografia</rdfs:label>
        <rdfs:label xml:lang="en">Photo colour</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa F: MT/MTX</a-cat:iccdNormTag>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/PhotoProgram -->

    <owl:NamedIndividual rdf:about="https://w3id.org/arco/ontology/denotative-description/PhotoProgram">
        <rdf:type rdf:resource="https://w3id.org/arco/ontology/denotative-description/TechnicalConcept"/>
        <rdfs:comment xml:lang="it">Questo individuo rappresenta il programma di visualizzazione, memorizzazione ed elaborazione utilizzato per la fotografia digitale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This individual represents the visualization, storage and processing program used for a digital photograph.</rdfs:comment>
        <rdfs:label xml:lang="en">Photo program</rdfs:label>
        <rdfs:label xml:lang="it">Programma per la fotografia digitale</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa F: MT/FVC/FVCP</a-cat:iccdNormTag>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/Software"/>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/PhotoSize -->

    <owl:NamedIndividual rdf:about="https://w3id.org/arco/ontology/denotative-description/PhotoSize">
        <rdf:type rdf:resource="https://w3id.org/arco/ontology/denotative-description/TechnicalConcept"/>
        <rdfs:comment xml:lang="it">Questo individuo rappresenta il formato di una fotografia digitale, inteso come la dimensione standardizzata dei materiali fotografici (negativi, positivi, ecc.).</rdfs:comment>
        <rdfs:comment xml:lang="en">This individual represents a digital photograph format, intended as the photogrphic material&apos;s standardised size (e.g. negative, positives).</rdfs:comment>
        <rdfs:label xml:lang="it">Dimensioni della foto (Formato)</rdfs:label>
        <rdfs:label xml:lang="en">Photo size</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
