        <rdfs:label xml:lang="it">è caratteristica tecnica di</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/isTechnicalConceptUsedIn -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/isTechnicalConceptUsedIn">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/usesTechnicalConcept"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/denotative-description/TechnicalConcept"/>
