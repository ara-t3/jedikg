        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BNB: SB/TBI/TBIT. BNM: SM/SMT/SMTT</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/natural-specimen-description/Typification -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/natural-specimen-description/Typification">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/EventOrSituationInTime"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/isConsequenceOf"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/LaboratoryTest"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasBibliography"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/Bibliography"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/hasTypeOfTypeSpecimen"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/TypeOfTypeSpecimen"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/isTypificationOf"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/producesTaxon"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/core/Taxon"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta l&apos;identificazione di un campione vegetale che è servito a produrne la prima descrizione e a denominare un taxon specifico o infraspecifico considerato nuovo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the identification of a specimen used to produce the first description an to produce the new taxon</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description"/>
        <rdfs:label xml:lang="it">Identificazione del tipo nomenclaturale</rdfs:label>
        <rdfs:label xml:lang="en">Typification</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BNB: SB/TBI. BNM: SM/SMT</a-cat:iccdNormTag>
    </owl:Class>
    


