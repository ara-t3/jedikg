                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/denotative-description/MeasurementCollection"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta un bene culturale immobile che è stato costruito dall&apos;uomo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents an immovable cultural entity that has been built by humankind.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/construction-description"/>
        <rdfs:label xml:lang="en">Construction</rdfs:label>
        <rdfs:label xml:lang="it">Costruzione</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/construction-description/ConstructionDevelopment -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/construction-description/ConstructionDevelopment">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Description"/>
        <rdfs:subClassOf>
            <owl:Restriction>
