        <rdfs:comment xml:lang="en">This individual represents an local designation.</rdfs:comment>
        <rdfs:label xml:lang="it">Denominazione locale</rdfs:label>
        <rdfs:label xml:lang="en">Local designation</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale: OGD/OGDT - Normative A e BDM 3: OGA/OGAG.</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT { ?x a a-cd:LocalDesignation .}
WHERE {?x a a-dd:LocalDesignation . }</core:constructQuery>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/Logo -->

