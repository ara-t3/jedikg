        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasSurvey"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/Survey"/>
