        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/location/TimeIndexedTypedLocation"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un contenitore fisico a una localizzazione tipizzata nel tempo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural site to the time indexed typed location.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
