    <owl:Class rdf:about="https://w3id.org/arco/ontology/core/Event"/>
    


    <!-- https://w3id.org/arco/ontology/core/EventOrSituation -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/core/EventOrSituation">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/EventOrSituation"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta un evento o una situazione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents an event or a situation.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="en">Event or situation</rdfs:label>
        <rdfs:label xml:lang="it">Evento o situazione</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/core/EventOrSituationInTime -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/core/EventOrSituationInTime">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/EventOrSituation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/involves"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/onto/TI/hasTemporalEntity"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/italia/onto/TI/TemporalEntity"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/onto/TI/hasTemporalEntity"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/italia/onto/TI/TemporalEntity"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">La classe che rappresenta una situazione o un evento nel tempo.</rdfs:comment>
        <rdfs:comment xml:lang="en">The class that models a situation or an event in time.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="en">Event or situation in time</rdfs:label>
        <rdfs:label xml:lang="it">Evento o situazione nel tempo</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/core/Identifier -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/core/Identifier">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Characteristic"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/issuedBy"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/italia/onto/COV/Organization"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/core/IdentifierType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/isIdentifierOf"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/identifier"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/current"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta un identificativo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents identifier.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="it">Identificativo</rdfs:label>
        <rdfs:label xml:lang="en">Identifier</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>NC/NCT, AC/ACC/ACCC, AC/ACS/ACSC, AC/MOD/MODI. ICCD Normativa Trasversale 4.00: UB/INP/INPS. ICCD Normativa FF: PA/PAC/PACI; PA/PAC/PACA. ICCD Normativa Trasversale 4.00: DO/FTA/FTAN; DO/DRA/DRAN; DO/VDC/VDCN; DO/REG/REGN; DO/FNT/FNTI. ICCD Normative F, RA, SMO, PST, S, OAC, OA, MI, D, NU: RO/ROF/ROFX. ICCD Normativa Trasversale 4.00: RE/FOI/FOID. UB/COL/COLI.</a-cat:iccdNormTag>
        <a-cat:iccdNormTag>Normativa trasversale: CD/NTC, AC/ACC, ACI, ACS/ACSC, AC/MOD/MODI; OG/OGT/OGTI; RO/ROF/ROFX, RO/CRF/CRFH, DO/BIB/BIBH, BIBK, NCUN, RE/RCG/RCGK, NCUN, NUCN, RCGH, RE/DSC/DSCK, NUCN, NCUN, DSCH, RE/FOI/FOID; AU/AUT/AUTH, AUTK, NUCN, NCUN; AU/AUF/AUFH, NUCN, NCUN; PD/PDF/PDFH; UB/INP/INPS: LC/LDC/LDCK, LDCG; LA/PRC/PRCK; MC/CMN/CMNN. MODI: CD/CDR, CDM. Normativa BDI: DU/DUC, DU/DUO/DUOC, DU/DUM/DUMC, DV/DVC, DV/DVO/DVOC, DV/DVM/DVMC, DF/DFC, DF/DFO/DFOC, DF/DFM/DFMC, AI/AIC, AI/AIO/AIOC, AI/AIM/AIMC, VI/VIC, VI/VIO/VIOC, VI/VIM/VIMC, FI/FIC, FI/FIO/FIOC, FI/FIM/FIMC</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/core/IdentifierType -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/core/IdentifierType">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Type"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta in tipo di identificativo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents identifier type.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="en">Identifier type</rdfs:label>
