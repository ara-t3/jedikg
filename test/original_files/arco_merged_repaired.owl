    <!-- https://w3id.org/arco/ontology/catalogue/CatalogueRecordVersion -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/catalogue/CatalogueRecordVersion">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/catalogue/RecordVersion"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/catalogue/hasImmediatePreviousVersion"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/catalogue/CatalogueRecordVersion"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/catalogue/hasPreviousVersion"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/catalogue/CatalogueRecordVersion"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/catalogue/isRecordVersionOf"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/catalogue/CatalogueRecord"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/catalogue/CatalogueRecordVersionType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Rappresenta una versione (relativa a operazioni di redazione, aggiornamento, revisione) di una scheda di catalogo, cioè un modello descrittivo che raccoglie in modo organizzato le informazioni sui beni.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a version (after creation, editing, updating) of a catalogue record on a cultural property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="en">Catalogue record version</rdfs:label>
        <rdfs:label xml:lang="it">Versione della scheda di catalogo</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>CM/CMP; CM/RVM; CM/AGG</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/catalogue/CatalogueRecordVersionType -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/catalogue/CatalogueRecordVersionType">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Type"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il tipo di versione della scheda di catalogo</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the type of the catalog record version</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="en">Catalogue record version type</rdfs:label>
        <rdfs:label xml:lang="it">Tipo di versione di scheda di catalogo</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>CM/CMO, RVM, AGG</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/catalogue/CataloguingLevel -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/catalogue/CataloguingLevel">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/arco/ontology/catalogue/C"/>
                    <rdf:Description rdf:about="https://w3id.org/arco/ontology/catalogue/I"/>
                    <rdf:Description rdf:about="https://w3id.org/arco/ontology/catalogue/P"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Characteristic"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/catalogue/isCataloguingLevelOf"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/catalogue/CatalogueRecord"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il livello catalogazione, cioè la sigla che individua il grado di approfondimento dell&apos;indagine condotta sul bene in esame (I corrisponde al livello di inventario, P al livello di precatalogo, C al livello di catalogo)</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the cataloguing level, defining the level of detail of the survey carried out on the cultural property (Minimum, Medium, Detailed)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="en">Cataloguing level</rdfs:label>
        <rdfs:label xml:lang="it">Livello catalogazione</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>CD/LIR</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/catalogue/ComplexCPCatalogueRecord -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/catalogue/ComplexCPCatalogueRecord">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/catalogue/CatalogueRecord"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta una scheda catalografica che descrive un bene culturale complesso, a prescindere dal trattamento catalografico applicato (scheda unica/scheda d&apos;insieme).</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a catalogue record describing a complex cultural property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="en">Complex cultural property catalogue record</rdfs:label>
        <rdfs:label xml:lang="it">Scheda catalografica su bene culturale complesso</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa trasversale: OG/OGC/OGCT</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/catalogue/CulturalPropertyRecord -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/catalogue/CulturalPropertyRecord">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/catalogue/Record"/>
        <rdfs:label xml:lang="en">Catalogue property record</rdfs:label>
        <rdfs:label xml:lang="it">Scheda su bene culturale</rdfs:label>
        
        <owl:versionInfo xml:lang="en">instable</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {
?x a-cat:Record .
}

WHERE {
?x a-cat:CulturalPropertyRecord .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/catalogue/Record"/>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/catalogue/PrivacyLevel -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/catalogue/PrivacyLevel">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Characteristic"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/catalogue/isPrivacyLevelOf"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/catalogue/AccessProfile"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il livello di riservatezza dei dati contenuti in una scheda catalografica (1 livello basso di riservatezza, 2 livello medio di riservatezza, 3 livello alto di riservatezza)</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the privacy level of the data recorded in a catalogue record (Minimum, Medium, Maximum).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="it">Livello di riservatezza</rdfs:label>
        <rdfs:label xml:lang="en">Privacy level</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: AD/ADS/ADSP</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/catalogue/PrivacyReason -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/catalogue/PrivacyReason">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Description"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/catalogue/isPrivacyReasonOf"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/catalogue/AccessProfile"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta la motivazione che ha determinato l&apos;adozione di un profilo di accesso relativamente ai dati contenuti in una scheda catalografica.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the reason for the adoption of a specific access profile for a catalogue record.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="it">Motivo di riservatezza</rdfs:label>
        <rdfs:label xml:lang="en">Privacy reason</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: AD/ADS/ADSM</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/catalogue/Record -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/catalogue/Record">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/describes"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasAgentRole"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/core/AgentRole"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasIdentifier"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/core/Identifier"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/catalogue/hasRecordVersion"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/catalogue/RecordVersion"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasAgentRole"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/core/AgentRole"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/catalogue/lastUpdateDate"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta una scheda che analizza il bene in esame per finalità diverse da quella specifica della catalogazione del patrimonio culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a record describing an entity for purposes other than cataloguing cultural heritage.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="en">Record</rdfs:label>
        <rdfs:label xml:lang="it">Scheda</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: AC/ACS</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/catalogue/RecordVersion -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/catalogue/RecordVersion">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasAgentRole"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/core/AgentRole"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/catalogue/editedAtTime"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/italia/onto/TI/TimeInterval"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/catalogue/hasImmediatePreviousVersion"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/catalogue/RecordVersion"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/catalogue/hasPreviousVersion"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/catalogue/RecordVersion"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/catalogue/isRecordVersionOf"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/catalogue/Record"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasAgentRole"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/core/AgentRole"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/catalogue/editedAtTime"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/italia/onto/TI/TimeInterval"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Rappresenta una versione (relativa a operazioni di redazione, aggiornamento, revisione) di una scheda.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a version (after creation, editing, updating) of a record.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="en">Record version</rdfs:label>
        <rdfs:label xml:lang="it">Versione della scheda</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/clothing-description/Bottom -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/clothing-description/Bottom">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/clothing-description/ClothingElement"/>
        <rdfs:comment xml:lang="it">Questa entità rappresenta la parte inferiore dei vestimenti (es. gonna)</rdfs:comment>
        <rdfs:comment xml:lang="en">This entity represents the bottom part of a piece of clothing (e.g. skirt)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/clothing-description"/>
        <rdfs:label xml:lang="en">Bottom (clothing)</rdfs:label>
        <rdfs:label xml:lang="it">Parte inferiore (vestiti)</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa VeAC 3.01: DA/SRC/SRCI-SRCD</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/clothing-description/Clothing -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/clothing-description/Clothing">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
        <rdfs:comment xml:lang="it">Questa entità rappresenta un capo d&apos;abbigliamento, un vestimento</rdfs:comment>
        <rdfs:comment xml:lang="en">This entity represents a piece of clothing</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/clothing-description"/>
        <rdfs:label xml:lang="en">Clothing</rdfs:label>
        <rdfs:label xml:lang="it">Vestimento</rdfs:label>
        <rdfs:label xml:lang="it">Vestito</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa VeAC</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/clothing-description/ClothingElement -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/clothing-description/ClothingElement">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
        <rdfs:comment xml:lang="it">Questa entità rappresenta un elemento di un capo d&apos;abbigliamento</rdfs:comment>
        <rdfs:comment xml:lang="en">This entity represents an element of a piece of clothing</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/clothing-description"/>
        <rdfs:label xml:lang="en">Clothing Element</rdfs:label>
        <rdfs:label xml:lang="it">Elemento di vestimento</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/clothing-description/Costume -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/clothing-description/Costume">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/clothing-description/Clothing"/>
        <rdfs:comment xml:lang="it">Questa entità rappresenta un vestimento definito come costume.</rdfs:comment>
        <rdfs:comment xml:lang="en">This entity represents a costume</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/clothing-description"/>
        <rdfs:label xml:lang="en">Costume</rdfs:label>
        <rdfs:label xml:lang="it">Costume</rdfs:label>
        <owl:versionInfo xml:lang="it">instable</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa VeAC 3.01</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/clothing-description/Cuff -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/clothing-description/Cuff">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/clothing-description/ClothingElement"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/clothing-description/CuffType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa entità rappresenta un polsino di un capo d&apos;abbigliamento</rdfs:comment>
        <rdfs:comment xml:lang="en">This entity represents a cuff of a piece of clothing.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/clothing-description"/>
        <rdfs:label xml:lang="en">Cuff</rdfs:label>
        <rdfs:label xml:lang="it">Polsino</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="en">ICCD Normativa VeAC 3.01: DA/SRM/SRMF</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/clothing-description/CuffType -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/clothing-description/CuffType">
