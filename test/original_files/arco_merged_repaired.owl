        <rdf:type rdf:resource="https://w3id.org/arco/ontology/denotative-description/AffixedElementType"/>
        <rdfs:label xml:lang="it">Marchio di fabbrica o cava</rdfs:label>
        <rdfs:label xml:lang="en">Quarry or masonry mark</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
