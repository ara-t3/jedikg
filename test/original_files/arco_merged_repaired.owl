        <rdfs:label xml:lang="en">Terrestrial age</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normative BNPL: SP/SPD/SPDT</a-cat:iccdNormTag>
    </owl:NamedIndividual>
    


