        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="en">Cadastre type</rdfs:label>
        <rdfs:label xml:lang="it">Tipo di catasto</rdfs:label>
