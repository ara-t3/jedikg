    <!-- https://w3id.org/arco/ontology/catalogue/isRecordVersionOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/catalogue/isRecordVersionOf">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/catalogue/RecordVersion"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/catalogue/Record"/>
        <rdfs:comment xml:lang="en">Property, inverse of &quot;has catalogue record version&quot;, used to associate a catalogue record version (e.g. after update) to the catalogue record.</rdfs:comment>
        <rdfs:comment xml:lang="it">Proprietà, inversa di &quot;ha versione&quot;, che permette di collegare una versione  (corrispondente a un particolare stato dovuto a operazioni di redazione, aggiornamento, revisione) di una scheda di catalogo alla scheda di catalogo intesa come oggetto informativo che descrive un bene culturale.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="en">is catalogue record version of</rdfs:label>
        <rdfs:label xml:lang="it">è versione di</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/catalogue/isRelatedToAdditionalForm -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/catalogue/isRelatedToAdditionalForm">
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/catalogue/AdditionalForm"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un bene culturale a un modulo di approfondimento in relazione con il bene in esame.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural property to an additional form.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="en">is related to additional form</rdfs:label>
        <rdfs:label xml:lang="it">è collegato a modulo di approfondimento</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: DA/APP</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?thing core:isDescribedBy ?form .
}

WHERE {
?thing a-cat:isRelatedToAdditionalForm ?form 
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/isDescribedBy"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/catalogue/isRelatedToInformationForm -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/catalogue/isRelatedToInformationForm">
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un bene culturale a un modulo informativo in relazione con il bene in esame.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural property to an information form.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="en">is related to information form</rdfs:label>
        <rdfs:label xml:lang="it">è collegato a modulo informativo</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasvesale 4.00: AC/MOD</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?thing core:isDescribedBy ?form .
}

WHERE {
?thing a-cat:isRelatedToInformationForm ?form 
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/isDescribedBy"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/catalogue/isResponsibleAgentOfCulturalPropertyRecord -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/catalogue/isResponsibleAgentOfCulturalPropertyRecord">
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/catalogue/Record"/>
        <rdfs:comment xml:lang="it">Questa proprietà, inversa a &quot;ha agente responsabile di scheda su bene culturale&quot;, collega l&apos;Ente o il soggetto che ha prodotto la scheda o che gestisce la banca dati di cui la scheda fa parte alla scheda stessa.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property, inverse of &quot;has cultural property record responsible agent&quot;, relates the agency or the person that created the record or manages the database where the record is to the record itself.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="en">is responsible agent of cultural property record</rdfs:label>
        <rdfs:label xml:lang="it">è ente responsabile della scheda su bene culturale</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: AC/ACS/ACSE</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?agent a-lite:isResponsibleAgentOfCulturalPropertyRecord ?thing .
}

WHERE {
?agent a-cat:isUpdateResponsibleAgentOf ?thing .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/isResponsibleAgentOf"/>
        <core:replacingQuery>select * where {
?agent core:isAgentOf ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/ResponsibleAgent&gt; ;
core:isAgentRoleOf ?thing .
}</core:replacingQuery>
    </owl:ObjectProperty>
    


