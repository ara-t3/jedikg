        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="en">Chronostratigraphic system</rdfs:label>
        <rdfs:label xml:lang="it">Sistema cronostratigrafico</rdfs:label>
