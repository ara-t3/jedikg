        <rdfs:comment xml:lang="it">Questa entità rappresenta la chiusura di un capo d&apos;abbigliamento</rdfs:comment>
        <rdfs:comment xml:lang="en">This entity represents a faster of a piece of clothing</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/clothing-description"/>
        <rdfs:label xml:lang="it">Chiusura</rdfs:label>
        <rdfs:label xml:lang="en">Fastener</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa VeAC 3.01: EDT, MTCD</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/clothing-description/FastenerType -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/clothing-description/FastenerType">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Type"/>
        <rdfs:comment xml:lang="it">Questa entità rappresenta il tipo di chiusura di un capo d&apos;abbigliamento</rdfs:comment>
        <rdfs:comment xml:lang="en">This entity represents the type of fastener of a piece of clothing</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/clothing-description"/>
        <rdfs:label xml:lang="en">Fastener type</rdfs:label>
        <rdfs:label xml:lang="it">Tipo di chiusura</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa VeAC 3.01: SRE/SREA</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/clothing-description/InteriorElement -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/clothing-description/InteriorElement">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/clothing-description/ClothingElement"/>
        <rdfs:comment xml:lang="it">Questa entità rappresenta la fodera di un capo d&apos;abbigliamento</rdfs:comment>
        <rdfs:comment xml:lang="en">This entity represents the internal element (lining) of a piece of clothing</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/clothing-description"/>
        <rdfs:label xml:lang="it">Fodera</rdfs:label>
        <rdfs:label xml:lang="en">Interior element</rdfs:label>
        <rdfs:label xml:lang="en">Lining</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa VeAC 3.01: MT/MTF</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/clothing-description/InteriorElementType -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/clothing-description/InteriorElementType">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Type"/>
        <rdfs:comment xml:lang="it">Questa entità rappresenta il tipo di fodera di un capo d&apos;abbigliamento</rdfs:comment>
        <rdfs:comment xml:lang="en">This entity represents the internal element type of a piece of clothing</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/clothing-description"/>
        <rdfs:label xml:lang="en">Interior element type</rdfs:label>
        <rdfs:label xml:lang="en">Lining type</rdfs:label>
        <rdfs:label xml:lang="it">Tipo di elemento interno</rdfs:label>
