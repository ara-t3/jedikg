    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/core/isAgentInvolvedIn -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/core/isAgentInvolvedIn">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isInvolvedIn"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/core/Agent"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/core/EventOrSituation"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la partecipazione di un agente.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents an agent partecipation</rdfs:comment>
