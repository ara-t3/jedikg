    <!-- https://w3id.org/arco/ontology/arco/isPhotographicHeritageClassificationTypeOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/arco/isPhotographicHeritageClassificationTypeOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isTypeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/arco/PhotographicHeritageClassificationType"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/arco/PhotographicHeritageClassification"/>
        <rdfs:comment xml:lang="it">Questa è la proprietà inversa di &quot;ha tipo di classificazione di bene fotografico&quot;.</rdfs:comment>
        <rdfs:comment xml:lang="en">This is the inverse property of &quot;has photographic heritage classification type&quot;.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/arco"/>
        <rdfs:label xml:lang="en">is photographic heritage classification type of</rdfs:label>
        <rdfs:label xml:lang="it">è tipo di classificazione di bene fotografico</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/isClassificationSystemOf"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/arco/isRFIdOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/arco/isRFIdOf">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/arco/RFId"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un identificatore a radiofrequenza RFId a un oggetto.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a radio-frequency identification (RFID) to an object.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/arco"/>
        <rdfs:label xml:lang="en">is RFId identifier of</rdfs:label>
        <rdfs:label xml:lang="it">è identificativo RFId di</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/arco/isReferenceCoinLegendOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/arco/isReferenceCoinLegendOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isConceptOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/arco/ReferenceCoinLegend"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/arco/NumismaticProperty"/>
        <rdfs:comment xml:lang="it">Questa è la proprietà inversa di &quot;ha legenda tipo&quot;.</rdfs:comment>
        <rdfs:comment xml:lang="en">This is the inverse property of &quot;ha reference coin legend&quot;.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/arco"/>
        <rdfs:label xml:lang="en">is reference coin legend of</rdfs:label>
        <rdfs:label xml:lang="it">è legenda tipo di</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/arco/isRelatedAgencyOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/arco/isRelatedAgencyOf">
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/arco/CulturalProperty"/>
        <rdfs:comment xml:lang="it">Questa proprietà, inversa a &quot;ha ente collegato&quot;, rappresenta la relazione che collega un ente che riveste un ruolo nei confronti di un bene culturale al bene culturale stesso. La relazione tra il ruolo e l&apos;ente che lo riveste è espressa, in maniera generica, nel nome della proprietà, che quindi ne fornisce una rappresentazione semplificata, con ridotta espressività. La proprietà è specializzata per mezzo di sottoproprietà. Nell&apos;ontologia questa relazione è modellata anche, in maniera più espressiva, dalla classe TimeIndexedRole, che permette di collegare l&apos;ente, il suo ruolo e la sua corrispondente estensione temporale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property, inverse of &quot;has related agency&quot;, relates an agency that plays a role related to a cultural property to that cultural property. The relation is declared in the name of the property, but within the ontology this relation is also modeled, in a more expressive way, through the class AgentRole.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/arco"/>
        <rdfs:label xml:lang="en">is related agency of</rdfs:label>
        <rdfs:label xml:lang="it">è ente collegato a</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {
?x &lt;https://w3id.org/arco/ontology/arco-lite/isRelatedAgentOf&gt; ?y .
}

WHERE {
?x arco:isRelatedAgencyOf ?y .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/isRelatedAgentOf"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/arco/isThematicCategoryOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/arco/isThematicCategoryOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isCategoryOf"/>
        <rdfs:comment xml:lang="it">Questa è la proprietà inversa di &quot;ha categoria tematica&quot;.</rdfs:comment>
        <rdfs:comment xml:lang="en">This is the inverse property of &quot;has thematic category&quot;.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/arco"/>
        <rdfs:label xml:lang="en">is thematic category of</rdfs:label>
        <rdfs:label xml:lang="it">è categoria tematica di</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/isCategoryOf"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/catalogue/describes -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/catalogue/describes">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/catalogue/isDescribedBy"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="it">Questa proprietà è stata creata come proprietà generica di sottoproprietà specifiche, e rappresenta la relazione tra un&apos;entità che descrive un&apos;altra entità.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property was created as a generic property for specific subproperties, and represents the relationship between an entity that describes another entity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="en">describes</rdfs:label>
        <rdfs:label xml:lang="it">descrive</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {
?x core:describes ?thing .
}

WHERE {
?x a-cat:describes ?thing .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/describes"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/catalogue/describesCulturalProperty -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/catalogue/describesCulturalProperty">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/catalogue/describes"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/catalogue/isDescribedByCatalogueRecord"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/catalogue/CatalogueRecord"/>
        <rdfs:range rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:comment xml:lang="en">Property used to associate the catalogue record with the cultural property that the catalogue record describes.</rdfs:comment>
        <rdfs:comment xml:lang="it">Proprietà che consente di associare la scheda di catalogo al bene culturale che essa descrive.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="en">describes</rdfs:label>
        <rdfs:label xml:lang="it">descrive</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {
?x core:describes ?thing .
}

WHERE {
?x a-cat:describesCulturalProperty ?thing .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/describes"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/catalogue/editedAtTime -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/catalogue/editedAtTime">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/catalogue/editingTimeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/catalogue/CatalogueRecordVersion"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/TI/TimeInterval"/>
        <rdfs:comment xml:lang="en">Property used to associate a catalogue record version with the time interval in which it was edited.</rdfs:comment>
        <rdfs:comment xml:lang="it">Proprietà che associa una versione di una scheda di catalogo all&apos;intervallo temporale in cui è stata compilata.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="it">compilato al tempo</rdfs:label>
        <rdfs:label xml:lang="en">edited at time</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>CM/CMP/CMPD; CM/RVM/RVMD; CM/AGG/AGGD</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/catalogue/editingTimeOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/catalogue/editingTimeOf">
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/TI/TimeInterval"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/catalogue/CatalogueRecordVersion"/>
        <rdfs:comment xml:lang="it">Questa è la proprietà inversa di &quot;compilato al tempo&quot;.</rdfs:comment>
        <rdfs:comment xml:lang="en">This is the inverse property of &quot;edited at time&quot;.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="en">editing time of</rdfs:label>
        <rdfs:label xml:lang="it">tempo di compilazione di</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/catalogue/hasAccessProfile -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/catalogue/hasAccessProfile">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasCharacteristic"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/catalogue/isAccessProfileOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/catalogue/CatalogueRecord"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/catalogue/AccessProfile"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una scheda di catalogo al profilo di accesso ai dati (basso, medio, alto).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="it">ha profilo di accesso</rdfs:label>
        <rdfs:label xml:lang="en">has access profile</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: AD/ADS</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/catalogue/hasAdditionalFormResponsibleAgent -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/catalogue/hasAdditionalFormResponsibleAgent">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/hasRelatedAgent"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/catalogue/isAdditionalFormResponsibleAgentOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/catalogue/AdditionalForm"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un modulo di approfondimento all&apos;ente/il soggetto responsabile nel SIGECweb della redazione del modulo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an additional form to the responsible agent of that form in the SIGECweb.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="it">ha responsabile di modulo di approfondimento</rdfs:label>
        <rdfs:label xml:lang="en">has additional form responsible agent</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: DA/APP/APPE</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?x a-lite:hasResponsibleAgent ?agent .
}

WHERE {
?x a-cat:hasAdditionalFormResponsibleAgent ?agent .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasResponsibleAgent"/>
        <core:replacingQuery>select * where {
?x core:hasAgentRole ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/ResponsibleAgent&gt; ;
core:hasAgent ?agent .
}</core:replacingQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/catalogue/hasAdditionalFormType -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/catalogue/hasAdditionalFormType">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/catalogue/isAdditionalFormTypeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/catalogue/AdditionalForm"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/catalogue/AdditionalFormType"/>
        <rdfs:comment>CONSTRUCT {
?x core:hasType ?type .
}

WHERE {
? a-cat:hasAdditionalFormType ?type .
}</rdfs:comment>
        <rdfs:comment xml:lang="it">Questa proprietà collega un modulo di approfondimento al tipo di modulo (Unità Stratigrafica, Tipo Murario, Epigrafia).</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an additional form to its type (Stratigraphic Unit, Epigraphy, Wall Typology).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="it">ha tipo di modulo di approfondimento</rdfs:label>
        <rdfs:label xml:lang="en">has additional form type</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: DA/APP/APPT</a-cat:iccdNormTag>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/catalogue/hasAlternativeIdentifier -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/catalogue/hasAlternativeIdentifier">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/catalogue/isAlternativeIdentifierOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/catalogue/CatalogueRecord"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/catalogue/AlternativeIdentifier"/>
        <rdfs:comment xml:lang="en">Property used to associate a catalogue record with an identifier created in the context of information systems other than ICCD&apos;s SIGECweb.</rdfs:comment>
        <rdfs:comment xml:lang="it">Questa proprietà collega una scheda di catalogo a un codice che identifica la scheda di catalogo nell&apos;ambito di altri sistemi informativi, assegnato da enti diversi da ICCD.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="it">ha altro codice identificativo</rdfs:label>
        <rdfs:label xml:lang="en">has alternative identifier</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale 4.00: AC/ACC</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?thing core:hasIdentifier ?id .
}

WHERE {
?thing a-cat:hasAlternativeIdentifier ?id 
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/hasIdentifier"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/catalogue/hasCatalogueRecordVersion -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/catalogue/hasCatalogueRecordVersion">
        
        <core:constructQuery>CONSTRUCT {
?x a-cat:hasRecordVersion ?thing .
}

WHERE {
?x a-cat:hasCatalogueRecordVersion ?thing .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/catalogue/hasRecordVersion"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/catalogue/hasCatalogueRecordVersionRiT -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/catalogue/hasCatalogueRecordVersionRiT">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/RO/hasRiT"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/catalogue/isCatalogueRecordVersionRiTOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/catalogue/CatalogueRecordVersion"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/RO/TimeIndexedRole"/>
        <rdfs:comment xml:lang="it">Questa proprietà permette di associare una particolare versione di una scheda al ruolo nel tempo che un agente esercita nell&apos;ambito della redazione, dell&apos;aggiornamento o revisione della scheda.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property is used to associate a particular version of a catalogue record to the role in time of an agent that plays a role in updating the catalogue record.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="it">ha ruolo nel tempo</rdfs:label>
        <rdfs:label xml:lang="en">has role in time</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {
?x core:hasAgentRole ?y .
?y a core:AgentRole .

?x a-cat:hasCatalogueRecordVersionRiT ?y .
?y a a-cat:TimeIndexedRole .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/hasAgentRole"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/catalogue/hasCataloguingAgent -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/catalogue/hasCataloguingAgent">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/hasRelatedAgent"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/catalogue/isCataloguingAgentOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/catalogue/CatalogueRecordVersion"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://w3id.org/italia/onto/RO/hasRiT"/>
            <rdf:Description rdf:about="https://w3id.org/italia/onto/RO/isRoleInTimeOf"/>
        </owl:propertyChainAxiom>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la relazione che collega una versione di una scheda di catalogo a un agente che riveste un ruolo nelle attività di catalogazione di quella scheda. La relazione tra il ruolo e l&apos;agente che lo riveste è espressa, in maniera generica, nel nome della proprietà, che quindi ne fornisce una rappresentazione semplificata, con ridotta espressività. Questa relazione è poi specializzata da sottoproprietà. Nell&apos;ontologia questa relazione è modellata anche, in maniera più espressiva, dalla classe TimeIndexedRole, che permette di collegare l’ente, il suo ruolo e la sua corrispondente estensione temporale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property is used to associate a catalogue record to an agent playing a role in cataloguing activities.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="it">ha agente coinvolto nella catalogazione</rdfs:label>
        <rdfs:label xml:lang="en">has cataloguing agent</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?x a-lite:hasCataloguingAgent ?agent .
}

WHERE {
?x a-cat:hasCataloguingAgent ?agent .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasCataloguingAgent"/>
        <core:replacingQuery>select * where {
?x core:hasAgentRole ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/CataloguingAgent&gt; ;
core:hasAgent ?agent .
}</core:replacingQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/catalogue/hasCataloguingLevel -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/catalogue/hasCataloguingLevel">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasCharacteristic"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/catalogue/isCataloguingLevelOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/catalogue/CatalogueRecord"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/catalogue/CataloguingLevel"/>
        <rdfs:comment xml:lang="it">Questa proprietà permette di associare una scheda di catalogo al suo livello di catalogazione.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="it">ha livello di catalogazione</rdfs:label>
        <rdfs:label xml:lang="en">has cataloguing level</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>CD/LIR</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/catalogue/hasCulturalPropertyRecordResponsibleAgent -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/catalogue/hasCulturalPropertyRecordResponsibleAgent">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/hasRelatedAgent"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/catalogue/isResponsibleAgentOfCulturalPropertyRecord"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/catalogue/Record"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una scheda in cui si analizza un bene culturale per finalità diverse da quella della catalogazione del patrimonio all&apos;Ente o al soggetto che ha prodotto la scheda o che gestisce la banca dati di cui la scheda fa parte.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural property record to the agency or the person that created that record or manages the database where the record is.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="it">ha agente responsabile della scheda su bene culturale</rdfs:label>
        <rdfs:label xml:lang="en">has cultural property record responsible agent</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: AC/ACS/ACSE</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?x a-lite:hasResponsibleAgent ?agent .
}

WHERE {
?x a-cat:hasCulturalPropertyRecordResponsibleAgent ?agent .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasResponsibleAgent"/>
        <core:replacingQuery>select * where {
?x core:hasAgentRole ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/ResponsibleAgent&gt; ;
core:hasAgent ?agent .
}</core:replacingQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/catalogue/hasDigitalTranscriptionOperator -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/catalogue/hasDigitalTranscriptionOperator">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/catalogue/hasCataloguingAgent"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/catalogue/isDigitalTranscriptionOperatorOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/catalogue/CatalogueRecordVersion"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la relazione che collega una versione, relativa a trascrizione per informatizzazione, di una scheda di catalogo al relativo operatore. La relazione tra il ruolo e l&apos;ente che lo riveste è espressa nel nome della proprietà, che quindi ne fornisce una rappresentazione semplificata, con ridotta espressività. Nell&apos;ontologia questa relazione è modellata anche, in maniera più espressiva, dalla classe TimeIndexedRole, che permette di collegare l&apos;ente, il suo ruolo e la sua corrispondente estensione temporale.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="it">ha operatore di trascrizione per informatizzazione</rdfs:label>
        <rdfs:label xml:lang="en">has digital transcription operator</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>CM/RVM/RVMN</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?x a-lite:hasOperator ?agent .
}

WHERE {
?x a-cat:hasDigitalTranscriptorOperator ?agent .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasOperator"/>
        <core:replacingQuery>select * where {
?x core:hasAgentRole ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/Operator&gt; ;
core:hasAgent ?agent .
}</core:replacingQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/catalogue/hasDigitalTranscriptionResponsibleAgent -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/catalogue/hasDigitalTranscriptionResponsibleAgent">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/catalogue/hasCataloguingAgent"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/catalogue/isDigitalTranscriptionResponsibleAgentOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/catalogue/CatalogueRecordVersion"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la relazione che collega una versione, relativa a trascrizione per informatizzazione, di una scheda di catalogo al relativo ente/soggetto responsabile. La relazione tra il ruolo e l&apos;ente che lo riveste è espressa nel nome della proprietà, che quindi ne fornisce una rappresentazione semplificata, con ridotta espressività. Nell&apos;ontologia questa relazione è modellata anche, in maniera più espressiva, dalla classe TimeIndexedRole, che permette di collegare l&apos;ente, il suo ruolo e la sua corrispondente estensione temporale.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="it">ha ente o soggetto responsabile di trascrizione per informatizzazione</rdfs:label>
        <rdfs:label xml:lang="en">has digital transcription responsible agent</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>CM/RVM/RVME</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?x a-lite:hasResponsibleAgent ?agent .
}

WHERE {
?x a-cat:hasDigitalTranscriptionResponsibleAgent ?agent .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasResponsibleAgent"/>
        <core:replacingQuery>select * where {
?x core:hasAgentRole ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/ResponsibleAgent&gt; ;
core:hasAgent ?agent .
}</core:replacingQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/catalogue/hasImmediatePreviousVersion -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/catalogue/hasImmediatePreviousVersion">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/catalogue/hasPreviousVersion"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/catalogue/isImmediatePreviousVersionOf"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/catalogue/CatalogueRecordVersion"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/catalogue/CatalogueRecordVersion"/>
        <opla:isNativeTo rdf:resource="https://w3id.org/arco/pattern/catalogue-record-sequence/"/>
        <rdfs:comment xml:lang="en">Property used to associate a catalogue record version to its immediate previous version.</rdfs:comment>
        <rdfs:comment xml:lang="it">Questa proprietà associa una versione di una scheda alla sua versione immediatamente precedente.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="it">ha la versione precedente</rdfs:label>
        <rdfs:label xml:lang="en">has immediate previous version</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/catalogue/hasOfficialInCharge -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/catalogue/hasOfficialInCharge">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/catalogue/hasCataloguingAgent"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/catalogue/isOfficialInChargeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/catalogue/CatalogueRecordVersion"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la relazione che collega la prima versione di una scheda di catalogo al relativo funzionario responsabile. La relazione tra il ruolo e l&apos;ente che lo riveste è espressa nel nome della proprietà, che quindi ne fornisce una rappresentazione semplificata, con ridotta espressività. Nell&apos;ontologia questa relazione è modellata anche, in maniera più espressiva, dalla classe TimeIndexedRole, che permette di collegare l&apos;ente, il suo ruolo e la sua corrispondente estensione temporale.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="it">ha funzionario responsabile</rdfs:label>
        <rdfs:label xml:lang="en">has official in charge</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>CM/FUR</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?x a-lite:hasOfficialInCharge ?agent .
}

WHERE {
?x a-cat:hasOfficialInCharge ?agent .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasOfficialInCharge"/>
        <core:replacingQuery>select * where {
?x core:hasAgentRole ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/OfficialInCharge&gt; ;
core:hasAgent ?agent .
}</core:replacingQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/catalogue/hasPreviousVersion -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/catalogue/hasPreviousVersion">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/follows"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/catalogue/isPreviousVersionOf"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/catalogue/CatalogueRecordVersion"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/catalogue/CatalogueRecordVersion"/>
        <opla:isNativeTo rdf:resource="https://w3id.org/arco/pattern/catalogue-record-sequence/"/>
        <rdfs:comment xml:lang="en">Property used to associate a catalogue record version to its previous version.</rdfs:comment>
        <rdfs:comment xml:lang="it">Questa proprietà associa una versione di una scheda a una sua versione precedente.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="it">ha versione precedente</rdfs:label>
        <rdfs:label xml:lang="en">has previous version</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/catalogue/hasPrivacyLevel -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/catalogue/hasPrivacyLevel">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasCharacteristic"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/catalogue/isPrivacyLevelOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/catalogue/AccessProfile"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/catalogue/PrivacyLevel"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega il profilo di accesso di una scheda catalografica al livello di riservatezza dei dati contenutevi (basso livello di riservatezza, alto livello di riservatezza, medio livello di riservatezza).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="it">ha livello di riservatezza</rdfs:label>
        <rdfs:label xml:lang="en">has privacy level</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: AD/ADS</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/catalogue/hasPrivacyReason -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/catalogue/hasPrivacyReason">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/hasDescription"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/catalogue/isPrivacyReasonOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/catalogue/AccessProfile"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/catalogue/PrivacyReason"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega uno specifico profilo d&apos;accesso ai dati di una scheda catalografica alla motivazione che ha determinato l&apos;adozione di quel profilo d&apos;accesso (es.: scheda contenente dati liberamente accessibili, scheda contenente dati personali, scheda di bene di proprietà privata, scheda di bene a rischio, scheda di bene non adeguatamente sorvegliabile)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="it">ha motivazione di riservatezza</rdfs:label>
        <rdfs:label xml:lang="en">has privacy reason</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: AD/ADS/ADSM</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/catalogue/hasRecordVersion -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/catalogue/hasRecordVersion">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/catalogue/isRecordVersionOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/catalogue/Record"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/catalogue/RecordVersion"/>
        <rdfs:comment xml:lang="en">Property used to associate a catalogue record to one of its versions (e.g. after update)</rdfs:comment>
        <rdfs:comment xml:lang="it">Proprietà che permette di collegare una scheda di catalogo, intesa come oggetto informativo che descrive un bene culturale, a una sua versione (corrispondente a un particolare stato dovuto a operazioni di redazione, aggiornamento, revisione).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="it">ha versione</rdfs:label>
        <rdfs:label xml:lang="en">has version</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>CM/CMP; CM/RVM; CM/AGG</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/catalogue/hasResponsibleResearchAndCompilation -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/catalogue/hasResponsibleResearchAndCompilation">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/catalogue/hasCataloguingAgent"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/catalogue/isResponsibleResearchAndCompilationOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/catalogue/CatalogueRecordVersion"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la relazione che collega la prima versione di una scheda di catalogo al relativo responsabile ricerca e redazione. La relazione tra il ruolo e l&apos;ente che lo riveste è espressa nel nome della proprietà, che quindi ne fornisce una rappresentazione semplificata, con ridotta espressività. Nell&apos;ontologia questa relazione è modellata anche, in maniera più espressiva, dalla classe TimeIndexedRole, che permette di collegare l&apos;ente, il suo ruolo e la sua corrispondente estensione temporale.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="it">ha responsabile ricerca e redazione</rdfs:label>
        <rdfs:label xml:lang="en">has responsible research and compilation</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>CM/CMP/CMPN</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?x a-lite:hasResponsibleResearchAndCompilation ?agent .
}

WHERE {
?x a-cat:hasAdditionalFormResponsibleResearchAndCompilation ?agent .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasResponsibleResearchAndCompilation"/>
        <core:replacingQuery>select * where {
?x core:hasAgentRole ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/ResponsibleResearchAndCompilation&gt; ;
core:hasAgent ?agent .
}</core:replacingQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/catalogue/hasScientificDirector -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/catalogue/hasScientificDirector">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/catalogue/hasCataloguingAgent"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/catalogue/isScientificDirectorOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/catalogue/CatalogueRecordVersion"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la relazione che collega la prima versione di una scheda di catalogo al relativo referente verifica scientifica. La relazione tra il ruolo e l&apos;ente che lo riveste è espressa nel nome della proprietà, che quindi ne fornisce una rappresentazione semplificata, con ridotta espressività. Nell&apos;ontologia questa relazione è modellata anche, in maniera più espressiva, dalla classe TimeIndexedRole, che permette di collegare l&apos;ente, il suo ruolo e la sua corrispondente estensione temporale.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="it">ha referente verifica scientifica</rdfs:label>
        <rdfs:label xml:lang="en">has scientific director</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>CM/RSR</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?x a-lite:hasScientificDirector ?agent .
}

WHERE {
?x a-cat:hasScientificDirector ?agent .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasScientificDirector"/>
        <core:replacingQuery>select * where {
?x core:hasAgentRole ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/ScientificDirector&gt; ;
core:hasAgent ?agent .
}</core:replacingQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/catalogue/hasUpdateOfficialInCharge -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/catalogue/hasUpdateOfficialInCharge">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/catalogue/hasCataloguingAgent"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/catalogue/isUpdateOfficialInChargeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/catalogue/CatalogueRecordVersion"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la relazione che collega una versione aggiornata di una scheda di catalogo al relativo funzionario responsabile. La relazione tra il ruolo e l&apos;ente che lo riveste è espressa nel nome della proprietà, che quindi ne fornisce una rappresentazione semplificata, con ridotta espressività. Nell&apos;ontologia questa relazione è modellata anche, in maniera più espressiva, dalla classe TimeIndexedRole, che permette di collegare l&apos;ente, il suo ruolo e la sua corrispondente estensione temporale.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="it">ha funzionario responsabile di aggiornamento</rdfs:label>
        <rdfs:label xml:lang="en">has update official in charge</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>CM/AGG/AGGF</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?x a-lite:hasOfficialInCharge ?agent .
}

WHERE {
?x a-cat:hasUpdateOfficialInCharge ?agent .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasOfficialInCharge"/>
        <core:replacingQuery>select * where {
?x core:hasAgentRole ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/OfficialInCharge&gt; ;
core:hasAgent ?agent .
}</core:replacingQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/catalogue/hasUpdateResponsibleAgent -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/catalogue/hasUpdateResponsibleAgent">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/catalogue/hasCataloguingAgent"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/catalogue/isUpdateResponsibleAgentOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/catalogue/CatalogueRecordVersion"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la relazione che collega una versione aggiornata di una scheda di catalogo al relativo ente/soggetto responsabile. La relazione tra il ruolo e l&apos;ente che lo riveste è espressa nel nome della proprietà, che quindi ne fornisce una rappresentazione semplificata, con ridotta espressività. Nell&apos;ontologia questa relazione è modellata anche, in maniera più espressiva, dalla classe TimeIndexedRole, che permette di collegare l&apos;ente, il suo ruolo e la sua corrispondente estensione temporale.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="it">ha ente o soggetto responsabile di aggiornamento</rdfs:label>
        <rdfs:label xml:lang="en">has update responsible agency or person</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>CM/AGG/AGGE</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?x a-lite:hasResponsibleAgent ?agent .
}

WHERE {
?x a-cat:hasUpdateResponsibleAgent ?agent .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasResponsibleAgent"/>
        <core:replacingQuery>select * where {
?x core:hasAgentRole ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/ResponsibleAgent&gt; ;
core:hasAgent ?agent .
}</core:replacingQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/catalogue/hasUpdateResponsibleResearchAndCompilation -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/catalogue/hasUpdateResponsibleResearchAndCompilation">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/catalogue/hasCataloguingAgent"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/catalogue/isUpdateResponsibleResearchAndCompilationOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/catalogue/CatalogueRecordVersion"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la relazione che collega una versione aggiornata di una scheda di catalogo al relativo responsabile ricerca e redazione. La relazione tra il ruolo e l&apos;ente che lo riveste è espressa nel nome della proprietà, che quindi ne fornisce una rappresentazione semplificata, con ridotta espressività. Nell&apos;ontologia questa relazione è modellata anche, in maniera più espressiva, dalla classe TimeIndexedRole, che permette di collegare l&apos;ente, il suo ruolo e la sua corrispondente estensione temporale.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="it">ha responsabile di ricerca e redazione di aggiornamento</rdfs:label>
        <rdfs:label xml:lang="en">has update responsible research and compilation</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>CM/AGG/AGGN</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?x a-lite:hasResponsibleResearchAndCompilation ?agent .
}

WHERE {
?x a-cat:hasUpdateResponsibleResearchAndCompilation ?agent .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasResponsibleResearchAndCompilation"/>
        <core:replacingQuery>select * where {
?x core:hasAgentRole ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/ResponsibleResearchAndCompilation&gt; ;
core:hasAgent ?agent .
}</core:replacingQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/catalogue/hasUpdateScientificRevisor -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/catalogue/hasUpdateScientificRevisor">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/catalogue/hasCataloguingAgent"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/catalogue/isUpdateScientificRevisorOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/catalogue/CatalogueRecordVersion"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la relazione che collega una versione aggiornata di una scheda di catalogo al relativo referente verifica scientifica. La relazione tra il ruolo e l&apos;ente che lo riveste è espressa nel nome della proprietà, che quindi ne fornisce una rappresentazione semplificata, con ridotta espressività. Nell&apos;ontologia questa relazione è modellata anche, in maniera più espressiva, dalla classe TimeIndexedRole, che permette di collegare l&apos;ente, il suo ruolo e la sua corrispondente estensione temporale.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="it">ha referente verifica scientifica di aggiornamento</rdfs:label>
        <rdfs:label xml:lang="en">has update scientific revisor</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>CM/AGG/AGGR</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?x a-lite:hasScientificDirector ?agent .
}

WHERE {
?x a-cat:hasUpdateScientificRevisor ?agent .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasScientificDirector"/>
        <core:replacingQuery>select * where {
?x core:hasAgentRole ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/ScientificDirector&gt; ;
core:hasAgent ?agent .
}</core:replacingQuery>
    </owl:ObjectProperty>
    


