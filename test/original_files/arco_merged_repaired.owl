    <!-- https://w3id.org/arco/ontology/natural-specimen-description/internalReflection -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/arco/ontology/natural-specimen-description/internalReflection">
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
