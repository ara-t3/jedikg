        <rdfs:label xml:lang="it">è terreno di appoggio di</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/isSoilOccupiedBy"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/construction-description/isTechnicalSystemOf -->

