<?xml version="1.0"?>
<rdf:RDF xmlns="https://w3id.org/arco/ontology/arco#"
     xml:base="https://w3id.org/arco/ontology/arco"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:l0="https://w3id.org/italia/onto/l0/"
     xmlns:mu="https://w3id.org/italia/onto/MU/"
     xmlns:ns="http://www.w3.org/2006/vcard/ns#"
     xmlns:sm="https://w3id.org/italia/onto/SM/"
     xmlns:CLV="https://w3id.org/italia/onto/CLV/"
     xmlns:cis="http://dati.beniculturali.it/cis/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:poi="https://w3id.org/italia/onto/POI/"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:a-cd="https://w3id.org/arco/ontology/context-description/"
     xmlns:a-ce="https://w3id.org/arco/ontology/cultural-event/"
     xmlns:a-dd="https://w3id.org/arco/ontology/denotative-description/"
     xmlns:a-mi="https://w3id.org/arco/ontology/musical-instrument/"
     xmlns:adms="https://w3id.org/italia/onto/ADMS/"
     xmlns:arco="https://w3id.org/arco/ontology/arco/"
     xmlns:core="https://w3id.org/arco/ontology/core/"
     xmlns:dcat="http://www.w3.org/ns/dcat#"
     xmlns:foaf="http://xmlns.com/foaf/0.1/"
     xmlns:opla="http://ontologydesignpatterns.org/opla/"
     xmlns:prov="http://www.w3.org/ns/prov#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:a-cat="https://w3id.org/arco/ontology/catalogue/"
     xmlns:a-clo="https://w3id.org/arco/ontology/clothing-descritpion/"
     xmlns:a-con="https://w3id.org/arco/ontology/construction-description/"
     xmlns:a-loc="https://w3id.org/arco/ontology/location/"
     xmlns:a-spe="https://w3id.org/arco/ontology/natural-specimen-description/"
     xmlns:opla1="http://www.ontologydesignpatterns.org/opla/"
     xmlns:terms="http://purl.org/dc/terms/"
     xmlns:roapit="https://w3id.org/italia/onto/RO/"
     xmlns:tiapit="https://w3id.org/italia/onto/TI/">
    <owl:Ontology rdf:about="https://w3id.org/arco/ontology/arco">
        <owl:versionIRI rdf:resource="https://w3id.org/arco/ontology/arco/2.0"/>
        <opla:reusesPatternAsTemplate rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/classification.owl"/>
        <opla:reusesPatternAsTemplate rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/collectionentity.owl"/>
        <opla:reusesPatternAsTemplate rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/componency.owl"/>
        <opla:reusesPatternAsTemplate rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/partof.owl"/>
        <opla:reusesPatternAsTemplate rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/situation.owl"/>
        <dc:creator>Aldo Gangemi (ISTC-CNR, STLab)</dc:creator>
        <dc:creator>Margherita Porena (ISTC-CNR, STLab)</dc:creator>
        <dc:creator>Maria Chiara Frangipane (ISTC-CNR, STLab)</dc:creator>
        <dc:creator>Maria Letizia Mancinelli (MiBAC, ICCD)</dc:creator>
        <dc:creator>Valentina Presutti (ISTC-CNR, STLab)</dc:creator>
        <dc:description xml:lang="it">Questo è il modulo centrale della rete di ontologie di ArCo - Architettura della Conoscenza. Qui si modellano informazioni, relative al dominio dei beni culturali, considerate top-level. Vengono importati tutti gli altri moduli della rete.</dc:description>
        <dc:description xml:lang="en">The ArCo module is the root of the network ArCo - Architecture of Knowledge. It imports all the other modules and models top-level distinctions from the cultural heritage domain.</dc:description>
        <dc:language rdf:resource="http://publications.europa.eu/resource/authority/language/ENG"/>
        <dc:language rdf:resource="http://publications.europa.eu/resource/authority/language/ITA"/>
        <dc:title xml:lang="en">ArCo Ontology (ArCo network)</dc:title>
        <dc:title xml:lang="it">Ontologia ArCo (ArCo network)</dc:title>
        <terms:issued>2019-03-05</terms:issued>
        <terms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <terms:license rdf:resource="https://w3id.org/italia/controlled-vocabulary/licences/A21_CCBY40"/>
        <terms:modified>2023-12-01</terms:modified>
        <rdfs:comment xml:lang="it">Questo è il modulo centrale della rete di ontologie di ArCo - Architettura della Conoscenza. Qui si modellano informazioni, relative al dominio dei beni culturali, considerate top-level. Vengono importati tutti gli altri moduli della rete.
In questo modulo sono riusati come template i seguenti Ontology Design Patterns:
- http://www.ontologydesignpatterns.org/cp/owl/classification.owl
- http://www.ontologydesignpatterns.org/cp/owl/collectionentity.owl
- http://www.ontologydesignpatterns.org/cp/owl/componency.owl
- http://www.ontologydesignpatterns.org/cp/owl/partof.owl
- http://www.ontologydesignpatterns.org/cp/owl/situation.owl</rdfs:comment>
        <rdfs:comment xml:lang="en">The ArCo module is the root of the network ArCo - Architecture of Knowledge. It imports all the other modules and models top-level distinctions from the cultural heritage domain.
In this module the following Ontology Design Patterns have been used:
- http://www.ontologydesignpatterns.org/cp/owl/classification.owl
- http://www.ontologydesignpatterns.org/cp/owl/collectionentity.owl
- http://www.ontologydesignpatterns.org/cp/owl/componency.owl
- http://www.ontologydesignpatterns.org/cp/owl/partof.owl
- http://www.ontologydesignpatterns.org/cp/owl/situation.owl</rdfs:comment>
        <rdfs:label xml:lang="en">ArCo Ontology (ArCo network)</rdfs:label>
        <rdfs:label xml:lang="it">Ontologia ArCo (ArCo network)</rdfs:label>
        <owl:versionInfo xml:lang="en">Version 2.0</owl:versionInfo>
        <owl:versionInfo xml:lang="it">Versione 2.0</owl:versionInfo>
    </owl:Ontology>
    


