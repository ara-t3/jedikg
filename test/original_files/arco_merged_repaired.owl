        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/hasGrains"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/Grains"/>
