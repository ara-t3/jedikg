        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>Normativa trasversale: CD/NTC, AC/ACC, ACI, ACS/ACSC, AC/MOD/MODI; OG/OGT/OGTI; RO/ROF/ROFX, RO/CRF/CRFH, DO/BIB/BIBH, BIBK, NCUN, RE/RCG/RCGK, NCUN, NUCN, RCGH, RE/DSC/DSCK, NUCN, NCUN, DSCH, RE/FOI/FOID; AU/AUT/AUTH, AUTK, NUCN, NCUN; AU/AUF/AUFH, NUCN, NCUN; PD/PDF/PDFH; UB/INP/INPS: LC/LDC/LDCK, LDCG; LA/PRC/PRCK; MC/CMN/CMNN. MODI: CD/CDR, CDM. Normativa BDI: DU/DUC, DU/DUO/DUOC, DU/DUM/DUMC, DV/DVC, DV/DVO/DVOC, DV/DVM/DVMC, DF/DFC, DF/DFO/DFOC, DF/DFM/DFMC, AI/AIC, AI/AIO/AIOC, AI/AIM/AIMC, VI/VIC, VI/VIO/VIOC, VI/VIM/VIMC, FI/FIC, FI/FIO/FIOC, FI/FIM/FIMC</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/core/Location -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/core/Location">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Location"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta la posizione (e.g. di un &apos;entità culturale).</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the location of an entity (e.g. of a cultural entity).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="en">Location</rdfs:label>
        <rdfs:label xml:lang="it">Luogo</rdfs:label>
        <rdfs:label xml:lang="it">Posizione</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/core/Method -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/core/Method">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Description"/>
        <rdfs:comment xml:lang="it">Classe che rappresenta il concetto di metodo.</rdfs:comment>
        <rdfs:comment xml:lang="en">The class representing the concept of method.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="en">Method</rdfs:label>
        <rdfs:label xml:lang="it">Metodo</rdfs:label>
