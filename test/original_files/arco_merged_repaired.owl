    <!-- http://dati.beniculturali.it/cis/involvesCulturalEntity -->

    <owl:ObjectProperty rdf:about="http://dati.beniculturali.it/cis/involvesCulturalEntity"/>
    


    <!-- http://dati.beniculturali.it/cis/isHostedBySite -->

    <owl:ObjectProperty rdf:about="http://dati.beniculturali.it/cis/isHostedBySite"/>
    


    <!-- http://dati.beniculturali.it/cis/isInvolvedInCulturalEvent -->

    <owl:ObjectProperty rdf:about="http://dati.beniculturali.it/cis/isInvolvedInCulturalEvent"/>
    


    <!-- http://dati.beniculturali.it/cis/isRelatedToRiT -->

    <owl:ObjectProperty rdf:about="http://dati.beniculturali.it/cis/isRelatedToRiT"/>
    


    <!-- https://w3id.org/arco/ontology/arco/hasAlternativeDiscipline -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/arco/hasAlternativeDiscipline">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/arco/isAlternativeDisciplineOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/arco/CulturalProperty"/>
        <rdfs:range rdf:resource="http://dati.beniculturali.it/cis/SubjectDiscipline"/>
        <rdfs:comment xml:lang="it">Questa proprietà permette di associare un bene culturale a discipline scientifiche, alternative a quella principale, cui fa riferimento.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural property to a related scientific discipline, alternative to the main one.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/arco"/>
        <rdfs:label xml:lang="it">ha altra disciplina</rdfs:label>
        <rdfs:label xml:lang="en">has alternative discipline</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa PST: CT/CTA, versione 4.00: OG/CTA</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/arco/hasArchaeologicalMaterialCategory -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/arco/hasArchaeologicalMaterialCategory">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasCategory"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/arco/isArchaeologicalMaterialCategoryOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/arco/ArchaeologicalMaterial"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/arco/ArchaeologicalMaterialCategory"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un materiale archeologico alla sua categoria (es.: ceramiche, industria litica, intonaco, legno, etc.)</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the archaeological material to its category (e.g.: ceramics, plaster, lithic materials, etc.)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/arco"/>
        <rdfs:label xml:lang="it">ha categoria di materiale archeologico</rdfs:label>
        <rdfs:label xml:lang="en">has archaeological material category</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa TMA: MA/MAC/MACC</a-cat:iccdNormTag>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/hasCategory"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/arco/hasCartographicClassification -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/arco/hasCartographicClassification">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasClassification"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/arco/isCartographicClassificationOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/arco/CulturalProperty"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un bene culturale alla sua classificazione cartografica.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural property to its cartographic classification.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/arco"/>
        <rdfs:label xml:lang="it">ha classificazione cartografica</rdfs:label>
        <rdfs:label xml:lang="en">has cartographic classification</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: CT</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/arco/hasCartographicSymbol -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/arco/hasCartographicSymbol">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasConcept"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/arco/isCartographicSymbolOf"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una classificazione cartografica di un bene cultural al simbolo cartografico, in riferimento al tema.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cartographic classification of a cultural property to the cartographic symbol related to the theme.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/arco"/>
        <rdfs:label xml:lang="it">ha simbolo cartografico</rdfs:label>
        <rdfs:label xml:lang="en">has cartographic symbol</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: CT/CTM/CTMD</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/arco/hasCartographicTheme -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/arco/hasCartographicTheme">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasConcept"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/arco/isCartographicThemeOf"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una classificazione cartografica di un bene culturale al tema di riferimento.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cartographic classification of a cultural property to the cartographic theme.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/arco"/>
        <rdfs:label xml:lang="it">ha tema cartografico</rdfs:label>
        <rdfs:label xml:lang="en">has cartographic theme</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: CT/CTM/CTMT</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/arco/hasCataloguingAgency -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/arco/hasCataloguingAgency">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/arco/hasRelatedAgency"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/arco/isCataloguingAgencyOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/arco/CulturalProperty"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la relazione che collega un bene culturale al relativo ente schedatore. La relazione tra il ruolo e l&apos;ente che lo riveste è espressa nel nome della proprietà, che quindi ne fornisce una rappresentazione semplificata, con ridotta espressività. Nell&apos;ontologia questa relazione è modellata anche, in maniera più espressiva, dalla classe AgentRole, che permette di collegare l&apos;ente e il suo ruolo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural property to its cagaloguing agency. The relation is declared in the name of the property, but within the ontology this relation is also modeled, in a more expressive way, through the class AgentRole.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/arco"/>
        <rdfs:label xml:lang="it">ha ente schedatore</rdfs:label>
        <rdfs:label xml:lang="en">has cataloguing agency</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: CD/ESC</a-cat:iccdNormTag>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasCataloguingAgency"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/arco/hasCulturalPropertyCataloguingCategory -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/arco/hasCulturalPropertyCataloguingCategory">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasCategory"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/arco/isCulturalPropertyCataloguingCategoryOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/arco/CulturalProperty"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/arco/CulturalPropertyCataloguingCategory"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un bene culturale a una categoria basata su una valutazione soggettiva del catalogatore durante il processo di catalogazione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural property to a category based on a subjective evaluation of the cataloguing agent, during the cataloguing process.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/arco"/>
        <rdfs:label xml:lang="it">ha categoria di bene culturale basata su catalogazione</rdfs:label>
        <rdfs:label xml:lang="en">has cultural property cataloguing category</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: OG/OGT/OGTV</a-cat:iccdNormTag>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/hasCategory"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/arco/hasCulturalPropertyCategory -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/arco/hasCulturalPropertyCategory">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasCategory"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/arco/isCulturalPropertyCategoryOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/arco/CulturalProperty"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/arco/CulturalPropertyCategory"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un bene culturale alla sua categoria.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural property to its category.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/arco"/>
        <rdfs:label xml:lang="it">ha categoria</rdfs:label>
        <rdfs:label xml:lang="en">has cultural property category</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: OG/CTG -  Normativa AT: OG/OGT/OGTP - Normativa RA: OG/CLS - Normative CA e MA e Normativa VeAC: OG/OGT/OGTC</a-cat:iccdNormTag>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/hasCategory"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/arco/hasCulturalPropertyComponent -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/arco/hasCulturalPropertyComponent">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasComponent"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/arco/isCulturalPropertyComponentOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/arco/ComplexCulturalProperty"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/arco/CulturalProperty"/>
        <opla:isNativeTo>https://w3id.org/arco/pattern/cultural-property-component-of/</opla:isNativeTo>
        <rdfs:comment xml:lang="it">Questa proprietà collega un bene culturale complesso a una delle sue parti componenti.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural property to its components.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/arco"/>
        <rdfs:label xml:lang="it">ha parte componente di bene culturale</rdfs:label>
        <rdfs:label xml:lang="en">has cultural property component</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>OG/OGT/OGTP</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/arco/hasCulturalPropertyInventoryCategory -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/arco/hasCulturalPropertyInventoryCategory">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasCategory"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/arco/isCulturalPropertyInventoryCategoryOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/arco/CulturalProperty"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/arco/CulturalPropertyInventoryCategory"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un bene culturale a una categoria basata su una classificazione relativa a un repertorio riconosciuto dallo specifico ambito disciplinare.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural property to a category based on a classification related to an inventory approved by the specific subject area.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/arco"/>
        <rdfs:label xml:lang="it">ha categoria basata su repertorio</rdfs:label>
        <rdfs:label xml:lang="en">has cultural property inventory category</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: OG/OGT/OGTS</a-cat:iccdNormTag>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/hasCategory"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/arco/hasCulturalPropertyResidual -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/arco/hasCulturalPropertyResidual">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasPart"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/arco/isCulturalPropertyResidualOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/arco/CulturalProperty"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/arco/CulturalPropertyResidual"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un bene culturale alla/alle sua/e parte/i residuale/i.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural property to its residual.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/arco"/>
        <rdfs:label xml:lang="it">ha parte residuale di bene culturale</rdfs:label>
        <rdfs:label xml:lang="en">has cultural property residual</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>OG/OGT/OGTW</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/arco/hasHeritageProtectionAgency -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/arco/hasHeritageProtectionAgency">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/arco/hasRelatedAgency"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/arco/isHeritageProtectionAgencyOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/arco/CulturalProperty"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la relazione che collega un bene culturale al relativo ente competente per la tutela. La relazione tra il ruolo e l&apos;ente che lo riveste è espressa nel nome della proprietà, che quindi ne fornisce una rappresentazione semplificata, con ridotta espressività. Nell&apos;ontologia questa relazione è modellata anche, in maniera più espressiva, dalla classe AgentRole, che permette di collegare l&apos;ente e il suo ruolo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural property to its heritage protection agency. The relation is declared in the name of the property, but within the ontology this relation is also modeled, in a more expressive way, through the class AgentRole.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/arco"/>
        <rdfs:label xml:lang="it">ha ente competente per la tutela</rdfs:label>
        <rdfs:label xml:lang="en">has heritage protection agency</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: CD/ECP</a-cat:iccdNormTag>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasHeritageProtectionAgency"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/arco/hasMainDiscipline -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/arco/hasMainDiscipline">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/arco/isMainDisciplineOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/arco/CulturalProperty"/>
        <rdfs:range rdf:resource="http://dati.beniculturali.it/cis/SubjectDiscipline"/>
        <rdfs:comment xml:lang="it">Questa proprietà permette di associare un bene culturale alla disciplina scientifica più importante, o storicamente riconosciuta, cui fa riferimento.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural property to the main related scientific discipline.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/arco"/>
        <rdfs:label xml:lang="it">ha disciplina principale</rdfs:label>
        <rdfs:label xml:lang="en">has main discipline</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa PST: CT/CTP</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/arco/hasMibacScopeOfProtection -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/arco/hasMibacScopeOfProtection">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/arco/isMibacScopeOfProtectionOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/arco/CulturalProperty"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/arco/MibacScopeOfProtection"/>
        <rdfs:comment xml:lang="it">Questa proprietà associa un bene culturale all&apos;ambito di tutela nel quale ricade.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural property to ist MiBAC scope of protection</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/arco"/>
        <rdfs:label xml:lang="it">ha ambito di tutela</rdfs:label>
        <rdfs:label xml:lang="en">has MiBAC scope of protection</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: OG/AMB</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/arco/hasMusicalInstrumentClassification -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/arco/hasMusicalInstrumentClassification">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasClassification"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/arco/isMusicalInstrumentClassificationOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/arco/MusicHeritage"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/arco/MusicalInstrumentClassification"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un bene musicale a una classificazione con cui lo strumento può essere codificato.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property connects a cultural entity to a classification through which the instrument can be coded.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/arco/"/>
        <rdfs:label xml:lang="it">ha classificazione di strumento musicale</rdfs:label>
        <rdfs:label xml:lang="en">has musical instrument classification</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/isClassifiedBy"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/arco/hasNumismaticPropertyCategory -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/arco/hasNumismaticPropertyCategory">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasCategory"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/arco/isNumismaticPropertyCategoryOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/arco/NumismaticProperty"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/arco/NumismaticPropertyCategory"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un bene numismatico a una sua categoria.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a numismatic property to one of its categories.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/arco"/>
        <rdfs:label xml:lang="it">ha categoria di bene numismatico</rdfs:label>
        <rdfs:label xml:lang="en">has numismatic property category</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa NU 4.00: OG/OGT/OGTH</a-cat:iccdNormTag>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/hasCategory"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/arco/hasPhotographicHeritageClassification -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/arco/hasPhotographicHeritageClassification">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasClassification"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/arco/isPhotographicHeritageClassificationOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/arco/PhotographicHeritage"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/arco/PhotographicHeritageClassification"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un bene fotografico a una classificazione di un bene fotografico secondo un sistema di classificazione alternativo a Iconclass, che sia comunque riconosciuto e utilizzato a livello nazionale, o preferibilmente internazionale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property connects a photographic property to a photographic property&apos;s classification, according to to other classification systems as Iconclass. The system has to be recognised and used at national or preferably international level.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/arco"/>
        <rdfs:label xml:lang="it">ha classificazione di bene fotografico</rdfs:label>
        <rdfs:label xml:lang="en">has photographic heritage classification</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa F 4.00: SG/CLF</a-cat:iccdNormTag>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/hasClassificationInTime"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/arco/hasPhotographicHeritageClassificationType -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/arco/hasPhotographicHeritageClassificationType">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/arco/isPhotographicHeritageClassificationTypeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/arco/PhotographicHeritageClassification"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/arco/PhotographicHeritageClassificationType"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una classificazione di un bene fotografico al tipo di classificazione, relativamente a un sistema di classificazione alternativo a Iconclass, che sia comunque riconosciuto e utilizzato a livello nazionale, o preferibilmente internazionale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property connects a photographic property&apos;s classification to the classification type, according to to other classification systems as Iconclass. The system has to be recognised and used at national or preferably international level.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/arco"/>
        <rdfs:label xml:lang="it">ha tipo di classificazione di bene fotografico</rdfs:label>
        <rdfs:label xml:lang="en">has photographic heritage classification type</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa F: SG/CLF/CLFT</a-cat:iccdNormTag>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/hasClassificationSystem"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/arco/hasRFId -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/arco/hasRFId">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/arco/isRFIdOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/arco/RFId"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un oggetto a un identificatore a radiofrequenza RFId.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an object to an RFId.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/arco"/>
        <rdfs:label xml:lang="it">ha identificativo RFId</rdfs:label>
        <rdfs:label xml:lang="en">has RFId identifier</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale: RF/RFI/RFID</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/arco/hasReferenceCoinLegend -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/arco/hasReferenceCoinLegend">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasConcept"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/arco/isReferenceCoinLegendOf"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/arco/NumismaticProperty"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/arco/ReferenceCoinLegend"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un bene numismatico alla sua legenda tipo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a numismatic property with its reference coin legend.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/arco"/>
        <rdfs:label xml:lang="it">ha legenda tipo</rdfs:label>
        <rdfs:label xml:lang="en">has reference coin legend</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa NU: OG/OGT/OGTL</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/arco/hasRelatedAgency -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/arco/hasRelatedAgency">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/arco/isRelatedAgencyOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/arco/CulturalProperty"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://w3id.org/arco/ontology/core/hasAgentRole"/>
            <rdf:Description rdf:about="https://w3id.org/arco/ontology/core/hasAgent"/>
        </owl:propertyChainAxiom>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la relazione che collega un bene culturale a un ente che riveste un ruolo nei suoi confronti. La relazione tra il ruolo e l&apos;ente che lo riveste è espressa, in maniera generica, nel nome della proprietà, che quindi ne fornisce una rappresentazione semplificata, con ridotta espressività. La proprietà è specializzata per mezzo di sottoproprietà. Nell&apos;ontologia questa relazione è modellata anche, in maniera più espressiva, dalla classe AgentRole, che permette di collegare l&apos;ente e il suo ruolo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural property to an agency that plays a role related to the cultural property. The relation is declared in the name of the property, but within the ontology this relation is also modeled, in a more expressive way, through the class AgentRole.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/arco"/>
        <rdfs:label xml:lang="it">ha ente collegato</rdfs:label>
        <rdfs:label xml:lang="en">has related agency</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {
?x &lt;https://w3id.org/arco/ontology/arco-lite/hasRelatedAgent&gt; ?y .
}
WHERE {
?x arco:hasRelatedAgency ?y .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasRelatedAgent"/>
    </owl:ObjectProperty>
    


