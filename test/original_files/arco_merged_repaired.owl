    <!-- https://w3id.org/arco/ontology/context-description/Acquisition -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/Acquisition">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/EventOrSituationInTime"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasAgentRole"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/core/AgentRole"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/AcquisitionType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/isAcquisitionOf"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/arco/ontology/context-description/AcquisitionType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/onto/TI/atTime"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/italia/onto/TI/TimeInterval"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/acquisitionCost"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/acquisitionLocation"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:description xml:lang="en">An example of usage of the class &apos;Acquisition&apos; is the following:

resource:Acquisition/1200865053-acquisition-1
        a  cd:Acquisition ;
        rdfs:label  &quot;Acquisizione 1 del bene culturale: 1200865053&quot;@it ;
        core:hasType resource:AcquisitionType/donazione ;
        core:hasAgentRole resource:AgentRole/1200865053-1-transferor ;
        tiapit:time &quot;1963&quot; .
resource:AgentRole/1200865053-1-transferor
        core:hasRole resource:Role/Transferor
        core:hasAgent resource:Agent/auriti-giacinto.</dc:description>
        <dc:description xml:lang="it">Un esempio d&apos;uso della classe &apos;Acquisizione&apos; è il seguente:

resource:Acquisition/1200865053-acquisition-1
        a  cd:Acquisition ;
        rdfs:label  &quot;Acquisizione 1 del bene culturale: 1200865053&quot;@it ;
        core:hasType resource:AcquisitionType/donazione ;
        core:hasAgentRole resource:AgentRole/1200865053-1-transferor ;
        tiapit:time &quot;1963&quot; .
resource:AgentRole/1200865053-1-transferor
        core:hasRole resource:Role/Transferor
        core:hasAgent resource:Agent/auriti-giacinto.</dc:description>
        <rdfs:comment xml:lang="it">Questa classe rappresenta un evento in cui un bene culturale è stato acquisito e si trova in una certa condizione giuridica.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a situation in which a cultural property is acquired, passing from an owner to another, and has a particular legal situation.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Acquisition</rdfs:label>
        <rdfs:label xml:lang="it">Acquisizione</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: TU/ACQ. BDI: DU/DUQ, DV/DVQ, DF/DFQ, AI/AIQ, VI/VIQ, FI/FIQ</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/AcquisitionType -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/AcquisitionType">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Type"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il tipo di acquisizione (es.: acquisto, alienazione, confisca, donazione) che ha interessato il bene culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the type of acquisition (e.g. purchase, donation, etc.) of a cultural property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Acquisition type</rdfs:label>
        <rdfs:label xml:lang="it">Tipo di acquisizione</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: TU/ACQ/ACQT. BDI: DU/DUQ/DUQT, DV/DVQ/DVQT, DF/DFQ/DFQT, AI/AIQ/AIQT, VI/VIQ/VIQT, FI/FIQ/FIQT</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/Age -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/Age">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/EventOrSituationInTime"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/AgeType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/isAgeOf"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/ageValue"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/informationSource"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta l&apos;età di un &apos;entità (animale, vegetale, minerale).</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the age of an entity (animal, vegetal, mineral).</rdfs:comment>
        <rdfs:label xml:lang="en">Age</rdfs:label>
        <rdfs:label xml:lang="it">Età</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BNPE: SR/SRL/SRLE, SR/SRR/SRRE. ICCD Normativa AT: DA/SEM, BDI: AT/ATT/ATTE, AI/AIF/AIFH, VI/VIF/VIFH, FI/FIF/FIFH. Normativa SM: MU/MUT/MUTE</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/AgeInterpretation -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/AgeInterpretation">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/Interpretation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasAgeType"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/AgeType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasInterpretationCriterion"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/arco/ontology/context-description/InterpretationCriterion"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/ageValue"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta la stima dell&apos;età della morte di un reperto antropologico.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the interpretation of the age of a specimen.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Age interpretation</rdfs:label>
        <rdfs:label xml:lang="it">Interpretazione dell&apos;età</rdfs:label>
        
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BNPE: SR/SRL/SRLE, SR/SRR/SRRE. ICCD Normativa AT: DA/SEM</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?x a a-cd:Age .
}

WHERE {
?x a a-cd.AgeInterpretation .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/Age"/>
        <core:replacingQuery>select * where {
?x a-cd:hasAge ?age .
?age a-cd:ageValue ?literal ;
core:hasType ?type ;
core:informationSource ?info .

}</core:replacingQuery>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/AgeOfDeathInterpretation -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/AgeOfDeathInterpretation">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/Interpretation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/isAgeOfDeathInterpretationOf"/>
                <owl:someValuesFrom rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/ageOfDeath"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta la stima dell&apos;età della morte di un reperto antropologico.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the interpretation of the age of death of an anthropological material.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Age of death interpretation</rdfs:label>
        <rdfs:label xml:lang="it">Interpretazione dell&apos;età della morte</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa AT: DA/SEM</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?x a a-cd:Age .
}

WHERE {
?x a a-cd.AgeOfDeathInterpretation .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/Age"/>
        <core:replacingQuery>select * where {
?x a-cd:hasAge ?age .
?age a-cd:ageValue ?literal ;
core:hasType ?type ;
core:informationSource ?info .

}</core:replacingQuery>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/AgeType -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/AgeType">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Type"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il tipo di età associata a un esemplare .</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the type of age of a specimen.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Age type</rdfs:label>
        <rdfs:label xml:lang="it">Tipo di età</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/AlternativeAuthorshipAttribution -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/AlternativeAuthorshipAttribution">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/AuthorshipAttribution"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasAttributedAuthor"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta un&apos;attribuzione di autore superata, alternativa o tradizionale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents an authorship attribution alternative to the preferred one.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/context-description"/>
        <rdfs:label xml:lang="en">Alternative Authorship Attribution</rdfs:label>
        <rdfs:label xml:lang="it">Attribuzione Alternativa di Autore</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>AU/AAT</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?x a a-cd:Responsibility ;
a-cd:alternativeOrOutdatedResponsibility &quot;True&quot; .
}

WHERE {
?x a a-cd:AlternativeAuthorshipAttribution .
}</core:constructQuery>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/AlternativeDating -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/AlternativeDating">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/Dating"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasAlternativeDatingType"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/AlternativeDatingType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/AlternativeDatingType -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/AlternativeDatingType">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Type"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il tipo di datazione alternativa che può riguardare un bene culturale (es.: altro metodo di datazione, datazione superata)</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the type of alternative dating of a cultural property (different dating, obsolete dating, other method dating)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Alternative dating type</rdfs:label>
        <rdfs:label xml:lang="it">Tipo di datazione alternativa</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale: DT/ADT/ADTT.</a-cat:iccdNormTag>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/Type"/>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/Anomaly -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/Anomaly">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/EventOrSituationInTime"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/isAnomalyOf"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/PhotoInterpretationRendering"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasAnomalyOrigin"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/AnomalyOrigin"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasClassification"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/AnomalyClassification"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/AnomalyType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta un&apos;anomalia rilevata nel corso di una fotointerpretazione o fotorestituzione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents an anomaly detected during a photo interpretation or rendering.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Anomalia</rdfs:label>
        <rdfs:label xml:lang="en">Anomaly</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: RE/FOI/FOIA</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/AnomalyClassification -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/AnomalyClassification">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Classification"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta la classificazione di un&apos;anomalia.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the classification of an anomaly.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Anomaly classification</rdfs:label>
        <rdfs:label xml:lang="it">Classificazione di anomalia</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">instable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: RE/FOI/FOIF</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/AnomalyOrigin -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/AnomalyOrigin">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/CulturalEntityCharacteristic"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/hasAnomalyOrigin"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/Anomaly"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://w3id.org/arco/ontology/context-description/CulturalPropertyStage"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta l&apos;origine dell&apos;anomalia rilevata nell&apos;indagine di fotointerpretazione o fotorestituzione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the anomaly origin of the photo interpretation rendering.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Anomaly origin</rdfs:label>
        <rdfs:label xml:lang="it">Origine dell&apos;anomalia</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: RE/FOI/FOIA</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/AnomalyType -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/AnomalyType">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Type"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il tipo di anomalia (puntuale, lineare, areale) rilevata durante una fotointerpretazione o fotorestituzione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the type of anomaly (line anomaly, point anomaly, polygon anomaly) observed during a photo interpretation or rendering survey.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Anomaly type</rdfs:label>
        <rdfs:label xml:lang="it">Tipo di anomalia</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: RE/FOI/FOIQ</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/ArchaeologicalExcavation -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/ArchaeologicalExcavation">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/Survey"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasStratigraphicUnit"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/StratigraphicUnit"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasTomb"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/Tomb"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasIdentifier"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/core/Identifier"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/areaRoomSquare"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta un tipo particolare di indagine su bene culturale, ovvero uno scavo archeologico, inteso come scavo stratigrafico.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a particular type of survey on a cultural property, that is an archaeological (stratigraphic) excavation.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Archaeological excavation</rdfs:label>
        <rdfs:label xml:lang="it">Scavo archeologico</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: RE/DSC</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/ArchaeologicalFieldSurvey -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/ArchaeologicalFieldSurvey">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/Survey"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasIdentifier"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/core/Identifier"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/environmentalState"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta un tipo particolare di indagine su bene culturale, ovvero una ricognizione archeologica, intesa come ricognizione di superficie.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a particular type of survey on a cultural property, that is an archaeological field survey, limited to the surface.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Archaeological field survey</rdfs:label>
        <rdfs:label xml:lang="it">Ricognizione archeologica</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: RE/RCG</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/ArchaeologicalPropertySurvey -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/ArchaeologicalPropertySurvey">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/Survey"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/SurveyType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta un&apos;indagine su una tipologia particolare di bene archeologico, ovvero i reperti antropologici (es.: analisi istologica, analisi chimica, TC, etc.).</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a particular type of survey on a cultural property, that is a survey on anthropological materials (e.g.: chemical analysis, histological analysis, CT scan, etc.).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Archaeological property survey</rdfs:label>
        <rdfs:label xml:lang="it">Indagine su bene archeologico</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa AT 3.01: IN/INI</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/ArchaeologicalPropertySurveyType -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/ArchaeologicalPropertySurveyType">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/SurveyType"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il tipo di indagine su bene archeologico.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the type of archaeological property survey.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Archaeological property survey type</rdfs:label>
        <rdfs:label xml:lang="it">Tipo di indagine su bene archeologico</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa AT 3.01: IN/INI/INIT</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?x a a-cd:SurveyType .
}

WHERE {
?x a a-cd:ArchaeologicalPropertySurveyType .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/SurveyType"/>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/ArchaeometricDiagnosticSurvey -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/ArchaeometricDiagnosticSurvey">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/Survey"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/ArchaeometricDiagnosticSurveyType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta un tipo particolare di indagine su bene culturale, ovvero un&apos;indagine archeometrica e diagnostica (carotaggi, prospezioni geofisiche, analisi di vario tipo).</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a particular type of survey on a cultural property, that is an archaeometric and diagnostic survey (coring, geophysical prospecting, etc.).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Archaeometric and diagnostic survey</rdfs:label>
        <rdfs:label xml:lang="it">Indagine archeometrica e diagnostica</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale 4.00: RE/IND - ICCD normative di versioni precedenti: RE/AIN</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/ArchaeometricDiagnosticSurveyType -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/ArchaeometricDiagnosticSurveyType">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/SurveyType"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il tipo di indagine archeometrica e diagnostica (es.: analisi della malta, carotaggio, termografia, etc.)</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the type of archaeometric and diagnostic survey (e.g. coring)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Archaeometric diagnostic survey type</rdfs:label>
        <rdfs:label xml:lang="it">Tipo di indagine archeometrica e diagnostica</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale 4.00: RE/IND/INDI - ICCD normative di versioni precedenti: RE/AIN/AINT</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/ArchivalFonds -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/ArchivalFonds">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/ArchivalRecordSet"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasComponent"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/ArchivalSeries"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <opla:isNativeTo rdf:resource="http://mklab.iti.gr/pericles/BornDigitalArchives_ODP.owl"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta un fondo archivistico.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents an archival fonds.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Archival fonds</rdfs:label>
        <rdfs:label xml:lang="it">Fondo archivistico</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa F: UB/UBF/UBFP</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/ArchivalRecord -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/ArchivalRecord">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/isPartOf"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/ArchivalRecordSet"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/onto/l0/identifier"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <opla:isNativeTo rdf:resource="http://mklab.iti.gr/pericles/BornDigitalArchives_ODP.owl"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta una unità documentaria che fa parte di una unità archivistica complessa.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the archival record that is part of an archival record set.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Archival record</rdfs:label>
        <rdfs:label xml:lang="it">Unità documentaria</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa F: UB/UBF</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/ArchivalRecordSet -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/ArchivalRecordSet">
        <rdfs:subClassOf rdf:resource="http://dati.beniculturali.it/cis/CollectionCulEnt"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasTitle"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/Title"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/isCollectionIn"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/CollectionMembership"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasPart"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/arco/ontology/context-description/ArchivalRecord"/>
                            <rdf:Description rdf:about="https://w3id.org/arco/ontology/context-description/ArchivalRecordSet"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/onto/l0/identifier"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>CONSTRUCT {
?x a a-arch:ArchivalResource .
}

WHERE {
?x a a-cd:ArchivalRecordSet.
}</rdfs:comment>
        <rdfs:comment xml:lang="it">Questa classe rappresenta un&apos;unità archivistica complessa (fondo, serie, sottoserie, etc.) di cui un bene culturale può fare parte.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents an archival record set (fonds, series, subseries) of which a cultural property can be member.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Archival record set</rdfs:label>
        <rdfs:label xml:lang="it">Unità archivistica complessa</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa F: UB/UBF</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/ArchivalRecordSetMembership -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/ArchivalRecordSetMembership">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/CollectionMembership"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasMemberOfArchivalRecordSet"/>
                <owl:someValuesFrom rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/involvesCollection"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/ArchivalRecordSet"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/archivalRecordLocation"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/archivalRecordSetTitle"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta l&apos;appartenenza di un bene culturale a un&apos;unità archivistica complessa (fondo, serie, sottoserie, etc.).</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the membership of a cultural property in an archival record set.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Appartenenza a unità archivistica complessa</rdfs:label>
        <rdfs:label xml:lang="en">Archival record set membership</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa F: UB/UBF</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?x a a-cd:CollectionMembership .
}

WHERE {
?x a a-cd:ArchivalRecordSetMembership .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/CollectionMembership"/>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/ArchivalResource -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/ArchivalResource">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/documentationLocation"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta una risorsa archivistica</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents an archival resource</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Archival resource</rdfs:label>
        <rdfs:label xml:lang="it">Risorsa archivistica</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa F: UB/UBF. Normativa F: PD/SFI, SSI. Normativa FF: PAC</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/ArchivalSeries -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/ArchivalSeries">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/ArchivalRecordSet"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasComponent"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/ArchivalSubseries"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/isComponentOf"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/ArchivalFonds"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <opla:isNativeTo rdf:resource="http://mklab.iti.gr/pericles/BornDigitalArchives_ODP.owl"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta una serie archivistica.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents an archival series.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Archival series</rdfs:label>
        <rdfs:label xml:lang="it">Serie archivistica</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa F: UB/UBF/UBFS</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/ArchivalSubseries -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/ArchivalSubseries">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/ArchivalRecordSet"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasComponent"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/ArchivalUnit"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/isComponentOf"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/ArchivalSeries"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta una sottoserie archivistica, ovvero una partizione interna alla serie.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents an archival subseries, that is component of an archival series.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Archival subseries</rdfs:label>
        <rdfs:label xml:lang="it">Sottoserie archivistica</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa F: UB/UBF/UBFT</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/ArchivalUnit -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/ArchivalUnit">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/ArchivalRecordSet"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/isComponentOf"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/ArchivalSubseries"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        
        <a-cat:iccdNormTag>Normativa F: UB/UBF/UBFU</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/AudioRecording -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/AudioRecording">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/Recording"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta la registrazione audio di un&apos;entità culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents an audio recording of a cultural entity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Audio recording</rdfs:label>
        <rdfs:label xml:lang="it">Registrazione audio</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BDI: DU, AI</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/AuthorshipAttribution -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/AuthorshipAttribution">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/Interpretation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasAttributedAuthor"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasInterventionRole"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/italia/onto/RO/Role"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasAttributedAuthor"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/preferredAuthorshipAttribution"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta l&apos;attribuzione di un autore o di una responsabilità per la creazione di un bene culturale, cioè le informazioni relative ai soggetti (persone singole o enti collettivi) intervenuti nella realizzazione del bene e/o all&apos;ambito culturale di riferimento.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the attribution of authorship or a responsibility for the creation of a cultural property, referring to the agents that played a role in the creation of the cultural property or to the reference cultural scope.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Attribuzione di Autore o responsabilità</rdfs:label>
        <rdfs:label xml:lang="it">Attribuzione di autore</rdfs:label>
        <rdfs:label xml:lang="it">Attribuzione di responsabilità</rdfs:label>
        <rdfs:label xml:lang="en">Authorship Attribution</rdfs:label>
        <rdfs:label xml:lang="en">Responsibility attribution</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale: AU/AAT; AU/ATB; AU/AUT. ICCD Normative F e FF: PD/PDF</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?x a a-cd:Responsibility .
}

WHERE {
?x a a-cd:AuthorshipAttribution .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/Responsibility"/>
        <core:replacingQuery>select * {
?x a-cd:hasResponsibility ?respo .
?respo a a-cd:Responsibility ;
a-cd:hasCulturalScope ?cultscope ;
a-cd:hasInterventionRole ?role ;
a-cd:hasAgentWithResponsibility ?agent;
a-cd:informationSource ?info ;
a-cd:alternativeOrOutdatedResponsibility, a-cd:mainResponsibility ?bool .
}</core:replacingQuery>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/BibliographicWork -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/BibliographicWork">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasCopyright"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/Copyright"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasEdition"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/Edition"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasTitle"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/Title"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasAgentRole"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/core/AgentRole"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta un&apos;opera biblioglarfica.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a bibliographic work.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Bibliographic work</rdfs:label>
        <rdfs:label xml:lang="it">Opera bibliografica</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/Bibliography -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/Bibliography">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/isBibliographicSourceOf"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasEdition"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/Edition"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasCategory"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/BibliographyCategory"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/BibliographyType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/completeBibliographicReference"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/abbreviation"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/bibliographyICCDIdentifier"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/specifications"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/onto/SM/URL"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta un riferimento bibliografico che riguarda un&apos;entità, per esempio un bene culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the bibliography of an entity, e.g. a cultural property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Bibliografia</rdfs:label>
        <rdfs:label xml:lang="en">Bibliography</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale 4.00: DO/BIB; RE/RCG/RCGS - Normative VeAC e AT 3.01: DO/BIB; DO/BSE.</a-cat:iccdNormTag>
        <core:replacingQuery>select * {
?thing a-cd:hasBibliographicSource ?edition .
?edition a a-cd:Edition ;
core:hasBibliographicEntry ?NEWbibEntry ;
a-cd:hasTitle ?NEWtitle .
?NEWbibEntry a BibliographicEntry ;
a-cd:completeBibliographicReference ?ref .
}</core:replacingQuery>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/BibliographyCategory -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/BibliographyCategory">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Category"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta la categoria della bibliografia. Nel contesto delle normative per la catalogazione ICCD, questa classe ha associato un vocabolario chiuso definito in tre tipi: bibliografia specifica, bibliografia di confronto e bibliografia di corredo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the category associated to a bibliography (e.g. accompanying bibliography, comparative bibliography, specific bibliography).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Bibliography category</rdfs:label>
        <rdfs:label xml:lang="it">Genere della bibliografia</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normative OA-OAC-MI-D-S-RA-TMA-CA-MA-SAS-SI 3.00: DO/BIB/BIBX - Normative VeAC e AT 3.01: DO/BSE/BSEX.</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?x a-cd:hasBibliographicSource| a-cd:hasSpecificBibliographicSource| a-cd:ContextBibliographicSource| a-cd:hasComparisonBibliographicSource ?ed .
}

WHERE {
?x a-cd:hasBibliography ?bib .
?bib a-cd:hasCategory ?bibCat ;
a-cd:hasEdition ?ed .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/hasBibliographicSource"/>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/hasComparisonBibliographicSource"/>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/hasContextBibliographicSource"/>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/hasSpecificBibliographicSource"/>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/BibliographyType -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/BibliographyType">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Type"/>
        <owl:disjointWith rdf:resource="https://w3id.org/arco/ontology/context-description/DocumentationType"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il tipo di riferimento bibliografico.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the type of bibliography.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Bibliography type</rdfs:label>
        <rdfs:label xml:lang="it">Tipo di bibliografia</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale DO/BIB/BIBF - Normative VeAC e AT 3.01: DO/BSE/BSES.</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?x a-cd:hasBibliographicSource|
a-cd:hasSpecificBibliographicSource|
a-cd:hasContextBibliographicSource|
a-cd:hasComparisonBibliographicSource ?y .
}

WHERE {
?x a-cd:hasBibliography ?y .
?y core:hasType a-cd:BibliographyType .
}</core:constructQuery>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/BiologicalTaxon -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/BiologicalTaxon">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Classification"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/isBiologicalTaxonOf"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasGenus"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/arco/ontology/context-description/Genus"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasSpecies"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/arco/ontology/context-description/Species"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasSubspecies"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/arco/ontology/context-description/Subspecies"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta una tassonomia biologica, ossia i criteri con cui si ordinano gli organismi in un sistema di classificazione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a biological taxon.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Biological taxon</rdfs:label>
        <rdfs:label xml:lang="it">Tassonomia biologica</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa AT: OG/OGS</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-spe: &lt;https://w3id.org/arco/ontology/natural-specimen-description/&gt;

CONSTRUCT {
?x a a-spe:BiologicalTaxon .
}

WHERE {
?x a a-cd:BiologicalTaxon .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/BiologicalTaxon"/>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/BiologicalTaxonomy -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/BiologicalTaxonomy"/>
    


    <!-- https://w3id.org/arco/ontology/context-description/Certification -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/Certification">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/Documentation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/CertificationType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta una certificazione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents certification.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Certification</rdfs:label>
        <rdfs:label xml:lang="it">Certificazione</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BNM: CD/CTF</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/CertificationType -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/CertificationType">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Type"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il tipo di certificazione di un bene culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the type of certification of a cultural property .</rdfs:comment>
        <rdfs:label xml:lang="en">Certification type</rdfs:label>
        <rdfs:label xml:lang="it">Tipo di certificazione</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale BNM: DO/CTF/CTFT</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/ChangeOfAvailability -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/ChangeOfAvailability">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/EventOrSituationInTime"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/isChangeOfAvailabilityOf"/>
                <owl:someValuesFrom rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/ChangeOfAvailabilityType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:description xml:lang="en">An example of usage of the class &apos;Change of availability&apos; is the following: resource:ChangeOfAvailability/0900041230-change-of-availability
        a  cd:ChangeOfAvailability ;
        rdfs:label &quot;Change of availability of cultural property: 0900041230&quot;@en ;
        cd:hasChangeOfAvailabilityType resource:ChangeOfAvailabilityType/furto ;
        tiapit:time &quot;1998/11/15&quot; .</dc:description>
        <dc:description xml:lang="it">Un esempio d&apos;uso della classe &apos;Mutamento condizione materiale&apos; è il seguente: resource:ChangeOfAvailability/0900041230-change-of-availability
        a  cd:ChangeOfAvailability ;
        rdfs:label &quot;Mutamento condizione materiale del bene culturale: 0900041230&quot;@it ;
        cd:hasChangeOfAvailabilityType resource:ChangeOfAvailabilityType/furto ;
        tiapit:time &quot;1998/11/15&quot; .</dc:description>
        <rdfs:comment xml:lang="it">Questa classe rappresenta un evento che modifica la disponibilità materiale del bene culturale (es. per distruzione, furto, perdita, recupero)</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the change of availability of a cultural property (e.g.: theft, distruction, rescue, etc.)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Change of availability</rdfs:label>
        <rdfs:label xml:lang="it">Mutamento condizione materiale</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: TU/ALN</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/ChangeOfAvailabilityType -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/ChangeOfAvailabilityType">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Type"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il tipo di mutamento di condizione materiale di un bene culturale (es.: furto, distruzione, recupero).</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the type of change of availability of a cultural property (e.g. theft, distruction)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Change of availability type</rdfs:label>
        <rdfs:label xml:lang="it">Tipo di mutamento condizione materiale</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: TU/ALN/ALNT</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/Circumstance -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/Circumstance">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/EventOrSituationInTime"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/isCircumstanceOf"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/CircumstanceType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta un&apos;occasione che ha determinato una certa situazione, per esempio l&apos;occasione per cui è stato commissionato un bene culturale, l&apos;occasione che ha determinato la ripresa di un bene fotografico, l&apos;occasione d&apos;uso di un bene, l&apos;occasione di un bene demoetnoantropologico immateriale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a circumstance that influenced a particular situation, e.g. the circumstance for which a cultural property was commissioned, tha circumstance in which a cultural property was used, etc.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Circumstance</rdfs:label>
        <rdfs:label xml:lang="en">Occasion</rdfs:label>
        <rdfs:label xml:lang="it">Occasione</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale: UT/UTU/UTUO - Normativa BDM: UT/UTO; AU/CMM/CMMC - Normativa VeAC: AU/FRU/FRUC, OG/OGT/OGTL - Normativa F: LR/LRO - Normativa BDI: CA</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/CircumstanceType -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/CircumstanceType">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Type"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il tipo di occasione (es.: civile, religiosa).</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the circumstance type (e.g.: civil, religious)</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the type of circumstance (e.g. civil, religious)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Circumstance type</rdfs:label>
        <rdfs:label xml:lang="it">Tipo di circostanza</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BDI: CA/CAR; CA/CAC</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/CoinIssuance -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/CoinIssuance">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/EventOrSituationInTime"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/isCoinIssuanceOf"/>
                <owl:someValuesFrom rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasAgentRole"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/core/AgentRole"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta l&apos;emissione di una moneta, intesa come un evento collocato nel tempo, cui partecipano diversi agenti con diversi ruoli (Stato emittente, Zecca, Monetiere, etc.)</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the issuance of a coin, at a particular time and with different agents participanting to it (Mint, Issuing State, etc.)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Coin issuance</rdfs:label>
        <rdfs:label xml:lang="it">Emissione di moneta</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa NU: DA/AUE - ICCD Normativa OA (dopo il rilascio della specifica scheda NU nel 2004 la scheda OA non è stata più utilizzata per la catalogazione di monete e medaglie): AU/EDT- DA/AUE</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/CollectionMembership -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/CollectionMembership">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/Membership"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/involvesMember"/>
                <owl:someValuesFrom rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/involvesCollection"/>
                <owl:allValuesFrom rdf:resource="http://dati.beniculturali.it/cis/CollectionCulEnt"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/collectionLeavingReason"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/onto/l0/positionInSequence"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta l&apos;appartenenza di un bene culturale a una collezione, in un certo intervallo di tempo. Uno stesso bene culturale può aver fatto parte di più collezioni nel corso del tempo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the membership of a cultural property in a collection.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Appartenenza a Collezione</rdfs:label>
        <rdfs:label xml:lang="en">Collection Membership</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>UB/COL. ICCD Normativa F: UB/UBF. ICCD Normativa NU: OG/OGT/OGTR. ICCD Normativa F: PD/SFI; PD/SSI. Normativa BDI: DU/DUR, DU/DUS, VI/VIR, VI/VIV, AI/AIR, AI/AIS</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/Commission -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/Commission">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/EventOrSituationInTime"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasAgentRole"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/core/AgentRole"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasCircumstance"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/Circumstance"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasAgentRole"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/core/AgentRole"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/isCommissionOf"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta l&apos;individuazione della committenza relativa a un bene culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the commission of a cultural property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Commission</rdfs:label>
        <rdfs:label xml:lang="it">Committenza</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: AU/CMM</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/ConservationIntervention -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/ConservationIntervention">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/Intervention"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/framework"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta un particolare tipo di intervento che ha interessato un bene culturale, cioè un intervento a fini conservativi (termine che sostituisce l&apos;obsoleto &quot;restauro&quot;, presente nelle versioni di normativa precedenti alla 4.00). Per esempio: consolidamento, controllo microclimatico, trattamento biocida-disinfestazione, rimozione di elementi non originali, pulitura meccanica, pulitura chimica, protezione finale, riadesione parti, trattamento parti metalliche.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a conservation intervention on a cultural property (e.g.: microclimatic inspection, mechanical cleaning or with chemicals, pest control, etc.)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Conservation Intervention</rdfs:label>
        <rdfs:label xml:lang="it">Intervento a fini conservativi</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale 4.00: CO/RST quando RSTI=&apos;consolidamento&apos; or &apos;controllo microclimatico&apos; or &apos;trattamento biocida-disinfestazione&apos; or &apos;rimozione di elementi non originali&apos; or &apos;pulitura meccanica&apos; or &apos;pulitura chimica&apos; or &apos;protezione finale&apos; or &apos;riadesione parti&apos; or &apos;trattamento parti metalliche&apos; - Normative di versioni precedenti: RS/RST</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/Copy -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/Copy">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/DerivatedWork"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta la copia di un bene culturale, per esempio di una fotografia o di una stampa. Nel caso della fotografia, in questo caso viene esplicitamente dichiarata la responsabilità del fotografo principale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the copy of a cultural property, e.g. a copy of a photography or a print.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Copia</rdfs:label>
        <rdfs:label xml:lang="en">Copy</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa S 3: RO/COP; ICCD Normativa F: RO/CRF/CRFT = &apos;copia&apos;</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/Copyright -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/Copyright">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/isCopyrightOf"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasAgentRole"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/core/AgentRole"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/expiryDate"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/expired"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta i diritti d&apos;autore detenuti da un agente su un oggetto, per esempio un bene culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the copyright of an object, e.g. a cultural property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Copyright</rdfs:label>
        <rdfs:label xml:lang="it">Diritti d&apos;autore</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa F 4.00 e OAC: TU/CPR. Normativa BDI v. 3.01: DU/DUY; DV/DVY, DF/DFY, AI/AIY, VI/VIY, FI/FIY.
Versioni 4.00: DO/FTA/FTAY, DO/DRA/DRAY, DO/VDC/VDCY, DO/REG/REGY, DO/FNT/FNTY, DO/BIB/BIBY.</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/CulturalPropertyEstimate -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/CulturalPropertyEstimate">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/Estimate"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/isCulturalPropertyEstimateOf"/>
                <owl:someValuesFrom rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/estimatedCulturalPropertyValue"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta una stima di un bene culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the estimate of a cultural property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Cultural property estimate</rdfs:label>
        <rdfs:label xml:lang="it">Stima di bene culturale</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: UB/STI</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?x a a-cd:Estimate .
}
WHERE {
?x a-cd:CulturalPropertyEstimate .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/Estimate"/>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/CulturalPropertyStage -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/CulturalPropertyStage">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/CulturalEntityCharacteristic"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/isCulturalPropertyStageIn"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/RelatedWorkSituation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta lo stadio del bene catalogato in rapporto con l&apos;oggetto che ne costituisce una fase preparatoria o che ne rappresenta la fase finale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the stage of the catalogued cultural property related to the object which constitutes its preparatory or final stage.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Cultural property stage</rdfs:label>
        <rdfs:label xml:lang="it">Stadio del bene culturale</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normative RA, SMO, PST, S, OAC, OA, MI, D, NU, F: RO/ROF/ROFF</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?rws a-cd:hasRelationshipType ?reltype .
?reltype a a-cd:RelationshipType.
}

WHERE {
?rws a-cd:hasCulturalPropertyStage ?reltype .
?reltype a a-cd:CulturalPropertyStage .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/RelationshipType"/>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/CulturalScope -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/CulturalScope">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Topic"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/isCulturalScopeOf"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/Responsibility"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta l&apos;ambito culturale a cui può essere riferito un bene culturale. Per l&apos;ambito culturale si usano definizioni quali: ambito, cultura, periodo, produzione, scuola, manifattura, ecc.; a questi termini segue la qualificazione geografica o il nome dell&apos;ambito, della cultura, del periodo, della produzione, della scuola, della manifattura, ecc. Nel caso della normativa VeAC, questa classe rappresenta l&apos;ambito sartoriale/di produzione, ovvero il contesto sartoriale (oppure la manifattura, la maestranza, ecc.) a cui può essere ricondotta la realizzazione del bene catalogato.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the cultural scope related to a cultural property (e.g.: neoclassical, Milanese manifacturing, etc.)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Ambito culturale</rdfs:label>
        <rdfs:label xml:lang="en">Cultural Scope</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: AU/ATB. Normativa BDM e SM: AU/AUT/AUTC. BDI: AT/ATT/ATTB, AI/AIF/AIFB, VI/VIF/VOFB, FI/FI/FIFB. Normativa SM: MU/MUT/MUTB. Normativa AUT: AU/AUT/AUTU</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/CulturalScopeAttribution -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/CulturalScopeAttribution">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/AuthorshipAttribution"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasCulturalScope"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/CulturalScope"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta l&apos;attribuzione di un ambito culturale a cui può essere riferito il bene culturale. Per l&apos;ambito culturale si usano definizioni quali: ambito, cultura, periodo, produzione, scuola, manifattura, ecc.; a questi termini segue la qualificazione geografica o il nome dell&apos;ambito, della cultura, del periodo, della produzione, della scuola, della manifattura, ecc.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the attribution of a cultural scope, to which the cultural property is related (e.g.: neoclassical, Milanese manifacturing, etc.)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/context-description"/>
        <rdfs:label xml:lang="it">Attribuzione di Ambito Culturale</rdfs:label>
        <rdfs:label xml:lang="en">Cultural Scope Attribution</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>AU/ATB</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?x a a-cd:Responsibility ;
a-cd:hasCulturalScope ?cultScope .
}

WHERE {
?x a a-cd:CulturalScopeAttribution ;
a-cd:hasCulturalScope ?cultScope .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/Responsibility"/>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/CurrentInventory -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/CurrentInventory">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/Inventory"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasResponsibleForInsertion"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasSECIdentifier"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/SECIdentifier"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/RCSReason"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/culturalPropertyInventoryDescription"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/methodOfInsertion"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/provenance"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta un inventario patrimoniale, che registra le informazioni amministrative relative alla situazione patrimoniale del bene.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the current inventory of a cultural property, e.g. patrimonial informations.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Current Inventory</rdfs:label>
        <rdfs:label xml:lang="it">Inventario Patrimoniale</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale: UB/INP</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCTION {
?x a-cd:hasInvenotry ?inv .
?inv a-cd:current &quot;True&quot; .
}

WHERE {
?x a-cd:hasInventory ?inv .
?inv a a-cd:CurrentInventory .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/current"/>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/Dating -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/Dating">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/Interpretation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasTimeInterval"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/italia/onto/TI/TimeInterval"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasDatingEvent"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/italia/onto/l0/EventOrSituation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta la cronologia di un&apos;entità, cioè i dati cronologici che riguardano la storia dell&apos;entità (es.: un bene culturale o un&apos;opera collegata a un bene culturale). In relazione alle diverse situazioni, indicheranno un periodo esteso nel tempo oppure una singola data. Per ciascun bene viene fornita la cronologia della sua realizzazione, o, nel caso di immobili che presentano diverse fasi edilizie o diversi momenti di vita, un arco cronologico di riferimento; possono essere fornite anche altre notizie cronologiche relative ad altri eventi che hanno riguardato il bene (demolizione, progettazione, rimaneggiamenti, etc.)</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the dating of an entity, that is information about the chronology of the entity (e.g.: a cultural property), referring to a particular event (e.g.: the creation of the cultural property, its distruction, etc.)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Cronologia</rdfs:label>
        <rdfs:label xml:lang="en">Dating</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: DT - ICCD Normative F, RA, SMO, PST, S, OAC, OA, MI, D, NU: RO/ROF/ROFD</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/DatingType -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/DatingType">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Type"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta la tipologia di cronologia di un&apos;entità, cioè i dati cronologici che riguardano la storia dell&apos;entità (es.: un bene culturale o un&apos;opera collegata a un bene culturale). La cronologia caratterizza dalle sue diverse tipologie: &quot;preferita&quot;, &quot;alternativa&quot;, &quot;superata&quot; e &quot;altra forma di datazione/differente&quot;.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the type of dating of an entity, that is information about the chronology of the entity (e.g.: a cultural property), referring to a particular event (e.g.: the creation of the cultural property, its distruction, etc.). The type of dating characterizes the dating as &quot;preferred&quot;, &quot;alternative&quot;, &quot;obsolete&quot; and &quot;different&quot;.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description"/>
        <rdfs:label xml:lang="en">Dating type</rdfs:label>
        <rdfs:label xml:lang="it">Tipo di cronologia</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: DT/DTN-DTS-DTZ &quot;preferred&quot; 
ICCD Normativa Trasversale 4.00: DT/ADT/ADTT &quot;alternative/obsolete/different&quot;</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/DerivatedWork -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/DerivatedWork">
        <rdfs:subClassOf rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasAgentRole"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/core/AgentRole"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/DerivatedWorkType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/relatedWorkLocation"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta una derivazione del bene catalogato (reimpiego, copia, contraffazione, replica, controtipo) prodotta dallo stesso o da altro autore.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a derivated work of a cultural property (copy, reuse, facsimile, forgery), created by the same author or by another author.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Derivated work</rdfs:label>
        <rdfs:label xml:lang="it">Opera derivata</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa S 3: RO/COP - Normativa F: RO/CRF - Normative RA, SMO, PST, OAC, OA, MI, D, NU: RO/REI - Normative CA, MA: RO/RIU</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/DerivatedWorkType -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/DerivatedWorkType">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Type"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il tipo di opera derivata da un bene culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the type of derivated work of a cultural property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Derivated work type</rdfs:label>
        <rdfs:label xml:lang="it">Tipo di opera derivata</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa F: RO/CRF/CRFT - Normativa S: RO/ADL/ADLL - Normative RA, SMO, PST, S, OA, MI, D, NU: RO/REI/REIT - Normative CA, MA: RO/RIU/RIUT</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/DesignationInTime -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/DesignationInTime">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/EventOrSituationInTime"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/DesignationType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/isDesignationInTimeOf"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/onto/l0/name"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/current"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta una denominazione e/o dedicazione attestata nel corso del tempo per l&apos;entità in esame (per es: un bene culturale). 

Per la normativa FF, la classe rappresenta nello specifico la denominazione o il titolo del fondo attestati nel corso del tempo per il bene in esame; uno stesso fondo può avere più denominazioni/titoli nel corso del tempo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a certain entity&apos;s (e.g. cultural property) designation/denomination attested over time.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Denominazione nel tempo</rdfs:label>
        <rdfs:label xml:lang="en">Designation In Time</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>OG/OGT/OGTN. ICCD Normativa Trasversale 4.00: OG/OGD. - Normative A, BDM, PG 3: OG/OGA. - Normativa BNB: OG/OGT/OGTE e OG/OGT/OGTC. - Normativa NU: OG/OGT/OGTO. - Normativa CA, MA: OG/OGT/OGTU. Normativa SI: OG/OGT/OGTY. VeAC: OG/OGT/OGTS. - Normativa PG e A v.2: OG/OGT/OGTD</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/DesignationType -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/DesignationType">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Type"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il tipo di denominazione o dedicazione o, per la normativa FF, titolo, del bene (altra lingua, attribuita, attuale, dialettale, etc.)</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a cultural property&apos;s denomination or dedication type, or its title (i.e. other language, current, attributed, dialectal).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Designation Type</rdfs:label>
        <rdfs:label xml:lang="it">Tipo di denominazione</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale 4.00: OG/OGD/OGDT - Normative A, BDM, PG 3: OGA/OGAG. Normativa CA, MA: OG/OGT/OGTU</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/DetectionMethod -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/DetectionMethod">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Method"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/isDetectionMethodOf"/>
                <owl:someValuesFrom rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta la modalità di individuazione che ha consentito l&apos;individuazione di un bene culturale e che è indicativa della tipologia e della consistenza di alcune informazioni presenti nella scheda di catalogo che lo descrive (es.: carotaggio, dati di archivio, fonti orali).</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the method of detection that allowed the detection of a cultural property and which is indicative of the type and consistency of some information in the catalogue record that describes it (e.g.: coring, archive data, oral sources).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Detection Method</rdfs:label>
        <rdfs:label xml:lang="it">Metodo di individuazione</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: OG/OGM</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/Documentation -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/Documentation">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasLicense"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/License"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/isDocumentationOf"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasCopyright"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/Copyright"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/isAttachedDocumentationOf"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/isDocumentationOf"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasIdentifier"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/core/Identifier"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/DocumentationType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/onto/TI/atTime"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/italia/onto/TI/TimeInterval"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/caption"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/digitalFilename"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/documentationLocation"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/documentationTitle"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/onto/SM/URL"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:description xml:lang="en">An example of usage of one of the subclasses of the class &apos;Documentation&apos; is the following:
resource:AudioDocumentation/1200924650-audio-documentation-1
        a   cd:AudioDocumentation ;
        rdfs:label  &quot;Documentazione audio 1 del bene culturale: 1200924650&quot;@it ;
        lite:localIdentifier &quot;New_1401358982589&quot; ;
        core:hasType resource:DocumentationType/cassetta-dat ;
        dd:hasFormat resource:Format/cassetta-dat ;
        a-cd:isAttachedDocumentationOf resource:CulturalPropertyX.</dc:description>
        <dc:description xml:lang="it">Un esempio d&apos;uso di una delle sottoclassi della classe &apos;Documentazione&apos; è il seguente:
resource:AudioDocumentation/1200924650-audio-documentation-1
        a   cd:AudioDocumentation ;
        rdfs:label  &quot;Documentazione audio 1 del bene culturale: 1200924650&quot;@it ;
        lite:localIdentifier &quot;New_1401358982589&quot; ;
        core:hasType resource:DocumentationType/cassetta-dat ;
        dd:hasFormat resource:Format/cassetta-dat ;
        a-cd:isAttachedDocumentationOf resource:CulturalPropertyX.</dc:description>
        <rdfs:comment xml:lang="it">Classe che rappresenta la documentazione, specializzata nelle sottoclassi che rappresentano tipi specifici di documentazione di corredo (immagini, disegni e rilievi, cartografia, documenti audio e video, fonti e documenti editi e inediti, referenze bibliografiche).</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the documentation, with subclasses for each specific type of documentation (images, drawings, audio, video, etc.)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Documentation</rdfs:label>
        <rdfs:label xml:lang="it">Documentazione</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale 4.00: DO</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/DocumentationCategory -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/DocumentationCategory">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Category"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta la categoria della documentazione. Nel contesto delle normative per la catalogazione ICCD, questa classe ha un vocabolario chiuso definito in due tipi: documentazione allegata e documentazione esistente.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the category associated to a documentation (e.g. attached documentation, existing documentation).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Documentation category</rdfs:label>
        <rdfs:label xml:lang="it">Genere della documentazione</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">FTAX, DRAX, VDCX, REGX, FNTX, ADMX (solo v. 3.00 e 3.01)</a-cat:iccdNormTag>
        <core:replacingQuery>CONSTRUCT {
?x a-cd:hasAttachedDocumentation ?doc .
}

WHERE {
?x a-cd:hasDocumentation ?doc .
?doc core:hasCategory a-cd:AttachedDocumentation .
}</core:replacingQuery>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/DocumentationType -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/DocumentationType">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Type"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il tipo di documentazione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the type of documentation.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Documentation type</rdfs:label>
        <rdfs:label xml:lang="it">Tipo di documentazione</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">FTAP, DRAT, FNTP (+VDCP, REGP), ADMP (v. 3.00 e 3.01)</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/Edition -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/Edition">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/isEditionOf"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasAgentRole"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/core/AgentRole"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/onto/TI/atTime"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/italia/onto/TI/TimeInterval"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasTitle"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/Title"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasAgentRole"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/core/AgentRole"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/editionLocation"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta l&apos;edizione di un&apos;entità. Per esempio, l&apos;edizione cartacea o digitale di un bene culturale o di un&apos;opera collegata a un bene culturale (ad es. una pubblicazione contenente una stampa).</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the edition of an entity (e.g. the print edition of a cultural property).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/context-description"/>
        <rdfs:label xml:lang="en">Edition</rdfs:label>
        <rdfs:label xml:lang="it">Edizione</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>OAC: AU/EDT.  ICCD Normative VeAC e AT 3.01: DO/BSE/BSEN - Normativa MI, S 3.00: RO/ADL/ADLE. Normativa F: PD/PDF, PD/EDI, .</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/EligibleIntervention -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/EligibleIntervention">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/Intervention"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/isEligibleInterventionDefinedBy"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/UrbanPlanningInstrument"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il tipo di intervento ammesso da una normativa specifica, ovvero da un piano regolatore generale e particolareggiato o da un piano paesaggistico che interessa un bene culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the intervention considered eligible by a specific urban planning instrument related to a cultural property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Eligible intervention</rdfs:label>
        <rdfs:label xml:lang="it">Intervento ammesso</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: TU/STU/STUN</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?x a-cd:definesEligibleIntervention ?intType .
?intType a a-cd:InterventionType .
}

WHERE {
?x a-cd:hasEligibleIntervention ?int .
?int a-cd:hasInterventionType ?intType .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/InterventionType"/>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/Estimate -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/Estimate">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/EventOrSituationInTime"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasAgentRole"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/core/AgentRole"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/isEstimateOf"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/informationSource"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/estimatedValue"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il concetto di stima di un&apos;entità.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the concept of estimate.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Estimate</rdfs:label>
        <rdfs:label xml:lang="it">Stima</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: UB/STI, UB/INPA. Versioni precedenti: UB/CO/COLV,  UB/INV/INVS, TU/ACQ/ACQC</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/ExpiredCopyright -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/ExpiredCopyright">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/Copyright"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta i diritti d&apos;autore scaduti, relativi quindi a un oggetto, per esempio un bene culturale, diventato di pubblico dominio.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents an expired copyright, related to an object, e.g. a cultural property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Diritti d&apos;autore scaduti</rdfs:label>
        <rdfs:label xml:lang="en">Expired Copyright</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa F 4.00 e OAC: TU/CPR (if CPRD = &apos;scaduti&apos; or &apos;diritti scaduti&apos; or &apos;in pubblico dominio&apos;)</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCTION {
?x a-cd:hasCopyright ?copyright .
?copyright a-cd:expired &quot;True&quot; .
}

WHERE {
?x a-cd:hasCopyright ?copyright .
?copyright a a-cd:ExpiredCopyright .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/expired"/>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/ExportImportCertification -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/ExportImportCertification">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/isExportImportCertificationOf"/>
                <owl:someValuesFrom rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/ExportImportCertificationType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasAgentRole"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/core/AgentRole"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta una certificazione amministrativa per la circolazione e l&apos;esportazione/importazione di un bene culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the export/import certification of a cultural property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Certificazione di importazione o esportazione</rdfs:label>
        <rdfs:label xml:lang="en">Export import certification</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: TU/ESP</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/ExportImportCertificationType -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/ExportImportCertificationType">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Type"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il tipo di certificazione amministrativa di circolazione ed esportazione/importazione di un bene culturale (es.: attestato di libera circolazione, licenza di esportazione definitiva, ecc).</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the type of export/import certification of a cultural property (e.g.: temporary movement certification, temporary export license, free movement certification, etc.).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Export import certification type</rdfs:label>
        <rdfs:label xml:lang="it">Tipo di certificazione di esportazione o importazione</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: TU/ESP/ESPT</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/Facsimile -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/Facsimile">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/DerivatedWork"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta un controtipo di un bene culturale, specificamente di una fotografia, cioè una duplicazione realizzata nello stesso formato e nella stessa tecnica.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a facsimile of a cultural property, and in particular of a photography, that has the same format and technique.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Controtipo</rdfs:label>
        <rdfs:label xml:lang="en">Facsimile</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa F: RO/CRF/CRFT = &apos;controtipo&apos;</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/FairMarketCircumstance -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/FairMarketCircumstance">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/Circumstance"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta un&apos;occasione connessa a fiere, mercati, sagre.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a circumstance related to fairs, markets, festivals.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Fair market circumstance</rdfs:label>
        <rdfs:label xml:lang="it">Occasione legata a fiere e mercati</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BDI 4.00: CA/CAO/CAOF</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/FilmDocumentation -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/FilmDocumentation">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/Documentation"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta la documentazione video-cinematografica relativa a un oggetto, per esempio a un bene culturale</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the film documentation of an object, e.g. a cultural property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Documentazione video-cinematografica</rdfs:label>
        <rdfs:label xml:lang="en">Video documentation</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">VDC</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/FinalWork -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/FinalWork">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/PreparatoryOrFinalWork"/>
        <owl:disjointWith rdf:resource="https://w3id.org/arco/ontology/context-description/PreparatoryWork"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta un&apos;entità collegata a un bene culturale, che ne costituisce la fase finale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents an entity related to a cultural property, as its final stage.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Final work</rdfs:label>
        <rdfs:label xml:lang="it">Opera finale</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normative F, RA, SMO, PST, S, OAC, OA, MI, D, NU: se RO/ROF/ROFF rappresenta uno stadio del bene catalogato riconducibile a una fase preparatoria, per cui è possibile dedurre che l&apos;opera collegata al bene è una sua fase finale.</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/FindingContext -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/FindingContext">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/EventOrSituationInTime"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/isFindingContextOf"/>
                <owl:someValuesFrom rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/FindingContextType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasAssociatedObject"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/specifications"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il contesto di ritrovamento (tipo di contesto, elementi associati) di un bene culturale, e in particolare di un reperto antropologico.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the context (type of context, associated objects) in which a cultural property (in particular, an anthropological material) is found.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Contesto di rinvenimento</rdfs:label>
        <rdfs:label xml:lang="en">Finding context</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa AT 3.01: OG/OGC</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/FindingContextType -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/FindingContextType">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Type"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il tipo di contesto di rinvenimento di un bene culturale, e in particolare di un reperto antropologico (es.: sepoltura collettiva, sepoltura singola primaria, etc.)</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the type of finding context of a cultural property, and in particular of an anthropological material (e.g.: individual burial, common burial, etc.)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Finding context type</rdfs:label>
        <rdfs:label xml:lang="it">Tipo di contesto di rinvenimento</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa AT 3.01: OG/OGC/OGCT</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/Forgery -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/Forgery">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/DerivatedWork"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta una contraffazione di un bene culturale, cioè una riproduzione di un bene culturale da parte di un autore che non dichiari l&apos;autore dell&apos;originale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a forgery of a cultural property, that is a copy of a cultural property for which the author doesn&apos;t declare the original author.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Contraffazione</rdfs:label>
        <rdfs:label xml:lang="en">Forgery</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa F: RO/CRF/CRFT = &apos;contraffazione&apos;</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/Format -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/Format">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Description"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/isFormatOf"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/Documentation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il formato della documentazione (es.: jpeg, A0, pdf, audiocassetta, MP4).</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the documentation format (e.g. jpeg, pdf, MP4)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Format</rdfs:label>
        <rdfs:label xml:lang="it">Formato</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: DO/FTA/FTAF, DO/DRA/DRAF, DO/FNT/FNTR (+ DO/VDC/VDCP, DO/REG/REGP)</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-dd: &lt;hhtps://w3id.org/arco/ontology/denotative-description/&gt;

CONSTRUCT {
?x a a-dd:Format .
}

WHERE {
?x a a-cd:Format .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/Format"/>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/Fruition -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/Fruition">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/Interpretation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasUser"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/isFruitionOf"/>
                <owl:someValuesFrom rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasCircumstance"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/Circumstance"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta un&apos;occasione in cui il capo oggetto di catalogazione è stato indossato da una o più persone, sia perché ad esse destinato sia perché, ad esse pervenuto, hanno potuto riadattarlo a loro nuove esigenze.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a circumstance in which a garment, catalogued as a cultural property, was worn by one or more people.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Fruition</rdfs:label>
        <rdfs:label xml:lang="it">Fruizione</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>Normativa VeAC: AU/FRU</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?x a-cd:hasUse ?use .
?use a a-cd:Use .
}

WHERE {
?x a-cd:hasFruition ?use .
?use a a-cd:Fruition .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/Use"/>
        <core:replacingQuery>select * where {
?x a-cd:hasUse ?use .
?use a a-cd:Use;
a-cd:hasUseFunction ?usefun ;
a-cd:hasCircumstance ?circ ;
core:hasType ?useType ;
core:hasAgentRole ?agentrole ;
a-cd:useConditions ?literal .
}</core:replacingQuery>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/Genus -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/Genus">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Concept"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/isGenusIn"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/BiologicalTaxon"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta uno dei livelli di classificazione di una tassonomia biologica, ovvero il genere.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents one level of a biological taxon, the genus.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description"/>
        <rdfs:label xml:lang="it">Genere</rdfs:label>
        <rdfs:label xml:lang="en">Genus</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa AT: OG/OGS/OGSG. - Normativa BNB: RB/RBN/RBNA; SB/NAA/NAAA; SB/NAT/NATA</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-spe: &lt;https://w3id.org/arco/ontology/natural-specimen-description/&gt;

CONSTRUCT {
?x a a-spe:Genus .
}

WHERE {
?x a-cd:Genus .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/Genus"/>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/GraphicOrCartographicDocumentation -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/GraphicOrCartographicDocumentation">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/Documentation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasScale"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/Scale"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta la documentazione grafica e cartografica relativa a un oggetto, per esempio a un bene culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the graphic or cartographic documentation of an object, e.g. a cultural property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Documentazione grafica e cartografica</rdfs:label>
        <rdfs:label xml:lang="en">Graphic and cartographic documentation</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">DRA</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/Herbarium -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/Herbarium">
        <rdfs:subClassOf rdf:resource="http://dati.beniculturali.it/cis/CollectionCulEnt"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta un erbario</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents an herbarium</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Erbario</rdfs:label>
        <rdfs:label xml:lang="en">Herbarium</rdfs:label>
        
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>Normativa BNB: OG/OGT/OGTE</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/IndeterminateCircumstance -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/IndeterminateCircumstance">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/Circumstance"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta un&apos;occasione indeterminata, cioè quando il bene non è in rapporto con una precisa occasione o scadenza, ma si realizza in modo del tutto estemporaneo e contingente. Occasioni indeterminate possono essere, per esempio, un&apos;esecuzione musicale, una narrazione, un
gioco, etc.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents an indeterminate circumstance, when the cultural property is not related to a determinate circumstance, but takes place in an extemporaneous and contingent way (e.g.: a musical performance, a narration, a game).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Indeterminate circumstance</rdfs:label>
        <rdfs:label xml:lang="it">Occasione indeterminata</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BDI 4.00: CA/CAO/CAOI</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/Inspection -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/Inspection">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/Survey"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta un tipo particolare di indagine su bene culturale, ovvero un&apos;ispezione effettuata per constatare lo stato del bene.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a particular type of survey on a cultural property, that is an inspection carried out to verify the condition of a cultural property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Inspection</rdfs:label>
        <rdfs:label xml:lang="it">Ispezione</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: CM/ISP</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/Interpretation -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/Interpretation">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/EventOrSituationInTime"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasInterpretationCriterion"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/InterpretationCriterion"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:description xml:lang="en">An example of usage of one of the subclasses of the class &apos;Interpretation&apos; is the following:
resource:PreferredAuthorshipAttribution/1200865600-1 a           cd:PreferredAuthorshipAttribution ;
        rdfs:label  &quot;Preferred authorship attribution of cultural property: 1200865600&quot;@en ;
        cd:hasAttributedAuthor resource:Agent/cavaceppi-bartolomeo-1717-1799 ;
        cd:hasSource resource:Source/documentation .</dc:description>
        <dc:description xml:lang="it">Un esempio di utilizzo di una delle sottoclassi della classe &quot;Interpretazione&quot; è il seguente:
resource:PreferredAuthorshipAttribution/1200865600-1 a           cd:PreferredAuthorshipAttribution ;
        rdfs:label &quot;Attribuzione di autore preferita, maggiormente accreditata o convincente del bene: 1200865600&quot;@it ;
        cd:hasAttributedAuthor resource:Agent/cavaceppi-bartolomeo-1717-1799 ;
        cd:hasSource resource:Source/documentazione .</dc:description>
        <rdfs:comment xml:lang="it">Questa classe rappresenta una situazione in cui viene individuata e registrata da un agente una certa informazione o un gruppo di informazioni relativamente a un oggetto, per esempio a un bene culturale o a una sua parte, supportata da una fonte o motivazione. Per esempio, l&apos;attribuzione di autore, l&apos;individuazione della committenza o delle entità responsabili di fasi successive alla creazione di un bene culturale sono tutte interpretazioni basate su fonti.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a situation in which pieces of information related to an object (e.g.: a cultural property) are detected and recorded by an agent, based on a specific source or motivation (e.g.:ithe authorship attribution, commission, etc.)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Interpretation</rdfs:label>
        <rdfs:label xml:lang="it">Interpretazione</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>AU/CMM</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/InterpretationCriterion -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/InterpretationCriterion">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Description"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/isInterpretationCriterionOf"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il criterio o la motivazione che ha determinato una certa interpretazione (es.: bibliografia, documentazione, iscrizione).</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the criterion that motivated an interpretation (e.g. inscription, bibliography, documentation).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Criterio interpretativo</rdfs:label>
        <rdfs:label xml:lang="en">Interpretation criterion</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: AU/AUT/AUTM; AU/CMM/CMMF; AU/AAT/AATM; AU/ATB/ATBM; DT/DTM/DTMM; SG/SGT/SGTL - Normativa VeAC: AU/FRU/FRUF - Normativa MI 3.00: AU/DC/DDCF. DA/SEM/SEMC. DA/STS/STSC. Normativa A e PG: RE/REN/RENF</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-cd: &lt;hhtps://w3id.org/arco/ontology/context-description/&gt;
prefix a-core: &lt;hhtps://w3id.org/arco/ontology/core/&gt;

CONSTRUCT {
?x a-core:informationSource ?y .
}

WHERE {
?x a-cd:hasInterpretationCriterion ?z .
?z rdfs:Label ?y
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/informationSource"/>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/Intervention -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/Intervention">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Activity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasAgentRole"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/core/AgentRole"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/isInterventionOn"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasAgentRole"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/core/AgentRole"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/InterventionType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/onto/TI/atTime"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/italia/onto/TI/TimeInterval"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/framework"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://w3id.org/arco/ontology/context-description/Survey"/>
        <dc:description xml:lang="en">An example of usage of the class &apos;Intervention&apos; is the following:
resource:Intervention/0800640527-10-intervention-1
        a           cd:Intervention ;
        rdfs:label  &quot;Intervention 1 on cultural property 0800640527-10&quot;@en ;
        cd:hasActivityOperator resource:Agent/tonelli-elvira ;
        cd:hasActivityResponsible resource:Agent/soprintendenza-per-i-beni-ambientali-ed-architettonici-di-bologna-modena-e-reggio-emilia ;
        cd:hasInterventionType resource:InterventionType/restauro ;
        tiapit:atTime resource:TimeInterval/1994 .</dc:description>
        <dc:description xml:lang="it">Un esempio di utilizzo della classe &quot;Intervento&quot; è il seguente:
resource:Intervention/0800640527-10-intervention-1
        a           cd:Intervention ;
        rdfs:label  &quot;Intervento 1 sul bene culturale 0800640527-10&quot;@it ;
        cd:hasActivityOperator resource:Agent/tonelli-elvira ;
        cd:hasActivityResponsible resource:Agent/soprintendenza-per-i-beni-ambientali-ed-architettonici-di-bologna-modena-e-reggio-emilia ;
        cd:hasInterventionType resource:InterventionType/restauro ;
        tiapit:atTime resource:TimeInterval/1994 .</dc:description>
        <rdfs:comment xml:lang="it">Questa classe rappresenta un intervento che ha interessato un oggetto (per es: un bene culturale), a fini conservativi (per i quali si crea una sottoclasse di &quot;Intervento&quot;) oppure di altro tipo: restauri (termine obsoleto che attualmente corrisponde a &quot;intervento a fine conservativo&quot;), rilavorazioni, ripristini, trasformazioni per recuperare aspetto e funzionalità rispondenti ai mutati gusti, ecc. In generale, per interventi si intendono attività che riguardano l&apos;oggetto, effettuate per la sua realizzazione/modifica e conservazione materiale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents an intervention on an object (e.g. a cultural property), that is an activity carried out for its conservation or for other purposes: conservation interventions, reprocessing, restoring, etc.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Intervention</rdfs:label>
        <rdfs:label xml:lang="it">Intervento</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale 4.00: CO/RST - normative di versioni precedenti: RS/RST; Normativa VeAC: CO/RIA; Normativa CA: RO/RIS</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/InterventionType -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/InterventionType">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Type"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il tipo di intervento (a fini conservativi o di altro tipo) che ha interessato un bene culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the type of intervention on a cultural property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Intervention type</rdfs:label>
        <rdfs:label xml:lang="it">Tipo di intervento</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale 4.00: valori di CO/RST/RSTI - Normativa VeAC: CO/RIA (riadattamento/modifica) - Normativa CA: RO/RIS (intervento successivo). Normative per beni immobili: TU/STU/STUN</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/Inventory -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/Inventory">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/isInventoryOf"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/InventorySituation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/inventoryLocation"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il registro di inventario.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents an inventory about a cultural property or about an entity or an activity related to the cultural property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Inventario</rdfs:label>
        <rdfs:label xml:lang="en">Inventory</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale 4.00: UB/INV; ICCD Normativa RA 3.00 RE/DSC/DSCI</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/InventorySituation -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/InventorySituation">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/EventOrSituationInTime"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasInventory"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/Inventory"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasInventory"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/Inventory"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasSECCategory"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/SECCategory"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasAgentRole"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/core/AgentRole"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/insertionDate"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/RCSReason"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/inventoryNumber"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/methodOfInsertion"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/provenance"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/relevantLegalAct"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/inventoryNumber"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta una situazione inventariale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents an inventory situation.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Inventory situation</rdfs:label>
        <rdfs:label xml:lang="it">Situazione inventariale</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale 4.00: UB/INV</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/LaboratoryTest -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/LaboratoryTest">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/Survey"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasConsequence"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/Typification"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasConsequence"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/arco/ontology/context-description/Review"/>
                            <rdf:Description rdf:about="https://w3id.org/arco/ontology/core/ClassificationInTime"/>
                            <rdf:Description rdf:about="https://w3id.org/arco/ontology/natural-specimen-description/IdentificationInTime"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/LaboratoryTestType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/claySpecifications"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/testResults"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta un tipo particolare di indagine su bene culturale, ovvero un&apos;analisi di laboratorio.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a particular type of survey on a cultural property, that is a laboratory test.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Analisi di laboratorio</rdfs:label>
        <rdfs:label xml:lang="en">Laboratory test</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normative NU, RA, BNB, MA, CA: RS/ALB.
Normativa BNB: RB</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/LaboratoryTestType -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/LaboratoryTestType">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/SurveyType"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il tipo di analisi di laboratorio (es.: analisi metallurgica, analisi chimica, etc.)</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the type of laboratory test (es.: chemical analysis)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Laboratory test type</rdfs:label>
        <rdfs:label xml:lang="it">Tipo di analisi di laboratorio</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normative NU, RA, BNB, MA, CA: RS/ALB/ALBT.
BNB: RB/RBR/RBRT</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/LegalSituation -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/LegalSituation">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/EventOrSituationInTime"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/isLegalSituationOf"/>
                <owl:someValuesFrom rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasAgentRole"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/core/AgentRole"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/LegalSituationType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:description xml:lang="en">An example of usage of the class &quot;Legal situation&quot; is the following:
resource:LegalSituation/1400054721-legal-situation-proprieta-stato
        a  cd:LegalSituation ;
        rdfs:label  &quot;Legal situation of cultural property 1400054721: State property&quot;@en ;
        lite:hasOwner resource:Agent/ministero-beni-culturali .</dc:description>
        <dc:description xml:lang="it">Un esempio d&apos;uso della classe &quot;Condizione giuridica&quot; è il seguente:
resource:LegalSituation/1400054721-legal-situation-proprieta-stato
        a  cd:LegalSituation ;
        rdfs:label  &quot;Condizione giuridica del bene culturale 1400054721: proprietà Stato&quot;@it ;
        lite:hasOwner resource:Agent/ministero-beni-culturali .</dc:description>
        <rdfs:comment xml:lang="it">Questa classe rappresenta la condizione giuridica di un bene culturale, con riferimenti al proprietario, detentore o possessore.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the legal situation of a cultural property, related to the owner.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Legal situation</rdfs:label>
        <rdfs:label xml:lang="it">Situazione giuridica</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: TU/CDG. - RP/LGC/LGCO. LS/CSS/CSSP. - CS/CTS/CTSP. DO/DCM/DCME</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/LegalSituationType -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/LegalSituationType">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Type"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il tipo di situazione legale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the type of a legal situation</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Legal situation type</rdfs:label>
        <rdfs:label xml:lang="it">Tipo di situazione legale</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">instable</owl:versionInfo>
        <a-cat:iccdNormTag>TU/CDG/CDGG. Normativa BDM:  DU/DUZ/DUZG, DV/DVZ/DVZG, DF/DFZ/DFZG, AI/AIZ/AIZG,  VI/VIZ/VIZG, FI/FIZ/FIZG</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/License -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/License">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta una licenza.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a license</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">License</rdfs:label>
        <rdfs:label xml:lang="it">Licenza</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa SCAN: DO/DCM/DCML</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/LifeCycleCircumstance -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/LifeCycleCircumstance">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/Circumstance"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta un&apos;occasione legata ai cicli della vita (cerimonie, riti, feste).</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a circumstance related to life cycles (ceremonies, custom, celebration)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Life cycle circumstance</rdfs:label>
        <rdfs:label xml:lang="it">Occasione legata al ciclo della vita</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BDI 4.00: CA/CAO/CAOV</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/Membership -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/Membership">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/EventOrSituationInTime"/>
        <dc:description xml:lang="en">An example of usage of one of the subclasses of the class &apos;Membership&apos; is the following: resource:CollectionMembership/0300633618-collection-membership-1
        a    cd:CollectionMembership ;
        rdfs:label  &quot;Collection membership 1 of cultural property: 0300633618&quot;@en ;
        cd:hasCollection resource:CollectionOfCulturalEntities/collezione-mingozzi ;
        cd:hasMemberOfCollection resource:ScientificOrTechnologicalHeritage/0300633618 ;
        tiapit:atTime resource:TimeInterval/1967 .</dc:description>
        <dc:description xml:lang="it">Un esempio d&apos;uso di una delle sottoclassi della classe &apos;Appartenenza&apos; è il seguente: resource:CollectionMembership/0300633618-collection-membership-1
        a    cd:CollectionMembership ;
        rdfs:label  &quot;Appartenenza a collezione 1 del bene culturale: 0300633618&quot;@it ;
        cd:hasCollection resource:CollectionOfCulturalEntities/collezione-mingozzi ;
        cd:hasMemberOfCollection resource:ScientificOrTechnologicalHeritage/0300633618 ;
        tiapit:atTime resource:TimeInterval/1967 .</dc:description>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il concetto di appartenenza.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the concept of membership.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Appartenenza</rdfs:label>
        <rdfs:label xml:lang="en">Membership</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/MultimediaDocumentation -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/MultimediaDocumentation">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/Documentation"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta la documentazione multimediale in formato digitale relativa al un oggetto, per esempio un bene culturale. Nel caso delle Normative per la catalogazione dell&apos;ICCD questa classe riguarda la documentazione multimediale realizzata in formati non compresi dalle norme ICCD, allegata alla scheda di catalogo o esistente e depositata presso l&apos;Ente schedatore o in altre raccolte.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the multimedia documentation of an object, e.g. a cultural property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Altra documentazione multimediale</rdfs:label>
        <rdfs:label xml:lang="en">Multimedia documentation</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ADM (solo versioni 3.00 e 3.01)</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/NoLongerInPublication -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/NoLongerInPublication">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/Reproduction"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta una stampa che non è più parte integrante della pubblicazione, ma che lo è stata in passato.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a print that is no longer was a part of a publication.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Print no longer in publication</rdfs:label>
        <rdfs:label xml:lang="it">Stampa non più in volume</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa S 3: RO/ADL/ADLS</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/NumismaticSeries -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/NumismaticSeries">
        <rdfs:subClassOf rdf:resource="http://dati.beniculturali.it/cis/CollectionCulEnt"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta la serie della quale una moneta fa parte (es.: Greca, Romana Repubblicana, Barbarica).</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the series which a particular coin is part of.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Numismatic series</rdfs:label>
        <rdfs:label xml:lang="it">Serie numismatica</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa NU: OG/OGT/OGTR</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/NumismaticSeriesMembership -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/NumismaticSeriesMembership">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/CollectionMembership"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/involvesCollection"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/NumismaticSeries"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta l&apos;appartenenza di un bene numismatico a una serie numismatica, esplicitamente indicata da un titolo o da una numerazione progressiva o da altri elementi che ne individuino inequivocabilmente l&apos;appartenenza</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the membership of numismatic property in a numismatic series, as a unit.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Appartenenza a serie numismatica</rdfs:label>
        <rdfs:label xml:lang="en">Numismatic series membership</rdfs:label>
        
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa NU: OG/OGT/OGTR</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?x a a-cd:CollectionMembership .
}

WHERE {
?x a a-cd:NumismaticSeriesMembership .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/CollectionMembership"/>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/ObservationSurvey -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/ObservationSurvey">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/Survey"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasResearch"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/Research"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/ObservationSurveyType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta un tipo particolare di indagine, ovvero il rilevamento (l&apos;occasione o l&apos;indagine in occasione della quale è stato rilevato, individuato, osservato il bene) di un bene musicale di interesse etno-organologico o di un bene demoetno-antropologico.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a particular type of survey on a cultural property, that is an observation survey: the observation of musical heritage or demoethnoanthropological heritage.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Indagine di rilevamento</rdfs:label>
        <rdfs:label xml:lang="en">Observation survey</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa SM e BDM 4.00: DR. Normativa BDI: LA/PRM</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/ObservationSurveyType -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/ObservationSurveyType">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Type"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il tipo di indagine di rilevamento (rilevamento nel contesto/ rilevamento decontestualizzato).</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the type of observation survey (in the context / out of the context).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Observation survey type</rdfs:label>
        <rdfs:label xml:lang="it">Tipo di indagine di rilevamento</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BDI 4.00: LA/PRM</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/PaleopathologySurvey -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/PaleopathologySurvey">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/Survey"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/diagnosis"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/refersToSurveys"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta un&apos;indagine, intesa come attività, in cui viene elaborata una diagnosi di una paleopatologia di un reperto antropologico.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a particular type of survey on a cultural property, that is a survey in which is possible to make a diagnosis of a paleopathology of an anthropological material.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Indagine su paleopatologia</rdfs:label>
        <rdfs:label xml:lang="en">Paleopathology survey</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa AT: PT</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-spe:  &lt;https://w3id.org/arco/ontology/natural-specimen-description/&gt;

CONSTRUCT {
?x a a-spe:PaleopathologySurvey .
}

WHERE {
?x a a-cd:PaleopathologySurvey .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/PaleopathologySurvey"/>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/PhotoInterpretationRendering -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/PhotoInterpretationRendering">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/Survey"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasAnomaly"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/Anomaly"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasReliability"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/Reliability"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasSurveyImage"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/SurveyImage"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/overlapSpecifications"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta un tipo particolare di indagine su bene culturale, ovvero una fotointerpretazione e fotorestituzione, intesa come indagine territoriale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a particular type of survey on a cultural property, that is photo interpretation and rendering.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Fotointerpretazione e fotorestituzione</rdfs:label>
        <rdfs:label xml:lang="en">Photo interpretation and rendering</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: RE/FOI</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/PhotographicDocumentation -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/PhotographicDocumentation">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/Documentation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/caption"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/stripRunAndFrameNumber"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta la documentazione fotografica relativa a un oggetto, per esempio a un bene culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the photographic documentation of an object, e.g. a cultural property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Documentazione fotografica</rdfs:label>
        <rdfs:label xml:lang="en">Photographic documentation</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale 4.00: DO/FTA</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/PhotographicFonds -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/PhotographicFonds">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/PhotographicRecordSet"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta un fondo fotografico.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the photographic fonds.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Fondo fotografico</rdfs:label>
        <rdfs:label xml:lang="en">Photographic fonds</rdfs:label>
        
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD F:UB/UBF/UBFP </a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?prs a a-cd:PhotographicRecordSet ;
a-cd:hasComponent ?y ;
?y a a-cd:PhotographicRecordSet .
}

WHERE {
?prs a a-cd:PhotographicRecordSet ;
a-cd:hasComponent ?y ;
?y a a-cd:PhotographicFonds .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/PhotographicRecordSet"/>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/PhotographicRecordSet -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/PhotographicRecordSet">
        <rdfs:subClassOf rdf:resource="http://dati.beniculturali.it/cis/CollectionCulEnt"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/isCollectionIn"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/CollectionMembership"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasComponent"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/PhotographicRecordSet"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/RecordSetType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/onto/l0/identifier"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta un unità archivistica fotografica complessa.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the photographic record set.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Photographic record set</rdfs:label>
        <rdfs:label xml:lang="it">Unità archivistica fotografica complessa</rdfs:label>
        
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD F:UB/UBF </a-cat:iccdNormTag>
        <a-cat:iccdNormTag>Normativa F: PD/SFI, SSI</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/PhotographicRecording -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/PhotographicRecording">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/Recording"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta la registrazione fotografica di un&apos;entità culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the photographic recording of a cultural entity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Photographic recording</rdfs:label>
        <rdfs:label xml:lang="it">Registrazione fotografica</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BDI: DF, FI</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/PhotographicSeries -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/PhotographicSeries">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/PhotographicRecordSet"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/isPhotographicSeriesIn"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/PhotographicSeriesMembership"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasPart"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/PhotographicSubseries"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta una serie editoriale fotografica, ovvero un insieme di immagini ideate o pubblicate come un&apos;unica entità, esplicitamente legate tra di loro da un titolo o da una numerazione progressiva o da altri elementi che ne individuino inequivocabilmente l&apos;unitarietà in senso biblioteconomico.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a photographic series, that is a set of photographs created or published as a unit, from a library sciences point of view.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Photographic series</rdfs:label>
        <rdfs:label xml:lang="it">Serie fotografica</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: PD/SFI</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?pf a a-cd:PhotographicRecordSet ;
a-cd:hasComponent ?y ;
?y a a-cd:PhotographicRecordSet .
}

WHERE {
?pf a a-cd:PhotographicFonds ;
a-cd:hasComponent ?y ;
?y a a-cd:PhotographicSeries .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/PhotographicRecordSet"/>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/PhotographicSeriesMembership -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/PhotographicSeriesMembership">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/CollectionMembership"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasMemberOfPhotographicSeries"/>
                <owl:someValuesFrom rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/involvesCollection"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/PhotographicSeries"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/photographicSeriesItemNumber"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta l&apos;appartenenza di un bene fotografico a una serie editoriale, esplicitamente indicata da un titolo o da una numerazione progressiva o da altri elementi che ne individuino inequivocabilmente l&apos;appartenenza.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the membership of photographic heritage in a photographic series, as a unit.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Appartenenza a serie fotografica</rdfs:label>
        <rdfs:label xml:lang="en">Photographic series membership</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa F: PD/SFI; PD/SSI</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?x a a-cd:CollectionMembership .
}

WHERE {
?x a a-cd:PhotographicSeriesMembership .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/CollectionMembership"/>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/PhotographicSubseries -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/PhotographicSubseries">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/PhotographicRecordSet"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/isPartOf"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/PhotographicSeries"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta una sottoserie di una serie editoriale fotografica, ovvero una partizione interna alla serie.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a photographic subseries, that is a component of a photographic series.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Photographic subseries</rdfs:label>
        <rdfs:label xml:lang="it">Sottoserie fotografica</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa F: PD/SSI</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?ps a a-cd:PhotographicRecordSet ;
a-cd:hasComponent ?y ;
?y a a-cd:PhotographicRecordSet .
}

WHERE {
?ps a a-cd:PhotographicSeries ;
a-cd:hasComponent ?y ;
?y a a-cd:PhotographicSubseries .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/PhotographicRecordSet"/>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/PreferredAuthorshipAttribution -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/PreferredAuthorshipAttribution">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/AuthorshipAttribution"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasAttributedAuthor"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta l&apos;attribuzione di autore maggiormente accreditata o convincente.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the preferred authorship attribution, most accredited or convincing.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/context-description"/>
        <rdfs:label xml:lang="it">Attribuzione Primaria di Autore</rdfs:label>
        <rdfs:label xml:lang="en">Preferred Authorship Attribution</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>AU/AUT</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?x a a-cd:Responsibility ;
a-cd:mainResponsibility &quot;True&quot; .
}

WHERE {
?x a a-cd:PreferredAuthorshipAttribution .
}</core:constructQuery>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/PreparatoryOrFinalWork -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/PreparatoryOrFinalWork">
        <rdfs:subClassOf rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasAuthor"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasDating"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/Dating"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasInventory"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/Inventory"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasTitle"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/Title"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/relatedWorkLocation"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/relatedWorkPreviousLocation"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/relatedWorkRecordIdentifier"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:description xml:lang="en">An example of usage of the class &apos;Preparatory or final work&apos; is the following::
resource:PreparatoryOrFinalWork/0500212038-disegno
        a           cd:PreparatoryOrFinalWork ;
        rdfs:label  &quot;Preparatory or final work 1 of cultural property 0500212038: disegno&quot;@en ;
        cd:hasAuthor resource:Agent/tiziano-vecellio ;
        cd:hasDating resoruce:Dating/0500212038-disegno .</dc:description>
        <dc:description xml:lang="it">Un esempio di utilizzo della classe &quot;Opera preparatoria o finale&quot; è il seguente:
resource:PreparatoryOrFinalWork/0500212038-disegno
        a           cd:PreparatoryOrFinalWork ;
        rdfs:label  &quot;Opera originale o finale 1 del bene culturale 0500212038: disegno&quot;@it ;
        cd:hasAuthor resource:Agent/tiziano-vecellio ;
        cd:hasDating resoruce:Dating/0500212038-disegno .</dc:description>
        <rdfs:comment xml:lang="it">Questa classe rappresenta un&apos;entità collegata a un bene culturale, che ne costituisce una fase preparatoria o una fase finale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents an entity related to a cultural property, that is its preparatory or final stage.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Opera preparatoria o finale</rdfs:label>
        <rdfs:label xml:lang="en">Preparatory or final work</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normative F, RA, SMO, PST, S, OAC, OA, MI, D, NU: RO/ROF</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/PreparatoryWork -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/PreparatoryWork">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/PreparatoryOrFinalWork"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta un&apos;entità collegata a un bene culturale, che ne costituisce una fase preparatoria.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents an entity related to a cultural property, as its preparatory stage.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Opera preparatoria</rdfs:label>
        <rdfs:label xml:lang="en">Preparatory work</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normative F, RA, SMO, PST, S, OAC, OA, MI, D, NU: se RO/ROF/ROFF rappresenta uno stadio del bene catalogato riconducibile a una fase finale, per cui è possibile dedurre che l&apos;opera collegata al bene è una sua fase preparatoria.</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/PrintInPublication -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/PrintInPublication">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/DerivatedWork"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta la pubblicazione di cui una stampa è, o è stata, parte integrante.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a publication of which a print is, or was, part.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Print in publication</rdfs:label>
        <rdfs:label xml:lang="it">Stampa in pubblicazione</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa S 3: RO/ADL</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/PrintingPlatesSeries -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/PrintingPlatesSeries">
        <rdfs:subClassOf rdf:resource="http://dati.beniculturali.it/cis/CollectionCulEnt"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta la serie della quale una matrice incisa fa parte.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the series which a printing plate is part of.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Printing plates series</rdfs:label>
        <rdfs:label xml:lang="it">Serie di matrici incise</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa MI: OG/SGT/SGTS</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/ProductionCycleCircumstance -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/ProductionCycleCircumstance">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/Circumstance"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta un&apos;occasione connessa ai cicli produttivi (bachicoltura, cerealicoltura, etc.)</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a circumstance related to production cycles (sericulture, cereal crop, etc.)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Occasione legata al ciclo produttivo</rdfs:label>
        <rdfs:label xml:lang="en">Production cycle circumstance</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BDI 4.00: CA/CAO/CAOP</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/Profession -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/Profession">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/RO/Role"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/isProfessionOf"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/italia/onto/CPV/Person"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://w3id.org/arco/ontology/context-description/UseFunction"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il mestiere o la professione dell&apos;utente del bene.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the profession of a cultural entity&apos;s user.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Profession</rdfs:label>
        <rdfs:label xml:lang="it">Professione</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BDM 2: UT/UTN/UTNM, BDM 4: AU/AUT/AUTE. BDI: AT/ATT/ATTM, AI/AIF/AIFM, VI/VIF/VIFM, FI/FIF/FIFM. SM: MU/MUT/MUTM. Normativa AUT 4.00: AU/AUT/AUTQ</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/ProtectiveMeasure -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/ProtectiveMeasure">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/isProtectiveMeasureOf"/>
                <owl:someValuesFrom rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasAgentRole"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/core/AgentRole"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/issueDate"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/noticeDate"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/openingNoticeDate"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/registrationDateOrGU"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta un provvedimento di tutela nazionale o internazionale, che ha interessato un bene culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the protective measure, national or international, related to a cultural property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Protective measure</rdfs:label>
        <rdfs:label xml:lang="it">Provvedimento di tutela</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: TU/NVC</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/RecordSetType -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/RecordSetType">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Type"/>
        <rdfs:comment>ICCD Normativa FF: PA/PAC/PACT 
ICCD Normativa F: UB/UBF/UBFU-UBFT-UBFS-UBFF-UBFP, 
PA/SSI, PA/SFI</rdfs:comment>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il tipo di unità archivistica complessa.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the type of record set.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label>Record set type</rdfs:label>
        <rdfs:label xml:lang="it">Tipo di unità archivistica complessa</rdfs:label>
        
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unsable</owl:versionInfo>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/Recording -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/Recording">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasLegalSituation"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/LegalSituation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasStorageMedium"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/StorageMedium"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasTitle"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/Title"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/involvesMember"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/CollectionMembership"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/RecordingType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/recordingEquipment"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta la registrazione di un&apos;entità culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the recording of a cultural entity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Recording</rdfs:label>
        <rdfs:label xml:lang="it">Registrazione</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BDI: DU</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/RecordingType -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/RecordingType">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Type"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta un tipo di registrazione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a type of recording.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Recording type</rdfs:label>
        <rdfs:label xml:lang="it">Tipo di registrazione</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BDI: DU/DUO/DUOT, DU/DUM/DUMT, DV/DVO/DVOT, DV/DVM/DVMT, AI/AIO/AIOT, VI/VIO/VIOT</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/ReferenceCatalogue -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/ReferenceCatalogue">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/isReferenceCatalogueOf"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il repertorio che cita un&apos;entità, es: la copia di una stampa.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the reference catalogue that cites another entity, e.g. the copy of a print.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Reference catalogue</rdfs:label>
        <rdfs:label xml:lang="it">Repertorio</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa NU: OG/OGT/OGTT 
ICCD Normativa S 3: RO/COP/COPR
ICCD Normativa 3.00: MA/MAC/MACP
ICCD Normativa NT: OG/OGT/OGTS</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/RelatedWorkSituation -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/RelatedWorkSituation">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/EventOrSituationInTime"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/involvesRelatedWork"/>
                <owl:someValuesFrom rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/isRelatedWorkSituationOf"/>
                <owl:someValuesFrom rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasRelationshipType"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/RelationshipType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:description xml:lang="en">An example of usage of the class &apos;Related work situation&apos; is the following:
resource:RelatedWorkSituation/0300199368-preparatory-final-work-1
        a  cd:RelatedWorkSituation ;
        rdfs:label  &quot;Relation 1 between the cultural property 0300199368 and preparatory or final work&quot;@en  ;
      cd:hasCulturalPropertyStage resource:CulturalPropertyStage/bozzetto ;
        cd:hasRelatedWork resource:FinalWork/0300199368-dipinto .</dc:description>
        <dc:description xml:lang="it">Un esempio d&apos;uso della classe &apos;Rapporto con opera collegata&apos; è il seguente:
resource:RelatedWorkSituation/0300199368-preparatory-final-work-1
        a  cd:RelatedWorkSituation ;
        rdfs:label  &quot;Relation 1 between the cultural property 0300199368 and preparatory or final work&quot;@en , &quot;Rapporto 1 tra il bene culturale 0300199368 e opera originale o finale&quot;@it ;
      cd:hasCulturalPropertyStage resource:CulturalPropertyStage/bozzetto ;
        cd:hasRelatedWork resource:FinalWork/0300199368-dipinto .</dc:description>
        <rdfs:comment xml:lang="it">Questa classe rappresenta la relazione, il rapporto, tra il bene culturale in esame e un&apos;altra opera, che può anche essere un bene culturale. In riferimento a questo rapporto, si definisce lo stadio di realizzazione del bene culturale in rapporto con l&apos;oggetto che ne costituisce una fase preparatoria o che ne rappresenta la fase finale o che ne rappresenta una derivazione. Nel caso di una relazione tra un bene culturale e un altro bene culturale, in riferimento a questo rapporto si definisce, se possibile, il tipo di relazione tra i due beni (es.: luogo di realizzazione, luogo di ritrovamento, etc.).</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a situation in which a cultural property is related to another work, that could even be another cultural property. The cultural property stage is defined referring to this relationship with a related work, that can represent a preparatory, a final phase or a derivation of the cultural property. When the relationship is between two cultural properties, when possible, the nature of the relationship is specified (e.g.: finding location)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Rapporto con opera collegata</rdfs:label>
        <rdfs:label xml:lang="en">Related work situation</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/RelationshipType -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/RelationshipType">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Type"/>
        <a-cat:iccdNormTag>ICCD Normative RA, SMO, PST, S, OAC, OA, MI, D, NU, F: RO/ROF/ROFF. VEAC: AU/AUT/AUTO</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/Reliability -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/Reliability">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Characteristic"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/hasReliability"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/PhotoInterpretationRendering"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il livello di affidabilità delle informazioni rilevate nell&apos;indagine di fotointerpretazione/fotorestituzione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the reliability level of detected information relative to photo interpretation rendering.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Affidabilità</rdfs:label>
        <rdfs:label xml:lang="en">Reliability</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: RE/FOI/FOIO</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/Reproduction -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/Reproduction">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/isReproductionOf"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/PrintInPublication"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasReproductionPosition"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/ReproductionPosition"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta la riproduzione dell&apos;immagine contenuta nella pubblicazione di cui la stampa è, o è stata, parte integrante.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the reproduction of an image, that is, or was, part of a publication.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Reproduction</rdfs:label>
        <rdfs:label xml:lang="it">Riproduzione</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa S 3: RO/ADL</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/ReproductionPosition -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/ReproductionPosition">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Location"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/isReproductionPositionOf"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/Reproduction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/pageOrTableNumber"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://w3id.org/arco/ontology/context-description/StratigraphicUnit"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta la posizione fisica della riproduzione della stampa all&apos;interno della pubblicazione, che rappresenta quindi una derivazione della stampa stessa.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the phisical position of a printed reproduction in a publication.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Posizione della riproduzione</rdfs:label>
        <rdfs:label xml:lang="en">Reproduction position</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa S 3: RO/ADL/ADLP</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/Research -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/Research">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Activity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/onto/l0/name"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta la ricerca nell&apos;ambito della quale è stata redatta la scheda, intendendo con il termine &quot;ricerca&quot; vari e differenziati livelli, fra cui quello della campagna di catalogazione. La ricerca si può collegare al rilevamento di un bene musicale di interesse etno-organologico.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the research in which the catalogue record describing a cultural property was recorded (e.g.: a cataloguing campaign). The research can be related to the observation survey on musical heritage.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Research</rdfs:label>
        <rdfs:label xml:lang="it">Ricerca</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa SM e BDM 4.00: DR/DRT</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/Responsibility -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/Responsibility">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/AgentRole"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasAgentWithResponsibility"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasInterventionRole"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/italia/onto/RO/Role"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/isResponsibilityFor"/>
                <owl:someValuesFrom rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasCulturalScope"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/CulturalScope"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/informationSource"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta l&apos;individuazione di una responsabilità attribuibile a un agente relativamente al suo ruolo o a una sua attività operata su un bene culturale (es: autorialità).</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the attribution of a responsibility to an agent on a role/intervention they had on a cultural entity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Responsabilità</rdfs:label>
        <rdfs:label xml:lang="en">Responsibility</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale: AU/AUT
ICCD Normative F e FF: PD/PDF</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/ResponsibilityType -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/ResponsibilityType">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Type"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il tipo di responsabilità di un agente (es: autore, editore, ecc) nei confronti di un lavoro (es: un&apos;opera d&apos;arte, un libro, ecc ).</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the type of responsibility of an agent related to its contribution to a work (e.g.: author, printer, editor...)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Responsibility type</rdfs:label>
        <rdfs:label xml:lang="it">Tipo di responsabilità</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale: AU/AUT</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/Reuse -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/Reuse">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/DerivatedWork"/>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/Review -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/Review">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Activity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasConsequence"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/onto/TI/atTime"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/italia/onto/TI/TimeInterval"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/isReviewOf"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasAgentRole"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/core/AgentRole"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/ReviewType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/onto/TI/atTime"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/italia/onto/TI/TimeInterval"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta una revisione</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a review.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Review</rdfs:label>
        <rdfs:label xml:lang="it">Revisione</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>Normativia BNB: RB/RBR. Normativa BNM: RM. Normativa BNPL: RP. Normativa BNPE: RR</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/ReviewType -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/ReviewType">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Type"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/isTypeOf"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/Review"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il tipo di revisione</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the type of review.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Review type</rdfs:label>
        <rdfs:label xml:lang="it">Tipo di revisione</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>Normativa BNM: RM/RMD/RMDT. Normativa BNB: RB/RBR/RBRT. Normativa BNPL: RP/RPV/RPVT. Normativa BNPE: RR/RRD/RRDT</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/SECCategory -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/SECCategory">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Category"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasIdentifier"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/core/Identifier"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/hasSECCategory"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/InventorySituation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta la categoria patrimoniale del bene, con riferimento alla classificazione del Sistema Europeo dei Conti 1995</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the patrimonial category of a cultural property, referring to the SEC classification 1995.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Categoria SEC</rdfs:label>
        <rdfs:label xml:lang="en">SEC Category</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: UB/INP/INPZ</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/SECIdentifier -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/SECIdentifier">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Category"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il codice patrimoniale del bene (SEC - Modello 15), con riferimento alla classificazione del Sistema Europeo dei Conti 1995.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the patrimonial code of a cultural property, referring to the SEC classification 1995.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Codice SEC</rdfs:label>
        <rdfs:label xml:lang="en">SEC Identifier</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: UB/INP/INPS</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt;

CONSTRUCT {
?x a core:Identifier .

WHERE {
?x a a-cd:SECIdentifier .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/Identifier"/>
        <core:replacingQuery>select * where {
?x core:hasIdentifier ?id .
?id core:hasType &lt;https://w3id.org/arco/ontology/arco-lite/localIdentifier&gt; .
}</core:replacingQuery>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/SameAuthorCopy -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/SameAuthorCopy">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/Copy"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta una replica di un bene culturale, cioè una duplicazione dell&apos;originale da parte dello stesso autore.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a copy of a cultural property created by the same author of the original cultural property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Replica</rdfs:label>
        <rdfs:label xml:lang="en">Same author copy</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa F: RO/CRF/CRFT = &apos;replica&apos;</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/Scale -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/Scale">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/isScaleOf"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/GraphicOrCartographicDocumentation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta le indicazioni sulla scala di rappresentazione della documentazione grafica e cartografica.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the representative scale of a graphic or cartographic documentation.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Scala</rdfs:label>
        <rdfs:label xml:lang="en">Scale</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: DO/DRA/DRAS</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/SeasonCycleCircumstance -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/SeasonCycleCircumstance">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/Circumstance"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta un&apos;occasione legata ai cicli stagionali, ovvero cicli che si riferiscono a: oggetto di concezioni, credenze, mito, scienza, di elaborazione in poesia, prosa, canto, arte e di culto; riferimento di attività, pratiche, comportamenti, di dati o fenomeni a particolari cicli, giorni, settimane, lunazioni, mesi, stagioni ecc.; giorni e periodi fausti e infausti.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a circumstance related to seasonal cycles, referred to: subject of popular belief, myth, science; poetry, prose, songs, art, ritual; practical activities, behaviour, phenomena connected to specific cycles, days, months, seasons; fortunate or unfortunate days and periods.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Occasione legata al ciclo stagionale</rdfs:label>
        <rdfs:label xml:lang="en">Season cycle circumstance</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BDI 4.00: CA/CAO/CAOS</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/Sex -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/Sex">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/EventOrSituationInTime"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/isSexOf"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/sex"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/informationSource"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il sesso di un entità.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the sex of an entity.</rdfs:comment>
        <rdfs:label xml:lang="it">Sesso</rdfs:label>
        <rdfs:label xml:lang="en">Sex</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa AT: DA/STS. Normativa BDI: AT/ATT/ATTS, AI/AIF/AIFO, VI/VIF/VIFO, FI/FIF/FIFO. Normativa SM: MU/MUT/MUTS. Normativa AUT: AU/AUT/AUTZ</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/SexInterpretation -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/SexInterpretation">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/Interpretation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/isSexInterpretationOf"/>
                <owl:someValuesFrom rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta la stima del sesso di un reperto antropologico.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the interpretation of the sex of an anthropological material.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Interpretazione del sesso</rdfs:label>
        <rdfs:label xml:lang="en">Sex interpretation</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa AT: DA/STS</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?x a a-cd:Sex .
}

WHERE {
?x a a-cd:SexInterpretation .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/Sex"/>
        <core:replacingQuery>select * where {
?x a-cd:hasSex ?sex .
?sex a a-cd:Sex ;
a-cd:sex ?literal ;
a-cd:informationSource ?info .
}</core:replacingQuery>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/SocialInteractionCircumstance -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/SocialInteractionCircumstance">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/Circumstance"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta un&apos;occasione connessa alla socialità quotidiana (balli, caffè, veglie, osterie)</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a circumstance related to social interaction (dances, pubs, wakes)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Occasione legata alla socialità quotidiana</rdfs:label>
        <rdfs:label xml:lang="en">Social interaction circumstance</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BDI 4.00: CA/CAO/CAOQ</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/SourceAndDocument -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/SourceAndDocument">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/Documentation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/folio"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta le fonti e i documenti testuali editi e inediti relativi a un oggetto, per esempio a un bene culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents source and document related to an object, e.g. a cultural property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Documentazione testuale</rdfs:label>
        <rdfs:label xml:lang="it">Fonti e documenti</rdfs:label>
        <rdfs:label xml:lang="en">Source and document</rdfs:label>
        <rdfs:label xml:lang="en">Textual documentation</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale 4.00: DO/FNT</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/Species -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/Species">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Concept"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/isSpeciesIn"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/BiologicalTaxon"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta uno dei livelli di classificazione di una tassonomia biologica, ovvero la specie.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents one level of a biological taxon, the species.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description"/>
        <rdfs:label xml:lang="it">Specie</rdfs:label>
        <rdfs:label xml:lang="en">Species</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa AT: OG/OGS/OGSN</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-spe: &lt;https://w3id.org/arco/ontology/natural-specimen-description/&gt;

CONSTRUCT {
?x a a-spe:Species .
}

WHERE {
?x a-cd:Species .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/Species"/>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/SpecimenCollection -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/SpecimenCollection">
        <rdfs:subClassOf rdf:resource="http://dati.beniculturali.it/cis/CollectionCulEnt"/>
        <rdfs:comment xml:lang="it">Questa casse rappresenta una collezione di esemplari</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a collection of specimens</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Collezione di esemplari</rdfs:label>
        <rdfs:label xml:lang="en">Specimen collection</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>Normative BN: OG/OGT/OGTC</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/StorageMedium -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/StorageMedium">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasAcquisition"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/Acquisition"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasLegalSituation"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/LegalSituation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il supporto di memoria di un&apos;entità culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the storage medium of a cultural entity.</rdfs:comment>
        <rdfs:label xml:lang="en">Storage medium</rdfs:label>
        <rdfs:label xml:lang="it">Supporto di memoria</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BDI: DU/DUO, DU/DUM, DV/DVM, DV/DVO, AI/AIO, AI/AIM, VI/VIO, VI/VIM</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/StorageMediumType -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/StorageMediumType">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Type"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il tipo di supporto di memeoria di un&apos;entità culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the storage medium type of a cultural entity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Storage medium type</rdfs:label>
        <rdfs:label xml:lang="it">Tipo di supporto di memoria</rdfs:label>
        <a-cat:iccdNormTag>Normativa F: MT/FVM. Normativa BDI: DU/DUO/DUOF, DV/DVO/DVOF, AI/AIO/AIOF, VI/VIO/VIOF</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/StratigraphicUnit -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/StratigraphicUnit">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Location"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/isStratigraphicUnitOf"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/ArchaeologicalExcavation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta l&apos;unità stratigrafica dalla quale può provenire un bene culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a stratigraphic unit from which a cultural property may come from.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Stratigraphic unit</rdfs:label>
        <rdfs:label xml:lang="it">Unità stratigrafica</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: RE/DSC/DSCU</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/Subject -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/Subject">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Topic"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/isSubjectOf"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/isClassifiedBy"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/core/Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/subjectDescription"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il soggetto rappresentato da un bene culturale o il suo motivo decorativo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the subject of a cultural property, or its ornamental motif.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Soggetto</rdfs:label>
        <rdfs:label xml:lang="en">Subject</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale: DA/AID/AIDI - Normativa F: SG/SGT/SGTI - Altre normative di versioni precedenti alla 4.00: OG/SGT/SGTI - ICCD Normative F, RA, SMO, PST, S, OAC, OA, MI, D, NU: RO/ROF/ROFS. DA/DES/DESU. VeAC: OG/PGT/OGTV</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/Subspecies -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/Subspecies">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Concept"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/isSubspeciesIn"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/BiologicalTaxon"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta uno dei livelli di classificazione di una tassonomia biologica, ovvero la sottospecie.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents one level of a biological taxon, the subspecies.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Sottospecie</rdfs:label>
        <rdfs:label xml:lang="en">Subspecies</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa AT: OG/OGS/OGST</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-spe: &lt;https://w3id.org/arco/ontology/natural-specimen-description/&gt;

CONSTRUCT {
?x a a-spe:Subspecies .
}

WHERE {
?x a-cd:Subspecies .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/Subspecies"/>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/Survey -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/Survey">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Activity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/onto/TI/atTime"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/italia/onto/TI/TimeInterval"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasSurveyMethod"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/SurveyMethod"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasSurveyMotivation"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/SurveyMotivation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasAgentRole"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/core/AgentRole"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/SurveyType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/onto/TI/atTime"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/italia/onto/TI/TimeInterval"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/report"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/informationSource"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:description xml:lang="en">An example of usage of one of the subclasses of the class &apos;Survey&apos; is the following:
resource:ArchaeologicalExcavation/0500590557-survey-1
        a           cd:ArchaeologicalExcavation ;
        rdfs:label  &quot;Archaeological excavation 1 of cultural property 0500590557: Monselice, via Valli&quot;@en ;
        lite:hasResponsibleAgent resource:Agent/sba ;
        cd:hasStratigraphicUnit resource:StratigraphicUnit/325 ;
        cd:hasSurveyMethod resource:SurveyMethod/scavo-stratigrafico ;
        cd:hasSurveyMotivation resource:SurveyMotivation/opere-pubbliche ; lite:hasScientificDirector resource:Agent/bianchin-citton-elodia ;
        core:hasAgentRole resource:AgentRole/0500590557-archaeological-excavation-1-activity-responsible , resource:AgentRole/0500590557-archaeological-excavation-1-scientific-director ;
        tiapit:time &quot;2004&quot; .</dc:description>
        <dc:description xml:lang="it">Un esempio d&apos;uso di una delle sottoclassi della classe &quot;Indagine&quot; è il seguente:
resource:ArchaeologicalExcavation/0500590557-survey-1
        a           cd:ArchaeologicalExcavation ;
        rdfs:label  &quot;Archaeological excavation 1 of cultural property 0500590557: Monselice, via Valli&quot;@en ;
        lite:hasResponsibleAgent resource:Agent/sba ;
        cd:hasStratigraphicUnit resource:StratigraphicUnit/325 ;
        cd:hasSurveyMethod resource:SurveyMethod/scavo-stratigrafico ;
        cd:hasSurveyMotivation resource:SurveyMotivation/opere-pubbliche ; lite:hasScientificDirector resource:Agent/bianchin-citton-elodia ;
        core:hasAgentRole resource:AgentRole/0500590557-archaeological-excavation-1-activity-responsible , resource:AgentRole/0500590557-archaeological-excavation-1-scientific-director ;
        tiapit:time &quot;2004&quot; .</dc:description>
        <rdfs:comment xml:lang="it">Questa classe rappresenta un&apos;indagine effettuata su un&apos;entità (per es: un bene culturale). Nel dominio dei beni culturali, per indagine si intende un&apos;attività che riguarda il bene, effettuata per la sua individuazione (nel caso dei beni archeologici), per il suo studio e per l&apos;approfondimento delle sue caratteristiche tecniche (indagini di scavo, di ricognizione, indagini geognostiche, analisi di vario genere e tipo, etc.). Questa classe viene specializzata in sottoclassi, per la rappresentazione di tipologie di indagini specifiche.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a survey carried out on an entity (e.g. a cultural property). In the cultural heritage perspective, it is an activity related to a cultural property and carried out for its identification, study or observation of its technical characteristics.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Indagine</rdfs:label>
        <rdfs:label xml:lang="en">Survey</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale: RE</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/SurveyImage -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/SurveyImage">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/isSurveyImageOf"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/PhotoInterpretationRendering"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/SurveyImageType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/surveyImageIdentifier"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta l&apos;immagine presa in esame nel corso di una fotointerpretazione o fotorestituzione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the image analysed during a photo interpretation or rendering survey.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Immagine di indagine</rdfs:label>
        <rdfs:label xml:lang="en">Survey Image</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: RE/FOI/FOIT + FOID</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/SurveyImageType -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/SurveyImageType">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Type"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta un tipo di immagine analizzata in una indagine di fotointerpretazione e restituzione (fotografia aerea o fotografia satellitare).</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the type of image analysed during a photo interpretation or rendering survey (aerial photograph, satellite photograph).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Survey image type</rdfs:label>
        <rdfs:label xml:lang="it">Tipo di immagine di indagine</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: RE/FOI/FOIT</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/SurveyMethod -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/SurveyMethod">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Method"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/isSurveyMethodOf"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/Survey"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il metodo di scavo archeologico o di ricognizione archeologica adottato nel corso dell&apos;indagine. (es.: sondaggio, per strati stratigrafici, occasionale, sistematico, etc.)</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the archeological survey method adopted.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Metodo di indagine</rdfs:label>
        <rdfs:label xml:lang="en">Survey method</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: RE/RCG/RCGM; RE/DSC/DSCM. Versioni precedent; RE/RCG/RCGE</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/SurveyMotivation -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/SurveyMotivation">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Description"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/isSurveyMotivationOf"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/Survey"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Normativa Trasversale: RE/RCG/RCGE; RE/DSC/DSCT; RE/IND/INDM; RE/FOI/FOIM</rdfs:comment>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il motivo principale che ha determinato una ricognizione archeologica o uno scavo archeologico.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the main motivation of a survey.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Motivo di indagine</rdfs:label>
        <rdfs:label xml:lang="en">Survey Motivation</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/SurveyType -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/SurveyType">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Type"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta un tipo di indagine.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the survey type.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Survey type</rdfs:label>
        <rdfs:label xml:lang="it">Tipo di indagine</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>Normativa trsversale: RE/IND/INDI</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/ThematicPath -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/ThematicPath">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/involves"/>
                <owl:someValuesFrom rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasDocumentation"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/Documentation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasIdentifier"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/core/Identifier"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasPart"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/ThematicPath"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/ThematicPathType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta un percorso tematico relativo a un particolare argomento o bene culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a thematic path focusing on a particular topic or cultural property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Ititnerario tematico</rdfs:label>
        <rdfs:label xml:lang="en">Thematic path</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/ThematicPathType -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/ThematicPathType">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Type"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il tipo di itinerario</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a thematic path type.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Thematic Path type</rdfs:label>
        <rdfs:label xml:lang="it">Tipo di itineario</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/Title -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/Title">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/isTitleOf"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasInterpretationCriterion"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/InterpretationCriterion"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/TitleType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/specifications"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il titolo di un oggetto. Nel caso del dominio dei beni culturali, può rappresentare il titolo del soggetto di un bene culturale o di un&apos;opera collegata a un bene culturale in quanto sua fase preparatoria o finale o in quanto pubblicazione contenente una stampa, oppure il titolo di una serie fotografica, etc.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the title of an object, e.g. the title of the subject represented by a cultural property, or the title of a photographic series, etc.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Title</rdfs:label>
        <rdfs:label xml:lang="it">Titolo</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale: DA/AID/AIDN (titolo alternativo); DA/AID/AIDT (titolo) - Normativa S e MI: OG/SGT/SGTP (titolo proprio); Normativa F: SG/SGL/SGLA (titolo attribuito); SG/SGL/SGLT (titolo proprio); SG/SGL/SGLL (titolo parallelo); - Altre normative di versioni precedenti alla 4.00: OG/SGT/SGTR (titolo parallelo); OG/SGT/SGTT (titolo); ICCD Normativa S 3: RO/ADL/ADLT. Normativa F: PD/EDI/EDIT-EDIP-EDIA</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/TitleType -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/TitleType">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Type"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il tipo di titolo di un oggetto (es.: originario, alternativo).</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the type of an object title (e.g. original, alternative)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Tipo di Titolo</rdfs:label>
        <rdfs:label xml:lang="en">Title Type</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale: DA/AID/AIDN; DA/AID/AIDT - Normativa S e MI: OG/SGT/SGTP Normativa F: SG/SGL/SGLA; SG/SGL/SGLT; SG/SGL/SGLL - Altre normative di versioni precedenti alla 4.00: OG/SGT/SGTR; OG/SGT/SGTT - Normative VeAC e AT: DO/BSE/BSET e BSEC.</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/Tomb -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/Tomb">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/isTombOf"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/ArchaeologicalExcavation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta una deposizione funeraria.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a tomb.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Deposizione funeraria</rdfs:label>
        <rdfs:label xml:lang="en">Tomb</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: RE/DSC/DSCS</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/UrbanPlanningInstrument -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/UrbanPlanningInstrument">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/isUrbanPlanningInstrumentOf"/>
                <owl:someValuesFrom rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasAgentRole"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/core/AgentRole"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/definesEligibleIntervention"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/InterventionType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/UrbanPlanningInstrumentType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta uno strumento urbanistico-territoriale, ovvero un piano regolatore generale e particolareggiato o un piano paesaggistico che interessa un bene culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a urban planning instrument, related to a cultural property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Strumento urbanistico-territoriale</rdfs:label>
        <rdfs:label xml:lang="en">Urban planning instrument</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: TU/STU</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/UrbanPlanningInstrumentType -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/UrbanPlanningInstrumentType">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Type"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il tipo di strumento urbanistico-territoriale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a urban planning instrument type.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Tipo di strumento urbanistico-territoriale</rdfs:label>
        <rdfs:label xml:lang="en">Urban planning instrument type</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: TU/STU/STUT</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/Use -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/Use">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/EventOrSituationInTime"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasUseFunction"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/UseFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasAgentRole"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/core/AgentRole"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasCircumstance"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/Circumstance"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasAgentRole"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/core/AgentRole"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/UseType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/onto/CLV/hasSpatialCoverage"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/italia/onto/CLV/Feature"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/useCondition"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta l&apos;uso del bene, che può variare nel corso del tempo, a seconda delle diverse occasioni e delle parti utilizzate del bene.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the use of a cultural property, that can change over time, depending on the circumstances and on which parts of the cultural property are used.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Use</rdfs:label>
        <rdfs:label xml:lang="it">Uso</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: UT. Normativa VeAC: AU/FRU. ICCD Normative RA, SMO, PST,  OAC, OA, MI, NU: RO/REI - ICCD Normative CA, MA: RO/RIU - ICCD Normativa F: ROP/CRF/CRFT = &apos;reimpiego&apos;. Normative A e PG: US/USO e US/USA. Normativa SM: MU, OS</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/UseFunction -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/UseFunction">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/RO/Role"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta la funzione d&apos;uso che ha un oggetto.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the use function of an object.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Funzione d&apos;uso</rdfs:label>
        <rdfs:label xml:lang="en">Use function</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale: UT/UTU/UTUF; LC/LDC/LDCF; LA/PRC/PRCF - BDM 2.00:UT/UTF - PST 3.01: DA/UTF
ICCD Normativa Trasversale: DA/ISE/ISEC - Normative di versioni precedenti: DA/ISR/ISRC; DA/APF/APFF - Normative VeAC, MA e CA: OG/OGT/OGTF. CF: CF/CFU. Normativa A e PG: US/USO/USOD, US/USA/USAD</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/UseType -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/UseType">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Type"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il tipo di uso del bene.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the type of use of a cultural property</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Tipo d&apos;uso</rdfs:label>
        <rdfs:label xml:lang="en">Use type</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale: UT/UTU/UTUT, UT/UTU/UTUS</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/UseTypeSpecification -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/UseTypeSpecification">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Type"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta le specifiche sul tipo di uso del bene (reimpiego, edilizio, epigrafico, ornamentale, strumentale, strutturale).</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the specification of the type of use of a cultural property (e.g. building, ornamental, structural, instrumental)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Specifiche del tipo d&apos;uso</rdfs:label>
        <rdfs:label xml:lang="en">Use type specification</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale: UT/UTU/UTUS</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?thing core:hasType ?type .
?type a a-cd:UseType .
}

WHERE {
?thing a-cd:hasUseTypeSpecification ?type .
?type a a-cd:UseTypeSpecification .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/UseType"/>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/UserSocialCategory -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/UserSocialCategory">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Category"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta la categoria sociale a cui appartiene l&apos;utente del bene.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the social category of a user (e.g. of a cultural property)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Categoria sociale dell&apos;utente</rdfs:label>
        <rdfs:label xml:lang="en">User social category</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normative BDM 2.00: UT/UTN/UTNC</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/VideoRecording -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/VideoRecording">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/Recording"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta la registrazione video di un&apos;entità culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a video recording of a cultural entity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Registrazione video</rdfs:label>
        <rdfs:label xml:lang="en">Video recording</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BDI: DV, VI</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/WorkCircumstance -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/WorkCircumstance">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/Circumstance"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta un&apos;occasione connessa al lavoro (es.: panificazione, agricoltura)</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a circumstance related to work (e.g.: agriculture, bakery)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Occasione legata al lavoro</rdfs:label>
        <rdfs:label xml:lang="en">Work circumstance</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BDI 4.00: CA/CAO/CAOL</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/context-description/YearCycleCircumstance -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/YearCycleCircumstance">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/context-description/Circumstance"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta un&apos;occasione legata ai cicli dell&apos;anno (es.: equinozio autunno, capodanno, Quaresima, Ramadan, carnevale, etc.)</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a circumstance related to year cycles (e.g.: autumnal equinox, New Year&apos;s Eve, Lent, Ramadan, carnival, etc.)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">Occasione legata al ciclo dell&apos;anno</rdfs:label>
        <rdfs:label xml:lang="en">Year cycle circumstance</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BDI 4.00: CA/CAO/CAOA</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/core/Agent -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/core/Agent">
        <rdfs:comment xml:lang="it">Questa classe rappresenta un agente, fisico (e.g. una persona) o sociale (e.g. un&apos;organizzazione).</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents an agent, either physical (e.g. a person) or social (e.g. an orgamization).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="en">Agent</rdfs:label>
        <rdfs:label xml:lang="it">Agente</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>Normativa trasversale: CD/ESC, CD/EPR, CD/ECP CM/CMP/CMPN, CM/CMC, CM/CMR, CM/RSR, CM/FUR, CM/RVM/RVMN, RVME, CM/AGG/AGGN, AGGR,AGGE, AGGF, AC/ACS/ACSE; RO/ROF/ROFA, RO/COP/COPA, RO/CRF/CRFN, CRFB, RO/ADL/ADLA, ADLE; AU/EDT/EDTN; PD/EDI/EDIR, TU/ACQ/ACQN, DO/DCM/DCMA, DCME, DO/FTA/FTAA, FTAE, DO/DRA/DRAA, DRAE; DO/VDC/VDCR, VDCE, DO/REG/REGA, REGE; DO/FNT/FNTA, FNTN, FNTE, DO/ADM/ADMA, ADME, DO/CTF/CTFC, DO/BIB/BIBA, DO/BSE/BSEA, TU/CDG/CDGS, TU/ESP/ESPU, TU/NVC/NVCA, TU/STU/STUE, AU/NMC/NMCN, RE/IND/INDE, INDR, INDN, RE/RCG/RCGA, RCGR, RCGF, RCGJ, RE/DSC/DSCA, DSCF, DSCR, DSCJ; CM/ISP/ISPN; */ALB/ALBO, ALBE; */FOI/FOIS, FOIE, FOIR, RE/AIN/AINR; DA/STM/STMI; DA/ISE/ISEO, ISEA; DA/ISR/ISRA; AU/DDC/DDCN, DDCM; TU/CPR/CPRN, DA/AUE/AUEE, AUEZ, AUES, DA/ZEC, AU/EDT/EDTN, EDTA, EDTZ; UT/UTN, UT/UTN/UTNN, AU/FRU/FRUN, */ACC/ACCE, AU/AUT/AUTN,  AUTB, AU/AAU/AAUN, AU/AUF/AUFN, AUFB; AU/AAF/AAFN, AU/AUI/AUIN, AUIB, AU/AAT/AATN, AU/AAT, AU/AAF/AAFN, AAFB; PD/PDF/PDFN, PDFB, UB/INP/INPE; AU/CMM/CMMN, CMME; */RST/RSTE, RSTR, RSTN; CON/CONA, CON/CONZ; MS/MST/MSTE, MSTO; MS/PRM/PRME; UB/COL/COLN. Normativa SCAN: BI/RIL/RILR, RILA. Normativa BDI: AT/ATT/ATTN; TCTCD; DR/DRV/DRVE, DRVR, DR/DRV, DRL, DRO, DRG, DRF, DRR; DU/DUY/DUYN, DU/DUX/DUXE, DUXC, DU/DUZ/DUZS, DU/DUQ/DUQN; DV/DVY/DVYN, DV/DVX/DVXE, DVXC, DV/DVZ/DVZS, DV/DVQ/DVQN; DF/DFY/DFYN, DF/DFX/DFXE, DFXC, DF/DFZ/DFZS, DF/DFQ/DFQN; AI/AIY/AIYN, AI/AIX/AIXE, AIXC, AI/AIZ/AIZS, AI/AIQ/AIQN, AI/AIF/AIFN, AI/AIE/AIED; VI/VIY/VIYN, VI/VIX/VIXE, VIXC, VI/VIZ/VIZS, VI/VIQ/VIQN, VI/VIF/VIFN, VI/VIE/VIED; FI/FIY/FIYN, FI/FIX/FIXE, FIXC, FI/FIZ/FIZS, FI/FIQ/FIQN, FI/FIF/FIFN, FI/FIE/FIED. Normativa MODI: RI/ATI/ATID, RI/ATC/ATCD. Normativa SM: MU/MUT/MUTN, OS/OSD, CL/CLA/CLAA. Versioni 4.00 e ICCD Normativa Trasversale: MS/MST/MSTE - Versioni precedenti a 4.00: DO/MST/MSTO</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/core/AgentRole -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/core/AgentRole">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/EventOrSituationInTime"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasAgent"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/core/Agent"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasRole"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/italia/onto/RO/Role"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://w3id.org/arco/ontology/core/Classification"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta una situazione relativa a un agente che ricopre un ruolo, senza la specificazione della dimensione tempo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a situation in which an agent holds a role, regardless of the timing.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="en">Agent Role</rdfs:label>
        <rdfs:label xml:lang="it">Ruolo ricoperto da agente</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>Normativa trasversale: CD/ESC, CD/EPR, CD/ECP CM/CMP/CMPN, CM/CMC, CM/CMR, CM/RSR, CM/FUR, CM/RVM/RVMN, RVME, CM/AGG/AGGN, AGGR,AGGE, AGGF, AC/ACS/ACSE; RO/ROF/ROFA, RO/COP/COPA, RO/CRF/CRFN, CRFB, RO/ADL/ADLA, ADLE; AU/EDT/EDTN; PD/EDI/EDIR, TU/ACQ/ACQN, DO/DCM/DCMA, DCME, DO/FTA/FTAA, FTAE, DO/DRA/DRAA, DRAE; DO/VDC/VDCR, VDCE, DO/REG/REGA, REGE; DO/FNT/FNTA, FNTN, FNTE, DO/ADM/ADMA, ADME, DO/CTF/CTFC, DO/BIB/BIBA, DO/BSE/BSEA, TU/CDG/CDGS, TU/ESP/ESPU, TU/NVC/NVCA, TU/STU/STUE, AU/NMC/NMCN, RE/IND/INDE, INDR, INDN, RE/RCG/RCGA, RCGR, RCGF, RCGJ, RE/DSC/DSCA, DSCF, DSCR, DSCJ; CM/ISP/ISPN; */ALB/ALBO, ALBE; */FOI/FOIS, FOIE, FOIR, RE/AIN/AINR; DA/STM/STMI; DA/ISE/ISEO, ISEA; DA/ISR/ISRA; AU/DDC/DDCN, DDCM; TU/CPR/CPRN, DA/AUE/AUEE, AUEZ, AAUES, DA/ZEC, AU/EDT/EDTN, EDTA, EDTZ; UT/UTN, , UT/UTN/UTNN, AU/FRU/FRUN, */ACC/ACCE, AU/AUT/AUTN,  AUTB, AU/AAU/AAUN, AU/AUF/AUFN, AUFB; AU/AAF/AAFN, AU/AUI/AUIN, AUIB, AU/AAT/AATN, AU/AAT, AU/AAF/AAFN, AAFB; PD/PDF/PDFN, PDFBM UB/INP/INPE; AU/CMM/CMMN, CMME; */RST/RSTE, RSTR, RSTN; DA/CON, CONZ/CONA; MS/MST/MSTE, MSTO; MS/PRM/PRME. Normativa BDI: AT/ATT/ATTN; TCTCD; DR/DRV/DRVE, DRVR, DR/DRV, DRL, DRO, DRG, DRF, DRR; DU/DUY/DUYN, DU/DUX/DUXE, DUXC, DU/DUZ/DUZS, DU/DUQ/DUQN; DV/DVY/DVYN, DV/DVX/DVXE, DVXC, DV/DVZ/DVZS, DV/DVQ/DVQN; DF/DFY/DFYN, DF/DFX/DFXE, DFXC, DF/DFZ/DFZS, DF/DFQ/DFQN; AI/AIY/AIYN, AI/AIX/AIXE, AIXC, AI/AIZ/AIZS, AI/AIQ/AIQN, AI/AIF/AIFN, AI/AIE/AIED; VI/VIY/VIYN, VI/VIX/VIXE, VIXC, VI/VIZ/VIZS, VI/VIQ/VIQN, VI/VIF/VIFN, VI/VIE/VIED; FI/FIY/FIYN, FI/FIX/FIXE, FIXC, FI/FIZ/FIZS, FI/FIQ/FIQN, FI/FIF/FIFN, FI/FIE/FIED. Normativa MODI: RI/ATI/ATID, RI/ATC/ATCD. Normativa SM: MU/MUT/MUTN, OS/OSD, CL/CLA/CLAA. Normativa BNB: SB/DBV/DBVA, SB/NAA/NAAG, NAAI, NAAE, NAAC, SB/NAT/NATG, NATI, NATE, NATC, SB/ABC/ABCA, RB/RBR/RBRA, RB/RBR/RBNG, RBNI, RBNE, RBNC, LR/LRD/LRDA, DB/DBR/DBRA, DB/DBC/DBCA, DB/DBX/DBXT, DB/DBP/DBPA, DB/DBS/DBSR, SB/TBI/TBIA. Normativa BNM: LR/LRI/LRIL, LRIZ, LRIG, LRIX, SM/SMT/SMTA, RM/RMT/RMTA. Normativa BNP: SP/SPS/SPSL, SPSA, SPSD. Normativa BNZ: SZ/SZS/SZSL, SZSE, SZSD. Normativa ATOG/OGS/OGSA, IN/INI/INIL, INIO. Normativa BNPE: RR/RRD/RRDA, RR/RRT/RRTA, SR/SRT/SRTA. Normativa BNPL: SP/SPN/SPNS, SPNM, SP/SPT/SPTA, RP/RPT/RPTA. Versioni 4.00 e ICCD Normativa Trasversale: MS/MST/MSTE - Versioni precedenti a 4.00: DO/MST/MSTO</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/core/Category -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/core/Category">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Concept"/>
        <rdfs:comment xml:lang="it">La classe che rappresenta una categoria.</rdfs:comment>
        <rdfs:comment xml:lang="en">The class representing a category.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="it">Categoria</rdfs:label>
        <rdfs:label xml:lang="en">Category</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/core/Characteristic -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/core/Characteristic">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Characteristic"/>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="it">Caratteristica</rdfs:label>
        <rdfs:label xml:lang="en">Characteristic</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <adms:hasTask xml:lang="it">Questa classe rappresenta la caratteristica che appartiene a un&apos;entità.</adms:hasTask>
        <adms:hasTask xml:lang="en">This class represents the characteristic of an entity.</adms:hasTask>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/core/Classification -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/core/Classification">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasClassificationSystem"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/core/ClassificationSystem"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <opla:isNativeTo rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/countingas.owl"/>
        <rdfs:comment xml:lang="it">La classe che rappresenta il concetto di classificazione.</rdfs:comment>
        <rdfs:comment xml:lang="en">The class that models the concept of classification.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="en">Classification</rdfs:label>
        <rdfs:label xml:lang="it">Classificazione</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/core/ClassificationInTime -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/core/ClassificationInTime">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Classification"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/EventOrSituationInTime"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasConcept"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/core/Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/involvesAgent"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/core/Agent"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasConcept"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/core/Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/isClassificationInTimeOf"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <opla:reusesPatternAsTemplate rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/timeindexedclassification.owl"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta una classificazione nel tempo</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a classification in time</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="en">Classification in time</rdfs:label>
        <rdfs:label xml:lang="it">Classificazione nel tempo</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>Normativa SM: CL/CHS, CL/CLA. Normativa BNB: SB/NBN/NBNA, SB/NAA, RB/RBR/RBRN, RB/RBN. Normativa BNM: SM/SMN, RM/RMN.
Normativa  BNP: SPS/SPSPS. Normativa AT: OG/OGS. Normativa BNPE: SR/SRN. Normativa BNPL:  SP/SPN. Normativa BNZ: SZ/SZS</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/core/ClassificationSystem -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/core/ClassificationSystem">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/System"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/definesConcept"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/core/Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/isClassificationSystemOf"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/core/ClassificationInTime"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il sistema di classificazione in base a cui un&apos;entità è stata classificata.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents classification system used to classify an entity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="en">Classification system</rdfs:label>
        <rdfs:label xml:lang="it">Sistema di classificazione</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BNM: SM/SMS/SMSG, SMSD, SMSC, SMSS. Normativa SM: CL/CLA. - Normativa BNB: SB/SBS/SBSC</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/core/Concept -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/core/Concept">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Concept"/>
        <opla:isNativeTo rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/timeindexedclassification.owl"/>
        <rdfs:comment xml:lang="it">La classe che rappresenta un concetto.</rdfs:comment>
        <rdfs:comment xml:lang="en">The class representing a concept.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="en">Concept</rdfs:label>
        <rdfs:label xml:lang="it">Concetto</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>Normativa trasversale: */SGT/SGTI, DA/DES/DESU, DA/AID/AIDI, RO/ROF/ROFS, */THS/THSD. VeAC: OG/OGT/OGTV. SM: CL/CHS/CHSN, CL/CLA/CLAT</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/core/CulturalEntityCharacteristic -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/core/CulturalEntityCharacteristic">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Characteristic"/>
        <rdfs:comment xml:lang="it">La classe che rappresenta una caratteristica di un&apos;entità di carattere culturale come ad esempio un bene culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">The class representing the characteristic of a cultural entity (e.g. a cultural property).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="it">Caratteristica di Entità Culturale</rdfs:label>
        <rdfs:label xml:lang="en">Cultural Entity Characteristic</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/core/CulturalEntityClassification -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/core/CulturalEntityClassification">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Classification"/>
        <rdfs:comment xml:lang="it">La classe che rappresenta il concetto di classificazione di un&apos;entità culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">The class that models the concept of cultural entity classification.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="it">Classificazione relativa a bene culturale</rdfs:label>
        <rdfs:label xml:lang="en">Cultural entity classification</rdfs:label>
        
        <core:constructQuery>CONSTRUCT {
?class a core:ClassificationInTime .
}

WHERE {
?class a core:CulturalEntityClassification .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/ClassificationInTime"/>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/core/Depiction -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/core/Depiction">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
        <rdfs:comment xml:lang="en">This class represents the depiction of a cultural entity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="en">Depiction</rdfs:label>
        <rdfs:label xml:lang="it">Foto</rdfs:label>
        <rdfs:label xml:lang="it">Ritratto</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/core/Description -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/core/Description">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Description"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta una descrizione, una concettualizzazione utilizzata per definire concetti a partire da un insieme di dati o osservazioni.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a description, a conceptualization used for defining concepts out of a set of data or observations.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="en">Description</rdfs:label>
        <rdfs:label xml:lang="it">Descrizione</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/core/Entity -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/core/Entity">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Entity"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta un&apos;entità, qualsiasi cosa reale o immaginaria.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents an entity, anything real, possible, or imaginary.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="en">Entity</rdfs:label>
        <rdfs:label xml:lang="it">Entità</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:Class>
    


