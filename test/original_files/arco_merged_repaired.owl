        <rdfs:label xml:lang="it">con indirizzo</rdfs:label>
        <rdfs:label xml:lang="en">with address</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


