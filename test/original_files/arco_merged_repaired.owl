        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/isGeologicalContextOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/GeologicalContext"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega la localizzazione del luogo di raccolta al contesto geologico</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the collecting site to the geological context</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description"/>
        <rdfs:label xml:lang="it">ha contesto geologico</rdfs:label>
        <rdfs:label xml:lang="en">has geological context</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BNM: IM/IMA/IMAC</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/natural-specimen-description/hasGrains -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/natural-specimen-description/hasGrains">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/Texture"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/Grains"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega la tessitura di un campione ai grani</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the texture of a specimen to the grains</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description"/>
        <rdfs:label xml:lang="it">ha grani</rdfs:label>
        <rdfs:label xml:lang="en">has grains</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>Normativa ICCD BNPE: SR/SRC/SRCF, SR/SRC/SRCG</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/natural-specimen-description/hasHarvestingMethod -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/natural-specimen-description/hasHarvestingMethod">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasMethod"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/isHarvestingMethodOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/SpecimenHarvesting"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/HarvestingMethod"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega la raccolta al suo metodo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the specimen harvesting to the method</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description"/>
        <rdfs:label xml:lang="it">ha metodo di raccolta</rdfs:label>
        <rdfs:label xml:lang="en">has harvesting method</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">Normativa Beni naturalistici: LR/LRI/LRIW</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/natural-specimen-description/hasHarvestingMotivation -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/natural-specimen-description/hasHarvestingMotivation">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/hasDescription"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/isHarvestingMotivation"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/SpecimenHarvesting"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/HarvestingMotivation"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega la raccolta alla sua motivazione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the specimen harvesting to the motivation</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description"/>
        <rdfs:label xml:lang="it">ha motivazione della raccolta</rdfs:label>
        <rdfs:label xml:lang="en">has harvesting motivation</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/natural-specimen-description/hasHarvestingOperator -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/natural-specimen-description/hasHarvestingOperator">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/hasRelatedAgent"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/isHarvestingOperatorOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/SpecimenHarvesting"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega la raccolta all&apos;operatore.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the specimen harvesting to operator</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description"/>
        <rdfs:label xml:lang="it">ha operatore</rdfs:label>
        <rdfs:label xml:lang="en">has harvesting operator</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {
?speharv a-lite:hasOperator ?agent.
}

WHERE {
?speharv a-spe:hasHarvestingOperator ?agent.
}</core:constructQuery>
        <core:replacingQuery rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasOperator"/>
        <core:replacingQuery>select * where {
?spehar core:hasAgentRole ?NEWagentRole .
?NEWagentRole core:hasRole ?NEWrole ;
core:hasAgent ?agent .
}</core:replacingQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/natural-specimen-description/hasHarvestingResponsible -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/natural-specimen-description/hasHarvestingResponsible">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/hasRelatedAgent"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/isHarvestingResponsibleOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/SpecimenHarvesting"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega la raccolta al responsabile della raccolta.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the specimen harvesting to the harvesting operator</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description"/>
        <rdfs:label xml:lang="it">ha responsabile della raccolta</rdfs:label>
        <rdfs:label xml:lang="en">has harvesting responsible</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {
?speharv a-lite:hasResponsibleAgent ?agent .
}

WHERE {
?speharv a-spe:hasHarvestingResponsible ?agent .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasResponsibleAgent"/>
        <core:replacingQuery>select * where {
?bib core:hasAgentRole ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/ResponsibleAgent&gt; ;
core:hasAgent ?agent .
}</core:replacingQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/natural-specimen-description/hasHarvestingSponsor -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/natural-specimen-description/hasHarvestingSponsor">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/hasRelatedAgent"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/isHarvestingSponsorOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/SpecimenHarvesting"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega la raccolta allo sponsor.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the specimen harvesting to the sponsor</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description"/>
        <rdfs:label xml:lang="it">ha sponsor</rdfs:label>
        <rdfs:label xml:lang="en">has harvesting sponsor</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {
?speharv a-lite:hasSponsor ?agent .
}

WHERE {
?speharv a-spe:hasHarvestingSponsor ?agent .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasSponsor"/>
        <core:replacingQuery>select * where {
?bib core:hasAgentRole ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/Sponsor&gt; ;
core:hasAgent ?agent .
}</core:replacingQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/natural-specimen-description/hasHostIndividual -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/natural-specimen-description/hasHostIndividual">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/isHostIndividualOf"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/HostIndividual"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega il campione all&apos;indivduo ospite</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the specimen to the host individual</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description"/>
        <rdfs:label xml:lang="it">ha individuo ospite</rdfs:label>
        <rdfs:label xml:lang="en">has host individual</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BNB: LR/LRI/LRIM</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/natural-specimen-description/hasHostRock -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/natural-specimen-description/hasHostRock">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/isHostRock"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/Specimen"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/HostRock"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un campione alla roccia ospitante</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a specimen to the host rock</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description"/>
        <rdfs:label xml:lang="it">ha roccia ospitante</rdfs:label>
        <rdfs:label xml:lang="en">has host rock</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>Normativa ICCD BNM: IM/IMA/IMAO</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?x a-spe:hasHostIndividual ?y .
}

WHERE {
?x a-spe:hasHostRock ?y .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/hasHostIndividual"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/natural-specimen-description/hasIdentificationInTime -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/natural-specimen-description/hasIdentificationInTime">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasEventOrSituationInTime"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/isIdentificationInTimeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/Specimen"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/IdentificationInTime"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;entità a un&apos;identificazione nel tempo</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an entity to an identification in time</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description"/>
        <rdfs:label xml:lang="it">ha identificazione nel tempo</rdfs:label>
        <rdfs:label xml:lang="en">has identification in time</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BNB: SB/TBI. BNM: SM/SMT&apos;</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/natural-specimen-description/hasIncline -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/natural-specimen-description/hasIncline">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/isInclineOf"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/Substrate"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/Incline"/>
        <rdfs:comment xml:lang="it">Questa proprietà  collega il luogo di raccolta all&apos;inclinazione</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the collecting site to the incline</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description"/>
        <rdfs:label xml:lang="it">ha inclinazione</rdfs:label>
        <rdfs:label xml:lang="en">has incline</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BNB: LR/LRI/LRII</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/natural-specimen-description/hasInclusion -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/natural-specimen-description/hasInclusion">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/isInclusionOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/Inclusion"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega il campione mineralogico all&apos;inclusione</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the mineral specimen to the inclusion.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description"/>
        <rdfs:label xml:lang="it">ha inclusione</rdfs:label>
        <rdfs:label xml:lang="en">has inclusion</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>Normativa ICCD BNB: SM/SMA/SMAI</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/natural-specimen-description/hasLabel -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/natural-specimen-description/hasLabel">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/isLabelOf"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/SpecimenLabel"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un bene culturale ad un&apos;etichetta</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural property to a label.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description"/>
        <rdfs:label xml:lang="it">ha etichetta</rdfs:label>
        <rdfs:label xml:lang="en">has label</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BNB: SB/SBE</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/natural-specimen-description/hasMatrix -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/natural-specimen-description/hasMatrix">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/isMatrixOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/Texture"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/Matrix"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega la tessitura di un campione alla matrice</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the texture of a specimen to the matrix</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description"/>
        <rdfs:label xml:lang="it">ha matrice</rdfs:label>
        <rdfs:label xml:lang="en">has matrix</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>Normativa ICCD BNPE: SR/SRC/SRCX</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/natural-specimen-description/hasMineralDeposit -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/natural-specimen-description/hasMineralDeposit">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/isMineralDepositOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/GeologicalContext"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/MineralDeposit"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega il contesto geologico al deposito mineraliogico</rdfs:comment>
        <rdfs:comment xml:lang="en">This property realtes the geological context to the mineral deposit</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description"/>
        <rdfs:label xml:lang="it">ha deposito mineralogico</rdfs:label>
        <rdfs:label xml:lang="en">has mineral deposit</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BNM: IM/IMA/IMAR</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/natural-specimen-description/hasMineralPresence -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/natural-specimen-description/hasMineralPresence">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/isMineralPresenceOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/Specimen"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/MineralPresence"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega il campione alla presenza di un minerale nel campione</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the specimen to the presence of a mineral in the specimen</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description"/>
        <rdfs:label xml:lang="it">ha presenza di minerale</rdfs:label>
        <rdfs:label xml:lang="en">has mineral presence</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>Normativa ICCD BNPE: SR/SRM/SRMP, SR/SRM/SRMS, SR/SRM/SRMT</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/natural-specimen-description/hasOutcrop -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/natural-specimen-description/hasOutcrop">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/isOutcropOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/GeologicalContext"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/Outcrop"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega il contesto geologico all&apos;affioramento</rdfs:comment>
        <rdfs:comment xml:lang="en">This property realtes the geological context to the outcrop</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description"/>
        <rdfs:label xml:lang="it">ha affioramento</rdfs:label>
        <rdfs:label xml:lang="en">has outcrop</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BNM: IM/IMA/IMAF, IMAD</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/natural-specimen-description/hasParamorphosis -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/natural-specimen-description/hasParamorphosis">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/hasCrystalMorphology"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/isParamorphosisOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/Specimen"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/Paramorphosis"/>
