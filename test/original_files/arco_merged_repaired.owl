    <!-- https://w3id.org/arco/ontology/denotative-description/isSupportOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/isSupportOf">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/denotative-description/Support"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/AffixedElement"/>
