    </owl:NamedIndividual>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/Rainfall -->

    <owl:NamedIndividual rdf:about="https://w3id.org/arco/ontology/denotative-description/Rainfall">
        <rdf:type rdf:resource="https://w3id.org/arco/ontology/denotative-description/MeasurementType"/>
        <rdfs:label xml:lang="it">Precipitazioni</rdfs:label>
        <rdfs:label xml:lang="en">Rainfall</rdfs:label>
        
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>Normativa PG: CA/CLM/CLMP. Normativa BNB: LR/LRI/LRIT</a-cat:iccdNormTag>
        <core:replacingQuery>select * where {
?x a a-loc:ClimateSituation ;
a-dd:hasMeasurementCollection ?measCol .
?measCol a-dd:hasMeasurement ?meas .
?meas a-dd:hasValue ?value ;
mu:hasMeasurementUnit ?unit ;
core:hasType ?rainfalltype .
}</core:replacingQuery>
    </owl:NamedIndividual>
    


