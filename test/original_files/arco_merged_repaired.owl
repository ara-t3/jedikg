    <!-- https://w3id.org/arco/ontology/location/NaturalEnvironment -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/location/NaturalEnvironment">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/EventOrSituationInTime"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/construction-description/hasWaterSystem"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/construction-description/WaterSystem"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/location/NaturalEnvironmentType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/denotative-description/hasMeasurementCollection"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/denotative-description/MeasurementCollection"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/location/hasClimateSituation"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/location/ClimateSituation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/location/hasFluidDynamism"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/location/FluidDynamism"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/location/hasMarineBiogeographicRealm"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/location/MarineBiogeographicRealm"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/location/hasShadeTolerance"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/location/ShadeTolerance"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/location/hasSoil"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/location/Soil"/>
