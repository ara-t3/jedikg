    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/core/isTypeOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/core/isTypeOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isConceptOf"/>
