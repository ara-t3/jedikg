        <rdfs:comment xml:lang="en">This class represents a door.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/construction-description"/>
        <rdfs:label xml:lang="en">Door</rdfs:label>
        <rdfs:label xml:lang="it">Porta</rdfs:label>
