        <rdfs:label xml:lang="it">Trave</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/construction-description/Building -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/construction-description/Building">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/construction-description/ConstructionSpace"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/construction-description/numberOfFloors"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/construction-description/numberOfRooms"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta un tipo di costruzione, definito dalla presenza di muri e di una copertura.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a kind of construction, defined by walls and a roof.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/construction-description"/>
