    <!-- https://w3id.org/arco/ontology/context-description/ExistingDocumentation -->

    <owl:NamedIndividual rdf:about="https://w3id.org/arco/ontology/context-description/ExistingDocumentation">
        <rdf:type rdf:resource="https://w3id.org/arco/ontology/context-description/DocumentationCategory"/>
        <rdfs:comment xml:lang="it">Questo individuo rappresenta la definizione (vocabolario chiuso) della documentazione che viene solo citata: non è acclusa alla scheda di catalogo, ma si trova presso un luogo di conservazione (Archivio, Biblioteca, ecc.), anche “virtuale”, come nel caso delle risorse disponibili sul web e consultabili on line.</rdfs:comment>
        <rdfs:comment xml:lang="en">This individual represents documentation definition that is only mentioned.</rdfs:comment>
        <rdfs:label xml:lang="it">Documentazione esistente</rdfs:label>
        <rdfs:label xml:lang="en">Existing documentation</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {
?x a-cd:hasDocumentation ?doc .
}

WHERE {
?x a-cd:hasDocumentation ?doc .
?doc core:hasCategory a-cd:ExistingDocumentation .
}</core:constructQuery>
    </owl:NamedIndividual>
    


