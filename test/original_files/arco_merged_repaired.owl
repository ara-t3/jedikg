        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {?char &lt;https://w3id.org/arco/ontology/arco-lite/isTechniqueOf&gt; ?class .}
WHERE {?char a-dd:isTechniqueOf ?class. }</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/isTechniqueOf"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/isTemperamentOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/isTemperamentOf">
