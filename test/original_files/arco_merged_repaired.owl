            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/construction-description/hasWaterAvailability"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/construction-description/WaterAvailability"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/construction-description/hasWaterDistribution"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/construction-description/WaterDistribution"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/construction-description/hasWaterElement"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/construction-description/WaterElement"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/construction-description/WaterSystemType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/description"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il sistema delle acque, inclusi elementi artificiali e naturali, di uno spazio (per es: una costruzione, un parco, un giardine, ecc).</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the water system of a construction.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/construction-description"/>
        <rdfs:label xml:lang="it">Impianto idrico</rdfs:label>
        <rdfs:label xml:lang="en">Water system</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>Normativa PG: CA/CAI, IM/IMP/IMPT</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/construction-description/WaterSystemType -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/construction-description/WaterSystemType">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Type"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta l&apos;impianto idrico di una costruzione (.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the type of a water system.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/construction-description"/>
