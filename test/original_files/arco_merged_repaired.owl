        <rdfs:label xml:lang="en">Host individual</rdfs:label>
        <rdfs:label xml:lang="it">Individuo ospite</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BNB: LR/LRI/LRIM</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/natural-specimen-description/HostRock -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/natural-specimen-description/HostRock">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/HostIndividual"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta la roccia ospite</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the host rock</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description"/>
        <rdfs:label xml:lang="en">Host rock</rdfs:label>
        <rdfs:label xml:lang="it">Roccia ospite</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BNM: IM/IMA/IMAO</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?x a a-spe:Rock .
}

WHERE {
?x a a-spe:HostRock .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/Rock"/>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/natural-specimen-description/IdentificationInTime -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/natural-specimen-description/IdentificationInTime">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/EventOrSituationInTime"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasTaxon"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/core/Taxon"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/involvesAgent"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/isIdentificationInTimeOf"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/Specimen"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasTaxon"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/core/Taxon"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/current"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta un&apos;identificazione nel tempo</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents an identification in time</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description"/>
        <rdfs:label xml:lang="en">Identification in time</rdfs:label>
        <rdfs:label xml:lang="it">Identificazione nel tempo</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>Normativa BNB: SB/NBN/NBNA, SB/NAA, RB/RBR/RBRN, RB/RBN. Normativa BNM: SM/SMN, RM/RMN.
Normativa  BNP: SPS/SPSPS. Normativa AT: OG/OGS. Normativa BNPE: SR/SRN. Normativa BNPL:  SP/SPN. Normativa BNZ: SZ/SZS</a-cat:iccdNormTag>
    </owl:Class>
    


