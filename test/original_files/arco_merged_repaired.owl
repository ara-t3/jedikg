        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/TI/TimeInterval"/>
        <rdfs:comment xml:lang="it">La object property che indica se un oggetto è valido per un intervallo di tempo.</rdfs:comment>
        <rdfs:comment xml:lang="en">The object property that indicates if an object is valid for a time interval.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
