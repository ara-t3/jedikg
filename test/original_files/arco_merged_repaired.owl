        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa CG: CG/CGT, CG/CGQ</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/location/Eon -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/location/Eon">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/location/GeochronologicalClass"/>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/location/Eontem -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/location/Eontem">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/location/ChronostratigraphicClass"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta l&apos;unità cronostratigrafica di rango più alto dell&apos;eonotema. L&apos;unità geocronologica corrispondente è l&apos;Eon.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the cronostratigraphic unit &quot;Eontem&quot;, corrisponding to the chronostratigraphic &quot;Eon&quot;.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="it">Eonotema</rdfs:label>
        <rdfs:label xml:lang="en">Eontem</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BNM: IMG/IMGE
ICCD Normativa BNP: ETG/ETGE
ICCD Normativa BNPE: IRG/IRGE</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/location/Erathem -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/location/Erathem">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/location/ChronostratigraphicClass"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta l&apos;unità cronostratigrafica era.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the cronostratigraphic class &quot;erathem&quot;.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="it">Eratema</rdfs:label>
        <rdfs:label xml:lang="en">Erathem</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BNM: IMG/IMGR
ICCD Normativa BNP: ETG/ETGR
ICCD Normativa BNPE: IRG/IRGR</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/location/FluidDynamism -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/location/FluidDynamism">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Characteristic"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta l&apos;idrodinamismo (moto ondoso) di un ambiente naturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the fluid dynamism of a natural environment.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="en">Fluid dynamism</rdfs:label>
        <rdfs:label xml:lang="it">Idrodinamismo</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BNB, BNP, BNZ: LR/LRI/LRID</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/location/GeochronologicalAge -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/location/GeochronologicalAge">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/location/GeochronologicalClass"/>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/location/GeochronologicalClass -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/location/GeochronologicalClass">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Concept"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta una classe geocronologica usata per descrivere il contesto in cui si trovava un bene prima di essere raccolto.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the geochronological class of the context of a cp before its harvesting.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="it">Classe geocronologica</rdfs:label>
        <rdfs:label xml:lang="en">Geochronological class</rdfs:label>
        <a-cat:iccdNormTag>ICCD Normativa BNM: IMG
ICCD Normativa BNP: ETG
ICCD Normativa BNPE: IRG</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/location/GeochronologicalEpoch -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/location/GeochronologicalEpoch">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/location/GeochronologicalClass"/>
