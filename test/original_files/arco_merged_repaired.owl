        <rdfs:label xml:lang="en">Facade type</rdfs:label>
        <rdfs:label xml:lang="it">Tipo di facciata</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/construction-description/FenceOrGate -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/construction-description/FenceOrGate">
