        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:comment xml:lang="it">Questa è la proprietà inversa di &quot;ha categoria sociale dell&apos;utente di&quot;</rdfs:comment>
        <rdfs:comment xml:lang="en">This is the inverse property of &quot;has user social category&quot;.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is user social category of</rdfs:label>
        <rdfs:label xml:lang="it">è categoria sociale dell&apos;utente di</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normative BDM 2.00: UT/UTN/UTNC</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isWorkRelatedTo -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isWorkRelatedTo">
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:comment xml:lang="it">Questa è la proprietà inversa a &quot;ha opera collegata&quot;.</rdfs:comment>
        <rdfs:comment xml:lang="en">This is the inverse property of &quot;has related work&quot;.</rdfs:comment>
        <rdfs:comment>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?cult a-lite:isWorkRelatedTo ?cultsec .
}

WHERE {
?cult a-cd:isWorlRelatedTo ?cultsec .
}</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is work related to</rdfs:label>
        <rdfs:label xml:lang="it">è opera collegata a</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/isWorkRelatedTo"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/reproduces -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/reproduces">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Reproduction"/>
        <rdfs:range rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega la riproduzione dell&apos;immagine contenuta nella pubblicazione di cui la stampa è, o è stata, parte integrante con la stampa stessa.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the reproduction of an print in a publication to the print itself.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">reproduces</rdfs:label>
        <rdfs:label xml:lang="it">riproduce</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa S 3: RO/ADL</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/reuses -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/reuses">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/isWorkRelatedTo"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:comment xml:lang="it">Questa è la proprietà inversa di &apos;è riutilizzato da&apos;, che collega un bene culturale a un altro bene culturale collegato che lo riutilizza in tutto o in parte.</rdfs:comment>
        <rdfs:comment xml:lang="en">This is the invers property of &apos;is reused by&apos;, which relates a cultural entity to a connected cultural entity that reuse it or a part of it.</rdfs:comment>
        <rdfs:comment>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?cult a-lite:reuses ?cultsec .
}

WHERE {
?cult a-cd:reuses ?cultsec .
}</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">reuses</rdfs:label>
        <rdfs:label xml:lang="it">riutilizza</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/reuses"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/specificTime -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/specificTime">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/TI/atTime"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/context-description/specificTimeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/EventOrSituation"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/TI/TimeInterval"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega l&apos;evento (realizzazione, demolizione, etc.) cui si riferisce una specifica cronologia di un bene culturale alla cronologia specifica, cioè la cronologia in anni (anche a cavallo di secoli diversi) o con date precise (nella forma &quot;aaaa/mm/gg&quot;). Nel caso in cui la cronologia corrisponda ad uno specifico anno, l&apos;intervallo di tempo avrà lo stesso valore per data di inizio e data di fine.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the event (creation, distruction) to which a dating of a cultural property is related to the &quot;specific time&quot;, as the dating expressed in year or as a date yyyy/mm/dd.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">cronologia specifica</rdfs:label>
        <rdfs:label xml:lang="en">specific time</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale: DT/DTS/DTSI + DT/DTS/DTSV + DT/DTS/DTSF + DT/DTS/DTSL</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/specificTimeOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/specificTimeOf">
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/TI/TimeInterval"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/EventOrSituation"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega la cronologia specifica, cioè la cronologia in anni (anche a cavallo di secoli diversi) o con date precise (nella forma &quot;aaaa/mm/gg&quot;) con l&apos;evento (realizzazione, demolizione, etc.) cui si riferisce una specifica cronologia di un bene culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the &quot;specific time&quot;, as the dating expressed in year or as a date yyyy/mm/dd, with the event (creation, distruction) to which a dating of a cultural property is related to.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="it">cronologia specifica di</rdfs:label>
        <rdfs:label xml:lang="en">specific time of</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale: DT/DTS/DTSI + DT/DTS/DTSV + DT/DTS/DTSF + DT/DTS/DTSL</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/core/classifies -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/core/classifies">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/core/isClassifiedBy"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/core/Concept"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un concetto ad un&apos;entità</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a concept to an entity</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="it">classifica</rdfs:label>
        <rdfs:label xml:lang="en">classifies</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>Normativa trasversale: */SGT/SGTI, DA/AID/AIDI, RO/ROF/ROFS, */THS/THSD. VeAC: OG/OGT/OGTV. SM: CL/CHS/CHSN, CL/CLA/CLAT</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/core/definesConcept -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/core/definesConcept">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/core/isDefinedByClassificationSystem"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/core/ClassificationSystem"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/core/Concept"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega sistema di classificazione al concetto</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a classification system to a concept</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="en">defines concept</rdfs:label>
        <rdfs:label xml:lang="it">definisce concetto</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>Normativa trasversale e normative precedenti 4.00: SG/CLF/CLFT. SM: CL/CLA/CLAA. Normativa BNM: SM/SMS/SMSX, SMSC, SMSD, RM/RMS/RMSX, RMSK</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/core/describes -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/core/describes">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/core/isDescribedBy"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="it">Questa proprietà è stata creata come proprietà generica di sottoproprietà specifiche, e rappresenta la relazione tra un&apos;entità che descrive un&apos;altra entità.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property was created as a generic property for specific subproperties, and represents the relationship between an entity that describes another entity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="en">describes</rdfs:label>
        <rdfs:label xml:lang="it">descrive</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>Tutte le schede di catalogo descrivono un bene. ICCD Normativa Tr: AC/ACS, AC/MOD</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/core/hasAgent -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/core/hasAgent">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/RO/isRoleInTimeOf"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/core/isAgentOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/core/AgentRole"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/core/Agent"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una situazione in cui un ruolo viene ricoperto da un agente all&apos;agente che lo ricopre.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a situation in which an agent holds a role to that agent.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="it">ha agente</rdfs:label>
        <rdfs:label xml:lang="en">has agent</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>Normativa trasversale: CD/ESC, CD/EPR, CD/ECP CM/CMP/CMPN, CM/CMC, CM/CMR, CM/RSR, CM/FUR, CM/RVM/RVMN, RVME, CM/AGG/AGGN, AGGR,AGGE, AGGF, AC/ACS/ACSE; RO/ROF/ROFA, RO/COP/COPA, RO/CRF/CRFN, CRFB, RO/ADL/ADLA, ADLE; TU/ACQ/ACQN, DO/DCM/DCMA, DCME, DO/FTA/FTAA, FTAE, DO/DRA/DRAA, DRAE; DO/VDC/VDCR, VDCE, DO/REG/REGA, REGE; DO/FNT/FNTA, FNTN, FNTE, DO/ADM/ADMA, ADME, DO/CTF/CTFC, DO/BIB/BIBA, DO/BSE/BSEA, TU/CDG/CDGS, TU/ESP/ESPU, TU/NVC/NVCA, TU/STU/STUE, RE/IND/INDE, INDR, INDN, RE/RCG/RCGA, RCGR, RCGF, RCGJ, RE/DSC/DSCA, DSCF, DSCR, DSCJ; CM/ISP/ISPN; */ALB/ALBO, ALBE; */FOI/FOIS, FOIE, FOIR, RE/AIN/AINR; AU/DDC/DDCN, DDCM; TU/CPR/CPRN, DA/AUE/AUEE, AUEZ, AUES, DA/ZEC, AU/EDT/EDTN, EDTA, EDTZ; UT/UTN, UT/UTN/UTNN, AU/FRU/FRUN, */ACC/ACCE. UB/INP/INPE; AU/CMM/CMMN, CMME; */RST/RSTE, RSTR, RSTN; CON/CONA, CON/CONZ; MS/MST/MSTE, MSTO; MS/PRM/PRME; UB/COL/COLN. Normativa SCAN: BI/RIL/RILR, RILA. Normativa BDI: DR/DRV/DRVE, DRVR, DR/DRV, DRL, DRO, DRG, DRF, DRR; DU/DUY/DUYN, DU/DUX/DUXE, DUXC, DU/DUZ/DUZS, DU/DUQ/DUQN; DV/DVY/DVYN, DV/DVX/DVXE, DVXC, DV/DVZ/DVZS, DV/DVQ/DVQN; DF/DFY/DFYN, DF/DFX/DFXE, DFXC, DF/DFZ/DFZS, DF/DFQ/DFQN; AI/AIY/AIYN, AI/AIX/AIXE, AIXC, AI/AIZ/AIZS, AI/AIQ/AIQN, AI/AIF/AIFN, AI/AIE/AIED; VI/VIY/VIYN, VI/VIX/VIXE, VIXC, VI/VIZ/VIZS, VI/VIQ/VIQN, VI/VIF/VIFN, VI/VIE/VIED; FI/FIY/FIYN, FI/FIX/FIXE, FIXC, FI/FIZ/FIZS, FI/FIQ/FIQN, FI/FIF/FIFN, FI/FIE/FIED. Normativa SM: CL/CLA/CLAA. Normativa BNB: SB/NAA/NAAG, NAAI, NAAE, NAAC, SB/NAT/NATG, NATI, NATE, NATC, RB/RBR/RBNG, RBNI, RBNE, RBNC, LR/LRD/LRDA, DB/DBR/DBRA, DB/DBC/DBCA, DB/DBX/DBXT, DB/DBP/DBPA, DB/DBS/DBSR. Normativa BNM: LR/LRI/LRIL, LRIZ, LRIG, LRIX,. Normativa BNP: SP/SPS/SPSA, SPSD. Normativa BNZ: SZ/SZS/SZSE, SZSD. Normativa ATOG/OGS/OGSA, IN/INI/INIL, INIO. Normativa BNPL: SP/SPN/SPNS, SPNM. Versioni 4.00 e ICCD Normativa Trasversale: MS/MST/MSTE - Versioni precedenti a 4.00: DO/MST/MSTO</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/core/hasAgentRole -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/core/hasAgentRole">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/core/isAgentRoleOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/core/AgentRole"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;entità a una situazione in cui un agente ricopre un ruolo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an entity to a situation in which an agent holds a role connected to that entity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="it">ha ruolo ricoperto da agente</rdfs:label>
        <rdfs:label xml:lang="en">has agent role</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>Normativa trasversale: CD/ESC, CD/EPR, CD/ECP CM/CMP/CMPN, CM/CMC, CM/CMR, CM/RSR, CM/FUR, CM/RVM/RVMN, RVME, CM/AGG/AGGN, AGGR,AGGE, AGGF, AC/ACS/ACSE; RO/ROF/ROFA, RO/COP/COPA, RO/CRF/CRFN, CRFB, RO/ADL/ADLA, ADLE; TU/ACQ/ACQN, DO/DCM/DCMA, DCME, DO/FTA/FTAA, FTAE, DO/DRA/DRAA, DRAE; DO/VDC/VDCR, VDCE, DO/REG/REGA, REGE; DO/FNT/FNTA, FNTN, FNTE, DO/ADM/ADMA, ADME, DO/CTF/CTFC, DO/BIB/BIBA, DO/BSE/BSEA, TU/CDG/CDGS, TU/ESP/ESPU, TU/NVC/NVCA, TU/STU/STUE, RE/IND/INDE, INDR, INDN, RE/RCG/RCGA, RCGR, RCGF, RCGJ, RE/DSC/DSCA, DSCF, DSCR, DSCJ; CM/ISP/ISPN; */ALB/ALBO, ALBE; */FOI/FOIS, FOIE, FOIR, RE/AIN/AINR; AU/DDC/DDCN, DDCM; TU/CPR/CPRN, DA/AUE/AUEE, AUEZ, AUES, DA/ZEC, AU/EDT/EDTN, EDTA, EDTZ; UT/UTN, UT/UTN/UTNN, AU/FRU/FRUN, */ACC/ACCE. UB/INP/INPE; AU/CMM/CMMN, CMME; */RST/RSTE, RSTR, RSTN; CON/CONA, CON/CONZ; MS/MST/MSTE, MSTO; MS/PRM/PRME; UB/COL/COLN. Normativa SCAN: BI/RIL/RILR, RILA. Normativa BDI: DR/DRV/DRVE, DRVR, DR/DRV, DRL, DRO, DRG, DRF, DRR; DU/DUY/DUYN, DU/DUX/DUXE, DUXC, DU/DUZ/DUZS, DU/DUQ/DUQN; DV/DVY/DVYN, DV/DVX/DVXE, DVXC, DV/DVZ/DVZS, DV/DVQ/DVQN; DF/DFY/DFYN, DF/DFX/DFXE, DFXC, DF/DFZ/DFZS, DF/DFQ/DFQN; AI/AIY/AIYN, AI/AIX/AIXE, AIXC, AI/AIZ/AIZS, AI/AIQ/AIQN, AI/AIF/AIFN, AI/AIE/AIED; VI/VIY/VIYN, VI/VIX/VIXE, VIXC, VI/VIZ/VIZS, VI/VIQ/VIQN, VI/VIF/VIFN, VI/VIE/VIED; FI/FIY/FIYN, FI/FIX/FIXE, FIXC, FI/FIZ/FIZS, FI/FIQ/FIQN, FI/FIF/FIFN, FI/FIE/FIED. Normativa SM: CL/CLA/CLAA. Normativa BNB: SB/NAA/NAAG, NAAI, NAAE, NAAC, SB/NAT/NATG, NATI, NATE, NATC, RB/RBR/RBNG, RBNI, RBNE, RBNC, LR/LRD/LRDA, DB/DBR/DBRA, DB/DBC/DBCA, DB/DBX/DBXT, DB/DBP/DBPA, DB/DBS/DBSR. Normativa BNM: LR/LRI/LRIL, LRIZ, LRIG, LRIX,. Normativa BNP: SP/SPS/SPSA, SPSD. Normativa BNZ: SZ/SZS/SZSE, SZSD. Normativa ATOG/OGS/OGSA, IN/INI/INIL, INIO. Normativa BNPL: SP/SPN/SPNS, SPNM. Versioni 4.00 e ICCD Normativa Trasversale: MS/MST/MSTE - Versioni precedenti a 4.00: DO/MST/MSTO</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/core/hasCategory -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/core/hasCategory">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasConcept"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/core/isCategoryOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/core/Category"/>
        <rdfs:comment xml:lang="it">La object property che associa un qualunque oggetto a una categoria.</rdfs:comment>
        <rdfs:comment xml:lang="en">The object property that associates any object with a category.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="it">ha categoria</rdfs:label>
        <rdfs:label xml:lang="en">has category</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: OG/CTG -  Normativa AT: OG/OGT/OGTP - Normativa RA: OG/CLS - Normative CA e MA e Normativa VeAC: OG/OGT/OGTC, Normativa BDM: OG/OGT/OGTG. ICCD Normativa TMA: MA/MAC/MACC</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/core/hasCharacteristic -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/core/hasCharacteristic">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/core/isCharacteristicOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/core/Characteristic"/>
        <rdfs:comment xml:lang="it">La object property che collega un&apos;entità a una sua caratteristica.</rdfs:comment>
        <rdfs:comment xml:lang="en">The object property that links an entity to one of its characteristics.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="it">ha caratteristica</rdfs:label>
        <rdfs:label xml:lang="en">has characteristic</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/core/hasClassification -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/core/hasClassification">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasSituation"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/core/isClassificationOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/core/Classification"/>
        <opla:isNativeTo rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/countingas.owl"/>
        <rdfs:comment xml:lang="it">La object property che permette di aggiungere una classificazione a un qualsiasi oggetto.</rdfs:comment>
        <rdfs:comment xml:lang="en">The object property that allows to add a classification to any object.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="it">ha classificazione</rdfs:label>
        <rdfs:label xml:lang="en">has classification</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/core/hasClassificationInTime -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/core/hasClassificationInTime">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasEventOrSituationInTime"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/core/isClassificationInTimeOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/core/ClassificationInTime"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;entità ad una classificazione nel tempo</rdfs:comment>
        <rdfs:comment xml:lang="it">This property relates a classification in time to an entityQuesta proprietà collega una identificazione nel tempo a un&apos;entità</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an entity to a classification in time</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="it">ha classificazione nel tempo</rdfs:label>
        <rdfs:label xml:lang="en">has classification in time</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa trasversale: SG/CLF.</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/core/hasClassificationSystem -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/core/hasClassificationSystem">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/core/isClassificationSystemOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/core/Classification"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/core/ClassificationSystem"/>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://w3id.org/arco/ontology/core/hasConcept"/>
            <rdf:Description rdf:about="https://w3id.org/arco/ontology/core/isDefinedByClassificationSystem"/>
        </owl:propertyChainAxiom>
        <rdfs:comment xml:lang="it">Questa proprietà collega una classificazione ad un sistema di classificazione</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a classification to a classification system</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="it">ha sistema di classificazione</rdfs:label>
        <rdfs:label xml:lang="en">has classification system</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/core/hasComponent -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/core/hasComponent">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasPart"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/core/isComponentOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <opla:isNativeTo rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/componency.owl"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega, in maniera non-transitiva, un&apos;entità a un suo componente.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates, non-transitively, an entity to a component.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="it">ha componente</rdfs:label>
        <rdfs:label xml:lang="en">has component</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/core/hasConcept -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/core/hasConcept">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/core/isConceptOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/core/Concept"/>
        <opla:isNativeTo rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/timeindexedclassification.owl"/>
        <rdfs:comment xml:lang="it">La object property che associa un qualunque oggetto a un concetto, che lo classifica.</rdfs:comment>
        <rdfs:comment xml:lang="en">The object property that associates any object with a concept, classifying it.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="it">ha concetto</rdfs:label>
        <rdfs:label xml:lang="en">has concept</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa trasversale: SG/CLF/CLFS</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/core/hasConsequence -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/core/hasConsequence">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/core/isConsequenceOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la conseguenza di qualcosa</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the consequence of something</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="it">ha conseguenza</rdfs:label>
        <rdfs:label xml:lang="en">has consequence</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>Normativa BNB: RB/RBR/RBRN, RB/RBN.</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/core/hasConstituent -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/core/hasConstituent">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasPart"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/core/isConstituentOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <opla:isNativeTo rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/constituency.owl"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega, in maniera transitiva, un&apos;entità a un suo costituente.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates, transitively, an entity to a constituent.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="it">ha costituente</rdfs:label>
        <rdfs:label xml:lang="en">has constituent</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>Normativa BNPE: SR/SRM/SRMP, SRMA; SR/SRL/SRLP. Normativa BNPL: SP/SPM/SPMO, SPMP, SPML, SPMM, SPMS</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/core/hasCulturalEntityCharacteristic -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/core/hasCulturalEntityCharacteristic">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasCharacteristic"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/core/isCulturalEntityCharacteristicOf"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/core/CulturalEntityCharacteristic"/>
        <rdfs:comment xml:lang="it">La object property che collega una cultural entity a una sua caratteristica.</rdfs:comment>
        <rdfs:comment xml:lang="en">The object property that links a cultural entity to one of its characteristics.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="it">ha caratteristica di entità culturale</rdfs:label>
        <rdfs:label xml:lang="en">has cultural entity characteristic</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/core/hasDepiction -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/core/hasDepiction">
