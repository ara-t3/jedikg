        <rdfs:label xml:lang="en">Religious circumstance</rdfs:label>
        <a-cat:iccdNormTag>ICCD Normativa BDI: CA/CAR; CA/CAC</a-cat:iccdNormTag>
    </owl:NamedIndividual>
    


