        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="it">ha foto</rdfs:label>
        <rdfs:label xml:lang="it">ha raffigurazione</rdfs:label>
        <rdfs:label xml:lang="en">has depiction</rdfs:label>
