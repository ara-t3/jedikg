        <rdfs:comment xml:lang="en">This property relates a title to the entity to which it is referred.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is title of</rdfs:label>
        <rdfs:label xml:lang="it">è titolo di</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>OG/SGT/SGTP; SG/SGL/SGLT; SG/SGL/SGLL; OG/SGT/SGTR; DA/AID/AIDN; SG/SGL/SGLA; DA/AID/AIDT; OG/SGT/SGTT; RO/ROF/ROFT; DO/BSE/BSET; DO/BSE/BSEC.</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isTitleTypeOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isTitleTypeOf">
