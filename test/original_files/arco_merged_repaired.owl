    <!-- https://w3id.org/arco/ontology/construction-description/OpeningSystem -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/construction-description/OpeningSystem">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/construction-description/TechnicalSystem"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il sistema di apertura di una porta o di una finestra.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the opening system of a door or a window.</rdfs:comment>
