        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/catalogue/CatalogueRecordVersion"/>
        <rdfs:comment xml:lang="en">Property, inverse of &quot;has catalogue record version role in time&quot;, used to associate a role in time to the agent playing that role, in the updating of a particular version of a catalogue record.</rdfs:comment>
        <rdfs:comment xml:lang="it">Questa proprietà, inversa a &quot;ha ruolo nel tempo&quot;, permette di associare il ruolo nel tempo che un agente esercita nell&apos;ambito della redazione, dell&apos;aggiornamento o revisione della scheda a una particolare versione di una scheda.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="en">is role in time of</rdfs:label>
        <rdfs:label xml:lang="it">è ruolo nel tempo di</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {
?x core:isAgentRoleOf ?thing .
}

WHERE {
?x a-cat:isCatalogueRecordVersionRiTOf ?thing .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/isAgentRoleOf"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/catalogue/isCataloguingAgentOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/catalogue/isCataloguingAgentOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/isAgentRelatedTo"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/catalogue/CatalogueRecordVersion"/>
        <rdfs:comment xml:lang="it">Questa proprietà, inversa a &quot;ha agente coinvolto nella catalogazione&quot;, rappresenta la relazione che collega un agente che riveste un ruolo nelle attività di catalogazione di una scheda di catalogo alla scheda stessa.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property, inverse of &quot;has cataloguin agent&quot;, is used to associate an agent playing a role in cataloguing activities to the catalogue record.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="en">is cataloguing agent of</rdfs:label>
        <rdfs:label xml:lang="it">è agente coinvolto nella catalogazione di</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?agent a-lite:isCataloguingAgentOf ?thing .
}

WHERE {
?agent a-cat:isCataloguingAgentOf ?thing .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/isCataloguingAgentOf"/>
        <core:replacingQuery>select * where {
?agent core:isAgentOf ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/CataloguingAgent&gt; ;
core:isAgentRoleOf ?thing .
}</core:replacingQuery>
    </owl:ObjectProperty>
    


