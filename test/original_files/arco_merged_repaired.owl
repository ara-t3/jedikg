        <rdfs:range rdf:resource="https://w3id.org/italia/onto/CLV/Address"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;area storico-geografica al suo indirizzo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property links a historical-geographical area to its address.</rdfs:comment>
