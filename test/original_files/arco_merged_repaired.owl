ICCD Normativa BNP: ETG/ETGP
ICCD Normativa BNPE: IRG/IRGP</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/location/Chronozone -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/location/Chronozone">
