CONSTRUCT {
?cult a-lite:isFindingLocationOf ?cultsec .
}

WHERE {
?cult a-cd:isFindingLocationOf ?cultsec .
}</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is finding location of</rdfs:label>
        <rdfs:label xml:lang="it">è luogo di ritrovamento di</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/isFindingLocationOf"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isFormatOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isFormatOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/isDescriptionOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Format"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Documentation"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega il formato con la relativa documentazione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the format to the related documentation.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is format of</rdfs:label>
        <rdfs:label xml:lang="it">è formato di</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {
?format a-dd:isFormatOf ?thing .
}

WHERE {
?format a-cd:isFormatOf ?thing .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/isFormatOf"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isFruitionOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isFruitionOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isSituationOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Fruition"/>
        <rdfs:range rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una fruizione di un vestimento al vestimento stesso.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the fruition of a garment to that garment.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:isDefinedBy>CONSTRUCT {
?fruition a-cd:isUseOf ?cultent .
}

WHERE {
?fruition a-cd:isFruitionOf ?cultent.
}</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">is fruition of</rdfs:label>
        <rdfs:label xml:lang="it">è fruizione di</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/isUseOf"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isFunctionalPurposeOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isFunctionalPurposeOf">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/UseFunction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="it">Questa è la proprietà inversa di &quot;ha scopo funzionale&quot;.</rdfs:comment>
        <rdfs:comment xml:lang="en">This is the inverse property of &quot;has functional purpose&quot;.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is functional purpose of</rdfs:label>
        <rdfs:label xml:lang="it">è scopo funzionale di</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale: DA/ISE/ISEC - Normative di versioni precedenti: DA/ISR/ISRC; DA/APF/APFF</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isGenusIn -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isGenusIn">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isConceptOf"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un genere alla tassonomia in cui è classificato.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a genus to the linnaean taxon in which it is classified.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is genus in</rdfs:label>
        <rdfs:label xml:lang="it">è genere in</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {
?tax core:isTaxonOf ?identificationOrClassification . 
}

WHERE {
?tax a-cd:isGenusOf ?identificationOrClassification .
}</core:constructQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isInterpretationCriterionOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isInterpretationCriterionOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/isDescriptionOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/InterpretationCriterion"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un criterio interpretativo all&apos;interpretazione che si è basata su quel criterio.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an interpretation criterion to the interpretation that was based on that criterion.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is interpretation criterion of</rdfs:label>
        <rdfs:label xml:lang="it">è criterio interpretativo di</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isInterventionEligibleBy -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isInterventionEligibleBy">
        <rdfs:comment xml:lang="it">Questa proprietà è l&apos;inversa di &quot;ha intervento ammesso&quot;.</rdfs:comment>
        <rdfs:comment xml:lang="en">This is the inverse property of &quot;defines eligible intervention&quot;.</rdfs:comment>
        <rdfs:label xml:lang="en">is intervention eligible by</rdfs:label>
        <rdfs:label xml:lang="it">è intervento ammesso da</rdfs:label>
        
        <core:constructQuery>CONSTRUCT {
?intType a-cd:isEligibleInterventionDefinedBy ?x .
}

WHERE {
?intType a-cd:isInterventionTypeOf ?int .
?int a-cd:isInterventionEligibleBy ?x .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/isEligibleInterventionDefinedBy"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isInterventionOn -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isInterventionOn">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Intervention"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="it">Questa proprietà, inversa a &quot;ha intervento&quot;, collega un intervento, a fini conservativi o di altro tipo, che ha interessato un bene culturale, al bene stesso.</rdfs:comment>
        <rdfs:comment xml:lang="it">This property relates an intervention on a cultural property to that cultural property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is intervention on</rdfs:label>
        <rdfs:label xml:lang="it">è intervento su</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: CO/RST; normative di versioni precedenti: RS/RST - Normativa VeAC: CO/RIA - Normativa CA: RO/RIS</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isInterventionRoleIn -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isInterventionRoleIn">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isRoleOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/RO/Role"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Responsibility"/>
        <rdfs:comment xml:lang="it">Questa è la proprietà inversa di &quot;ha ruolo nell&apos;intervento&quot;.</rdfs:comment>
        <rdfs:comment xml:lang="en">This is the inverse property of &quot;has intervention role&quot;.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is intervention role in</rdfs:label>
        <rdfs:label xml:lang="it">è ruolo nell&apos;intervento</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>AU/ATB/ATBR; AU/AUT/AUTR.
ICCD Normative F e FF: PD/PDF/PDFR</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isInterventionTypeOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isInterventionTypeOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isTypeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/InterventionType"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Intervention"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega il tipo di intervento, a fini conservativi o di altro tipo, che ha interessato un bene culturale al relativo intervento.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the type of intervention on a cultural property to the related intervention.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is intervention type of</rdfs:label>
        <rdfs:label xml:lang="it">è tipo di intervento di</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {
?type core:isTypeOf ?thing .
}

WHERE {
?type a-cd:isInterventionTypeOf ?thing .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/isTypeOf"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isInventoryIdentifierResponsibleOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isInventoryIdentifierResponsibleOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/isAgentRelatedTo"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/InventorySituation"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega il contenitore giuridico che conserva attualmente il bene, o che lo ha conservato in passato, e che è responsabile dell&apos;assegnazione del numero di inventario all&apos;inventario stesso.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the juridical container responsible for the inventory identifier of the cultural property to the inventory itself.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is inventory identifier responsible of</rdfs:label>
        <rdfs:label xml:lang="it">è responsabile di numero di inventario di</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?agent a-lite:isResponsibleAgentOf ?thing .
}

WHERE {
?agent a-cd:isInventoryIdentifierResponsibleOf ?thing .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/isResponsibleAgentOf"/>
        <core:replacingQuery>select * where {
?agent core:isAgentOf ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/ResponsibleAgent&gt; ;
core:isAgentRoleOf ?thing .
}</core:replacingQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isInventoryOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isInventoryOf">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Inventory"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/InventorySituation"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un inventario che registra informazioni relative al bene culturale al bene culturale o alle entità o attività collegate al bene culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an inventory to a cultural property or an entity or an activity related to it.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is inventory of</rdfs:label>
        <rdfs:label xml:lang="it">è inventario di</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>UB/INV; ICCD Normativa Trasversale: UB/INP. -  ICCD Normativa RA 3.00 RE/DSC/DSCI</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isInventorySituationOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isInventorySituationOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isEventOrSituationInTimeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/InventorySituation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega la situazione inventariale a una cosa.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the inventory situation to an entity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is inventory situation of</rdfs:label>
        <rdfs:label xml:lang="it">è situazione inventariale di</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>UB/INV; ICCD Normativa Trasversale: UB/INP.</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isInvolvedIn -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isInvolvedIn">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/hasRelatedWork"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un bene culturale a un altro bene culturale collegato, di tipo immateriale, in cui è coinvolto.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural entity to another involved  cultural entity (e.g. immaterial).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is involved in</rdfs:label>
        <rdfs:label xml:lang="it">è coinvolto in</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: RV/RSE/RSER = &apos;è coinvolto in&apos; (versioni precedenti: &apos;esecuzione/evento di riferimento&apos;)</a-cat:iccdNormTag>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?x a-lite:isInvolvedIn ?y .
}

WHERE {
?x a-cd:isInvolvedIn ?y .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/isInvolvedIn"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isIssuerIn -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isIssuerIn">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/isAgentRelatedTo"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/CoinIssuance"/>
        <rdfs:comment xml:lang="it">Questa è la proprietà inversa di &quot;ha emittente&quot;.</rdfs:comment>
        <rdfs:comment xml:lang="en">This is the inverse property of &quot;has issuer&quot;.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is issuer in</rdfs:label>
        <rdfs:label xml:lang="it">è emittente in</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="it">stable</owl:versionInfo>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?agent a-lite:isIssuerOf ?thing .
}

WHERE {
?agent a-cd:isIssuerIn ?thing .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/isIssuerOf"/>
        <core:replacingQuery>select * where {
?agent core:isAgentOf ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/Issuer&gt; ;
core:isAgentRoleOf ?thing .
}</core:replacingQuery>
    </owl:ObjectProperty>
    


