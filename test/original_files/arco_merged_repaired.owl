        <rdfs:comment xml:lang="en">This class represents the geochronological class &quot;epoch&quot;.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="it">Epoca geocronologica</rdfs:label>
        <rdfs:label xml:lang="en">Geochronological epoch</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BNM: IMG/IMGO
ICCD Normativa BNP: ETG/ETGO
ICCD Normativa BNPE: IRG/IRGO</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/location/GeochronologicalEra -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/location/GeochronologicalEra">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/location/GeochronologicalClass"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta l&apos;unità geocronologica era.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the geochronological class &quot;era&quot;.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="it">Era geocronologica</rdfs:label>
        <rdfs:label xml:lang="en">Geochronological era</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BNM: IMG/IMGR
ICCD Normativa BNP: ETG/ETGR
ICCD Normativa BNPE: IRG/IRGR</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/location/GeochronologicalPeriod -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/location/GeochronologicalPeriod">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/location/GeochronologicalClass"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta l&apos;unità geocronologica periodo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the geochronological class &quot;period&quot;.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="en">Geochronological period</rdfs:label>
        <rdfs:label xml:lang="it">Periodo geocronologico</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BNM: IMG/IMGP
ICCD Normativa BNP: ETG/ETGP
ICCD Normativa BNPE: IRG/IRGP</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/location/GeochronologicalSubage -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/location/GeochronologicalSubage">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/location/GeochronologicalClass"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta l&apos;unità geocronologica sottoetà.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the geochronological class &quot;subage&quot;.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="en">Geochronological subage</rdfs:label>
        <rdfs:label xml:lang="it">Sottoerà geocronologica</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BNM: IMG/IMGS
ICCD Normativa BNP: ETG/ETGS
ICCD Normativa BNPE: IRG/IRGS</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/location/GeologicalContext -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/location/GeologicalContext">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/EventOrSituationInTime"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/location/hasMineralDeposit"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/location/MineralDeposit"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/location/hasOutcrop"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/location/Outcrop"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/location/hasStratum"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/location/Stratum"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il contesto geologico da cui proviene il bene catalogato.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the geological context from which the cp originates.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="it">Contesto geologico</rdfs:label>
        <rdfs:label xml:lang="en">Geological context</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BNM: IMAC
ICCD Normativa BNP: ET/ETA/ETAC
ICCD Normativa BNPE: IR/IRA/IRAC</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/location/GeologicalMap -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/location/GeologicalMap">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/location/Map"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta una carta geografica.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents a geological map.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="en">Geological map</rdfs:label>
        <rdfs:label xml:lang="it">Mappa geologica</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa SI 3.00: CA/GEL/GELC</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/location/Geometry -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/location/Geometry">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/CLV/Geometry"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/location/hasGeometryMethod"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/location/GeometryMethod"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/location/hasBaseMap"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/location/BaseMap"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/location/hasGeometryMethod"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/location/GeometryMethod"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/location/hasGeometryTechnique"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/location/GeometryTechnique"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/location/hasLocationType"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/location/LocationType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta la geometria associabile a una entità spaziale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the geometry of a spatial entity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="it">Geometria</rdfs:label>
        <rdfs:label xml:lang="en">Geometry</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/location/GeometryMethod -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/location/GeometryMethod">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Method"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/location/isGeometryMethodOf"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/italia/onto/CLV/Geometry"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://w3id.org/arco/ontology/location/GeometryTechnique"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il metodo utilizzato per il posizionamento (esatto, approssimato, con rappresentazione simbolica).</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the method used for the object positioning (i.e. exact, approximate, with a symbolic representation).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="en">Geometry method</rdfs:label>
        <rdfs:label xml:lang="it">Metodo di posizionamento</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa trasversale 4.00: GE/GPM - Normative precedenti: GP/GPM;  GA/GAM; GL/GLM</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/location/GeometryTechnique -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/location/GeometryTechnique">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Method"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/location/isGeometryTechniqueOf"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/italia/onto/CLV/Geometry"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta la tecnica di georeferenziazione, utilizzata per l&apos;acquisizione delle coordinate (rilievo da cartografia con sopralluogo, rilievo da cartografia senza sopralluogo, rilievo da foto aerea con sopralluogo, rilievo da foto aerea senza sopralluogo, rilievo da satellite, rilievo tradizionale, rilievo tramite GPS, rilievo tramite punti d&apos;appoggio fiduciali o trigonometrici, stereofotogrammetria).</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the technique of georeferencing, used for the acquisition of coordinates (i.e. survey from cartography with or without inspection, survey from aerial photos with or without inspection, satellite survey, traditional survey, survey via GPS, etc.).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="en">Geometry technique</rdfs:label>
        <rdfs:label xml:lang="it">Tecnica di georeferenziazione</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale 4.00: GE/GPT - Normative precedenti: GP/GPT; GA/GAT; GL/GLT</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/location/Geotope -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/location/Geotope">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/location/MineralDeposit"/>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/location/HistoricalAddress -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/location/HistoricalAddress">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/CLV/Address"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/location/hasGovernmentalAdministrativeArea"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/italia/onto/CLV/AdminUnitComponent"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/location/hasTerritorialArea"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/italia/onto/CLV/Feature"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta l indirizzo storico, inteso come il contesto topografico e amministrativo storico.</rdfs:comment>
