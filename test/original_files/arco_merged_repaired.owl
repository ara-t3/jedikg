    a tiapit:TimeInterval ;
    rdfs:label &quot;Intervallo di durata dell&apos;evento &apos;Vincenzo Gemito, dal salotto Minozzi al Museo di Capodimonte&apos;&quot; ;
    tiapit:startTime &quot;2014-11-28T00:00:00&quot;^^xsd:dateTime;
