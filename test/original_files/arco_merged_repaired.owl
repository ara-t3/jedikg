                <owl:allValuesFrom rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://w3id.org/arco/ontology/construction-description/MovableFurnishingElement"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta gli elementi d&apos;arredo integrati in una costruzione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the built-in furnishing elements in a construction.</rdfs:comment>
