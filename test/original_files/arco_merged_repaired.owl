    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/core/hasMethod -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/core/hasMethod">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasDescription"/>
