    <!-- https://w3id.org/arco/ontology/natural-specimen-description/isHarvestingOperatorOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/natural-specimen-description/isHarvestingOperatorOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/isAgentRelatedTo"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/SpecimenHarvesting"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega l&apos;operatore della raccolta alla raccolta del campione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the harvesting operator to the specimen harvesting.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description"/>
        <rdfs:label xml:lang="en">is harvesting operator of</rdfs:label>
        <rdfs:label xml:lang="it">è operatore della raccolta di</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {
?agent a-lite:isOperatorOf ?speharv .
}

WHERE {
?agent a-spe:isHarvestingOperatorOf ?speharv.
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/isOperatorOf"/>
        <core:replacingQuery>select * where {
?agent core:isAgentOf ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/Operator&gt; ;
core:isAgentRoleOf ?thing .
}</core:replacingQuery>
    </owl:ObjectProperty>
    


