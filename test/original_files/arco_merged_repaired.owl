        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>UB/COL</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?cp a-cd:isMemberInvolvedIn ?collmem .
}

WHERE {
?cp a-cd:isMemberOfCollectionOf ?collmem .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/isMemberInvolvedIn"/>
