        <rdfs:comment xml:lang="en">This class represents the chronostratigraphic unit &quot;chronozone&quot;.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="en">Chronozone</rdfs:label>
        <rdfs:label xml:lang="en">Cronozona</rdfs:label>
