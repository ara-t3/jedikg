        <rdfs:label xml:lang="en">Cuff type</rdfs:label>
        <rdfs:label xml:lang="it">Tipo di maniche</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa VeAC 3.01: SRM/SRMT</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/clothing-description/Fastener -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/clothing-description/Fastener">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/clothing-description/ClothingElement"/>
