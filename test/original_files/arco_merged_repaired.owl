        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Concept"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega il concetto al sistema di classificazione</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the concept to the classification system</rdfs:comment>
