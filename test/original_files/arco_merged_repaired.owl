        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa OA: MT/MIS/MIST</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/core/issuedBy -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/core/issuedBy">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/core/issues"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/core/Identifier"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/COV/Organization"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un identificativo con l&apos;organizzazione che l&apos;ha emesso.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an identifier to the organization that has issued it.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="en">issued by</rdfs:label>
        <rdfs:label xml:lang="it">rilasciato da</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>AC/ACC/ACCE. Usato per tutti gli identificativi emessi da ICCD</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/core/issues -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/core/issues">
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/COV/Organization"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/core/Identifier"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;organizzazione con  l&apos;identificativo che ha rilasciato.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an issuing organization with an identifier.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="it">emette</rdfs:label>
        <rdfs:label xml:lang="en">issues</rdfs:label>
        <rdfs:label xml:lang="it">rilascia</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>AC/ACC/ACCE. Usato per tutti gli identificativi emessi da ICCD</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/core/refersToClassificationSystem -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/core/refersToClassificationSystem"/>
    


    <!-- https://w3id.org/arco/ontology/cultural-event/hasAcknowledgment -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/cultural-event/hasAcknowledgment">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/cultural-event/isAcknowledgmentOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/cultural-event/Competition"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/cultural-event/Acknowledgment"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la relazione che collega una competizione al riconoscimento che rilascia.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a competition to the acknowledgment.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/cultural-event"/>
        <rdfs:label xml:lang="it">ha riconoscimento</rdfs:label>
        <rdfs:label xml:lang="en">has acknowledgment</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/cultural-event/hasAgentRelatedToCulturalEvent -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/cultural-event/hasAgentRelatedToCulturalEvent">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/hasRelatedAgent"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/cultural-event/isAgentRelatedToCulturalEventOf"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEvent"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://w3id.org/italia/onto/RO/hasRiT"/>
            <rdf:Description rdf:about="https://w3id.org/italia/onto/RO/isRoleInTimeOf"/>
        </owl:propertyChainAxiom>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la relazione che collega un evento culturale a un agente che riveste un ruolo relativo all&apos;evento. La relazione tra il ruolo e l’agente che lo riveste è espressa, in maniera generica, nel nome della proprietà, che quindi ne fornisce una rappresentazione semplificata, con ridotta espressività. La relazione è poi specializzata da sottoproprietà. Nell’ontologia questa relazione è modellata anche, in maniera più espressiva, dalla classe TimeIndexedRole, che permette di collegare l’ente, il suo ruolo e la sua corrispondente estensione temporale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural event to an agent playing a role related to that cultural event.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/cultural-event"/>
        <rdfs:label xml:lang="it">ha agente collegato a evento culturale</rdfs:label>
        <rdfs:label xml:lang="en">has agent related to cultural event</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/cultural-event/hasAward -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/cultural-event/hasAward">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/cultural-event/isAwardOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/cultural-event/Competition"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/cultural-event/Award"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una competizione ad un premio.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a competition to  a prize.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/cultural-event"/>
        <rdfs:label xml:lang="it">ha premio</rdfs:label>
        <rdfs:label xml:lang="en">has prize</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/cultural-event/hasComponentEvent -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/cultural-event/hasComponentEvent">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasPart"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/cultural-event/isComponentEventOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/core/EventOrSituation"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/core/EventOrSituation"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/cultural-event/hasEventOrganiser -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/cultural-event/hasEventOrganiser">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/hasRelatedAgent"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/cultural-event/isEventOrganiserOf"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEvent"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un evento culturale all&apos;ente o soggetto che ha organizzato quell&apos;evento.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural evento to the agency or person that is the organiser of that event.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/cultural-event"/>
        <rdfs:label xml:lang="it">ha ente o soggetto organizzatore</rdfs:label>
        <rdfs:label xml:lang="en">has event organiser</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">Versioni 4.00 e ICCD Normativa Trasversale: MS/MST/MSTE - Versioni precedenti a 4.00: DO/MST/MSTO</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?x a-ce:hasEventOrganiser ?y .
}

WHERE {
?x arco-lite:hasOrganiser ?y .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasOrganiser"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/cultural-event/hasImmediateNextEvent -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/cultural-event/hasImmediateNextEvent">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/cultural-event/hasNextSituation"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/cultural-event/hasImmediatePreviousEvent"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/EventOrSituation"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/EventOrSituation"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un evento che è membro di un evento ricorrente, inteso come collezione, all&apos;evento immediatamente successivo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an event that is member of a recurrent event, as a collection, to the immediate next event.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/cultural-event"/>
        <rdfs:label xml:lang="it">ha evento immediatamente successivo</rdfs:label>
        <rdfs:label xml:lang="en">has immediate next event</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/cultural-event/hasImmediatePreviousEvent -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/cultural-event/hasImmediatePreviousEvent">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/cultural-event/hasPreviousSituation"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/EventOrSituation"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/EventOrSituation"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un evento che è membro di un evento ricorrente, inteso come collezione, all&apos;evento immediatamente precedente.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an event that is member of a recurrent event, as a collection, to the immediate previous event.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/cultural-event"/>
        <rdfs:label xml:lang="it">ha evento immediatamente precedente</rdfs:label>
        <rdfs:label xml:lang="en">has immediate previous event</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/cultural-event/hasMemberSituation -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/cultural-event/hasMemberSituation">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/hasMember"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/cultural-event/isSituationMemberOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/cultural-event/RecurrentSituationSeries"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/EventOrSituation"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un evento ricorrente, inteso come collezione di eventi, a uno degli eventi membri della collezione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a recurrent event, as a collection of events, to one of its member events.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/cultural-event"/>
        <rdfs:label xml:lang="it">ha evento membro</rdfs:label>
        <rdfs:label xml:lang="it">ha situazione membro</rdfs:label>
        <rdfs:label xml:lang="en">has member event</rdfs:label>
        <rdfs:label xml:lang="en">has member situation</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/cultural-event/hasNextSituation -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/cultural-event/hasNextSituation">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/precedes"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/cultural-event/hasPreviousSituation"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/EventOrSituation"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/EventOrSituation"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un evento che è membro di un evento ricorrente, inteso come collezione, a uno degli eventi successivi.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an event that is member of a recurrent event, as a collection, to one of the next events.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/cultural-event"/>
        <rdfs:label xml:lang="it">ha evento successivo</rdfs:label>
        <rdfs:label xml:lang="it">ha situazione successiva</rdfs:label>
        <rdfs:label xml:lang="en">has next event</rdfs:label>
        <rdfs:label xml:lang="en">has next sitution</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/cultural-event/hasPreviousSituation -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/cultural-event/hasPreviousSituation">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/follows"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/EventOrSituation"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/EventOrSituation"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un evento che è membro di un evento ricorrente, inteso come collezione, a uno degli eventi precedenti.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an event that is member of a recurrent event, as a collection, to one of the previous events.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/cultural-event"/>
        <rdfs:label xml:lang="it">ha evento precedente</rdfs:label>
        <rdfs:label xml:lang="it">ha situazione precedente</rdfs:label>
        <rdfs:label xml:lang="en">has previous event</rdfs:label>
        <rdfs:label xml:lang="en">has previous situation</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/cultural-event/hasRecurrentTimePeriod -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/cultural-event/hasRecurrentTimePeriod">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/cultural-event/isRecurrentTimePeriodOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/cultural-event/RecurrentSituationSeries"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/cultural-event/RecurrentTimePeriod"/>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://w3id.org/arco/ontology/cultural-event/hasMemberSituation"/>
            <rdf:Description rdf:about="https://w3id.org/arco/ontology/cultural-event/hasTimePeriodBeforeNextEvent"/>
        </owl:propertyChainAxiom>
        <rdfs:comment xml:lang="it">Questa proprietà collega un evento ricorrente al periodo di tempo che intercorre tra uno dei suoi eventi membri e quello successivo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a recurrent event to the time period that elapses between one of its member events and the next one.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/cultural-event"/>
        <rdfs:label xml:lang="it">ha periodo ricorrente di tempo</rdfs:label>
        <rdfs:label xml:lang="en">has recurrent time period</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>SCAN: BI/DTC/DTCP</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/cultural-event/hasRelatedEvent -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/cultural-event/hasRelatedEvent">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/core/EventOrSituation"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/core/EventOrSituation"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/cultural-event/hasTimePeriodBeforeNextEvent -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/cultural-event/hasTimePeriodBeforeNextEvent">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/cultural-event/isTimePeriodBeforeNextEventOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/EventOrSituation"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/cultural-event/RecurrentTimePeriod"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un evento, membro di un evento ricorrente inteso come collezione di eventi, al periodo di tempo che intercorre tra l&apos;evento stesso e l&apos;evento successivo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an event, member of a recurrent event as a collection of events, to the time period that is between that event and the next one.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/cultural-event"/>
        <rdfs:label xml:lang="it">ha periodo di tempo prima di evento successivo</rdfs:label>
        <rdfs:label xml:lang="en">has time period before next event</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/cultural-event/hasTimePeriodMeasurementUnit -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/cultural-event/hasTimePeriodMeasurementUnit">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasCharacteristic"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/cultural-event/isTimePeriodMeasurementUnitOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/cultural-event/RecurrentTimePeriod"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/cultural-event/TimePeriodMeasurementUnit"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega il periodo di tempo massimo che intercorre tra un evento membro di un evento ricorrente, inteso come collezione di eventi, e un evento membro successivo alla sua unità di misura.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the maximum time period that elapses between one of the member events of a recurrent event, as a collection of events, and the next one, to the unit of measurement associated to it.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/cultural-event"/>
        <rdfs:label xml:lang="it">ha unità di misura di periodo di tempo</rdfs:label>
        <rdfs:label xml:lang="en">has time period measurement unit</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/cultural-event/hasTraditionBearer -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/cultural-event/hasTraditionBearer">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasAgentRole"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/cultural-event/isTraditionBearerOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/cultural-event/IntangibleCulturalEntity"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/cultural-event/TraditionBearer"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/cultural-event/hasTransmissionMode -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/cultural-event/hasTransmissionMode">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasCharacteristic"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/cultural-event/isTransmissionModeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/cultural-event/IntangibleCulturalEntity"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/cultural-event/TransmissionMode"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/cultural-event/hasUnifyingFactor -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/cultural-event/hasUnifyingFactor">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasConcept"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/cultural-event/isUnifyingFactorOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/cultural-event/RecurrentSituationSeries"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un evento ricorrente a un fattore unificante.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a recurrent event to a unifying factor.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/cultural-event"/>
        <rdfs:label xml:lang="it">ha fattore unificante</rdfs:label>
        <rdfs:label xml:lang="en">has unifying factor</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/cultural-event/isAcknowledgmentOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/cultural-event/isAcknowledgmentOf">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/cultural-event/Acknowledgment"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/cultural-event/Competition"/>
        <rdfs:comment xml:lang="it">Questa proprietà è inversa di ha riconoscimento.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property is inverse of has acknowledgment.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/cultural-event"/>
        <rdfs:label xml:lang="en">is acknowledgment of</rdfs:label>
        <rdfs:label xml:lang="it">è riconoscimento di</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/cultural-event/isAcknowledgmentReceivedBy -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/cultural-event/isAcknowledgmentReceivedBy">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/cultural-event/receivesAcknowledgment"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/cultural-event/Acknowledgment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la relazione che collega un riconoscimento a una entità.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an acknowledgment to an entity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/cultural-event"/>
        <rdfs:label xml:lang="it">ha riconoscimento</rdfs:label>
        <rdfs:label xml:lang="en">has acknowledgment</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/cultural-event/isAgentRelatedToCulturalEventOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/cultural-event/isAgentRelatedToCulturalEventOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/isAgentRelatedTo"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:range rdf:resource="http://dati.beniculturali.it/cis/CulturalEvent"/>
        <rdfs:comment xml:lang="it">Questa è la proprietà inversa a &quot;ha agente collegato a evento culturale&quot;.</rdfs:comment>
        <rdfs:comment xml:lang="en">This is the inverse property of &quot;has agent related to cultural event&quot;.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/cultural-event"/>
        <rdfs:label xml:lang="en">is agent related to cultural event of</rdfs:label>
        <rdfs:label xml:lang="it">è agente collegato a evento culturale</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/cultural-event/isAwardOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/cultural-event/isAwardOf">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/cultural-event/Award"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/cultural-event/Competition"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un premio a una competizione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a prize to a competition.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/cultural-event"/>
        <rdfs:label xml:lang="en">is prize of</rdfs:label>
        <rdfs:label xml:lang="it">è premio di</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/cultural-event/isComponentEventOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/cultural-event/isComponentEventOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isPartOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/core/EventOrSituation"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/core/EventOrSituation"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/cultural-event/isEventOrganiserOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/cultural-event/isEventOrganiserOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/context-description/isAgentRelatedTo"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:range rdf:resource="http://dati.beniculturali.it/cis/CulturalEvent"/>
        <rdfs:comment xml:lang="it">Questa è la proprietà inversa a &quot;ha ente o soggetto organizzatore&quot;.</rdfs:comment>
        <rdfs:comment xml:lang="en">This is the inverse property of &quot;has event organiser&quot;.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/cultural-event"/>
        <rdfs:label xml:lang="en">is event organiser of</rdfs:label>
        <rdfs:label xml:lang="it">è organizzatore di evento</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/isOrganiserOf"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/cultural-event/isRecurrentTimePeriodOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/cultural-event/isRecurrentTimePeriodOf">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/cultural-event/RecurrentTimePeriod"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/cultural-event/RecurrentSituationSeries"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega il periodo di tempo massimo che intercorre tra uno degli eventi membri di un evento ricorrente e l&apos;evento successivo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the maximum time period that elapses between one of the member events of a recurrent event and the next one.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/cultural-event"/>
        <rdfs:label xml:lang="en">is recurrent time period of</rdfs:label>
        <rdfs:label xml:lang="it">è periodo di tempo di</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>SCAN: BI/DTC/DTCP</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/cultural-event/isSituationMemberOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/cultural-event/isSituationMemberOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/isMemberOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/EventOrSituation"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/cultural-event/RecurrentSituationSeries"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un evento, membro di un evento ricorrente inteso come una collezione di eventi, all&apos;evento ricorrente di cui è membro.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an event, member of a recurrent event as a collection of events, to the recurrent event that is member of.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/cultural-event"/>
        <rdfs:label xml:lang="en">is event member of</rdfs:label>
        <rdfs:label xml:lang="en">is situation member of</rdfs:label>
        <rdfs:label xml:lang="it">è evento membro di</rdfs:label>
        <rdfs:label xml:lang="it">è situazione membro di</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/cultural-event/isTimePeriodBeforeNextEventOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/cultural-event/isTimePeriodBeforeNextEventOf">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/cultural-event/RecurrentTimePeriod"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/EventOrSituation"/>
        <rdfs:comment xml:lang="it">Questa è la proprietà inversa a &quot;ha periodo di tempo prima di evento successivo&quot;.</rdfs:comment>
        <rdfs:comment xml:lang="en">This is the inverse property of &quot;has time period before next event&quot;.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/cultural-event"/>
        <rdfs:label xml:lang="en">is time period before next event of</rdfs:label>
        <rdfs:label xml:lang="it">è periodo di tempo prima di evento successivo di</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/cultural-event/isTimePeriodMeasurementUnitOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/cultural-event/isTimePeriodMeasurementUnitOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isCharacteristicOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/cultural-event/TimePeriodMeasurementUnit"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/cultural-event/RecurrentTimePeriod"/>
        <rdfs:comment xml:lang="it">Questa è la proprietà inversa a &quot;ha unità di misura di periodo di tempo&quot;.</rdfs:comment>
        <rdfs:comment xml:lang="en">This is the inverse property of &quot;has time period measurement unit&quot;.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/cultural-event"/>
        <rdfs:label xml:lang="en">is time period measurement unit of</rdfs:label>
        <rdfs:label xml:lang="it">è unità di misura di periodo di tempo</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/cultural-event/isTraditionBearerOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/cultural-event/isTraditionBearerOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isAgentRoleOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/cultural-event/TraditionBearer"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/cultural-event/IntangibleCulturalEntity"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/cultural-event/isTransmissionModeOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/cultural-event/isTransmissionModeOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isCharacteristicOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/cultural-event/TransmissionMode"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/cultural-event/IntangibleCulturalEntity"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/cultural-event/isUnifyingFactorOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/cultural-event/isUnifyingFactorOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isConceptOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/cultural-event/RecurrentSituationSeries"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un fattore unificante a un evento ricorrente.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a unifying factor to a recurrent event.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/cultural-event"/>
        <rdfs:label xml:lang="en">is unifying factor of</rdfs:label>
        <rdfs:label xml:lang="it">è fattore unificante di</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/cultural-event/receivesAcknowledgment -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/cultural-event/receivesAcknowledgment">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/cultural-event/Acknowledgment"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta la relazione che collega una entità a un riconoscimento.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class relates an entity to an acknowledgment.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/cultural-event"/>
        <rdfs:label xml:lang="it">ha riconoscimento</rdfs:label>
        <rdfs:label xml:lang="en">has acknowledgment</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/areAvailableNotesOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/areAvailableNotesOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isTechnicalCharacteristicOf"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/hasAvailableNotes"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/denotative-description/TechnicalCharacteristic"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="it">Questa è la proprietà inversa di &quot;ha note producibili&quot;.</rdfs:comment>
        <rdfs:comment xml:lang="en">This is the inverse property of &quot;has available notes&quot;.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="en">are available notes of</rdfs:label>
        <rdfs:label xml:lang="it">sono note producibili di</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:replacingQuery>prefix mi: &lt;https://w3id.org/arco/ontology/musical-instrument/&gt;
select distinct * where {
?note a mi:MusicalNote ;
a-mi:areAvailableNotesOf ?cp .
}</core:replacingQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/classifiesCharacteristic -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/classifiesCharacteristic">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isConceptOf"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isCharacteristicClassifiedBy"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/denotative-description/TechnicalConcept"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/TechnicalCharacteristic"/>
        <opla:isNativeTo rdf:resource="https://w3id.org/arco/pattern/technical-characteristic/"/>
        <rdfs:comment xml:lang="it">Questa proprietà, inversa a &quot;è caratteristica classificata da&quot;, collega un concetto tecnico a una caratteristica tecnica di un&apos;entità - come un bene culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property connects a techical concept to an entity&apos;s technical characteristic. It is the inverse property of isCharacteristicClassifiedBy.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">classifica caratteristica tecnica</rdfs:label>
        <rdfs:label xml:lang="en">classifies technical characteristic</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasAccessory -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasAccessory">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isAccessoryOf"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/Accessory"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un bene musicale a un suo accessorio, ovvero un oggetto collegabile al bene musicale, sia nel caso in cui sia funzionale alla produzione del suono, sia nel caso in cui sia di supporto alla produzione del suono o alla conservazione o alla prassi musicale del bene.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a musical good to one of its accessories. In other words, it is an object linkable to a musical object, whether it is functional to the sound production, or if it is the sound&apos;s production or conservation medium.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha accessorio</rdfs:label>
        <rdfs:label xml:lang="en">has accessory</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa SM 4.00: AS/ASS/ASST</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasAffixedElement -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasAffixedElement">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isElementAffixedOn"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/AffixedElement"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un bene culturale a un elemento apposto sul bene (es.: emblema, timbro, iscrizione, etc.)</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural property to an element affixed on it (e.g. inscription, stamp, etc.)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha elemento apposto sul bene</rdfs:label>
        <rdfs:label xml:lang="en">has element affixed to cultural property</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale 4.00: DA/ISE - ICCD versioni precedenti alla 4.00: DA/ISR; DA/STM - ICCD Normativa A: LI/LSI - ICCD Normativa MI: AU/DDC. -  Normativa NU: DA/DES/DESA, DESL, DESN, DESF, DESM, DESG, DESR, DEST</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasAffixedElementType -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasAffixedElementType">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isAffixedElementTypeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/denotative-description/AffixedElement"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/AffixedElementType"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;iscrizione, un emblema, un timbro, uno stemma, etc., al suo tipo (es.: gentilizio, civile, religioso, etc.)</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relatesan inscription (or an emblem, a mark, etc.) to its type.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha tipo di elemento apposto</rdfs:label>
        <rdfs:label xml:lang="en">has affixed element type</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale 4.00: DA/ISE/ISEE - Normative di versioni precedenti: DA/STM/STMQ</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {?class core:hasType ?type .}
WHERE {?class a-dd:hasAffixedElementType ?type.}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasArrangement -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasArrangement">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isArrangementOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/denotative-description/Bandage"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/Arrangement"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una fasciatura alla sua disposizione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a bandage to its arrangement, disposition.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha disposizione</rdfs:label>
        <rdfs:label xml:lang="en">has arrangement</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa AT 3.01: PR/PRF/PRFM</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasAssociatedObject -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasAssociatedObject">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isAssociatedObjectOf"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una entità ad un oggetto.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an entity to an object.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha oggetto associato</rdfs:label>
        <rdfs:label xml:lang="en">has associated object</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa AT 3.01: PR/PRO, OG/OGC/OGCE, PR/PRF/PRFI</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasAvailableNotes -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasAvailableNotes">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/hasTechnicalCharacteristic"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/TechnicalCharacteristic"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega uno strumento musicale, dal grave all&apos;acuto, alle note producibili dallo strumento.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a musical instrument to the playable notes by it, from low to high.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha note producibili</rdfs:label>
        <rdfs:label xml:lang="en">has available notes</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:replacingQuery>prefix mi: &lt;https://w3id.org/arco/ontology/musical-instrument/&gt;
select distinct * where {
?cp mi:producesMusicalNote ?note.
?note a mi:MusicalNote
}</core:replacingQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasClimateSituation -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasClimateSituation">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isClimateSituationOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/denotative-description/NaturalEnvironment"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/ClimateSituation"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega l&apos;ambiente alla situazione climatica</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the ambient to the climate situation</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha situazione climatica</rdfs:label>
        <rdfs:label xml:lang="en">has climate situation</rdfs:label>
        
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <core:constructQuery>prefix a-loc: &lt;https://w3id.org/arco/ontology/location/&gt;

CONSTRUCT {?x a-loc:hasClimateSituation ?y .}
WHERE {?x a-dd:hasClimateSituation ?y.}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/location/hasClimateSituation"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasColour -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasColour">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/hasTechnicalCharacteristic"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isColourOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/TechnicalCharacteristic"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un oggetto al colore .</rdfs:comment>
        <rdfs:comment xml:lang="en">This property connects an object to the colour.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha colore</rdfs:label>
        <rdfs:label xml:lang="en">has colour</rdfs:label>
        
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {?class &lt;https://w3id.org/arco/ontology/arco-lite/hasColour&gt; ?char .}
WHERE {?class a-dd:hasColour ?char. }</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasColour"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasCommunicationMedium -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasCommunicationMedium">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasCulturalEntityCharacteristic"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isCommunicationMediumOf"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/CommunicationMedium"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un bene culturale immateriale a una modalità comunicativa mediante la quale il bene viene veicolato.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an intangible cultural property to a communication medium.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha modalità comunicativa</rdfs:label>
        <rdfs:label xml:lang="en">has communication medium</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BDI: CU</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasCommunicationMediumType -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasCommunicationMediumType">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isCommunicationMediumTypeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/denotative-description/CommunicationMedium"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/CommunicationMediumType"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una modalità comunicativa di un oggetto al tipo di modalità comunicativa (verbale, strumentale, etc.)</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a communication medium to its type (e.g.: verbal, singing, etc.)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha tipo di modalità comunicativa</rdfs:label>
        <rdfs:label xml:lang="en">has communication medium type</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BDI: CU</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {?class core:hasType ?type .}
WHERE {?class a-dd:hasCommunicationMediumType ?type.}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasConservationMethod -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasConservationMethod">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasMethod"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isConservationMethodOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/denotative-description/ConservationStatus"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/ConservationMethod"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega lo stato di conservazione ad un metodo di conservazione</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates conservation status to a conservation method</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha metodo di conservazione</rdfs:label>
        <rdfs:label xml:lang="en">has conservation method</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">instable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BNM, BNPE, BNPL: CO/STC/STCM</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasConservationStatus -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasConservationStatus">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasEventOrSituationInTime"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isConservationStatusOf"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/ConservationStatus"/>
        <rdfs:comment xml:lang="it">Questa proprietà associa il bene culturale al suo stato di conservazione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the cultural property with its conservation status.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha stato di conservazione</rdfs:label>
        <rdfs:label xml:lang="en">has conservation status</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>CO/STC</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasConservationStatusType -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasConservationStatusType">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isConservationStatusTypeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/denotative-description/ConservationStatus"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/ConservationStatusType"/>
        <rdfs:comment xml:lang="it">Questa proprietà associa lo stato di conservazione a uno dei valori del tipo di stato di conservazione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a conservation status to one of its type&apos;s values.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha tipo di stato di conservazione</rdfs:label>
        <rdfs:label xml:lang="en">has conservation status type</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>CO/STC/STCC</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {?class core:hasType ?type .}
WHERE {?class a-dd:hasConservationStatusType ?type.}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasCulturalPropertyAccessibility -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasCulturalPropertyAccessibility">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasCulturalEntityCharacteristic"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isCulturalPropertyAccessibilityOf"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/CulturalPropertyAccessibility"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega il bene culturale alla sua accessibilità, ovvero la possibilità di accedere al bene, in tutto o in parte, per esempio per effettuare un esame diretto finalizzato alla catalogazione (es.: un bene immobile posto in un luogo recintato non accessibile, un bene mobile che non si può osservare da vicino perché posto troppo in alto su una parete; un bene totalmente accessibile, etc.).</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the cultural property to its accessibility, that is the possibility to reach or enter that cultural property, for example for cataloguing activities (e.g.: an immovable cultural property located in a walled area, a movable cultural property located on the top shelf, a totally accessible cultural property, etc.)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha accessibilità</rdfs:label>
        <rdfs:label xml:lang="en">has cultural property accessibility</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: LC/ACB</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasCulturalPropertyAvailability -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasCulturalPropertyAvailability">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasCulturalEntityCharacteristic"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isCulturalPropertyAvailabilityOf"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/CulturalPropertyAvailability"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega il bene culturale alla sua disponibilità materiale, ovvero se il bene è materialmente disponibile, per esempio per attività di catalogazione, o se non è disponibile (es.: furto, distruzione)</rdfs:comment>
        <rdfs:comment xml:lang="en">This class relates the cultural property to its availability, that is whether the cultural property is available or not (e.g.: theft, destruction) for example for cataloguing activities.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha disponibilità materiale</rdfs:label>
        <rdfs:label xml:lang="en">has cultural property availability</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: OG/OGR</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasCulturalPropertyDefinition -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasCulturalPropertyDefinition">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isCulturalPropertyDefinitionOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/denotative-description/CulturalPropertyType"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/CulturalPropertyDefinition"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega la tipologia di un bene culturale a una delle sue componenti, cioè la definizione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural entity&apos;s typology to one of its components, i.e.  its definition.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha definizione del bene culturale</rdfs:label>
        <rdfs:label xml:lang="en">has cultural property definition</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>OG/OGT/OGTD</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasCulturalPropertySpecification -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasCulturalPropertySpecification">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isCulturalPropertySpecificationOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/denotative-description/CulturalPropertyType"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/CulturalPropertySpecification"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega la tipologia di un bene culturale a una delle sue componenti, cioè alle specifiche morfologiche e funzionali.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural entity&apos;s typology to its components, i.e. morphological and functional specifications.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha specifiche del bene culturale</rdfs:label>
        <rdfs:label xml:lang="en">has cultural property specification</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>OG/OGT/OGTT. Scheda A e PG (v. 1 e v.2): OG/OGT/OGTQ. - Normativa BNB: OG/OGT/OGTK, OGTZ</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasCulturalPropertyType -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasCulturalPropertyType">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isCulturalPropertyTypeOf"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/CulturalPropertyType"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un bene culturale al tipo di bene, per permettere la corretta e precisa individuazione del bene.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural property to its type.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha tipo di bene culturale</rdfs:label>
        <rdfs:label xml:lang="en">has cultural property type</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>OG/OGT</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasDedicatee -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasDedicatee">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isDedicateeOf"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una dedica al dedicatario, cioè alla persona o ente cui è rivolta la dedica.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property connects a dedication to its dedicaatee, which is the person or institution to whom the dedication is addressed.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha dedicatario</rdfs:label>
        <rdfs:label xml:lang="en">has dedicatee</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa MI 3.00: AU/DDC/DDCM</a-cat:iccdNormTag>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasDedicatee"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasDesignationInTime -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasDesignationInTime">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasSituation"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isDesignationInTimeOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/DesignationInTime"/>
        <rdfs:comment xml:lang="it">Questa proprietà associa un bene culturale alla sua denominazione e/o dedicazione o, per la normativa FF, titolo, nel corso del tempo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property connects a cultural entity to its denomination and/or dedication, or title (for FF legislation) over time.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha designazione nel tempo</rdfs:label>
        <rdfs:label xml:lang="en">has designation in time</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: OG/OGD. - Normativa BNB: OG/OGT/OGTE e OG/OGT/OGTC. - Normativa NU: OG/OGT/OGTO. - OG/OGT/OGTU. Normativa SI: OG/OGT/OGTY</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {?class a-cd:hasDesignationInTime ?des .}
WHERE {?class a-dd:hasDesignationInTime ?des. }</core:constructQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasDesignationType -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasDesignationType">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isDesignationTypeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/denotative-description/DesignationInTime"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/DesignationType"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una denominazione o dedicazione o, per la normativa FF, titolo nel tempo al tipo di denominazione del bene (altra lingua, attribuita, attuale, dialettale, etc.)</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural entity designation to its type.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha tipo di denominazione</rdfs:label>
        <rdfs:label xml:lang="en">has designation type</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: OG/OGD/OGDT</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {?class core:hasType ?type .}
WHERE {?class a-dd:hasDesignationType ?type.}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasDiapason -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasDiapason">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/hasTechnicalCharacteristic"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isDiapasonOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/TechnicalCharacteristic"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega uno strumento musical al corista rilevato (nota, temperatura ed eventualmente umidità ambientale al momento della rilevazione).</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a musical instrument to the identified diapason (note, temperature and eventually humidity during the detection).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha corista</rdfs:label>
        <rdfs:label xml:lang="en">has diapason</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {?class &lt;https://w3id.org/arco/ontology/arco-lite/hasDiapason&gt; ?char .}
WHERE {?class a-dd:hasDiapason ?char. }</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasDiapason"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasEnvironment -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasEnvironment">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isEnvironmentOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/NaturalEnvironment"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una cosa all&apos;ambiente in cui è inserito</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a thing to its environment</rdfs:comment>
        <rdfs:label xml:lang="it">ha ambiente</rdfs:label>
        <rdfs:label xml:lang="en">has environment</rdfs:label>
        
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <core:constructQuery>prefix a-loc: &lt;https://w3id.org/arco/ontology/location/&gt;

CONSTRUCT {?x a-loc:hasEnvironment ?y .}
WHERE {?x a-dd:hasEnvironment ?y.}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/location/hasEnvironment"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasExtension -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasExtension">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/hasTechnicalCharacteristic"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isExtensionOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/TechnicalCharacteristic"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega uno strumento musicale alla sua estensione musicale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a musical instrument to its extension.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha estensione</rdfs:label>
        <rdfs:label xml:lang="en">has extension</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {?class &lt;https://w3id.org/arco/ontology/arco-lite/hasExtension&gt; ?char .}
WHERE {?class a-dd:hasExtension ?char. }</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasExtension"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasFileFormat -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasFileFormat">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/hasTechnicalCharacteristic"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isFileFormatOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/TechnicalCharacteristic"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una risorsa digitale su supporto informatico al formato utilizzato per la scrittura della risorsa.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a digital resource to the format used to write it on a data medium.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha formato di estensione/compressione del file</rdfs:label>
        <rdfs:label xml:lang="en">has file format</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasFiligree -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasFiligree">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isFiligreeOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/Filigree"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;opera d&apos;arte, un disegno, una fotografia, una stampa alla sua filigrana.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an artwork, painting, photography, print to its filigree.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha filigrana</rdfs:label>
        <rdfs:label xml:lang="en">has filigree</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>MT/FIL</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasFontStyle -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasFontStyle">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isFontStyleOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/denotative-description/AffixedElement"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/FontStyle"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;iscrizione, uno stemma, un timbro, etc., al tipo di caratteri che viene adottato (es.: corsivo, grassetto, caratteri gotici, etc.).</rdfs:comment>
        <rdfs:comment xml:lang="en">This property connects an inscription or emblem, postmark, crest, etc. to the font style which has been adopted (e.g.: italic, bold, gothic etc).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha tipo di caratteri</rdfs:label>
        <rdfs:label xml:lang="en">has font style</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Traversale 4.00: DA/ISE/ISET - Normative di versioni precedenti: DA/ISR/ISRT. Normativa BNB: SB/SBE/SBEC</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasFormat -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasFormat">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/hasDescription"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isFormatOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/Format"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;entità al formato</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an entity to a format</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha formato</rdfs:label>
        <rdfs:label xml:lang="en">has format</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: DO/FTA/FTAF, DO/DRA/DRAF, DO/FNT/FNTR (+ DO/VDC/VDCP, DO/REG/REGP). ICCD Normativa F: MT/FVC/FVCF. ICCD Normative OA, D, S, MI: MT/FRM. Normativa BNB: DB/DBX/DBXX</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasFunctionalPurpose -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasFunctionalPurpose">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasCharacteristic"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isFunctionalPurposeOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/FunctionalPurpose"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un oggetto (es bene culturale, apparato iconografico/decorativo o elemento apposto su un bene culturale come un&apos;iscrizione) al suo scopo funzionale (decorativo, religioso, simbolico, magico-offensivo, etc.), inteso come funzione che deve svolgere.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property realtes an object (e.g. cultural entity, iconographic/decorative apparatus, affixed element like an inscription) to its functional purpose, intended as the function the object has to perform (decorative, religious, symbolic, magic-offensive etc.).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha scopo funzionale</rdfs:label>
        <rdfs:label xml:lang="en">has functional purpose</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale: DA/ISE/ISEC - Normative di versioni precedenti: DA/ISR/ISRC; DA/APF/APFF</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {?class &lt;https://w3id.org/arco/ontology/arco-lite/hasCulturalEntityUseFunction&gt; ?fun .}
WHERE {?class a-dd:hasFunctionalPurpose ?fun.}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasCulturalEntityUseFunction"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasGarmentAnalysis -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasGarmentAnalysis">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/hasTechnicalCharacteristic"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isGarmentAnalysisOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/TechnicalCharacteristic"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un vestimento antico o contemporaneo alla definizione tecnica completa dei tessuti, secondo le norme fornite dal C.I.E.T.A., o dei merletti, oppure rappresenta la distinzione fra tessuto unito e tessuto operato.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an ancient or contemporary garment to the technical definition of textured fabrics, according to the standard provided by C.I.E.T.A., or laces. It can represent the dinstinction between plain fabric and textured fabric.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha analisi del vestimento</rdfs:label>
        <rdfs:label xml:lang="en">has garment analysis</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {?class &lt;https://w3id.org/arco/ontology/arco-lite/hasGarmentAnalysis&gt; ?char .}
WHERE {?class a-dd:hasGarmentAnalysis ?char. }</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasGarmentAnalysis"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasGarmentColour -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasGarmentColour">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/hasTechnicalCharacteristic"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isGarmentColourOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/TechnicalCharacteristic"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un vestimento antico o contemporaneo al colore dominante, di solito quello del fondo del tessuto, o quello risultante dall&apos;intreccio.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an ancient and contemporary garment to its dominant color, usually it is base fabric&apos;s color, or the interlaced decoration&apos;s color.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha colore del vestimento</rdfs:label>
        <rdfs:label xml:lang="en">has garment colour</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {?class &lt;https://w3id.org/arco/ontology/arco-lite/hasColour&gt; ?char .}
WHERE {?class a-dd:hasColour ?char. }</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasColour"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasIconographicOrDecorativeApparatus -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasIconographicOrDecorativeApparatus">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/hasDescription"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isIconographicOrDecorativeApparatusOf"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/IconographicOrDecorativeApparatus"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un bene culturale al suo apparato iconografico e/o decorativo, inteso come l&apos;insieme, che può essere più o meno complesso, delle rappresentazioni iconografiche e/o delle decorazioni presenti sul bene.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a cultural enitity to its iconographic or decorative apparatus.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha apparato iconografico e decorativo</rdfs:label>
        <rdfs:label xml:lang="en">has iconographic or decorative apparatus</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: DA/AID - ICCD Normative PST e BDM: DA/APF</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasIconographicOrDecorativeApparatusType -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasIconographicOrDecorativeApparatusType">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isIconographicOrDecorativeApparatusTypeOf"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/denotative-description/IconographicOrDecorativeApparatus"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/IconographicOrDecorativeApparatusType"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un apparato iconografico e decorativo di un bene culturale al tipo di apparato (iconografico, decorativo, iconografico-decorativo).</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a iconographic or decorative apparatus to its type.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha tipo di apparato iconografico e decorativo</rdfs:label>
        <rdfs:label xml:lang="en">has iconographic or decorative apparatus type</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {?class core:hasType ?type .}
WHERE {?class a-dd:hasIconographicOrDecorativeApparatusType ?type.}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasImplementationMethod -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasImplementationMethod">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isImplementationMethodOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/denotative-description/CommunicationMedium"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/ImplementationMethod"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una modalità comunicativa verbale o musicale vocale o musicale strumentale alla modalità esecutiva associata (es.: polifonica).</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a verbal or singing or instrumental communication medium to its implementation method (e.g.: polyphonic) associated to it.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha modalità esecutiva</rdfs:label>
        <rdfs:label xml:lang="en">has implementation method</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BDI: CU/CUM/CUMD; CU/CUS/CUSD</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasLegibility -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasLegibility">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasCharacteristic"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isLegibilityOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/denotative-description/ConservationStatus"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/Legibility"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega lo stato di conservazione di un bene numismatico al suo stato di leggibilità.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a numismatic entity&apos;s conservation status to its legibility status.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha leggibilità</rdfs:label>
        <rdfs:label xml:lang="en">has legibility</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa NU: CO/STC/STCL</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasLocationSubject -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasLocationSubject">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isLocationSubjectOf"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/location/TimeIndexedTypedLocation"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta l&apos;area rappresentata come soggetto di un bene culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represent the location as a subject of a cultural entity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha localizzazione rappresentata</rdfs:label>
        <rdfs:label xml:lang="en">has location as subject</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">se 4.00 LA/TLC o versioni precedenti a 4.00 LA/TCL = &quot;area rappresentata&quot;</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasMassStorage -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasMassStorage">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/hasTechnicalCharacteristic"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isMassStorageOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/TechnicalCharacteristic"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una risorsa digitale alla memoria di massa nella quale è stata memorizzata la fotografia digitale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a digital photograph to the mass storage where a digital photograph is stored.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha memoria di massa</rdfs:label>
        <rdfs:label xml:lang="en">has mass storage</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:replacingQuery>select * where {
?x a-cd:hasStorageMedium ?medium .
?medium core:hasType ?storageMediumType .
}</core:replacingQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasMaterial -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasMaterial">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/hasMaterialOrTechnique"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isMaterialOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/TechnicalCharacteristic"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un oggetto (per esempio un bene culturale) alla materia con cui è realizzato.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an object to its material.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha materia</rdfs:label>
        <rdfs:label xml:lang="en">has material</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {?class &lt;https://w3id.org/arco/ontology/arco-lite/hasMaterial&gt; ?char .}
WHERE {?class a-dd:hasMaterial ?char. }</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasMaterial"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasMaterialOrTechnique -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasMaterialOrTechnique">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/hasTechnicalCharacteristic"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isMaterialOrTechniqueOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/TechnicalCharacteristic"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un oggetto alla materia e/o la tecnica con cui è realizzato l&apos;oggetto, per esempio un bene culturale. Nel dominio delle normative  ICCD per la catalogazione dei beni culturali, si rende necessaria nei casi in cui materia e tecnica sono registrate nello stesso campo, nella forma &quot;materia/ tecnica&quot;.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an object to the material or technique through which an object has been realized, e.g. a cultural entity. In ICCD standards for cataloguing cultural entities, this label is necessary when material and technique are registered in the same field.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha materia e tecnica</rdfs:label>
        <rdfs:label xml:lang="en">has material or technique</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {?class &lt;https://w3id.org/arco/ontology/arco-lite/hasMaterialOrTechnique&gt; ?char .}
WHERE {?class a-dd:hasMaterialOrTechnique ?char. }</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasMaterialOrTechnicque"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasMeasurement -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasMeasurement">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isMeasurementIn"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/denotative-description/MeasurementCollection"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/Measurement"/>
        <opla:isNativeTo rdf:resource="https://w3id.org/arco/pattern/object-collection/"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un insieme di misure osservate per un oggetto a una delle misure.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property connects a set of observed measures on an object to one of those measures.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha misura</rdfs:label>
        <rdfs:label xml:lang="en">has measurement</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">MT/MIS - Normativa VeAC: anche MT/MIM</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasMeasurementCollection -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasMeasurementCollection">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isMeasurementCollectionOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/MeasurementCollection"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un oggetto all&apos;insieme delle misure osservate per quell&apos;oggetto.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property connects an object to the collection of observed measures on it.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha collezione di misure</rdfs:label>
        <rdfs:label xml:lang="en">has measurement collection</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">MT/MIS - Normativa VeAC: anche MT/MII e MT/MIM - Normativa BNB: LR/LRI/LRIT, LRIH, LRIO)</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasMeasurementType -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasMeasurementType">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/denotative-description/Measurement"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/MeasurementType"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una misura al tipo di misura (altezza, larghezza, diametro, etc.)</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a measurement to its type.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha tipo di misura</rdfs:label>
        <rdfs:label xml:lang="en">has measurement type</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale: MT/MIS/MISZ; MT/MNR - Per versioni di normativa precedenti alla 4.00: MT/MIS/MISA; MT/MIS/MISD; MT/MIS/MISL; MT/MIS/MISN; MT/MIS/MISG; MT/MIS/MISP; MT/MIS/MISS; MT/MIS/MISR; MT/MIS/MISV - ICCD scheda VeAC: MT/MII/MIIA; MT/MII/MIIL; MT/MII/MIIP; MT/MIS/MISR; MT/MIS/MISD; MT/MIS/MISS; MT/MIS/MISP; MT/MIS/MISV; MT/MIS/MISF; MT/MIS/MISO</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {?class core:hasType ?type .}
WHERE {?class a-dd:hasMeasurementType ?type.}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasOrientation -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasOrientation">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isOrientationOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/Orientation"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un oggetto al suo orientamento, secondo l&apos;asse principale individuato.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property connects an object to its orientation, considering its major axis.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha orientamento</rdfs:label>
        <rdfs:label xml:lang="en">has orientation</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale: MT/ORT - ICCD Schede CA e MA: MT/ORT - Normativa BNB: LR/LRI/LRIP - Normativa PG: CA/CAE</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasOrnamentalMotif -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasOrnamentalMotif">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isOrnamentalMotifOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/denotative-description/IconographicOrDecorativeApparatus"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/OrnamentalMotif"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega l&apos;apparato iconografico e decorativo di un bene culturale al motivo decorativo (antropomorfo, zoomorfo, geometrico) rappresentato.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property connects a cultural entity&apos;s iconographic or decorative apparatus to its ornamental motif (anthropomorphic, zoomorphic, geometric).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha motivo decorativo</rdfs:label>
        <rdfs:label xml:lang="en">has ornamental motif</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>DA/APF/APFT</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasPhotoColour -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasPhotoColour">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/hasTechnicalCharacteristic"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isPhotoColourOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/TechnicalCharacteristic"/>
        <rdfs:comment xml:lang="it">Questo individuo collega una fotografia digitale al colore della fotografia digitale, ovvero se trattasi di fotografia in bianco/nero o a colori.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a digital photograph to its colour, i.e. black and white or colours.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha colore della foto</rdfs:label>
        <rdfs:label xml:lang="en">has photo colour</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {?class &lt;https://w3id.org/arco/ontology/arco-lite/hasPhotoColour&gt; ?char .}
WHERE {?class a-dd:hasPhotoColour ?char. }</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasPhotoColour"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasPhotoProgram -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasPhotoProgram">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/hasTechnicalCharacteristic"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isPhotoProgramOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/TechnicalCharacteristic"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una fotografia digitale al programma di visualizzazione, memorizzazione ed elaborazione utilizzato per la fotografia digitale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a digital photograph to the visualization, storage and processing program used for the digital photograph.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha programma per foto</rdfs:label>
        <rdfs:label xml:lang="en">has photo program</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/usesSoftware"/>
        <core:replacingQuery>select distinct * where {

?cp a-dd:usesSoftware ?software.
?software a a-dd:Software

}</core:replacingQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasPhotoSize -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasPhotoSize">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/hasTechnicalCharacteristic"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isPhotoSizeOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/TechnicalCharacteristic"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una risorsa digitale al formato della risorsa, inteso come la dimensione standardizzata (es.: per i materiali fotografici negativi, positivi, ecc.).</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a digital photograph to its format, intended as the photographic material&apos;s standardised size (e.g. negative, positives).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha dimensioni della foto</rdfs:label>
        <rdfs:label xml:lang="en">has photo size</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {?class &lt;https://w3id.org/arco/ontology/arco-lite/hasPhotoSize&gt; ?char .}
WHERE {?class a-dd:hasPhotoSize ?char. }</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasPhotoSize"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasPixelDimension -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasPixelDimension">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/hasTechnicalCharacteristic"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isPixelDimensionOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/TechnicalCharacteristic"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;immagine digitale (es.: fotografia) alle dimensioni, in pixel, dell&apos;immagine.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a digital resource to its size in pixels.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha dimensioni in pixel</rdfs:label>
        <rdfs:label xml:lang="en">has pixel dimension</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {?class &lt;https://w3id.org/arco/ontology/arco-lite/hasPixelDimension&gt; ?char .}
WHERE {?class a-dd:hasPixelDimension ?char. }</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasPixelDimension"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasQualityLevel -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasQualityLevel">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/hasTechnicalCharacteristic"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isQualityLevelOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/TechnicalCharacteristic"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una risorsa digitale al livello di qualità della risorsa (es.: alta risoluzione, bassa risoluzione, preview)</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a digital resource to its quality level, e.g. high-resolution, low-resolution, preview.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha livello di qualità</rdfs:label>
        <rdfs:label xml:lang="en">has quality level</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {?class &lt;https://w3id.org/arco/ontology/arco-lite/hasResolution&gt; ?char .}
WHERE {?class a-dd:hasQualityLevel ?char. }</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasResolution"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasResolution -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasResolution">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/hasTechnicalCharacteristic"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isResolutionOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/TechnicalCharacteristic"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una fotografia alla risoluzione e al valore specifico utilizzati per la memorizzazione di una fotografia digitale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a digital resource to theresolution used for storing it.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha risoluzione</rdfs:label>
        <rdfs:label xml:lang="en">has resolution</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {?class &lt;https://w3id.org/arco/ontology/arco-lite/hasResolution&gt; ?char .}
WHERE {?class a-dd:hasResolution ?char. }</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasResolution"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasSampleCollected -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasSampleCollected">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isSampleCollectedFrom"/>
        <rdfs:domain rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/Sample"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un bene archeologico a un campione prelevato da esso.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property connects a archaeological entity to a sample collected from it.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha campione prelevato</rdfs:label>
        <rdfs:label xml:lang="en">has sample collected</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa MA, CA, SI, SAS: MC/CMN</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasSampleCollectedType -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasSampleCollectedType">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isSampleCollectedTypeOf"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/denotative-description/SampleCollected"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/SampleCollectedType"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un campione prelevato da un bene archeologico al tipo di campione (es.: intonaco, carbone, etc.)</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a sample collected to its type.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha tipo di campione prelevato</rdfs:label>
        <rdfs:label xml:lang="en">has sample collected type</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa MA, CA, SI, SAS: MC/CMN/CMNT</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {?class core:hasType ?type .}
WHERE {?class a-dd:hasSampleCollectedType ?type.}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasShape -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasShape">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/hasTechnicalCharacteristic"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isShapeOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/TechnicalCharacteristic"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un oggetto al formato dell&apos;oggetto, per oggetti bidimensionali (es.: ottagonale, tondo)</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an object to its shape. It is used for bidimensional objects, e.g. octagonal or round shape.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha forma</rdfs:label>
        <rdfs:label xml:lang="en">has shape</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>Normativa BNB: DB/DBX/DBXX</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {?class &lt;https://w3id.org/arco/ontology/arco-lite/hasShape&gt; ?char .}
WHERE {?class a-dd:hasShape ?char. }</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasShape"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasSoil -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasSoil">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isSoilOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/Soil"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una cosa al suolo</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a thing to the soil</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha suolo</rdfs:label>
        <rdfs:label xml:lang="en">has soil</rdfs:label>
        
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <core:constructQuery>prefix a-loc: &lt;https://w3id.org/arco/ontology/location/&gt;

CONSTRUCT {?x a-loc:hasSoil ?y .}
WHERE {?x a-dd:hasSoil ?y.}</core:constructQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasSoilUse -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasSoilUse">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isSoilUseOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/denotative-description/Soil"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/SoilUse"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega il suolo al suo uso</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a soil to its use</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha uso del suolo</rdfs:label>
        <rdfs:label xml:lang="en">has soil use</rdfs:label>
        
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <core:constructQuery>prefix a-loc: &lt;https://w3id.org/arco/ontology/location/&gt;

CONSTRUCT {?x a-loc:soilUse ?y .}
WHERE {?x a-dd:hasSoilUse ?y.}</core:constructQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasSortingCriterion -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasSortingCriterion">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isSortingCriterionOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/SortingCriterion"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;entità (e.g. un bene complesso, un fondo fotografico) con il criterio di ordinamento delle sue componenti.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an entity (e.g. a complex cultural property, a photographic record set) with the sorting criterion of its inner components.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha criterio di ordinamento</rdfs:label>
        <rdfs:label xml:lang="en">has sorting criterion</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa FF: OG/OGT/OGTO</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasStorageMethodOrColourDepth -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasStorageMethodOrColourDepth">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/hasTechnicalCharacteristic"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isStorageMethodOrColourDepthOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/TechnicalCharacteristic"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una fotografia al metodo e alla profondità di colore con cui è stata memorizzata la fotografia digitale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a digital photograph to the method and color depth through which a digital photograph has been stored.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha metodo di memorizzazione e profondità del colore</rdfs:label>
        <rdfs:label xml:lang="en">has storage method or colour depth</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {?class &lt;https://w3id.org/arco/ontology/arco-lite/hasStorageMethodOrColourDepth&gt; ?char .}
WHERE {?class a-dd:hasStorageMethodOrColourDepth ?char. }</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasStorageMethodOrColourDepth"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasSupport -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasSupport">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isSupportOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/denotative-description/AffixedElement"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/Support"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una iscrizione, un timbro, un emblema, etc., rappresentato su un bene culturale al supporto su cui si trova l&apos;elemento.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property connects an inscription, stamp, emblem etc., represented on a cultural entity to the support on which the entity is located.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha supporto</rdfs:label>
        <rdfs:label xml:lang="en">has support</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: DA/ISE/ISES</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasTechnicalCharacteristic -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasTechnicalCharacteristic">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isTechnicalCharacteristicOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/TechnicalCharacteristic"/>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://w3id.org/arco/ontology/denotative-description/hasTechnicalStatus"/>
            <rdf:Description rdf:about="https://w3id.org/arco/ontology/denotative-description/includesTechnicalCharacteristic"/>
        </owl:propertyChainAxiom>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;entità a una caratteristica tecnica (es.: materia, tecnica, colore, livello di qualità, formato).</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an entity to a technical characteristic (e.g. material, technique, colour, quality level).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha caratteristica tecnica</rdfs:label>
        <rdfs:label xml:lang="en">has technical characteristic</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasTechnicalStatus -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasTechnicalStatus">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasEventOrSituationInTime"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isTechnicalStatusOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/TechnicalStatus"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;entità culturale al suo stato tecnico, valido fino a determinato momento, che è rappresentato dalle caratteristiche tecniche che il bene culturale ha in quel momento.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property connects a cultural entity to its technical status, valid until a specific moment, that is represented by the technical characteristics that a cultural entity has in that moment.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha stato tecnico</rdfs:label>
        <rdfs:label xml:lang="en">has technical status</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: MT/MTC/MTCM; MT/MTC/MTCT - Normativa OA, D, F, S, MI: MT/FRM - Normativa OA, D, F, S: MT/FIL - Normativa VeAC: MT/MTC/MTCC; MT/MTC/MTCF - Normativa F: MT/FVC/FVCC; MT/FVC/FVCF; MT/FVC/FVCP; MT/FVC/FVCU; MT/FVC/FVCM; MT/FVM; DA/APF/APFE</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasTechnique -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasTechnique">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/hasMaterialOrTechnique"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isTechniqueOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/TechnicalCharacteristic"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un oggetto alla tecnica di esecuzione dell&apos;oggetto, per esempio un bene culturale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates an object to its execution technique.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha tecnica</rdfs:label>
        <rdfs:label xml:lang="en">has technique</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {?class &lt;https://w3id.org/arco/ontology/arco-lite/hasTechnique&gt; ?char .}
WHERE {?class a-dd:hasTechnique ?char. }</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasTechnicque"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasTemperament -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasTemperament">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/hasTechnicalCharacteristic"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isTemperamentOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/TechnicalCharacteristic"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega uno strumento al temperamento adottato, soprattutto in caso di oggetto in condizioni originali, o dopo un restauro, dello strumento musicale. Per gli idiofoni a tasti fissi (come xilofoni, litofoni, metallofoni) rappresenta la successione degli intervalli.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a musical instrument to the adopted temperament, especially in relation to an object in its original conditions, or after its restoration. For idiophones with fixed keys (e.g. xylophone, litophone, metallophone) the temperament represents the succession of intervals.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha temperamento</rdfs:label>
        <rdfs:label xml:lang="en">has temperament</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {?class &lt;https://w3id.org/arco/ontology/arco-lite/hasTemperament&gt; ?char .}
WHERE {?class a-dd:hasTemperament ?char. }</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasTemperament"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasTuning -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasTuning">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/hasTechnicalCharacteristic"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isTuningOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/TechnicalCharacteristic"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega uno strumento all&apos;accordatura dello strumento musicale.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a musical instrument to its tuning.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha accordatura</rdfs:label>
        <rdfs:label xml:lang="en">has tuning</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {?class &lt;https://w3id.org/arco/ontology/arco-lite/hasTuning&gt; ?char .}
WHERE {?class a-dd:hasTuning ?char. }</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasTuning"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasValue -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasValue">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isValueOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/denotative-description/Measurement"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/MU/Value"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una misura al suo valore.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a measurement to its value.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha valore</rdfs:label>
        <rdfs:label xml:lang="en">has value</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>MT/MIS/MISM</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasVibratingLenght -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasVibratingLenght">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/hasTechnicalCharacteristic"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isVibratingLenghtOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/TechnicalCharacteristic"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un uno strumento alla lunghezza vibrante dello strumento, in particolare di un cordofono.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a musical instrument to its vibrating length, in particular a chordophone.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha lunghezza vibrante</rdfs:label>
        <rdfs:label xml:lang="en">has vibrating lenght</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {?class &lt;https://w3id.org/arco/ontology/arco-lite/hasLength&gt; ?char .}
WHERE {?class a-dd:isVibratingLenghtOf ?char. }</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/hasLength"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasVolumetricDimensionsMeasurement -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasVolumetricDimensionsMeasurement">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/hasMeasurement"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isVolumetricDimensionsMeasurementIn"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/denotative-description/MeasurementCollection"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/Measurement"/>
        <opla:isNativeTo rdf:resource="https://w3id.org/arco/pattern/object-collection/"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un insieme di misure osservate per un oggetto a una dell misure, quando questa sia relativa all&apos;ingombro di un vestimento antico o contemporaneo. Le misure ingombro determinano l&apos;ingombro per l&apos;immagazzinaggio e si possono quindiconsiderare le coordinate ortogonali dell&apos;oggetto.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property connects a collection of observed measures on an object to one of these measures, when the latter is relative to an ancient or contemporary apparel&apos;s size. The volumetric dimensions measurements determine the size for storage and can be considered as the object&apos;s orthogonal coordinates.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label>ha misura di ingombro</rdfs:label>
        <rdfs:label>has volumetric dimensions measurement</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>Normativa VeAC: MT/MII</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/hasWritingSystem -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasWritingSystem">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isWritingSystemOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/denotative-description/AffixedElement"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/WritingSystem"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una iscrizione, un timbro, uno stemma, etc., al sistema di scrittura/alfabeto adottati.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property connects an inscription, stamp, crest etc., to the adopted writing system or alphabet.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">ha sistema di scrittura</rdfs:label>
        <rdfs:label xml:lang="en">has writing system</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: DA/ISE/ISEF. DA/DES/DEST, DESF</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/includesTechnicalCharacteristic -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/includesTechnicalCharacteristic">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isIncludedInTechnicalStatus"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/denotative-description/CulturalEntityTechnicalStatus"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/TechnicalCharacteristic"/>
        <opla:isNativeTo rdf:resource="https://w3id.org/arco/pattern/technical-characteristic/"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega lo stato tecnico di un&apos;entità culturale a una delle caratteristiche tecniche dell&apos;entità relativamente a quello stato.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property connects a technical status, with respect to a specific entity (as a cultural entity) to one of the technical characteristics related to that status.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">include caratteristica tecnica</rdfs:label>
        <rdfs:label xml:lang="en">includes technical characteristic</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/involvesAccompanyingInstrument -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/involvesAccompanyingInstrument">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isAccompanyingInstrumentInvolvedIn"/>
        
        <core:constructQuery>CONSTRUCT {
?x &lt;https://w3id.org/arco/ontology/musical-instrument/involvesAccompanyingInstrument&gt; ?y.
}

WHERE {
?x &lt;https://w3id.org/arco/ontology/musical-instrument/involvesAccompanyingInstrument&gt; ?y.
}</core:constructQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/involvesAgeRange -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/involvesAgeRange">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isAgeRangeInvolvedIn"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/denotative-description/CommunicationMedium"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/AgeRange"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una modalità comunicativa (prossemica, cinesica) alla fascia d&apos;età delle persone che attuano la comunicazione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a communication medium (proxemics, kinetic) to the age range of the participants to the communication.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">coinvolge fascia d&apos;età</rdfs:label>
        <rdfs:label xml:lang="en">involves age range</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BDI: CU/CUC/CUCE; CU/CUP/CUPE</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/involvesElement -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/involvesElement">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isElementInvolvedIn"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;entità (es: un bene demoetnoantropologico) a un elemento materiale coinvolto nel bene (oggetto, enimale, vegetale, minerale, ecc).</rdfs:comment>
        <rdfs:comment xml:lang="en">This class relates an entity (a demoethnoantropological cp) to an element involved in the cp (e.g. an object, an animal, a vegetal, a mineral etc).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <rdfs:label xml:lang="it">coinvolge elemento</rdfs:label>
        <rdfs:label xml:lang="en">involves element</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="it">unstable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="en">ICCD Normativa BDI: DA/DRM</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/involvesMainAgent -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/involvesMainAgent">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/denotative-description/isMainAgentInvolvedIn"/>
        
        <core:constructQuery>CONSTRUCT {
?x &lt;https://w3id.org/arco/ontology/arco-lite/involvesMainAgent&gt; ?y.
}

WHERE {
?x &lt;https://w3id.org/arco/ontology/denotative-description/involvesMainAgent&gt; ?y.
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/involvesMainAgent"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/involvesSoloInstrument -->

