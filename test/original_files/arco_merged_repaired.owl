        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/core/hasDescription -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/core/hasDescription">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/core/isDescriptionOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/core/Description"/>
