    <owl:AnnotationProperty rdf:about="https://w3id.org/arco/ontology/catalogue/iccdNormTag">
        <rdfs:comment xml:lang="it">Questa proprietà permette di annotare il campo o i campi della normativa ICCD corrispondenti a una determinata classe o proprietà dell&apos;ontologia.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property annotates the field or the fields of the ICCD regulation to which a specific class or property refers.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="en">ICCD norm tag</rdfs:label>
        <rdfs:label xml:lang="it">acronimo normativa ICCD</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:AnnotationProperty>
    


