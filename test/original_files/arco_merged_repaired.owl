        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa SM 4.00: AA/AAA</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT { ?x a &lt;https://w3id.org/arco/ontology/musical-instrument/Tuning&gt; .}
WHERE {?x a a-dd:Tuning .}</core:constructQuery>
    </owl:NamedIndividual>
    


