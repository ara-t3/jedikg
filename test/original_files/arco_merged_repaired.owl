    <!-- https://w3id.org/arco/ontology/construction-description/Floor -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/construction-description/Floor">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/construction-description/ConstructionSpace"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/construction-description/numberOfRooms"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il piano di una costruzione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the floor of a construction.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/construction-description"/>
        <rdfs:label xml:lang="en">Floor</rdfs:label>
        <rdfs:label xml:lang="it">Piano</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa A: SI/SII/SIIN</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/construction-description/Flooring -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/construction-description/Flooring">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/construction-description/Covering"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/construction-description/hasFlooringLayout"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/construction-description/FlooringLayout"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/construction-description/FlooringType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://w3id.org/arco/ontology/construction-description/Roofing"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta la pavimentazione di una costruzione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the flooring of a construction.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/construction-description"/>
        <rdfs:label xml:lang="en">Flooring</rdfs:label>
        <rdfs:label xml:lang="it">Pavimentazione</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>Normativa A: PV/PVM</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/construction-description/FlooringLayout -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/construction-description/FlooringLayout">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/construction-description/Layout"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta lo schema compositivo del disegno della pavimentazione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the pattern of the floor.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/construction-description"/>
        <rdfs:label xml:lang="en">Flooring layout</rdfs:label>
        <rdfs:label xml:lang="it">Schema di posa</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">Normativa A: PV/PVM/PVMS</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/construction-description/FlooringType -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/construction-description/FlooringType">
