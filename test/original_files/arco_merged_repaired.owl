    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/natural-specimen-description/Substrate -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/natural-specimen-description/Substrate">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
