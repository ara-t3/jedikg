    <!-- https://w3id.org/arco/ontology/natural-specimen-description/GeologicalContext -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/natural-specimen-description/GeologicalContext">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Situation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/context-description/hasBibliography"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/context-description/Bibliography"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/hasMineralDeposit"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/MineralDeposit"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/hasOutcrop"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/Outcrop"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta il contesto geologico del luogo di raccolta di un bene.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents geological context of a collecting location.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description"/>
        <rdfs:label xml:lang="it">Contesto geologico</rdfs:label>
        <rdfs:label xml:lang="en">Geological context</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BNM: IM/IMA/IMAC</a-cat:iccdNormTag>
    </owl:Class>
    


