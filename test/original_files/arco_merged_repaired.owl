        <rdfs:label xml:lang="it">Elemento idrico</rdfs:label>
        <rdfs:label xml:lang="en">Water element</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa PG: FOT* (FOTD)</a-cat:iccdNormTag>
        <a-cat:iccdNormTag>Normativa PG: FO/FOT</a-cat:iccdNormTag>
    </owl:Class>
    


