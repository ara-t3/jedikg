        <rdfs:comment xml:lang="en">This property relates an entity to its description.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="it">ha descrizione</rdfs:label>
        <rdfs:label xml:lang="en">has description</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/core/hasDirectHigherRank -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/core/hasDirectHigherRank">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasHigherRank"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/core/hasDirectHigherRank"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/core/Taxon"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/core/Taxon"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega due taxa, dove la prima è più specifica della seconda e non ci sono altri taxa che siano più generali del primo e più specifici del secondo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates two taxa, where the first is more specific then the second and there is no other taxon that is both more general than the first and more specific than the second.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="it">ha rango superiore diretto</rdfs:label>
        <rdfs:label xml:lang="en">has direct higher rank</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa trasversale: SG/CLF. Normativa BNB: SB/NBN, SB/NAA, RB/RBR/RBRN, RB/RBN. Normativa BNM: SM/SMN, RM/RMN. Normativa BNP: SP/SPS. Normativa BNZ: SZ/SZS. Normativa AT: OG/OGS. Normativa BNPE: SR/SRN, RR/RRN. Normativa BNPL: SP/SPN, RP/RPN</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/core/hasDirectLowerRank -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/core/hasDirectLowerRank">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasLowerRank"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/core/Taxon"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/core/Taxon"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega due taxa, dove la prima è meno specifica della seconda e non ci sono altri taxa che siano più specifici del primo e più denerali del secondo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates two taxa, where the first is less specific then the second and there is no other taxon that is both more specific than the first and more general than the second.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="it">ha rango inferiore diretto</rdfs:label>
        <rdfs:label xml:lang="en">has direct lower rank</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa trasversale: SG/CLF. Normativa BNB: SB/NBN, SB/NAA, RB/RBR/RBRN, RB/RBN. Normativa BNM: SM/SMN, RM/RMN. Normativa BNP: SP/SPS. Normativa BNZ: SZ/SZS. Normativa AT: OG/OGS. Normativa BNPE: SR/SRN, RR/RRN. Normativa BNPL: SP/SPN, RP/RPN</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/core/hasEventOrSituationInTime -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/core/hasEventOrSituationInTime">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/core/isEventOrSituationInTimeOf"/>
