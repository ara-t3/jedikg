WHERE {?x a a-dd:MaximumTotalWidth .}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/clothing-description/MaximumTotalWidth"/>
    </owl:NamedIndividual>
    


