    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/construction-description/Window -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/construction-description/Window">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/construction-description/ArchitecturalElement"/>
