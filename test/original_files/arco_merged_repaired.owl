        <rdfs:comment xml:lang="en">This property relates the type of a cultural entity title to its title.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is title type of</rdfs:label>
        <rdfs:label xml:lang="it">è tipo di titolo di</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {
