    <!-- https://w3id.org/arco/ontology/natural-specimen-description/HostIndividual -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/natural-specimen-description/HostIndividual">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description/isHostIndividualOf"/>
                <owl:someValuesFrom rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
            </owl:Restriction>
