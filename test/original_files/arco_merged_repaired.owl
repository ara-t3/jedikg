    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/core/hasSituation -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/core/hasSituation">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasEventOrSituationInTime"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/core/isSituationOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/core/Situation"/>
        <opla:isNativeTo rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/situation.owl"/>
        <rdfs:comment xml:lang="it">La proprietà che collega un qualsiasi oggetto a una situazione.</rdfs:comment>
        <rdfs:comment xml:lang="en">The property that links any object to a situation.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="it">ha situazione</rdfs:label>
        <rdfs:label xml:lang="en">has situation</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/core/hasTaxon -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/core/hasTaxon">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasConcept"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/core/isTaxonOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/core/Taxon"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega una classificazione a un taxon, quando il sistema di classificazione è di tipo gerarchico.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates a classification to a taxon, when the classification system is hierarchical.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="it">ha taxon</rdfs:label>
        <rdfs:label xml:lang="en">has taxon</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>Normativa BNB: SB/NBN, SB/NAA, RB/RBR/RBRN, RB/RBN. Normativa BNM: SM/SMN, RM/RMN. Normativa BNP: SP/SPS. Normativa BNZ: SZ/SZS. Normativa AT: OG/OGS. Normativa BNPE: SR/SRN, RR/RRN. Normativa BNPL: SP/SPN, RP/RPN</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/core/hasTopic -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/core/hasTopic">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/core/isTopicOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un&apos;entità all&apos;argomento corrispondente.</rdfs:comment>
        <rdfs:comment xml:lang="it">This property relates an entity with its topic.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="it">ha argomento</rdfs:label>
        <rdfs:label xml:lang="en">has topic</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/core/hasType -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/core/hasType">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasConcept"/>
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/core/isTypeOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/core/Type"/>
        <rdfs:comment xml:lang="it">La object property che associa un qualunque oggetto a un tipo.</rdfs:comment>
        <rdfs:comment xml:lang="en">The object property that associates any object with a type.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="it">ha tipo</rdfs:label>
        <rdfs:label xml:lang="en">has type</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/core/involves -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/core/involves">
        <owl:inverseOf rdf:resource="https://w3id.org/arco/ontology/core/isInvolvedIn"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/core/EventOrSituationInTime"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta il collegamento con una situazione o un evento.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents the link to a situation or event</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="it">coinvolge</rdfs:label>
        <rdfs:label xml:lang="en">involves</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/core/involvesAgent -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/core/involvesAgent">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/involves"/>
