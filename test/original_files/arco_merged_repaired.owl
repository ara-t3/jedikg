    <!-- https://w3id.org/arco/ontology/context-description/isUrbanPlanningInstrumentOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isUrbanPlanningInstrumentOf">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/UrbanPlanningInstrument"/>
        <rdfs:range rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega uno strumento urbanistico-territoriale, ovvero un piano regolatore generale e particolareggiato o un piano paesaggistico che interessa un bene culturale al bene stesso.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class relates a urban planning instrument to the related cultural property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is urban planning instrument of</rdfs:label>
        <rdfs:label xml:lang="it">è strumento urbanistico-territoriale di</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale 4.00: TU/STU</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isUseFunctionOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isUseFunctionOf">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/UseFunction"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Use"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega la funzione d&apos;uso di un&apos;entità alla relativa entità.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the use function of an entity to the related entity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is use function of</rdfs:label>
        <rdfs:label xml:lang="it">è funzione d&apos;uso di</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isUseOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isUseOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isEventOrSituationInTimeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/Use"/>
        <rdfs:range rdf:resource="http://dati.beniculturali.it/cis/CulturalEntity"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega l&apos;uso di un bene culturale con il bene culturale stesso.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the use of a cultural entity to the related cultural property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is use of</rdfs:label>
        <rdfs:label xml:lang="it">è uso di</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa Trasversale: UT</a-cat:iccdNormTag>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isUseTypeOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isUseTypeOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isTypeOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/UseType"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Use"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega il tipo di uso del bene (attuale, precedente, storico) con il suo uso.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the type of a cultural entity use to its use.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is use type of</rdfs:label>
        <rdfs:label xml:lang="it">è tipo d&apos;uso di</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {
?type core:isTypeOf ?thing .
}

WHERE {
?type a-cd:isUseTypeOf ?thing .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/isTypeOf"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isUseTypeSpecificationOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isUseTypeSpecificationOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/hasConcept"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/UseTypeSpecification"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/context-description/Use"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega le specifiche relative al tipo di utilizzo di un bene con il relativo uso.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the specification of the type of a cultural property use to the related use.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is use type specification of</rdfs:label>
        <rdfs:label xml:lang="it">è specifica del tipo di uso di</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {
?spec core:isTypeOf ?useType .
}

WHERE {
?spec a-cd:isUseTypeSpecificationOf ?useType .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/isTypeOf"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isUserOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isUserOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/core/isAgentInvolvedIn"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un utente, inteso come agente che ha fatto uso di un&apos;entità, all&apos;entità stessa.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property relates the user, intended as the agent who employed an entity, to the related entity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">is user of</rdfs:label>
        <rdfs:label xml:lang="it">è utente di</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>PREFIX &lt;https://w3id.org/arco/ontology/arco-lite/&gt;

CONSTRUCT {
?agent a-lite:isUserOf ?thing .
}

WHERE {
?agent a-cd:isUserOf ?thing .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/isUserOf"/>
        <core:replacingQuery>prefix &lt;https://w3id.org/arco/ontology/arco-lite/isUserOf&gt;

select * where {
?NEWagent core:isAgentOf ?NEWagentRole .
?NEWagentRole core:hasRole ?NEWrole ;
core:isAgentRoleOf a-cd:Use .
}</core:replacingQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/context-description/isUserSocialCategoryOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/context-description/isUserSocialCategoryOf">
