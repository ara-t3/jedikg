    <!-- https://w3id.org/arco/ontology/catalogue/isDescribedBy -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/catalogue/isDescribedBy">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="it">Questa proprietà, inversa della proprietà &quot;descrive&quot;, è stata creata come proprietà generica di sottoproprietà specifiche, e rappresenta la relazione tra un&apos;entità descritta da un&apos;altra entità.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property, inverse property of &quot;describes&quot;, was created as a generic property for specific subproperties, and represents the relationship between an entity described by another entity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="en">is described by</rdfs:label>
        <rdfs:label xml:lang="it">è descritto da</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>CONSTRUCT {
?x core:isDescribedBy ?thing .
}

WHERE {
?x a-cat:isDescribedBy ?thing .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/core/isDescribedBy"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/catalogue/isDescribedByCatalogueRecord -->

