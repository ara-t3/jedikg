        <rdfs:label xml:lang="it">Tipo di elemento verticale</rdfs:label>
        <rdfs:label xml:lang="en">Vertical element type</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa A: SV/SVCU;SVCT</a-cat:iccdNormTag>
    </owl:Class>
    


