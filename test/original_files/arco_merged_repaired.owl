    <!-- https://w3id.org/arco/ontology/catalogue/isImmediatePreviousVersionOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/catalogue/isImmediatePreviousVersionOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/catalogue/isPreviousVersionOf"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/catalogue/CatalogueRecordVersion"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/catalogue/CatalogueRecordVersion"/>
        <opla:isNativeTo rdf:resource="https://w3id.org/arco/pattern/catalogue-record-sequence/"/>
        <rdfs:comment xml:lang="en">Property used to associate a catalogue record version to its immediate next version.</rdfs:comment>
        <rdfs:comment xml:lang="it">Questa proprietà associa una versione di una scheda alla sua versione immediatamente successiva.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="en">is immediate previous version of</rdfs:label>
        <rdfs:label xml:lang="it">è la versione precedente di</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/catalogue/isOfficialInChargeOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/catalogue/isOfficialInChargeOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/arco/ontology/catalogue/isCataloguingAgentOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/catalogue/CatalogueRecordVersion"/>
        <rdfs:comment xml:lang="it">Questa è la proprietà inversa a &quot;ha funzionario responsabile&quot;.</rdfs:comment>
        <rdfs:comment xml:lang="en">This is the inverse property of &quot;has official in charge&quot;.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
        <rdfs:label xml:lang="en">is official in charge of</rdfs:label>
        <rdfs:label xml:lang="it">è funzionario responsabile di</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <core:constructQuery>prefix a-lite: &lt;https://w3id.org/arco/ontology/arco-lite/&gt; 

CONSTRUCT {
?agent a-lite:isOfficialInChargeOf ?thing .
}

WHERE {
?agent a-cat:isOfficialInChargeOf ?thing .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/arco-lite/isOfficialInChargeOf"/>
        <core:replacingQuery>select * where {
?agent core:isAgentOf ?NEWagentRole .
?NEWagentRole core:hasRole &lt;https://w3id.org/arco/resource/Role/OfficialInCharge&gt; ;
core:isAgentRoleOf ?thing .
}</core:replacingQuery>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/catalogue/isPreviousVersionOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/catalogue/isPreviousVersionOf">
