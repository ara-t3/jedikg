                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/construction-description/Layout"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta la suddivisione orizzontale e verticale dello spazio interno di una costruzione.</rdfs:comment>
        <rdfs:comment xml:lang="en">subdivision of the interior space of a construction.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/construction-description"/>
        <rdfs:label xml:lang="en">ConstructionDevelopment</rdfs:label>
        <rdfs:label xml:lang="en">Interior subdvision</rdfs:label>
        <rdfs:label xml:lang="it">Suddivisione interna</rdfs:label>
        <rdfs:label xml:lang="it">Sviluppo della costruzione</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>Normativa A: SI/SII/SIIV;SIIO</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/construction-description/ConstructionElement -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/construction-description/ConstructionElement">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/construction-description/Construction"/>
        <owl:disjointWith rdf:resource="https://w3id.org/arco/ontology/construction-description/ConstructionSpace"/>
        <rdfs:comment xml:lang="it">Questa classe rappresenta tutti gli elementi fisici che fanno parte di una costruzione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents all the physical elements that are part of a construction.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/construction-description"/>
        <rdfs:label xml:lang="en">Construction element</rdfs:label>
        <rdfs:label xml:lang="it">Elemento della costruzione</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/construction-description/ConstructionPart -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/construction-description/ConstructionPart">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/denotative-description/hasOrientation"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/denotative-description/Orientation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/construction-description/numberOfFloors"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/construction-description/numberOfRooms"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta la parte di una costruzione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the part of a construction.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/construction-description"/>
        <rdfs:label xml:lang="en">Construction part</rdfs:label>
        <rdfs:label xml:lang="it">Parte di costruzione</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/construction-description/ConstructionSpace -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/construction-description/ConstructionSpace">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/construction-description/Construction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasType"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/arco/ontology/construction-description/ConstructionSpaceType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/construction-description/hasConstructionDevelopment"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/construction-description/ConstructionDevelopment"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/construction-description/hasLayout"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/construction-description/Layout"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/denotative-description/hasOrientation"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/denotative-description/Orientation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Questa classe rappresenta lo spazio interno o esterno di una costruzione, eventualmente delimitato da elementi fisici e destinato a una determinata funzione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the interior or exterior space of a construction, possibly bounded by physical elements and intended for a certain function.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/construction-description"/>
        <rdfs:label xml:lang="en">Construction space</rdfs:label>
        <rdfs:label xml:lang="it">Spazio della costruzione</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa A: SI/SII/SIIP</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/construction-description/ConstructionSpaceType -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/construction-description/ConstructionSpaceType">
        <rdfs:subClassOf rdf:resource="https://w3id.org/arco/ontology/core/Type"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/isTypeOf"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/arco/ontology/construction-description/ConstructionSpace"/>
