        <rdfs:comment xml:lang="en">This property relates a geographical feature to a time indexed typed location that refers to that feature.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/location/"/>
        <rdfs:label xml:lang="en">is location in</rdfs:label>
