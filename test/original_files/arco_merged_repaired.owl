    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/denotative-description/isTechnicalCharacteristicOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/isTechnicalCharacteristicOf">
