    <rdf:Description rdf:about="https://w3id.org/arco/ontology/construction-description/Wall">
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/construction-description"/>
        <rdfs:label xml:lang="it">Parete</rdfs:label>
        <rdfs:label xml:lang="en">Wall</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </rdf:Description>
    <rdf:Description rdf:about="https://w3id.org/arco/ontology/context-description/AlternativeDating">
        <rdfs:comment xml:lang="it">Questa classe rappresenta una eventuale altra datazione che può riguardare un bene culturale (es.: datazione tradizionale, altro metodo di datazione).</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents an alternative dating of a cultural property (e.g.: an obsolete dating, a dating based on another method of dating).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Alternative dating</rdfs:label>
        <rdfs:label xml:lang="it">Datazione alternativa</rdfs:label>
        
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag xml:lang="it">ICCD Normativa Trasversale: DT/ADT.</a-cat:iccdNormTag>
    </rdf:Description>
    <rdf:Description rdf:about="https://w3id.org/arco/ontology/context-description/Reuse">
        <rdfs:comment xml:lang="it">Questa classe rappresenta il riuso subito dal bene catalogato o da una sua parte.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents cultural entity&apos;s reuse.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class represents the reuse of a cultural property or of one of its parts.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <rdfs:label xml:lang="en">Reuse</rdfs:label>
        <rdfs:label xml:lang="it">Riuso</rdfs:label>
        
        <owl:versionInfo xml:lang="en">provvisoria</owl:versionInfo>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normative RA, SMO, PST,  OAC, OA, MI, NU: RO/REI - ICCD Normative CA, MA: RO/RIU - ICCD Normativa F: ROP/CRF/CRFT = &apos;reimpiego&apos;</a-cat:iccdNormTag>
        <core:constructQuery>CONSTRUCT {
?use a a-cd:Use .
}

WHERE {
?use a-cd:Reuse .
}</core:constructQuery>
        <core:replacedBy rdf:resource="https://w3id.org/arco/ontology/context-description/Use"/>
    </rdf:Description>
    <rdf:Description rdf:about="https://w3id.org/arco/ontology/core/hasIdentifier">
        <rdfs:comment xml:lang="it">La object property che collega una entità a un identificativo.</rdfs:comment>
        <rdfs:comment xml:lang="en">The object property that links an entity to an identifier.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/core"/>
        <rdfs:label xml:lang="it">ha identificativo</rdfs:label>
        <rdfs:label xml:lang="en">has identifier</rdfs:label>
        <owl:versionInfo xml:lang="it">instabile</owl:versionInfo>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <owl:versionInfo xml:lang="en">unstable</owl:versionInfo>
        <a-cat:iccdNormTag>Normativa trasversale: CD/NTC, AC/ACC, ACI, ACS/ACSC, AC/MOD/MODI; OG/OGT/OGTI; RO/ROF/ROFX, RO/CRF/CRFH, DO/BIB/BIBH, BIBK, NCUN, RE/RCG/RCGK, NCUN, NUCN, RCGH, RE/DSC/DSCK, NUCN, NCUN, DSCH, RE/FOI/FOID; AU/AUT/AUTH, AUTK, NUCN, NCUN; AU/AUF/AUFH, NUCN, NCUN; PD/PDF/PDFH; UB/INP/INPS: LC/LDC/LDCK, LDCG; LA/PRC/PRCK; MC/CMN/CMNN. MODI: CD/CDR, CDM. Normativa BDI: DU/DUC, DU/DUO/DUOC, DU/DUM/DUMC, DV/DVC, DV/DVO/DVOC, DV/DVM/DVMC, DF/DFC, DF/DFO/DFOC, DF/DFM/DFMC, AI/AIC, AI/AIO/AIOC, AI/AIM/AIMC, VI/VIC, VI/VIO/VIOC, VI/VIM/VIMC, FI/FIC, FI/FIO/FIOC, FI/FIM/FIMC</a-cat:iccdNormTag>
    </rdf:Description>
    <rdf:Description rdf:about="https://w3id.org/arco/ontology/natural-specimen-description/Reflectance">
        <rdfs:comment xml:lang="it">Questa individuo rappresenta la riflettanza</rdfs:comment>
        <rdfs:comment xml:lang="en">This individual represents the reflectance</rdfs:comment>
        <rdfs:label xml:lang="en">Reflectance</rdfs:label>
        <rdfs:label xml:lang="it">Riflettanza</rdfs:label>
        <owl:deprecated rdf:resource="https://w3id.org/arco/ontology/natural-specimen-description"/>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa BNM: SM/SMM/SMMF, SMMB</a-cat:iccdNormTag>
    </rdf:Description>
    


