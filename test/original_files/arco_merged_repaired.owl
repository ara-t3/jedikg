        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
        <a-cat:iccdNormTag>ICCD Normativa A: FN/FNST;FNSQ</a-cat:iccdNormTag>
    </owl:Class>
    


    <!-- https://w3id.org/arco/ontology/construction-description/Fountain -->

    <owl:Class rdf:about="https://w3id.org/arco/ontology/construction-description/Fountain">
