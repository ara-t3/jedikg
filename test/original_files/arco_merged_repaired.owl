    </owl:ObjectProperty>
    


    <!-- https://w3id.org/arco/ontology/core/isAgentRoleOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/core/isAgentRoleOf">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/core/AgentRole"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
