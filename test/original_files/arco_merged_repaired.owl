        <opla:isNativeTo rdf:resource="https://w3id.org/arco/pattern/catalogue-record-sequence/"/>
        <rdfs:comment xml:lang="en">Property used to associate a catalogue record version one of its next version.</rdfs:comment>
        <rdfs:comment xml:lang="it">Questa proprietà associa una versione di una scheda a una sua versione successiva.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/arco/ontology/catalogue"/>
