    <!-- https://w3id.org/arco/ontology/core/hasLowerRank -->

    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/core/hasLowerRank">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/core/Taxon"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/core/Taxon"/>
