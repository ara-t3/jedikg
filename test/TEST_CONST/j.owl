<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.w3.org/2002/07/owl#"
     xml:base="http://www.w3.org/2002/07/owl"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:ontology="http://dbpedia.org/ontology/">
    <Ontology/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://dbpedia.org/ontology/almaMater -->

    <ObjectProperty rdf:about="http://dbpedia.org/ontology/almaMater">
        <rdfs:range rdf:resource="http://dbpedia.org/ontology/EducationalInstitution"/>
    </ObjectProperty>
    


    <!-- http://dbpedia.org/ontology/city -->

    <ObjectProperty rdf:about="http://dbpedia.org/ontology/city">
        <rdfs:range rdf:resource="http://dbpedia.org/ontology/City"/>
    </ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://dbpedia.org/ontology/Agent -->

    <Class rdf:about="http://dbpedia.org/ontology/Agent">
        <disjointWith rdf:resource="http://dbpedia.org/ontology/Place"/>
    </Class>
    


    <!-- http://dbpedia.org/ontology/City -->

    <Class rdf:about="http://dbpedia.org/ontology/City">
        <rdfs:subClassOf rdf:resource="http://dbpedia.org/ontology/Settlement"/>
    </Class>
    


    <!-- http://dbpedia.org/ontology/EducationalInstitution -->

    <Class rdf:about="http://dbpedia.org/ontology/EducationalInstitution">
        <rdfs:subClassOf rdf:resource="http://dbpedia.org/ontology/Organisation"/>
    </Class>
    


    <!-- http://dbpedia.org/ontology/Organisation -->

    <Class rdf:about="http://dbpedia.org/ontology/Organisation">
        <rdfs:subClassOf rdf:resource="http://dbpedia.org/ontology/Agent"/>
    </Class>
    


    <!-- http://dbpedia.org/ontology/Place -->

    <Class rdf:about="http://dbpedia.org/ontology/Place"/>
    


    <!-- http://dbpedia.org/ontology/PopulatedPlace -->

    <Class rdf:about="http://dbpedia.org/ontology/PopulatedPlace">
        <rdfs:subClassOf rdf:resource="http://dbpedia.org/ontology/Place"/>
    </Class>
    


    <!-- http://dbpedia.org/ontology/Settlement -->

    <Class rdf:about="http://dbpedia.org/ontology/Settlement">
        <rdfs:subClassOf rdf:resource="http://dbpedia.org/ontology/PopulatedPlace"/>
    </Class>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://dbpedia.org/resource/Dulwich_College -->

    <NamedIndividual rdf:about="http://dbpedia.org/resource/Dulwich_College">
        <ontology:city rdf:resource="http://dbpedia.org/resource/Dulwich_College"/>
    </NamedIndividual>
    


    <!-- http://dbpedia.org/resource/Nigel_Farage -->

    <NamedIndividual rdf:about="http://dbpedia.org/resource/Nigel_Farage">
        <ontology:almaMater rdf:resource="http://dbpedia.org/resource/Dulwich_College"/>
    </NamedIndividual>
</rdf:RDF>



