    <!-- http://dbpedia.org/ontology/ceremonialCounty -->

    <ObjectProperty rdf:about="http://dbpedia.org/ontology/ceremonialCounty">
        <rdfs:domain rdf:resource="http://dbpedia.org/ontology/PopulatedPlace"/>
    </ObjectProperty>
    


