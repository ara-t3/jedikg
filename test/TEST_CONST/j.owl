    <!-- http://dbpedia.org/resource/The_Grays_(band) -->

    <NamedIndividual rdf:about="http://dbpedia.org/resource/The_Grays_(band)">
        <rdf:type rdf:resource="http://dbpedia.org/ontology/Band"/>
