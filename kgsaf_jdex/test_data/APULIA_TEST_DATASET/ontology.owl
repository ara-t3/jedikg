        <rdfs:comment xml:lang="en">Property that links anything to a possible rating.</rdfs:comment>
        <rdfs:comment xml:lang="it">Proprietà che collega qualsiasi cosa a una possibile valutazione generale.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/italia/onto/SM"/>
        <rdfs:label xml:lang="it">ha valutazione</rdfs:label>
        <rdfs:label xml:lang="en">has rating</rdfs:label>
