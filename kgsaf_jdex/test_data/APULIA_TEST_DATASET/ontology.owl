        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/TI/Year"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#gYear"/>
        <rdfs:comment xml:lang="en">Datatype property for linking a year to its literal representation as xsd:gYear.</rdfs:comment>
        <rdfs:comment xml:lang="it">Properietà definita per collegare un individuo di tipo Year alla sua rappresentazione letterale con datatype xsd:gYear.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/italia/onto/TI"/>
        <rdfs:label xml:lang="it">anno</rdfs:label>
        <rdfs:label xml:lang="en">year</rdfs:label>
