        <rdfs:label xml:lang="it">ha punto di contatto online</rdfs:label>
        <rdfs:label xml:lang="en">has online contact point</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
    </owl:ObjectProperty>
    


