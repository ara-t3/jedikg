        <rdfs:comment xml:lang="en">This property links a user account to its name (i.e. a literal).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/italia/onto/SM"/>
        <rdfs:label xml:lang="it">nome dell&apos;account utente</rdfs:label>
        <rdfs:label xml:lang="en">user account name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/italia/onto/SM/userRating -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/italia/onto/SM/userRating">
