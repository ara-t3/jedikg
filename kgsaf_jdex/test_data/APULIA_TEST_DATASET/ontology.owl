        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Il contenuto di un post.</rdfs:comment>
        <rdfs:comment xml:lang="en">The content of a post.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/italia/onto/SM"/>
        <rdfs:label xml:lang="it">contenuto del post</rdfs:label>
        <rdfs:label xml:lang="en">post content</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/italia/onto/SM/reviewAspect -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/italia/onto/SM/reviewAspect">
