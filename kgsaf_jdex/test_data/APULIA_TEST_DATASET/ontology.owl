    <owl:ObjectProperty rdf:about="https://w3id.org/italia/onto/SM/hasPhysicalContactPoint">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/SM/hasContactPoint"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/SM/PhysicalContactPoint"/>
        <rdfs:comment xml:lang="en">Property used to associate a physical contact point to any thing.</rdfs:comment>
        <rdfs:comment xml:lang="it">Proprietà utilizzata per associare un contatto fisico a una qualunque cosa del dominio modellato</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/italia/onto/SM"/>
        <rdfs:label xml:lang="it">ha punto di contatto fisico</rdfs:label>
        <rdfs:label xml:lang="en">has physical contact point</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


