        <rdfs:range rdf:resource="https://w3id.org/italia/onto/SM/Email"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un punto di contatto online con uno o più indirizzi email di vario tipo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property links an online contact  point with one or more email addresses of various types.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/italia/onto/SM"/>
        <rdfs:label xml:lang="it">ha email</rdfs:label>
        <rdfs:label xml:lang="en">has email</rdfs:label>
    </owl:ObjectProperty>
    


