        <rdfs:range rdf:resource="https://w3id.org/italia/onto/SM/Telephone"/>
        <rdfs:comment xml:lang="it">Questa proprietà collega un punto di contatto online con il telefono.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property links the online contact point with the telephone element</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/italia/onto/SM"/>
        <rdfs:label xml:lang="it">ha telefono</rdfs:label>
        <rdfs:label xml:lang="en">has telephone</rdfs:label>
