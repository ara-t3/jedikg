    <owl:ObjectProperty rdf:about="https://w3id.org/italia/onto/SM/hasCreator">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <owl:inverseOf rdf:resource="https://w3id.org/italia/onto/SM/isCreatorOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/SM/Post"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/SM/UserAccount"/>
        <rdfs:comment xml:lang="it">Questa proprietà asserisce che un post è stato creato da un certo account utente.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property states that a post has been created by a certain user account.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/italia/onto/SM"/>
        <rdfs:label xml:lang="it">ha autore</rdfs:label>
        <rdfs:label xml:lang="en">has creator</rdfs:label>
        <prov:wasInfluencedBy rdf:resource="http://rdfs.org/sioc/ns"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/italia/onto/SM/hasEmail -->

    <owl:ObjectProperty rdf:about="https://w3id.org/italia/onto/SM/hasEmail">
        <owl:inverseOf rdf:resource="https://w3id.org/italia/onto/SM/isEmailOf"/>
