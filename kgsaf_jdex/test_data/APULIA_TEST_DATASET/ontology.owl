        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Object"/>
        <owl:disjointWith rdf:resource="https://w3id.org/italia/onto/l0/Concept"/>
        <owl:disjointWith rdf:resource="https://w3id.org/italia/onto/l0/Description"/>
        <owl:disjointWith rdf:resource="https://w3id.org/italia/onto/l0/EventOrSituation"/>
        <rdfs:comment xml:lang="en">Any agentive Object , either physical (e.g. a person, a robot, an oak), or social (e.g. a corporation, an institution, a community).</rdfs:comment>
        <rdfs:comment xml:lang="it">Un agente, sia fisico (ex. una persona, un robot, una quercia), o sociale (ex. una società, un&apos;istituzione, una comunità).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/italia/onto/l0"/>
