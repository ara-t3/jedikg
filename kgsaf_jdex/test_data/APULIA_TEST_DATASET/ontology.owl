        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/SM/Telephone"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/SM/TelephoneType"/>
        <rdfs:comment xml:lang="it">Questa proprietà lega un telefono al suo tipo (voce, fax).</rdfs:comment>
        <rdfs:comment xml:lang="en">This property links the Telephone to its type (voice, fax)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/italia/onto/SM"/>
