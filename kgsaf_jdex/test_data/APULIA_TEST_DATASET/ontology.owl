        <rdfs:range rdf:resource="https://w3id.org/italia/onto/SM/Review"/>
        <rdfs:comment xml:lang="en">Property that links a thing of the modelled domain to a review</rdfs:comment>
        <rdfs:comment xml:lang="it">Proprietà che collega qualsiasi cosa del dominio modellato a una recensione</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/italia/onto/SM"/>
        <rdfs:label xml:lang="it">ha recensione</rdfs:label>
        <rdfs:label xml:lang="en">has review</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


