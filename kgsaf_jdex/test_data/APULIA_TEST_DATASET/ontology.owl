        <rdfs:isDefinedBy rdf:resource="https://w3id.org/italia/onto/SM"/>
        <rdfs:label xml:lang="en">is email of</rdfs:label>
        <rdfs:label xml:lang="it">è email di</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/italia/onto/SM/isEmailTypeOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/italia/onto/SM/isEmailTypeOf">
        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/SM/EmailType"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/SM/Email"/>
        <rdfs:comment xml:lang="en">Inverse property of has email type. Hence, this property links an email type to an email.</rdfs:comment>
        <rdfs:comment xml:lang="it">Proprietà inversa di &apos;ha tipo di email&apos;. Di conseguenza, questa proprietà collega un individuo della classe &apos;Tipo di email&apos; ad un individuo della classe &apos;Email&apos;.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/italia/onto/SM"/>
        <rdfs:label xml:lang="en">is email type of</rdfs:label>
        <rdfs:label xml:lang="it">è tipo di email di</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/italia/onto/SM/isImageOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/italia/onto/SM/isImageOf">
