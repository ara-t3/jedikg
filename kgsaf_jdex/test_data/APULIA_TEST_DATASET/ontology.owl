        <rdfs:label xml:lang="it">Anno</rdfs:label>
        <rdfs:label xml:lang="en">Year</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/onto/l0/Activity -->

    <owl:Class rdf:about="https://w3id.org/italia/onto/l0/Activity">
