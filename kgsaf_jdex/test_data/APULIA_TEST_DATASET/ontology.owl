    <!-- https://w3id.org/italia/data/distribution/MUAPIT-JSON-LD -->

    <owl:NamedIndividual rdf:about="https://w3id.org/italia/data/distribution/MUAPIT-JSON-LD">
        <rdf:type rdf:resource="https://w3id.org/italia/onto/ADMS/SemanticAssetDistribution"/>
