        <rdfs:domain rdf:resource="https://w3id.org/italia/onto/l0/Sequence"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/l0/Entity"/>
        <rdfs:comment xml:lang="it">La object property che permette di rappresentare il primo membro di una sequenza.</rdfs:comment>
        <rdfs:comment xml:lang="en">The object property that enables to represent the first member of a sequence.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/italia/onto/l0"/>
        <rdfs:label xml:lang="en">has first member</rdfs:label>
        <rdfs:label xml:lang="it">primo membro</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:ObjectProperty>
    


