        <rdfs:label xml:lang="it">ha immagine</rdfs:label>
        <rdfs:label xml:lang="en">has image</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/italia/onto/SM/hasOnlineContactPoint -->

    <owl:ObjectProperty rdf:about="https://w3id.org/italia/onto/SM/hasOnlineContactPoint">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/SM/hasContactPoint"/>
        <owl:inverseOf rdf:resource="https://w3id.org/italia/onto/SM/isOnlineContactPointOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/SM/OnlineContactPoint"/>
