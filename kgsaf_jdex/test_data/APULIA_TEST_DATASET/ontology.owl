        <rdfs:comment xml:lang="en">This property represents the telephone number</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/italia/onto/SM"/>
        <rdfs:label xml:lang="it">numero di telefono</rdfs:label>
        <rdfs:label xml:lang="en">telephone number</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/italia/onto/SM/userAccountName -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/italia/onto/SM/userAccountName">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/italia/onto/l0/name"/>
