        <rdfs:comment xml:lang="en">The name associated with a social media entity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/italia/onto/SM"/>
        <rdfs:label xml:lang="it">nome di social media</rdfs:label>
        <rdfs:label xml:lang="en">social media name</rdfs:label>
    </owl:DatatypeProperty>
    


