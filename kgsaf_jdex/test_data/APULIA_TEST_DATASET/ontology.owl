    <owl:ObjectProperty rdf:about="https://w3id.org/italia/onto/SM/hasWebSite">
        <owl:inverseOf rdf:resource="https://w3id.org/italia/onto/SM/isWebSiteOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/italia/onto/SM/WebSite"/>
        <rdfs:comment xml:lang="en">Relation between anything and its web site.</rdfs:comment>
        <rdfs:comment xml:lang="it">Relazione tra una qualsiasi entità e la sua pagina Web.</rdfs:comment>
