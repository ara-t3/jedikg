        <rdfs:label xml:lang="en">Temporal entity</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/onto/TI/TimeIndexedEvent -->

    <owl:Class rdf:about="https://w3id.org/italia/onto/TI/TimeIndexedEvent">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Entity"/>
