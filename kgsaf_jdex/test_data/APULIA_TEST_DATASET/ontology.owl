        <rdfs:label xml:lang="en">Day of the Week</rdfs:label>
        <rdfs:label xml:lang="it">Giorno della settimana</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/onto/TI/Duration -->

