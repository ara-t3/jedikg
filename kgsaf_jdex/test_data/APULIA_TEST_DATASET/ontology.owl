        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/italia/onto/TI/date -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/italia/onto/TI/date">
