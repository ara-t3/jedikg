        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="it">Questa proprietà rappresenta una valutazione dell&apos;utente espressa come 1,2,3,4,5 oppure ogni altro tipo di valutazione associata a una recensione.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property represents a user evaluation/rating expressed as 1,2,3,4,5 or any other type of rating associated with a review.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/italia/onto/SM"/>
        <rdfs:label xml:lang="en">user rating</rdfs:label>
        <rdfs:label xml:lang="it">valutazione utente</rdfs:label>
        <owl:versionInfo xml:lang="it">stabile</owl:versionInfo>
        <owl:versionInfo xml:lang="en">stable</owl:versionInfo>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/italia/onto/SM/worstUserRating -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/italia/onto/SM/worstUserRating">
