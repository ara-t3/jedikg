{
    "dataset_name": "DBPEDIA_100K_C_RON",
    "verbose": 1,
    "interactive_shell": true,

    "paths": {
        "schema": "./data/schemas/unpack/DBPEDIA-2026/materialized.owl",
        "data": "./data/facts/unpack/dbpedia100k.owl",
        "output": "./data/datasets/unpack"
    },

    "reasoning": {
        "java_8_home": "/Library/Java/JavaVirtualMachines/temurin-8.jdk/Contents/Home",
        "java_11_home": "/opt/homebrew/opt/openjdk@11/",
        "java_max_ram": 20,
  

        "materialization": {
            "enabled": false,
            "axioms": []
        },

        "realization": {
            "enabled": true
        },

        "modularization": {
            "enabled": true
        },

        "decomposition" : {
            "tbox" : true,
            "rbox" : true
        },

        "consistency" : {
            "convert_ntriples" : false
        }
    },

    "split": {
        "enabled": true,
        "train_percent": 80,
        "validation_percent": 10,
        "test_percent": 10,
        "transductive": true,
        "test_leakage_filtering": {
            "enabled": true,
            "minimum_frequency": 0.97

        }
    },

    "post_processing": {
        "json_conversion": true,
        "id_mapping": true
    }
}