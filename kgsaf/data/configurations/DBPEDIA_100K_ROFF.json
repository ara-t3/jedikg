{
    "dataset_name": "DBPEDIA-100K-ROFF",
    "verbose": 1,

    "paths": {
        "schema": "./kgsaf_data/ontologies/unpack/DBPEDIA-2026/ontology.owl",
        "data": "./kgsaf_data/triples/dbpedia100k.owl",
        "output": "./kgsaf_data/datasets/unpack"
    },

    "reasoning": {
        "java_8_home": "/usr/lib/jvm/java-1.8.0-openjdk-amd64",
        "java_11_home": "/usr/lib/jvm/java-1.11.0-openjdk-amd64",
        "java_max_ram": 20,
        "filter_unsatisfiable": false,

        "materialization": {
            "enabled": false,
            "axioms": []
        },

        "realization": {
            "enabled": false
        },

        "modularization": {
            "enabled": true
        },

        "decomposition" : {
            "tbox" : true,
            "rbox" : true
        }
    },

    "split": {
        "enabled": true,
        "train_percent": 80,
        "validation_percent": 10,
        "test_percent": 10,
        "transductive": true,
        "test_leakage_filtering": {
            "enabled": true,
            "minimum_frequency": 0.97

        }
    },

    "post_processing": {
        "json_conversion": true,
        "id_mapping": true
    }
}