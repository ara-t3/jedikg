    <!-- http://dbpedia.org/ontology/BodyOfWater -->

    <owl:Class rdf:about="http://dbpedia.org/ontology/BodyOfWater">
        <owl:equivalentClass rdf:resource="http://schema.org/BodyOfWater"/>
        <rdfs:subClassOf rdf:resource="http://dbpedia.org/ontology/NaturalPlace"/>
        <rdfs:subClassOf rdf:resource="http://dbpedia.org/ontology/Place"/>
        <rdfs:comment xml:lang="el">Συγκεντρωμένες, συνήθως μεγάλες ποσότητες νερού (π.χ. ωκεανοί) που βρίσκονται στη Γη ή σε οποιονδήποτε άλλο πλανήτη. Ο όρος χρησιμοποιείται και για υδάτινους σχηματισμούς όπου υπάρχει κίνηση του νερού, όπως ποταμοί, ρεύματα ή κανάλια.</rdfs:comment>
        <rdfs:comment xml:lang="ur">مرکوز ، عام طور پر پانی کی بڑی مقدار (جیسے سمندر) جو زمین یا کسی دوسرے سیارے پر پائے جاتے ہیں۔ یہ اصطلاح آبی شکلوں کے لیے بھی استعمال ہوتی ہے جہاں پانی کی نقل و حرکت ہوتی ہے ، جیسے دریا ، نہریں یا نہریں</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://dbpedia.org/ontology/"/>
        <rdfs:label xml:lang="es">Cuerpo de agua</rdfs:label>
        <rdfs:label xml:lang="de">Gewässer</rdfs:label>
        <rdfs:label xml:lang="en">body of water</rdfs:label>
        <rdfs:label xml:lang="it">distesa d&apos;acqua</rdfs:label>
        <rdfs:label xml:lang="pt">extensão d’água</rdfs:label>
        <rdfs:label xml:lang="nl">watervlakte</rdfs:label>
        <rdfs:label xml:lang="fr">étendue d&apos;eau</rdfs:label>
        <rdfs:label xml:lang="el">ύδατα</rdfs:label>
        <rdfs:label xml:lang="ur">اجسامِ آب</rdfs:label>
        <rdfs:label xml:lang="ja">水域</rdfs:label>
        <rdfs:label xml:lang="ko">수역</rdfs:label>
        <ns1:describedby rdf:resource="http://dbpedia.org/ontology/data/definitions.ttl"/>
        <prov:wasDerivedFrom rdf:resource="http://mappings.dbpedia.org/index.php/OntologyClass:BodyOfWater"/>
