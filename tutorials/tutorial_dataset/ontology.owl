    </owl:Class>
    


    <!-- http://dbpedia.org/ontology/AdministrativeRegion -->

    <owl:Class rdf:about="http://dbpedia.org/ontology/AdministrativeRegion">
        <owl:equivalentClass rdf:resource="http://schema.org/AdministrativeArea"/>
        <owl:equivalentClass rdf:resource="http://www.wikidata.org/entity/Q3455524"/>
        <rdfs:subClassOf rdf:resource="http://dbpedia.org/ontology/Region"/>
        <rdfs:comment xml:lang="ur">(نتظامی علاقہ)انتظامی ادارے کے دائرہ اختیار میں ایک آبادی والی جگہ۔ یہ ادارہ یا تو ایک پورے علاقے یا ایک یا اس سے ملحقہ بستیوں کا انتظام کر سکتا ہے</rdfs:comment>
        <rdfs:comment xml:lang="en">A PopulatedPlace under the jurisdiction of an administrative body. This body may administer either a whole region or one or more adjacent Settlements (town administration)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://dbpedia.org/ontology/"/>
        <rdfs:label xml:lang="de">Verwaltungsregion</rdfs:label>
        <rdfs:label xml:lang="en">administrative region</rdfs:label>
        <rdfs:label xml:lang="nl">bestuurlijk gebied</rdfs:label>
        <rdfs:label xml:lang="it">regione amministrativa</rdfs:label>
        <rdfs:label xml:lang="gl">rexión administrativa</rdfs:label>
        <rdfs:label xml:lang="fr">région administrative</rdfs:label>
        <rdfs:label xml:lang="ga">réigiún riaracháin</rdfs:label>
        <rdfs:label xml:lang="el">διοικητική περιφέρεια</rdfs:label>
        <rdfs:label xml:lang="ur">انتظامی علاقہ</rdfs:label>
        <rdfs:label xml:lang="ja">行政区画</rdfs:label>
        <rdfs:label xml:lang="zh">行政區</rdfs:label>
        <rdfs:label xml:lang="ko">관리 지역</rdfs:label>
        <powder-s:describedby rdf:resource="http://dbpedia.org/ontology/data/definitions.ttl"/>
        <prov:wasDerivedFrom rdf:resource="http://mappings.dbpedia.org/index.php/OntologyClass:AdministrativeRegion"/>
    </owl:Class>
    


    <!-- http://dbpedia.org/ontology/AdultActor -->

    <owl:Class rdf:about="http://dbpedia.org/ontology/AdultActor">
        <owl:equivalentClass rdf:resource="http://www.wikidata.org/entity/Q488111"/>
        <rdfs:subClassOf rdf:resource="http://dbpedia.org/ontology/Actor"/>
        <rdfs:comment xml:lang="en">A pornographic actor or actress or a porn star is a person who performs sex acts in film, normally characterised as a pornographic film.</rdfs:comment>
        <rdfs:comment xml:lang="gl">Un actor ou unha actriz porno ou pornográfico/a, é un actor ou actriz de cine porno que actúa en películas de temática pornográfica..&amp;lt;ref&amp;gt;https://gl.wikipedia.org/wiki/Actor_pornogr%C3%A1fico&amp;lt;/ref&amp;gt;</rdfs:comment>
        <rdfs:comment xml:lang="ur">ایک فحش اداکار یا اداکارہ یا پورن سٹار وہ شخص ہوتا ہے جو فلم میں جنسی حرکتیں کرتا ہے، عام طور پر اسے فحش فلم کے طور پر دیکھا جاتا ہے۔</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://dbpedia.org/ontology/"/>
        <rdfs:label xml:lang="fr">acteur porno/acteur adulte</rdfs:label>
        <rdfs:label xml:lang="es">actor porno</rdfs:label>
        <rdfs:label xml:lang="gl">actor porno</rdfs:label>
        <rdfs:label xml:lang="en">adult (pornographic) actor</rdfs:label>
        <rdfs:label xml:lang="ga">aisteoir pornagrafaíochta</rdfs:label>
        <rdfs:label xml:lang="pl">aktor pornograficzny</rdfs:label>
        <rdfs:label xml:lang="pt">ator adulto</rdfs:label>
        <rdfs:label xml:lang="it">attore porno</rdfs:label>
        <rdfs:label xml:lang="nl">pornografisch acteur</rdfs:label>
        <rdfs:label xml:lang="de">pornographischer Schauspieler</rdfs:label>
        <rdfs:label xml:lang="el">ενήλικας (πορνογραφικός) ηθοποιός</rdfs:label>
        <rdfs:label xml:lang="ur">بالغ اداکار</rdfs:label>
        <rdfs:label xml:lang="ja">ポルノ女優</rdfs:label>
        <rdfs:label xml:lang="zh">色情演員</rdfs:label>
        <rdfs:label xml:lang="ko">성인 배우</rdfs:label>
        <powder-s:describedby rdf:resource="http://dbpedia.org/ontology/data/definitions.ttl"/>
        <prov:wasDerivedFrom rdf:resource="http://mappings.dbpedia.org/index.php/OntologyClass:AdultActor"/>
    </owl:Class>
    


    <!-- http://dbpedia.org/ontology/Agent -->

    <owl:Class rdf:about="http://dbpedia.org/ontology/Agent">
        <owl:equivalentClass rdf:resource="http://www.wikidata.org/entity/Q24229398"/>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <owl:disjointWith rdf:resource="http://dbpedia.org/ontology/Place"/>
        <rdfs:comment xml:lang="en">Analogous to a foaf:Agent, an agent is an entity that acts. This is intended to be the super class of Person and Organisation.</rdfs:comment>
        <rdfs:comment xml:lang="gl">Análogo a foaf:Agent, un axente é unha entidade que actúa. Destínase a ser a super clase de Persoa e Organización.</rdfs:comment>
        <rdfs:comment xml:lang="fr">Equivaut à foaf:Agent, un agent est une entité qui agit. C&apos;est supposé être la super classe de Person et de Organisation.</rdfs:comment>
        <rdfs:comment xml:lang="el">Ανάλογα με την κλάση foaf:Agent, ένας πράκτορας είναι μια οντότητα που ενεργεί. Αυτό προορίζεται να είναι μια υπερκλάση της κλάσης Άτόμο και Οργανισμός.</rdfs:comment>
        <rdfs:comment xml:lang="ur">ایک (ایجنٹ) ایک ایسا ادارہ ہے جو کام کرتا ہے۔ اس کا مقصد شخص اور تنظیم کا فوق درجہ ہونا ہے ۔</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://dbpedia.org/ontology/"/>
        <rdfs:label xml:lang="de">Agent</rdfs:label>
        <rdfs:label xml:lang="da">agent</rdfs:label>
        <rdfs:label xml:lang="en">agent</rdfs:label>
        <rdfs:label xml:lang="fr">agent</rdfs:label>
        <rdfs:label xml:lang="nl">agent</rdfs:label>
        <rdfs:label xml:lang="es">agente</rdfs:label>
        <rdfs:label xml:lang="it">agente</rdfs:label>
        <rdfs:label xml:lang="gl">axente</rdfs:label>
        <rdfs:label xml:lang="ga">gníomhaire</rdfs:label>
        <rdfs:label xml:lang="el">πράκτορας</rdfs:label>
        <rdfs:label xml:lang="ur">نمائندہ</rdfs:label>
        <rdfs:label xml:lang="ja">エージェント</rdfs:label>
        <rdfs:label xml:lang="ko">에이전트</rdfs:label>
