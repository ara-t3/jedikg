        <rdfs:label xml:lang="es">director deportivo</rdfs:label>
        <rdfs:label xml:lang="nl">sportbestuurder</rdfs:label>
        <rdfs:label xml:lang="en">sports manager</rdfs:label>
        <rdfs:label xml:lang="el">αθλητικός μάνατζερ</rdfs:label>
        <rdfs:label xml:lang="ur">کھیلوں کا منتظم</rdfs:label>
        <powder-s:describedby rdf:resource="http://dbpedia.org/ontology/data/definitions.ttl"/>
