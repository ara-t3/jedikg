    <!-- http://dbpedia.org/ontology/BiologicalDatabase -->

    <owl:Class rdf:about="http://dbpedia.org/ontology/BiologicalDatabase">
        <rdfs:subClassOf rdf:resource="http://dbpedia.org/ontology/Database"/>
        <rdfs:comment xml:lang="el">Διάφορες βάσεις δεδομένων οι οποίες περιέχουν πληροφορίες που ταυτοποιούν τα βασικά βιολογικά χαρακτηριστικά των οργανισμών. Οι πληροφορίες αυτές συγκροτούνται σε σύνολα βιβλιοθηκών των βασικών δομών των κυττάρων των οργανισμών, όπως οι βιλβιοθήκες νουκλεϊνικών οξέων (genomics) και πρωτεϊνών (proteomics).</rdfs:comment>
        <rdfs:comment xml:lang="ur">حیاتیات کی بنیادی حیاتیاتی خصوصیات کی نشاندہی کرنے والی معلومات پر مشتمل مختلف ڈیٹا بیس۔ یہ معلومات حیاتیات کے خلیات کے بنیادی ڈھانچے کی لائبریریوں کے سیٹوں میں مرتب کی جاتی ہیں، جیسے کہ نیوکلک ایسڈ (جینومکس) اور پروٹین (پروٹومکس) کی لائبریریاں۔</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://dbpedia.org/ontology/"/>
        <rdfs:label xml:lang="pt">Banco de dados biológico</rdfs:label>
        <rdfs:label xml:lang="fr">Base de données biologiques</rdfs:label>
        <rdfs:label xml:lang="en">Biological database</rdfs:label>
        <rdfs:label xml:lang="de">Biologische Datenbank</rdfs:label>
        <rdfs:label xml:lang="nl">biologische databank</rdfs:label>
        <rdfs:label xml:lang="it">database biologico</rdfs:label>
        <rdfs:label xml:lang="el">Βάση Δεδομένων Βιολογικών Χαρακτηριστικών</rdfs:label>
        <rdfs:label xml:lang="ur">حیاتیاتی ریکارڈرز_پر_مبنی_ایک_فائل</rdfs:label>
        <rdfs:label xml:lang="ja">バイオデータベース</rdfs:label>
        <rdfs:label xml:lang="ko">생물학 데이터베이스</rdfs:label>
        <powder-s:describedby rdf:resource="http://dbpedia.org/ontology/data/definitions.ttl"/>
        <prov:wasDerivedFrom rdf:resource="http://mappings.dbpedia.org/index.php/OntologyClass:BiologicalDatabase"/>
    </owl:Class>
    


