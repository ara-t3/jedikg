        <rdfs:label xml:lang="en">instrumentalist</rdfs:label>
        <rdfs:label xml:lang="nl">instrumentalist</rdfs:label>
        <rdfs:label xml:lang="fr">instrumentiste</rdfs:label>
        <rdfs:label xml:lang="ga">ionstraimí</rdfs:label>
        <rdfs:label xml:lang="el">μουσικός</rdfs:label>
        <rdfs:label xml:lang="ur">سازندہ</rdfs:label>
        <rdfs:label xml:lang="ja">音楽家</rdfs:label>
        <powder-s:describedby rdf:resource="http://dbpedia.org/ontology/data/definitions.ttl"/>
        <prov:wasDerivedFrom rdf:resource="http://mappings.dbpedia.org/index.php/OntologyClass:Instrumentalist"/>
    </owl:Class>
    


