    <!-- http://dbpedia.org/ontology/BusinessPerson -->

    <owl:Class rdf:about="http://dbpedia.org/ontology/BusinessPerson">
        <rdfs:subClassOf rdf:resource="http://dbpedia.org/ontology/Person"/>
        <rdfs:comment xml:lang="fr">Le terme entrepreneur désigne principalement une personne qui occupe un poste supérieur, tel qu&apos;un cadre.</rdfs:comment>
        <rdfs:comment xml:lang="en">The term entrepreneur mainly means someone who holds a senior position, such as an executive.</rdfs:comment>
        <rdfs:comment xml:lang="el">Με τον όρο επιχειρηματίας νοείται κυρίως κάποιος που κατέχει μία ανώτερη θέση, όπως ένα στέλεχος.</rdfs:comment>
        <rdfs:comment xml:lang="ur">اصطلاح کاروباری کا بنیادی طور پر مطلب وہ شخص ہے جو اعلی عہدے پر فائز ہو ، جیسے ایگزیکٹو۔</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://dbpedia.org/ontology/"/>
        <rdfs:label xml:lang="de">Unternehmer</rdfs:label>
        <rdfs:label xml:lang="en">businessperson</rdfs:label>
        <rdfs:label xml:lang="ga">duine den lucht gnó</rdfs:label>
        <rdfs:label xml:lang="fr">homme d&apos;affaires</rdfs:label>
        <rdfs:label xml:lang="it">imprenditore</rdfs:label>
        <rdfs:label xml:lang="nl">ondernemer</rdfs:label>
        <rdfs:label xml:lang="el">επιχειρηματίας</rdfs:label>
        <rdfs:label xml:lang="ur">کاروباری شخص</rdfs:label>
        <powder-s:describedby rdf:resource="http://dbpedia.org/ontology/data/definitions.ttl"/>
        <prov:wasDerivedFrom rdf:resource="http://mappings.dbpedia.org/index.php/OntologyClass:BusinessPerson"/>
    </owl:Class>
    


    <!-- http://dbpedia.org/ontology/Camera -->

    <owl:Class rdf:about="http://dbpedia.org/ontology/Camera">
        <rdfs:subClassOf rdf:resource="http://dbpedia.org/ontology/Device"/>
        <rdfs:comment xml:lang="it">Una fotocamera (in lingua italiana nota tradizionalmente come macchina fotografica) è uno strumento utilizzato per la ripresa fotografica e per ottenere immagini di oggetti reali stampabili su supporti materiali cartacei o archiviabili su supporti elettronici.</rdfs:comment>
        <rdfs:comment xml:lang="el">Φωτογραφική μηχανή ονομάζεται η συσκευή που χρησιμοποιείται για τη λήψη φωτογραφιών.Οι ευρύτερα χρησιμοποιούμενες σήμερα φωτογραφικές μηχανές, ερασιτεχνικής ή επαγγελματικής χρήσης, διακρίνονται σε δύο βασικές κατηγορίες: τις συμπαγείς και στις μονοοπτικές ρεφλέξ. Διακρινόμενες, ανάλογα με την τεχνολογία τους,είναι οι κλασικές φωτογραφικές μηχανές με φιλμ και οι ψηφιακές φωτογραφικές μηχανές.</rdfs:comment>
        <rdfs:comment xml:lang="ur">ایک کیمرہ (اطالوی میں روایتی طور پر کیمرے کے نام سے جانا جاتا ہے) ایک ایسا آلہ ہے جو فوٹو گرافی کی شوٹنگ اور حقیقی اشیاء کی تصاویر حاصل کرنے کے لیے استعمال کیا جاتا ہے جو کاغذ پر چھپ سکتی ہیں یا الیکٹرانک میڈیا پر محفوظ کی جا سکتی ہیں۔</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://dbpedia.org/ontology/"/>
        <rdfs:label xml:lang="de">Kamera</rdfs:label>
        <rdfs:label xml:lang="fr">appareil photographique</rdfs:label>
        <rdfs:label xml:lang="en">camera</rdfs:label>
        <rdfs:label xml:lang="nl">camera</rdfs:label>
        <rdfs:label xml:lang="ga">ceamara</rdfs:label>
        <rdfs:label xml:lang="it">fotocamera</rdfs:label>
        <rdfs:label xml:lang="el">φωτογραφική μηχανή</rdfs:label>
        <rdfs:label xml:lang="ur">تصویر کھینچنے کا آلہ</rdfs:label>
        <rdfs:label xml:lang="ja">カメラ</rdfs:label>
        <rdfs:label xml:lang="ko">카메라</rdfs:label>
        <powder-s:describedby rdf:resource="http://dbpedia.org/ontology/data/definitions.ttl"/>
        <prov:wasDerivedFrom rdf:resource="http://mappings.dbpedia.org/index.php/OntologyClass:Camera"/>
    </owl:Class>
    


    <!-- http://dbpedia.org/ontology/CanadianFootballLeague -->

    <owl:Class rdf:about="http://dbpedia.org/ontology/CanadianFootballLeague">
        <rdfs:subClassOf rdf:resource="http://dbpedia.org/ontology/SportsLeague"/>
        <rdfs:comment xml:lang="en">A group of sports teams that compete against each other in canadian football league.</rdfs:comment>
        <rdfs:comment xml:lang="el">ένα σύνολο αθλητικών ομάδων που ανταγωνίζονται μεταξύ τους στην Καναδική ένωση ποδοσφαίρου</rdfs:comment>
        <rdfs:comment xml:lang="ur">کھیلوں کی ٹیموں کا ایک گروپ جو کینیڈین فٹ بال لیگ میں ایک دوسرے کے خلاف مقابلہ کرتے ہیں۔.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://dbpedia.org/ontology/"/>
        <rdfs:label xml:lang="de">Kanadische Footballliga</rdfs:label>
        <rdfs:label xml:lang="nl">canadian football competitie</rdfs:label>
        <rdfs:label xml:lang="it">lega di football canadese</rdfs:label>
        <rdfs:label xml:lang="en">liga de fútbol canadiense</rdfs:label>
        <rdfs:label xml:lang="fr">ligue de football canadien</rdfs:label>
        <rdfs:label xml:lang="el">καναδική ένωση ποδοσφαίρου</rdfs:label>
        <rdfs:label xml:lang="ur">کینیڈین فٹ بال لیگ</rdfs:label>
        <rdfs:label xml:lang="ja">カナディアン・フットボール・リーグ</rdfs:label>
        <rdfs:label xml:lang="ko">캐나다 풋볼 리그</rdfs:label>
        <powder-s:describedby rdf:resource="http://dbpedia.org/ontology/data/definitions.ttl"/>
        <prov:wasDerivedFrom rdf:resource="http://mappings.dbpedia.org/index.php/OntologyClass:CanadianFootballLeague"/>
    </owl:Class>
    


