        <rdfs:label xml:lang="en">single</rdfs:label>
        <rdfs:label xml:lang="fr">single</rdfs:label>
        <rdfs:label xml:lang="nl">single</rdfs:label>
        <rdfs:label xml:lang="ur">اکیلا</rdfs:label>
        <rdfs:label xml:lang="ja">シングル</rdfs:label>
        <rdfs:label xml:lang="ko">싱글</rdfs:label>
        <powder-s:describedby rdf:resource="http://dbpedia.org/ontology/data/definitions.ttl"/>
        <prov:wasDerivedFrom rdf:resource="http://mappings.dbpedia.org/index.php/OntologyClass:Single"/>
