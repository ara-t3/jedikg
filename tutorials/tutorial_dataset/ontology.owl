    <!-- http://dbpedia.org/ontology/broadcastRepeater -->

    <owl:DatatypeProperty rdf:about="http://dbpedia.org/ontology/broadcastRepeater">
        <rdfs:domain rdf:resource="http://dbpedia.org/ontology/Broadcaster"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">A repeater is an electronic device that receives a signal and retransmits it at a higher level and/or higher power, or onto the other side of an obstruction, so that the signal can cover longer distances (http://en.wikipedia.org/wiki/Repeater).</rdfs:comment>
        <rdfs:comment xml:lang="fr">Un répéteur est un équipement électronique qui reçoit un signal et le retransmet avec un niveau supérieur et/ou à une puissance plus grande, ou après un obstacle de sorte à ce que le signal puisse couvrir des distances plus grandes  (https://fr.wikipedia.org/wiki/Répéteur).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://dbpedia.org/ontology/"/>
        <rdfs:label xml:lang="en">broadcast repeater</rdfs:label>
        <rdfs:label xml:lang="fr">répéteur de diffusion</rdfs:label>
        <rdfs:label xml:lang="el">επαναληπτική αναμετάδοση</rdfs:label>
