    <!-- http://dbpedia.org/ontology/Arrondissement -->

    <owl:Class rdf:about="http://dbpedia.org/ontology/Arrondissement">
        <rdfs:subClassOf rdf:resource="http://dbpedia.org/ontology/GovernmentalAdministrativeRegion"/>
        <rdfs:comment xml:lang="en">An administrative (France) or lawcourts (Netherlands) body governing a territorial unity on the intermediate level, between local and national level</rdfs:comment>
        <rdfs:comment xml:lang="de">Das Wort Arrondissement dient zur Bezeichnung verschiedener Verwaltungsbezirke in Frankreich, Belgien, Kanada und anderen Ländern</rdfs:comment>
        <rdfs:comment xml:lang="ur">ایک انتظامی (فرانس) یا قانون کی عدالتیں (نیدرلینڈز) جو کہ علاقائی وحدت پر مقامی اور قومی سطح کے درمیان حکمرانی کرتی ہیں</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://dbpedia.org/ontology/"/>
        <rdfs:label xml:lang="de">arrondissement</rdfs:label>
        <rdfs:label xml:lang="en">arrondissement</rdfs:label>
        <rdfs:label xml:lang="fr">arrondissement</rdfs:label>
        <rdfs:label xml:lang="nl">arrondissement</rdfs:label>
        <rdfs:label xml:lang="ur">فرانس کا انتظامی ضلع</rdfs:label>
        <rdfs:label xml:lang="ja">フランスの群</rdfs:label>
        <powder-s:describedby rdf:resource="http://dbpedia.org/ontology/data/definitions.ttl"/>
        <prov:wasDerivedFrom rdf:resource="http://mappings.dbpedia.org/index.php/OntologyClass:Arrondissement"/>
    </owl:Class>
    


