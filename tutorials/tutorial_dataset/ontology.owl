    <!-- http://dbpedia.org/ontology/Play -->

    <owl:Class rdf:about="http://dbpedia.org/ontology/Play">
        <owl:equivalentClass rdf:resource="http://www.wikidata.org/entity/Q25379"/>
        <rdfs:subClassOf rdf:resource="http://dbpedia.org/ontology/WrittenWork"/>
        <rdfs:comment xml:lang="en">A play is a form of literature written by a playwright, usually consisting of scripted dialogue between characters, intended for theatrical performance rather than just reading.</rdfs:comment>
        <rdfs:comment xml:lang="el">Ένα παιχνίδι είναι μια μορφή της λογοτεχνίας, γραμμένο από έναν συγγραφέα, που συνήθως αποτελείται από σενάριο του διαλόγου μεταξύ των χαρακτήρων, που προορίζεται για την θεατρική παράσταση και όχι μόνο ανάγνωση.</rdfs:comment>
        <rdfs:comment xml:lang="ur">ڈرامہ ادب کی ایک شکل ہے جسے ڈرامہ نگار نے لکھا ہے، عام طور پر کرداروں کے درمیان تحریری مکالمے پر مشتمل ہوتا ہے، جس کا مقصد صرف پڑھنے کے بجائے تھیٹر کی کارکردگی کے لیے ہوتا ہے۔</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://dbpedia.org/ontology/"/>
        <rdfs:label xml:lang="de">Theaterstück</rdfs:label>
        <rdfs:label xml:lang="ga">dráma</rdfs:label>
        <rdfs:label xml:lang="es">obra de teatro</rdfs:label>
        <rdfs:label xml:lang="fr">pièce de théâtre</rdfs:label>
        <rdfs:label xml:lang="en">play</rdfs:label>
        <rdfs:label xml:lang="nl">toneelstuk</rdfs:label>
        <rdfs:label xml:lang="el">παιχνίδι</rdfs:label>
        <rdfs:label xml:lang="ur">تماشہ</rdfs:label>
        <rdfs:label xml:lang="ja">戯曲</rdfs:label>
        <powder-s:describedby rdf:resource="http://dbpedia.org/ontology/data/definitions.ttl"/>
        <prov:wasDerivedFrom rdf:resource="http://mappings.dbpedia.org/index.php/OntologyClass:Play"/>
    </owl:Class>
    


