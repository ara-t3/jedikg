    <!-- http://dbpedia.org/ontology/Altitude -->

    <owl:Class rdf:about="http://dbpedia.org/ontology/Altitude">
        <owl:equivalentClass rdf:resource="http://www.wikidata.org/entity/Q190200"/>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="gl">A altitude é a distancia vertical dun obxecto respecto dun punto de orixe dado, considerado como o nivel cero, para o que se adoita tomar o nivel absoluto do mar.&amp;lt;ref&amp;gt;https://gl.wikipedia.org/wiki/Altitude&amp;lt;/ref&amp;gt;</rdfs:comment>
        <rdfs:comment xml:lang="el">Το υψόμετρο είναι η κάθετη απόσταση ενός αντικειμένου σε σχέση με ένα καθορισμένο επίπεδο αναφοράς. Συνήθως το υψόμετρο μετριέται ως η κάθετη απόσταση (υψομετρική διαφορά) ενός τόπου από το επίπεδο της θάλασσας (Μέση Στάθμη Θάλασσας), ενώ για πιο ακριβείς μετρήσεις χρησιμοποιείται το γεωειδές.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://dbpedia.org/ontology/"/>
        <rdfs:label xml:lang="de">Höhe</rdfs:label>
        <rdfs:label xml:lang="ga">airde</rdfs:label>
        <rdfs:label xml:lang="en">altitude</rdfs:label>
        <rdfs:label xml:lang="fr">altitude</rdfs:label>
        <rdfs:label xml:lang="gl">altitude</rdfs:label>
        <rdfs:label xml:lang="nl">hoogte</rdfs:label>
        <rdfs:label xml:lang="da">højde</rdfs:label>
        <rdfs:label xml:lang="el">υψόμετρο</rdfs:label>
        <rdfs:label xml:lang="ur">اونچائی</rdfs:label>
        <rdfs:label xml:lang="ja">高度</rdfs:label>
        <powder-s:describedby rdf:resource="http://dbpedia.org/ontology/data/definitions.ttl"/>
        <prov:wasDerivedFrom rdf:resource="http://mappings.dbpedia.org/index.php/OntologyClass:Altitude"/>
    </owl:Class>
    


