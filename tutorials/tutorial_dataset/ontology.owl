        <powder-s:describedby rdf:resource="http://dbpedia.org/ontology/data/definitions.ttl"/>
        <prov:wasDerivedFrom rdf:resource="http://mappings.dbpedia.org/index.php/OntologyProperty:academyAward"/>
    </owl:ObjectProperty>
    


