    <!-- http://dbpedia.org/ontology/GolfCourse -->

    <owl:Class rdf:about="http://dbpedia.org/ontology/GolfCourse">
        <owl:equivalentClass rdf:resource="http://www.wikidata.org/entity/Q1048525"/>
        <rdfs:subClassOf rdf:resource="http://dbpedia.org/ontology/SportFacility"/>
        <rdfs:comment xml:lang="fr">Dans un parcours de golf, les trous comportent souvent des dangers, définis comme des zones spéciales auxquelles s&apos;appliquent des règles de jeu supplémentaires.</rdfs:comment>
        <rdfs:comment xml:lang="en">In a golf course, holes often carry hazards, defined as special areas to which additional rules of the game apply.</rdfs:comment>
        <rdfs:comment xml:lang="el">Σε ένα γήπεδο γκολφ οι τρύπες συχνά κρύβουν κινδύνους, που ορίζονται ως ειδικές περιοχές για τις οποίες ισχύουν επιπρόσθετοι κανόνες διεξαγωγής του παιχνιδιού.</rdfs:comment>
        <rdfs:comment xml:lang="ur">زمین کا ایک علاقہ جس میں گولف کے لیے 9 یا 18 سوراخ ہوتے ہیں جن میں سے ہر ایک میں ٹی ، فیئر وے ، اور سبز اور اکثر ایک یا زیادہ قدرتی یا مصنوعی خطرات شامل ہیں۔ - جسے گولف لنکس بھی کہا جاتا ہے۔</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://dbpedia.org/ontology/"/>
        <rdfs:label xml:lang="de">Golfplatz</rdfs:label>
        <rdfs:label xml:lang="it">campo da golf</rdfs:label>
        <rdfs:label xml:lang="ga">cúrsa gailf</rdfs:label>
        <rdfs:label xml:lang="en">golf course</rdfs:label>
        <rdfs:label xml:lang="nl">golfbaan</rdfs:label>
        <rdfs:label xml:lang="fr">terrain de golf</rdfs:label>
        <rdfs:label xml:lang="el">γήπεδο γκολφ</rdfs:label>
        <rdfs:label xml:lang="ur">گالف کا میدان</rdfs:label>
        <powder-s:describedby rdf:resource="http://dbpedia.org/ontology/data/definitions.ttl"/>
        <prov:wasDerivedFrom rdf:resource="http://mappings.dbpedia.org/index.php/OntologyClass:GolfCourse"/>
    </owl:Class>
    


