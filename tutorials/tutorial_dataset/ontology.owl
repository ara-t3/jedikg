        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <owl:disjointWith rdf:resource="http://dbpedia.org/ontology/wgs84_pos:SpatialThing"/>
        <rdfs:comment xml:lang="fr">Elément sur lequel on a passé du temps pour le réaliser. L&apos;acteur peut être humain (homme) ou pas (machine, insectes, nature, ...)</rdfs:comment>
        <rdfs:comment xml:lang="en">Item on which time has been spent for its realisation. Actor can be a human on not (machine, insects, nature...)</rdfs:comment>
        <rdfs:comment xml:lang="ur">وہ شے جس پر اس کی تکمیل کے لیے وقت صرف کیا گیا ہو۔ اداکار انسان نہیں ہو سکتا (مشین، کیڑے، فطرت</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://dbpedia.org/ontology/"/>
        <rdfs:label xml:lang="de">Werk</rdfs:label>
        <rdfs:label xml:lang="da">arbejde</rdfs:label>
        <rdfs:label xml:lang="ga">obair</rdfs:label>
        <rdfs:label xml:lang="pt">obra</rdfs:label>
        <rdfs:label xml:lang="nl">werk</rdfs:label>
        <rdfs:label xml:lang="en">work</rdfs:label>
        <rdfs:label xml:lang="fr">œuvre</rdfs:label>
        <rdfs:label xml:lang="el">δημιουργία</rdfs:label>
        <rdfs:label xml:lang="ur">کام</rdfs:label>
        <rdfs:label xml:lang="ja">仕事</rdfs:label>
        <powder-s:describedby rdf:resource="http://dbpedia.org/ontology/data/definitions.ttl"/>
        <prov:wasDerivedFrom rdf:resource="http://mappings.dbpedia.org/index.php/OntologyClass:Work"/>
    </owl:Class>
    


