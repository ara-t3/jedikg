        <rdfs:isDefinedBy rdf:resource="http://dbpedia.org/ontology/"/>
        <rdfs:label xml:lang="de">Zitat</rdfs:label>
        <rdfs:label xml:lang="es">cita</rdfs:label>
        <rdfs:label xml:lang="fr">citation</rdfs:label>
        <rdfs:label xml:lang="en">quotation</rdfs:label>
