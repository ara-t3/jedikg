        <owl:disjointWith rdf:resource="http://dbpedia.org/ontology/Person"/>
        <owl:disjointWith rdf:resource="http://dbpedia.org/ontology/PrehistoricalPeriod"/>
        <rdfs:comment xml:lang="en">A historical Period should be linked to a Place by way of the property dct:spatial (already defined)</rdfs:comment>
        <rdfs:comment xml:lang="fr">Une période historique doit être liée à un lieu au moyen de la propriété dct:spatial (déjà définie)</rdfs:comment>
