        <owl:equivalentClass rdf:resource="http://www.wikidata.org/entity/Q206229"/>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="nl">Een molecuul wat van nature voorkomt in een organisme en gevormd kan worden door organismen.</rdfs:comment>
        <rdfs:comment xml:lang="en">equivalent to http://ccdb.ucsd.edu/NIF/BIRNLex-OBO-UBO.owl#birnlex_22.</rdfs:comment>
        <rdfs:comment xml:lang="el">Κάθε μόριο που παράγεται σε έναν ζωντανό οργανισμό. Συνήθως μεγαλομοριακές ενώσεις που χρησιμεύουν στην δομή και στο μεταβολισμό του κυττάρου. Πρωτεΐνες, νουκλεϊνικά οξέα, υδατάνθρακες και λιπίδια.</rdfs:comment>
        <rdfs:comment xml:lang="ur">ایسے پیچدہ نامیاتی مالیکیولز جو زندگی کی بنیاد ہیں یعنی وہ زندہ اجسام کو تعمیر کرنے ، ان کو نشوونما کرنے اور برقرار رکھنے کے لیے ضروری ہوتے ہیں</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://dbpedia.org/ontology/"/>
        <rdfs:label xml:lang="en">Biomolecule</rdfs:label>
        <rdfs:label xml:lang="nl">Biomolecuul</rdfs:label>
        <rdfs:label xml:lang="de">Biomolekül</rdfs:label>
        <rdfs:label xml:lang="it">biomolecola</rdfs:label>
        <rdfs:label xml:lang="fr">biomolécule</rdfs:label>
        <rdfs:label xml:lang="el">βιομόριο</rdfs:label>
        <rdfs:label xml:lang="ur">حیاتیاتی مرکبات</rdfs:label>
        <rdfs:label xml:lang="ja">生体物質</rdfs:label>
        <rdfs:label xml:lang="ko">생체 분자</rdfs:label>
        <powder-s:describedby rdf:resource="http://dbpedia.org/ontology/data/definitions.ttl"/>
        <prov:wasDerivedFrom rdf:resource="http://mappings.dbpedia.org/index.php/OntologyClass:Biomolecule"/>
    </owl:Class>
    


