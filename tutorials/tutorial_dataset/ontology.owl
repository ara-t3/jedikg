        <rdfs:label xml:lang="nl">bergpas</rdfs:label>
        <rdfs:label xml:lang="fr">col de montagne</rdfs:label>
        <rdfs:label xml:lang="pt">desfiladeiro</rdfs:label>
        <rdfs:label xml:lang="en">mountain pass</rdfs:label>
        <rdfs:label xml:lang="el">Πέρασμα βουνού</rdfs:label>
        <rdfs:label xml:lang="ur">درہ</rdfs:label>
        <rdfs:label xml:lang="ja">峠</rdfs:label>
        <powder-s:describedby rdf:resource="http://dbpedia.org/ontology/data/definitions.ttl"/>
        <prov:wasDerivedFrom rdf:resource="http://mappings.dbpedia.org/index.php/OntologyClass:MountainPass"/>
    </owl:Class>
    


    <!-- http://dbpedia.org/ontology/MountainRange -->

    <owl:Class rdf:about="http://dbpedia.org/ontology/MountainRange">
        <owl:equivalentClass rdf:resource="http://www.wikidata.org/entity/Q46831"/>
        <rdfs:subClassOf rdf:resource="http://dbpedia.org/ontology/NaturalPlace"/>
        <rdfs:comment xml:lang="en">a chain of mountains bordered by highlands or separated from other mountains by passes or valleys.</rdfs:comment>
        <rdfs:comment xml:lang="ur">پہاڑوں کی ایک زنجیر جو پہاڑوں سے متصل ہے یا دوسرے پہاڑوں سے راستوں یا وادیوں سے الگ ہے۔.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://dbpedia.org/ontology/"/>
        <rdfs:label xml:lang="de">Bergkette</rdfs:label>
        <rdfs:label xml:lang="nl">bergketen</rdfs:label>
        <rdfs:label xml:lang="pt">cadeia montanhosa</rdfs:label>
        <rdfs:label xml:lang="fr">chaîne de montagne</rdfs:label>
