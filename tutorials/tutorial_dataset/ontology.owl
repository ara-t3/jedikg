        <rdfs:label xml:lang="es">cervecería</rdfs:label>
        <rdfs:label xml:lang="el">ζυθοποιία</rdfs:label>
        <rdfs:label xml:lang="ur">کَشید گاہ</rdfs:label>
        <rdfs:label xml:lang="ja">ブルワリー</rdfs:label>
        <powder-s:describedby rdf:resource="http://dbpedia.org/ontology/data/definitions.ttl"/>
        <prov:wasDerivedFrom rdf:resource="http://mappings.dbpedia.org/index.php/OntologyClass:Brewery"/>
    </owl:Class>
    


    <!-- http://dbpedia.org/ontology/Bridge -->

    <owl:Class rdf:about="http://dbpedia.org/ontology/Bridge">
        <owl:equivalentClass rdf:resource="http://www.wikidata.org/entity/Q12280"/>
        <rdfs:subClassOf rdf:resource="http://dbpedia.org/ontology/RouteOfTransportation"/>
        <rdfs:comment xml:lang="en">A bridge is a structure built to span physical obstacles such as a body of water, valley, or road, for the purpose of providing passage over the obstacle (http://en.wikipedia.org/wiki/Bridge).</rdfs:comment>
        <rdfs:comment xml:lang="ur">ایک پل ایک ایسا ڈھانچہ ہے جو جسمانی رکاوٹوں جیسے پانی ، وادی یا سڑک کی راہ میں رکاوٹ کو عبور کرنے کے مقصد سے بنایا گیا ہے</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://dbpedia.org/ontology/"/>
        <rdfs:label xml:lang="de">Brücke</rdfs:label>
        <rdfs:label xml:lang="en">bridge</rdfs:label>
