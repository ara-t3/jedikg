        <rdfs:isDefinedBy rdf:resource="http://dbpedia.org/ontology/"/>
        <rdfs:label xml:lang="de">Künstler der klassischen Musik</rdfs:label>
        <rdfs:label xml:lang="nl">artiest klassieke muziek</rdfs:label>
        <rdfs:label xml:lang="fr">artiste de musique classique</rdfs:label>
        <rdfs:label xml:lang="ga">ceoltóir clasaiceach</rdfs:label>
        <rdfs:label xml:lang="en">classical music artist</rdfs:label>
        <rdfs:label xml:lang="el">καλλιτέχνης κλασικής μουσικής</rdfs:label>
        <rdfs:label xml:lang="ur">اعلی درجےکاموسیقی فنکار</rdfs:label>
        <powder-s:describedby rdf:resource="http://dbpedia.org/ontology/data/definitions.ttl"/>
        <prov:wasDerivedFrom rdf:resource="http://mappings.dbpedia.org/index.php/OntologyClass:ClassicalMusicArtist"/>
    </owl:Class>
    


