    <!-- http://dbpedia.org/ontology/HistoricalPeriod -->

    <owl:Class rdf:about="http://dbpedia.org/ontology/HistoricalPeriod">
        <owl:equivalentClass rdf:resource="http://www.wikidata.org/entity/Q11514315"/>
