        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="en">Color or colour is the visual perceptual property corresponding in humans to the categories called red, yellow, blue and others. Color derives from the spectrum of light (distribution of light energy versus wavelength) interacting in the eye with the spectral sensitivities of the light receptors.</rdfs:comment>
        <rdfs:comment xml:lang="ur">رنگ یا رنگ بصری ادراکی املاک ہے جو انسانوں میں سرخ ، پیلے ، نیلے اور دیگر نامی زمروں کے مطابق ہے۔ رنگ روشنی کے سپیکٹرم سے حاصل ہوتا ہے (روشنی کی تقسیم بمقابلہ طول موج) آنکھوں میں روشنی کے رسیپٹروں کی سپیکٹرمل حساسیت کے ساتھ تعامل کرتا ہے۔</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://dbpedia.org/ontology/"/>
        <rdfs:label xml:lang="de">Farbe</rdfs:label>
        <rdfs:label xml:lang="en">colour</rdfs:label>
        <rdfs:label xml:lang="pt">cor</rdfs:label>
        <rdfs:label xml:lang="fr">couleur</rdfs:label>
        <rdfs:label xml:lang="ga">dath</rdfs:label>
        <rdfs:label xml:lang="da">farve</rdfs:label>
        <rdfs:label xml:lang="nl">kleur</rdfs:label>
        <rdfs:label xml:lang="el">χρώμα</rdfs:label>
        <rdfs:label xml:lang="ur">رنگ</rdfs:label>
        <rdfs:label xml:lang="ja">色</rdfs:label>
        <rdfs:label xml:lang="ko">색</rdfs:label>
