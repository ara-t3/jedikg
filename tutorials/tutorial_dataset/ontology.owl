    <!-- http://dbpedia.org/ontology/Brain -->

    <owl:Class rdf:about="http://dbpedia.org/ontology/Brain">
        <rdfs:subClassOf rdf:resource="http://dbpedia.org/ontology/AnatomicalStructure"/>
        <rdfs:comment xml:lang="el">Το βασικό όργανο του νευρικού συστήματος των ζώων, το οποίο καθορίζει ασυνείδητες και συνειδητές λειτουργίες. Ο όρος χρησιμοποιείται πλέον και για τον χαρακτηρισμό των καθοριστικότερων στοιχείων μίας μηχανής ή ενός συνόλου πραγμάτων.</rdfs:comment>
        <rdfs:comment xml:lang="ur">جانوروں کے اعصابی نظام کا بنیادی عضو، جو لاشعوری اور شعوری افعال کا تعین کرتا ہے۔ یہ اصطلاح اب کسی مشین یا چیزوں کے سیٹ کے سب سے زیادہ متعین عناصر کو بیان کرنے کے لیے بھی استعمال ہوتی ہے۔</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://dbpedia.org/ontology/"/>
        <rdfs:label xml:lang="de">Gehirn</rdfs:label>
        <rdfs:label xml:lang="en">brain</rdfs:label>
        <rdfs:label xml:lang="es">cerebro</rdfs:label>
        <rdfs:label xml:lang="fr">cerveau</rdfs:label>
        <rdfs:label xml:lang="it">cervello</rdfs:label>
        <rdfs:label xml:lang="nl">hersenen</rdfs:label>
        <rdfs:label xml:lang="da">hjerne</rdfs:label>
        <rdfs:label xml:lang="ga">inchinn</rdfs:label>
        <rdfs:label xml:lang="el">εγκέφαλος</rdfs:label>
        <rdfs:label xml:lang="ur">دماغ</rdfs:label>
        <rdfs:label xml:lang="ja">脳</rdfs:label>
        <rdfs:label xml:lang="ko">뇌</rdfs:label>
        <powder-s:describedby rdf:resource="http://dbpedia.org/ontology/data/definitions.ttl"/>
        <prov:wasDerivedFrom rdf:resource="http://mappings.dbpedia.org/index.php/OntologyClass:Brain"/>
    </owl:Class>
    


    <!-- http://dbpedia.org/ontology/Brewery -->

    <owl:Class rdf:about="http://dbpedia.org/ontology/Brewery">
        <rdfs:subClassOf rdf:resource="http://dbpedia.org/ontology/Company"/>
        <rdfs:comment xml:lang="el">Ζυθοποιία ονομάζεται η βιομηχανία παρασκευής μπύρας.</rdfs:comment>
