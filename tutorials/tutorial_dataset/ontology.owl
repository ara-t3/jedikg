    <!-- http://dbpedia.org/ontology/CardinalDirection -->

    <owl:Class rdf:about="http://dbpedia.org/ontology/CardinalDirection">
        <rdfs:subClassOf rdf:resource="http://dbpedia.org/ontology/TopicalConcept"/>
        <rdfs:comment xml:lang="en">One of the four main directions on a compass or any other system to determine a geographical position</rdfs:comment>
        <rdfs:comment xml:lang="fr">Une des 4 principales directions d&apos;un compas ou  de tout autre système pour déterminer une position geographique</rdfs:comment>
        <rdfs:comment xml:lang="ur">جغرافیائی پوزیشن کا تعین کرنے کے لیے کمپاس یا کسی دوسرے نظام پر چار اہم سمتوں میں سے ایک</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://dbpedia.org/ontology/"/>
        <rdfs:label xml:lang="en">Cardinal direction</rdfs:label>
        <rdfs:label xml:lang="de">Windrichtung</rdfs:label>
        <rdfs:label xml:lang="fr">direction cardinale</rdfs:label>
        <rdfs:label xml:lang="nl">windrichting</rdfs:label>
        <rdfs:label xml:lang="ur">ہوا کی سمت</rdfs:label>
        <powder-s:describedby rdf:resource="http://dbpedia.org/ontology/data/definitions.ttl"/>
        <prov:wasDerivedFrom rdf:resource="http://mappings.dbpedia.org/index.php/OntologyClass:CardinalDirection"/>
    </owl:Class>
    


    <!-- http://dbpedia.org/ontology/CareerStation -->

    <owl:Class rdf:about="http://dbpedia.org/ontology/CareerStation">
