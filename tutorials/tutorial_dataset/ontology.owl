        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:comment xml:lang="ga">Is eard is uimhir adamhach (Z) adaimh ann ná líon na bprótón i núicléas an adaimh sin</rdfs:comment>
        <rdfs:comment xml:lang="de">die Anzahl der Protonen im Atomkern eines chemischen Elements, deshalb auch Protonenzahl.</rdfs:comment>
        <rdfs:comment xml:lang="nl">het atoomnummer of atoomgetal (symbool: Z) geeft het aantal protonen in de kern van een atoom aan.</rdfs:comment>
        <rdfs:comment xml:lang="pl">liczba określająca, ile protonów znajduje się w jądrze danego atomu</rdfs:comment>
        <rdfs:comment xml:lang="en">the ratio of the average mass of atoms of an element (from a single given sample or source) to 1⁄12 of the mass of an atom of carbon-12</rdfs:comment>
        <rdfs:comment xml:lang="ur">کسی عنصر کے ایٹموں کی اوسط کمیت کا تناسب (ایک دیے گئے نمونے یا ماخذ سے) کاربن 12 کے ایٹم کے بڑے پیمانے پر</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://dbpedia.org/ontology/"/>
        <rdfs:label xml:lang="de">Ordnungszahl</rdfs:label>
        <rdfs:label xml:lang="en">atomic number</rdfs:label>
        <rdfs:label xml:lang="nl">atoomnummer</rdfs:label>
        <rdfs:label xml:lang="pl">liczba atomowa</rdfs:label>
        <rdfs:label xml:lang="ga">uimhir adamhach</rdfs:label>
        <rdfs:label xml:lang="ur">جوہری عدد</rdfs:label>
        <powder-s:describedby rdf:resource="http://dbpedia.org/ontology/data/definitions.ttl"/>
        <prov:wasDerivedFrom rdf:resource="http://mappings.dbpedia.org/index.php/OntologyProperty:atomicNumber"/>
    </owl:DatatypeProperty>
    


    <!-- http://dbpedia.org/ontology/australiaOpenDouble -->

