    <!-- http://dbpedia.org/ontology/elementBlock -->

    <owl:DatatypeProperty rdf:about="http://dbpedia.org/ontology/elementBlock">
        <rdfs:domain rdf:resource="http://dbpedia.org/ontology/ChemicalElement"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">A block of the periodic table of elements is a set of adjacent groups.</rdfs:comment>
        <rdfs:comment xml:lang="de">Als Block im Periodensystem werden chemische Elemente nach den energiereichsten Atomorbitalen ihrer Elektronenhülle zusammengefasst.</rdfs:comment>
        <rdfs:comment xml:lang="ca">La taula periòdica dels elements es pot dividir en blocs d&apos;elements segons l&apos;orbital que estiguen ocupant els electrons més externs</rdfs:comment>
        <rdfs:comment xml:lang="ru">совокупность химических элементов со сходным расположением валентных электронов в атоме.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://dbpedia.org/ontology/"/>
        <rdfs:label xml:lang="de">Block des Periodensystems</rdfs:label>
        <rdfs:label xml:lang="ca">bloc de la taula periòdica</rdfs:label>
        <rdfs:label xml:lang="pl">blok układu okresowego</rdfs:label>
        <rdfs:label xml:lang="en">element block</rdfs:label>
        <rdfs:label xml:lang="ru">блок периодической таблицы</rdfs:label>
        <powder-s:describedby rdf:resource="http://dbpedia.org/ontology/data/definitions.ttl"/>
        <prov:wasDerivedFrom rdf:resource="http://mappings.dbpedia.org/index.php/OntologyProperty:elementBlock"/>
    </owl:DatatypeProperty>
    


    <!-- http://dbpedia.org/ontology/elementGroup -->

    <owl:DatatypeProperty rdf:about="http://dbpedia.org/ontology/elementGroup">
        <rdfs:domain rdf:resource="http://dbpedia.org/ontology/ChemicalElement"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:comment xml:lang="en">In chemistry, a group (also known as a family) is a column of elements in the periodic table of the chemical elements.</rdfs:comment>
        <rdfs:comment xml:lang="ga">Séard atá i gceist le grúpa sa choimhthéacs seo ná colún ceartingearach i dtábla peiriadach na ndúl ceimiceach.</rdfs:comment>
        <rdfs:comment xml:lang="ca">Un grup d&apos;elements equival a una columna de la taula periòdica.</rdfs:comment>
        <rdfs:comment xml:lang="de">Unter einer Gruppe des Periodensystems versteht man in der Chemie jede Spalte des Periodensystems.</rdfs:comment>
        <rdfs:comment xml:lang="pl">grupa jest pionową kolumną w układzie okresowym pierwiastków chemicznych.</rdfs:comment>
        <rdfs:comment xml:lang="ru">последовательность атомов по возрастанию заряда ядра, обладающих однотипным электронным строением.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://dbpedia.org/ontology/"/>
        <rdfs:label xml:lang="de">Gruppe des Periodensystems</rdfs:label>
        <rdfs:label xml:lang="en">element group</rdfs:label>
        <rdfs:label xml:lang="ca">grup de la taula periòdica</rdfs:label>
        <rdfs:label xml:lang="pl">grupa układu okresowego</rdfs:label>
        <rdfs:label xml:lang="ga">grúpa an tábla pheiriadaigh</rdfs:label>
        <rdfs:label xml:lang="ru">группа периодической системы</rdfs:label>
        <powder-s:describedby rdf:resource="http://dbpedia.org/ontology/data/definitions.ttl"/>
        <prov:wasDerivedFrom rdf:resource="http://mappings.dbpedia.org/index.php/OntologyProperty:elementGroup"/>
    </owl:DatatypeProperty>
    


    <!-- http://dbpedia.org/ontology/elementPeriod -->

    <owl:DatatypeProperty rdf:about="http://dbpedia.org/ontology/elementPeriod">
        <rdfs:domain rdf:resource="http://dbpedia.org/ontology/ChemicalElement"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:comment xml:lang="ca">En la taula periòdica dels elements, un període és una filera de la taula</rdfs:comment>
        <rdfs:comment xml:lang="en">In the periodic table of the elements, elements are arranged in a series of rows (or periods) so that those with similar properties appear in a column.</rdfs:comment>
        <rdfs:comment xml:lang="de">Unter einer Periode des Periodensystems versteht man in der Chemie jede Zeile des Periodensystems der Elemente.</rdfs:comment>
        <rdfs:comment xml:lang="ru">строка периодической системы химических элементов, последовательность атомов по возрастанию заряда ядра и заполнению электронами внешней электронной оболочки.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://dbpedia.org/ontology/"/>
        <rdfs:label xml:lang="de">Periode des Periodensystems</rdfs:label>
        <rdfs:label xml:lang="en">element period</rdfs:label>
        <rdfs:label xml:lang="pl">okres układu okresowego</rdfs:label>
        <rdfs:label xml:lang="ga">peiriad an tábla pheiriadaigh</rdfs:label>
        <rdfs:label xml:lang="ca">període de la taula periòdica</rdfs:label>
        <rdfs:label xml:lang="ru">период периодической таблицы</rdfs:label>
        <powder-s:describedby rdf:resource="http://dbpedia.org/ontology/data/definitions.ttl"/>
        <prov:wasDerivedFrom rdf:resource="http://mappings.dbpedia.org/index.php/OntologyProperty:elementPeriod"/>
    </owl:DatatypeProperty>
    


