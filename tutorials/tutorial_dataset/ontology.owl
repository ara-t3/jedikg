        <rdfs:label xml:lang="en">holiday</rdfs:label>
        <rdfs:label xml:lang="fr">jour férié</rdfs:label>
        <rdfs:label xml:lang="ga">lá saoire</rdfs:label>
        <rdfs:label xml:lang="nl">vakantie</rdfs:label>
        <rdfs:label xml:lang="el">αργία</rdfs:label>
