        <rdfs:subClassOf rdf:resource="http://dbpedia.org/ontology/Artist"/>
        <rdfs:comment xml:lang="en">An actor or actress is a person who acts in a dramatic production and who works in film, television, theatre, or radio in that capacity.</rdfs:comment>
        <rdfs:comment xml:lang="gl">Un actor, se é home, ou unha actriz, se é muller, é unha persoa que representa un papel nunha obra teatral, cinematográfica, radiofónica ou televisiva.</rdfs:comment>
        <rdfs:comment xml:lang="it">Un attore o un attrice è una persona che recita in una produzione teatrale, televisiva, cinematografica o radiofonica.</rdfs:comment>
        <rdfs:comment xml:lang="el">Μια ηθοποιός ή ένας ηθοποιός είναι ένα άτομο που παίζει σε μια δραματική παραγωγή και που εργάζεται στο χώρο του κινηματογράφου, της τηλεόρασης, του θεάτρου, ή το ραδιόφωνο.</rdfs:comment>
        <rdfs:comment xml:lang="ur">ایک اداکار یا اداکارہ وہ شخص ہوتا ہے جو ڈرامائی پروڈکشن میں کام کرتا ہے اور جو فلم ، ٹیلی ویژن ، تھیٹر یا ریڈیو میں اس صلاحیت کے ساتھ کام کرتا ہے</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://dbpedia.org/ontology/"/>
        <rdfs:label xml:lang="de">Schauspieler</rdfs:label>
        <rdfs:label xml:lang="fr">acteur</rdfs:label>
        <rdfs:label xml:lang="nl">acteur</rdfs:label>
        <rdfs:label xml:lang="en">actor</rdfs:label>
        <rdfs:label xml:lang="es">actor</rdfs:label>
        <rdfs:label xml:lang="gl">actor</rdfs:label>
        <rdfs:label xml:lang="ga">aisteoir</rdfs:label>
        <rdfs:label xml:lang="lv">aktieris</rdfs:label>
        <rdfs:label xml:lang="pl">aktor</rdfs:label>
        <rdfs:label xml:lang="eu">aktore</rdfs:label>
        <rdfs:label xml:lang="pt">ator</rdfs:label>
        <rdfs:label xml:lang="it">attore</rdfs:label>
        <rdfs:label xml:lang="da">skuespiller</rdfs:label>
        <rdfs:label xml:lang="el">ηθοποιός</rdfs:label>
        <rdfs:label xml:lang="ur">اداکار</rdfs:label>
