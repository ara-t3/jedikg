    <!-- http://dbpedia.org/ontology/quotation -->

    <owl:DatatypeProperty rdf:about="http://dbpedia.org/ontology/quotation">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
