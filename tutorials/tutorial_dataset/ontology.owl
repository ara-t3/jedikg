    <!-- http://dbpedia.org/ontology/UnitOfWork -->

    <owl:Class rdf:about="http://dbpedia.org/ontology/UnitOfWork">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="fr">Cette classe est destinée à transmettre la notion de quantité de travail à faire. Elle est différente de l&apos;activité en ce qu&apos;elle a une fin définie et qu&apos;elle est mesurée.</rdfs:comment>
        <rdfs:comment xml:lang="en">This class is meant to convey the notion of an amount work to be done. It is different from Activity in that it has a definite end and is being measured.</rdfs:comment>
        <rdfs:comment xml:lang="ur">اس کلاس کا مقصد کام کی مقدار کو سمجھانا ہے۔ یہ سرگرمی سے مختلف ہے کہ اس کا ایک حتمی اختتام ہے اور اسے ناپا جا رہا ہے۔</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://dbpedia.org/ontology/"/>
        <rdfs:label xml:lang="de">Arbeitseinheit</rdfs:label>
        <rdfs:label xml:lang="ga">aonad oibre</rdfs:label>
        <rdfs:label xml:lang="en">unit of work</rdfs:label>
        <rdfs:label xml:lang="fr">unité de travail</rdfs:label>
        <rdfs:label xml:lang="nl">werkeenheid</rdfs:label>
        <rdfs:label xml:lang="ur">کام کی اکائی</rdfs:label>
        <ns1:describedby rdf:resource="http://dbpedia.org/ontology/data/definitions.ttl"/>
        <prov:wasDerivedFrom rdf:resource="http://mappings.dbpedia.org/index.php/OntologyClass:UnitOfWork"/>
    </owl:Class>
    


