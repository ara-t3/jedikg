        <rdfs:label xml:lang="fr">Dramaturge</rdfs:label>
        <rdfs:label xml:lang="en">Playwright</rdfs:label>
        <rdfs:label xml:lang="ga">drámadóir</rdfs:label>
        <rdfs:label xml:lang="nl">toneelschrijver</rdfs:label>
        <rdfs:label xml:lang="ur">ڈرامہ نگار</rdfs:label>
        <powder-s:describedby rdf:resource="http://dbpedia.org/ontology/data/definitions.ttl"/>
        <prov:wasDerivedFrom rdf:resource="http://mappings.dbpedia.org/index.php/OntologyClass:PlayWright"/>
    </owl:Class>
    


    <!-- http://dbpedia.org/ontology/PlayboyPlaymate -->

    <owl:Class rdf:about="http://dbpedia.org/ontology/PlayboyPlaymate">
        <rdfs:subClassOf rdf:resource="http://dbpedia.org/ontology/Person"/>
        <rdfs:comment xml:lang="ur">پلے میٹ ایک خاتون ماڈل ہے جسے پلے بوائے میگزین کے سینٹر فولڈ/گیٹ فولڈ میں پلے میٹ آف دی منتھ کے طور پر دکھایا گیا ہے</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://dbpedia.org/ontology/"/>
