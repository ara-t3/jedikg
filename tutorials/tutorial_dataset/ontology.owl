    <!-- http://dbpedia.org/ontology/ArchitecturalStructure -->

    <owl:Class rdf:about="http://dbpedia.org/ontology/ArchitecturalStructure">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="en">An architectural structure is a human-made, free-standing, immobile outdoor construction (http://en.wikipedia.org/wiki/Architectural_structure).</rdfs:comment>
        <rdfs:comment xml:lang="de">Ein Bauwerk ist eine von Menschen errichtete Konstruktion mit ruhendem Kontakt zum Untergrund. Es ist in der Regel für eine langfristige Nutzungsdauer konzipiert (http://de.wikipedia.org/wiki/Bauwerk).</rdfs:comment>
        <rdfs:comment xml:lang="fr">Une structure architecturale est une construction extérieure immobile, autonome et construite par l&apos;homme (http://en.wikipedia.org/wiki/Architectural_structure).</rdfs:comment>
        <rdfs:comment xml:lang="el">Μια αρχιτεκτονική κατασκευή είναι μια ανθρώπινη κατασκευή, επιδαπέδια, ακίνητη κατασκευή (http://en.wikipedia.org/wiki/Architectural_structure).</rdfs:comment>
        <rdfs:comment xml:lang="ur">یہ تعمیراتی ڈھانچے مواد سے بنے ہیں۔، آزادانہ ، غیر مستحکم بیرونی تعمیر۔</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://dbpedia.org/ontology/"/>
        <rdfs:label xml:lang="de">Bauwerk</rdfs:label>
        <rdfs:label xml:lang="en">architectural structure</rdfs:label>
        <rdfs:label xml:lang="nl">bouwsel</rdfs:label>
        <rdfs:label xml:lang="es">estructura arquitectural</rdfs:label>
        <rdfs:label xml:lang="ga">struchtúr ailtireachta</rdfs:label>
        <rdfs:label xml:lang="fr">structure architecturale</rdfs:label>
        <rdfs:label xml:lang="it">struttura architettonica</rdfs:label>
        <rdfs:label xml:lang="el">αρχιτεκτονική κατασκευή</rdfs:label>
        <rdfs:label xml:lang="ur">تعمیراتی ڈھانچے</rdfs:label>
        <rdfs:label xml:lang="ja">構造物</rdfs:label>
        <rdfs:label xml:lang="ko">건축 구조</rdfs:label>
        <powder-s:describedby rdf:resource="http://dbpedia.org/ontology/data/definitions.ttl"/>
        <prov:wasDerivedFrom rdf:resource="http://mappings.dbpedia.org/index.php/OntologyClass:ArchitecturalStructure"/>
    </owl:Class>
    


    <!-- http://dbpedia.org/ontology/Archive -->

