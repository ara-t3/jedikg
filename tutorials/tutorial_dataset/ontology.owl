        <owl:equivalentClass rdf:resource="http://www.wikidata.org/entity/Q166118"/>
        <rdfs:subClassOf rdf:resource="http://dbpedia.org/ontology/CollectionOfValuables"/>
        <rdfs:comment xml:lang="fr">Collection de documents appartenant à une personne ou une organisation.</rdfs:comment>
        <rdfs:comment xml:lang="en">Collection of documents pertaining to a person or organisation.</rdfs:comment>
        <rdfs:comment xml:lang="nl">Verzameling van documenten rondom een persoon of organisatie.</rdfs:comment>
        <rdfs:comment xml:lang="el">Η συλλογή των εγγράφων που σχετίζονται με ένα πρόσωπο ή οργανισμό.</rdfs:comment>
        <rdfs:comment xml:lang="ur">کسی شخص یا تنظیم سے متعلق دستاویزات کا مجموع</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://dbpedia.org/ontology/"/>
