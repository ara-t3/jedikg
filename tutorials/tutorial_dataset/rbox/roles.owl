    <!-- http://dbpedia.org/ontology/academicAdvisor -->

    <owl:ObjectProperty rdf:about="http://dbpedia.org/ontology/academicAdvisor">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://dbpedia.org/ontology/Scientist"/>
        <rdfs:domain rdf:resource="http://www.wikidata.org/entity/Q901"/>
        <rdfs:range rdf:resource="http://dbpedia.org/ontology/Person"/>
        <rdfs:range rdf:resource="http://schema.org/Person"/>
        <rdfs:range rdf:resource="http://www.wikidata.org/entity/Q215627"/>
        <rdfs:range rdf:resource="http://www.wikidata.org/entity/Q5"/>
        <rdfs:range rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
        <rdfs:isDefinedBy rdf:resource="http://dbpedia.org/ontology/"/>
        <rdfs:label xml:lang="en">academic advisor</rdfs:label>
        <rdfs:label xml:lang="fr">conseiller académique</rdfs:label>
        <rdfs:label xml:lang="nl">promotor</rdfs:label>
        <rdfs:label xml:lang="el">ακαδημαϊκοί_σύμβουλοι</rdfs:label>
